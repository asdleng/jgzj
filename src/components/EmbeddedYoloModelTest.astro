<section
  id="yolo-model-test-panel"
  class="cloud-chat-panel ai-check-panel yolo-model-test-panel embedded-panel inspection-panel inspection-panel--check"
  aria-live="polite"
  data-requires-permission="ai:detect"
>
  <header class="cloud-chat-head">
    <div class="cloud-chat-head-main">
      <p class="cloud-chat-title">YOLO小模型测试</p>
      <p id="yolo-test-status" class="cloud-chat-status" data-state="idle">待上传</p>
    </div>
  </header>
  <div class="ai-check-workbench yolo-test-workbench">
    <div class="ai-check-side yolo-test-control-column">
      <div class="ai-check-form yolo-test-form">
        <label class="ai-check-field" for="yolo-test-image">
          <span>上传图片</span>
          <input id="yolo-test-image" type="file" accept="image/*" />
        </label>
      </div>
      <section id="yolo-test-result" class="ai-check-result yolo-test-result" data-state="idle">
        <p class="ai-check-result-label">测试结果</p>
        <p id="yolo-test-answer" class="ai-check-answer">等待测试</p>
        <p id="yolo-test-detail" class="ai-check-detail">上传图片后选择一个固定任务。</p>
        <div id="yolo-test-output" class="yolo-test-output"></div>
      </section>
    </div>
    <div class="yolo-test-visual-column">
      <div class="yolo-task-panel">
        <section class="yolo-task-section yolo-task-section--events" aria-label="事件查看">
          <div class="yolo-task-section-head">
            <p class="yolo-task-section-title">事件查看</p>
            <p class="yolo-task-section-meta">按巡检事件选择</p>
          </div>
          <div class="yolo-event-grid">
            <button class="yolo-task-button yolo-task-button--event yolo-task-button--wide" type="button" data-yolo-task="all_yolo">
              <span class="yolo-task-kind">框</span>
              <span class="yolo-task-title">全部事件</span>
              <span class="yolo-task-meta">人员 / 车辆 / 车牌 / 宠物 / 地面垃圾 / 烟火 / 手机 / 摆摊 / 钓鱼 / 吸烟</span>
            </button>
            <button class="yolo-task-button yolo-task-button--event" type="button" data-yolo-task="smoking_two_stage">
              <span class="yolo-task-kind">Yes/No</span>
              <span class="yolo-task-title">吸烟事件</span>
              <span class="yolo-task-meta">人员 + 抽烟确认</span>
            </button>
            <button class="yolo-task-button yolo-task-button--event" type="button" data-yolo-task="fishing_event">
              <span class="yolo-task-kind">Yes/No</span>
              <span class="yolo-task-title">钓鱼事件</span>
              <span class="yolo-task-meta">人员 + 鱼竿关系</span>
            </button>
            <button class="yolo-task-button yolo-task-button--event" type="button" data-yolo-task="vehicle_plate_ocr">
              <span class="yolo-task-kind">框/OCR</span>
              <span class="yolo-task-title">车牌事件</span>
              <span class="yolo-task-meta">车辆 / 车牌 / OCR</span>
            </button>
            <button class="yolo-task-button yolo-task-button--event" type="button" data-yolo-task="person_behavior_cls">
              <span class="yolo-task-kind">Yes/No</span>
              <span class="yolo-task-title">人员行为</span>
              <span class="yolo-task-meta">玩手机 / 抽烟</span>
            </button>
            <button class="yolo-task-button yolo-task-button--event" type="button" data-yolo-task="phone_yolo">
              <span class="yolo-task-kind">框</span>
              <span class="yolo-task-title">手机目标</span>
              <span class="yolo-task-meta">手机目标框</span>
            </button>
            <button class="yolo-task-button yolo-task-button--event" type="button" data-yolo-task="fire_smoke_yolo">
              <span class="yolo-task-kind">框</span>
              <span class="yolo-task-title">烟火事件</span>
              <span class="yolo-task-meta">火焰 / 烟雾</span>
            </button>
            <button class="yolo-task-button yolo-task-button--event" type="button" data-yolo-task="trash_ground_event">
              <span class="yolo-task-kind">Yes/No</span>
              <span class="yolo-task-title">地面垃圾</span>
              <span class="yolo-task-meta">小垃圾 + 地面接触</span>
            </button>
            <button class="yolo-task-button yolo-task-button--event" type="button" data-yolo-task="stall_yolo">
              <span class="yolo-task-kind">框</span>
              <span class="yolo-task-title">摆摊事件</span>
              <span class="yolo-task-meta">摊位候选</span>
            </button>
            <button class="yolo-task-button yolo-task-button--event" type="button" data-yolo-task="pet_yolo">
              <span class="yolo-task-kind">框</span>
              <span class="yolo-task-title">宠物事件</span>
              <span class="yolo-task-meta">猫 / 狗 / 宠物候选</span>
            </button>
          </div>
        </section>
        <section class="yolo-task-section yolo-task-section--models" aria-label="基础检测">
          <div class="yolo-task-section-head">
            <p class="yolo-task-section-title">基础检测</p>
            <p class="yolo-task-section-meta">模型级入口</p>
          </div>
          <div class="yolo-task-grid">
            <button class="yolo-task-button" type="button" data-yolo-task="person_yolo">
              <span class="yolo-task-kind">框</span>
              <span class="yolo-task-title">人员识别</span>
              <span class="yolo-task-meta">行人 / 人群 / 远距离人员</span>
            </button>
            <button class="yolo-task-button" type="button" data-yolo-task="vehicle_yolo">
              <span class="yolo-task-kind">框</span>
              <span class="yolo-task-title">车辆识别</span>
              <span class="yolo-task-meta">汽车 / 货车 / 非机动车</span>
            </button>
            <button class="yolo-task-button" type="button" data-yolo-task="license_plate_yolo">
              <span class="yolo-task-kind">框</span>
              <span class="yolo-task-title">车牌检测</span>
              <span class="yolo-task-meta">车牌目标框</span>
            </button>
            <button class="yolo-task-button" type="button" data-yolo-task="trash_yolo">
              <span class="yolo-task-kind">框</span>
              <span class="yolo-task-title">垃圾框</span>
              <span class="yolo-task-meta">瓶 / 盒 / 纸 / 袋原始候选</span>
            </button>
            <button class="yolo-task-button" type="button" data-yolo-task="segmentation_yolo">
              <span class="yolo-task-kind">Mask</span>
              <span class="yolo-task-title">实例分割</span>
              <span class="yolo-task-meta">目标轮廓 / 区域 mask</span>
            </button>
            <button class="yolo-task-button" type="button" data-yolo-task="fishing_rod_yolo">
              <span class="yolo-task-kind">框</span>
              <span class="yolo-task-title">钓鱼杆识别</span>
              <span class="yolo-task-meta">鱼竿 / 钓鱼候选</span>
            </button>
            <button class="yolo-task-button" type="button" data-yolo-task="general_yolo">
              <span class="yolo-task-kind">框</span>
              <span class="yolo-task-title">通用目标</span>
              <span class="yolo-task-meta">车 / 非机动车 / 宠物 / 摊位</span>
            </button>
          </div>
        </section>
      </div>
      <div class="ai-check-preview-shell yolo-test-preview-shell">
        <div id="yolo-test-preview" class="ai-check-preview yolo-test-preview" data-empty="true">
          <p class="ai-check-preview-empty">选择图片后会在这里预览</p>
        </div>
      </div>
      <section id="yolo-model-registry" class="yolo-model-registry" data-state="loading">
        <div class="yolo-model-registry-head">
          <p class="ai-check-result-label">模型版本</p>
          <button id="yolo-model-registry-refresh" class="cloud-chat-close" type="button">刷新</button>
        </div>
        <p id="yolo-model-registry-status" class="yolo-test-empty">正在读取模型列表。</p>
        <div id="yolo-model-registry-list" class="yolo-model-registry-list"></div>
      </section>
    </div>
  </div>
</section>
