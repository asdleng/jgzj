  }

  .gm-finding-columns {
    gap: 10px;
    margin-top: 14px;
  }

  .gm-finding-columns li {
    border-left-color: rgba(241, 184, 75, 0.6);
  }

  .gm-finding-columns li.gm-clear,
  .gm-observation-block li.gm-clear {
    border-left-color: rgba(57, 217, 138, 0.56);
    background: rgba(17, 86, 54, 0.2);
    color: #bfe8d1;
  }

  .gm-flow-band {
    margin-top: 12px;
    padding: 20px;
  }

  .gm-vegetation-ledger {
    width: 100%;
    min-width: 0;
    max-width: 100%;
    margin-top: 12px;
    padding: 20px;
    overflow: hidden;
  }

  .gm-ledger-head,
  .gm-ledger-toolbar,
  .gm-ledger-filters,
  .gm-ledger-pagination,
  .gm-veg-presence {
    display: flex;
    align-items: center;
  }

  .gm-ledger-head,
  .gm-ledger-toolbar {
    justify-content: space-between;
    gap: 16px;
  }

  .gm-vegetation-ledger h2 {
    margin: 4px 0 0;
    color: #f3faf7;
    font-size: 1.25rem;
  }

  .gm-ledger-head > p {
    margin: 0;
    color: var(--gm-muted);
    font-size: 0.72rem;
    text-align: right;
  }

  .gm-ledger-toolbar {
    margin-top: 16px;
    padding: 9px 0;
    border-top: 1px solid var(--gm-line);
    border-bottom: 1px solid var(--gm-line);
  }

  .gm-ledger-filters,
  .gm-ledger-pagination {
    gap: 5px;
  }

  .gm-ledger-filters button,
  .gm-ledger-pagination button,
  .gm-table-locate {
    height: 34px;
    border: 1px solid rgba(119, 168, 153, 0.3);
    border-radius: 3px;
    background: rgba(19, 45, 39, 0.72);
    color: #b8cbc4;
    font: inherit;
    font-size: 0.7rem;
    font-weight: 800;
    cursor: pointer;
  }

  .gm-ledger-filters button {
    padding: 0 11px;
  }

  .gm-ledger-filters button[aria-pressed="true"] {
    border-color: rgba(57, 217, 138, 0.62);
    background: rgba(24, 112, 72, 0.42);
    color: #ddf8e9;
  }

  .gm-ledger-filters b {
    margin-left: 5px;
    color: #f2fbf7;
  }

  .gm-ledger-pagination button {
    width: 34px;
    padding: 0;
    font-size: 1.15rem;
  }

  .gm-ledger-pagination button:disabled {
    cursor: not-allowed;
    opacity: 0.38;
  }

  .gm-ledger-pagination span {
    min-width: 82px;
    color: var(--gm-muted);
    font-size: 0.68rem;
    text-align: center;
  }

  .gm-vegetation-table-wrap {
    width: 100%;
    min-width: 0;
    max-width: 100%;
    overflow-x: auto;
    overscroll-behavior-x: contain;
  }

  .gm-vegetation-table {
    width: 100%;
    min-width: 980px;
    border-collapse: collapse;
    table-layout: fixed;
  }

  .gm-vegetation-table th,
  .gm-vegetation-table td {
    padding: 11px 10px;
    border-bottom: 1px solid rgba(150, 188, 175, 0.14);
    text-align: left;
    vertical-align: middle;
  }

  .gm-vegetation-table th {
    color: #90a9a0;
    font-size: 0.66rem;
    font-weight: 900;
    white-space: nowrap;
  }

  .gm-vegetation-table td {
    color: #d2e1dc;
    font-size: 0.7rem;
    line-height: 1.45;
  }

  .gm-vegetation-table th:nth-child(1) { width: 82px; }
  .gm-vegetation-table th:nth-child(2) { width: 270px; }
  .gm-vegetation-table th:nth-child(3),
  .gm-vegetation-table th:nth-child(4) { width: 82px; }
  .gm-vegetation-table th:nth-child(5) { width: 104px; }
  .gm-vegetation-table th:nth-child(6),
  .gm-vegetation-table th:nth-child(7) { width: 88px; }
  .gm-vegetation-table th:nth-child(8) { width: 104px; }
  .gm-vegetation-table th:nth-child(9) { width: 66px; }

  .gm-vegetation-table tbody tr {
