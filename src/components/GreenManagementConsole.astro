  .gm-indicator[data-state="fair"] > i > b { background: var(--gm-amber); }
  .gm-indicator[data-state="poor"] > i > b { background: var(--gm-red); }

  .gm-indicator p {
    display: -webkit-box;
    grid-column: 1 / -1;
    overflow: hidden;
    margin: 0;
    color: #aec0ba;
    font-size: 0.65rem;
    line-height: 1.4;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .gm-operation-note {
    display: grid;
    grid-template-columns: minmax(240px, 0.8fr) minmax(0, 2fr);
    gap: 12px 16px;
    margin-top: 16px;
    padding: 0;
    border: 0;
    background: transparent;
  }

  .gm-inspection-summary {
    grid-column: 1 / -1;
    margin-top: 12px;
    padding: 11px 12px;
    border-left: 3px solid var(--gm-blue);
    background: rgba(22, 66, 73, 0.28);
    color: #d4e7e1;
  }

  .gm-observation-block {
    margin-top: 0;
    padding: 0;
    border: 0;
  }

  .gm-observation-block h4,
  .gm-finding-columns h4 {
    color: #c5d8d1;
  }

  .gm-observation-block ul,
  .gm-finding-columns ul {
    margin: 8px 0 0;
    padding: 0;
    list-style: none;
  }

  .gm-observation-block li,
  .gm-finding-columns li {
    position: relative;
    margin: 0 0 6px;
    padding: 8px 9px 8px 22px;
    border-left: 2px solid rgba(67, 185, 216, 0.64);
    background: rgba(14, 38, 34, 0.5);
    color: #c8d9d3;
    font-size: 0.7rem;
    line-height: 1.55;
  }

  .gm-observation-block li::before,
  .gm-finding-columns li::before {
    position: absolute;
    left: 9px;
    content: "·";
    color: var(--gm-green);
  }

  .gm-finding-columns {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin-top: 0;
  }

  .gm-finding-columns li {
    border-left-color: rgba(241, 184, 75, 0.6);
  }

  .gm-finding-columns li.gm-clear,
  .gm-observation-block li.gm-clear {
    border-left-color: rgba(57, 217, 138, 0.56);
    background: rgba(17, 86, 54, 0.2);
    color: #bfe8d1;
  }

  .gm-flow-band {
    margin-top: 12px;
    padding: 20px;
  }

  .gm-vegetation-ledger {
    display: flex;
    width: 100%;
    height: 680px;
    min-width: 0;
    max-width: 100%;
    flex-direction: column;
    margin-top: 0;
    padding: 14px;
    overflow: hidden;
  }

  .gm-ledger-head,
  .gm-ledger-toolbar,
  .gm-ledger-filters,
  .gm-ledger-pagination,
  .gm-veg-presence {
    display: flex;
    align-items: center;
  }

  .gm-ledger-head,
  .gm-ledger-toolbar {
    justify-content: space-between;
    gap: 16px;
  }

  .gm-vegetation-ledger h2 {
    margin: 2px 0 0;
    color: #f3faf7;
    font-size: 1.05rem;
  }

  .gm-ledger-head > p {
    max-width: 58%;
    margin: 0;
    color: var(--gm-muted);
    font-size: 0.72rem;
    text-align: right;
  }

  .gm-ledger-toolbar {
    flex-wrap: wrap;
    margin-top: 10px;
    padding: 7px 0;
    border-top: 1px solid var(--gm-line);
    border-bottom: 1px solid var(--gm-line);
  }

  .gm-ledger-filters,
  .gm-ledger-pagination {
    gap: 5px;
  }

  .gm-ledger-filters button,
  .gm-ledger-pagination button,
  .gm-table-locate {
    height: 30px;
    border: 1px solid rgba(119, 168, 153, 0.3);
    border-radius: 3px;
    background: rgba(19, 45, 39, 0.72);
    color: #b8cbc4;
    font: inherit;
    font-size: 0.64rem;
    font-weight: 800;
    cursor: pointer;
  }

  .gm-ledger-filters button {
    padding: 0 8px;
  }

  .gm-ledger-filters button[aria-pressed="true"] {
    border-color: rgba(57, 217, 138, 0.62);
    background: rgba(24, 112, 72, 0.42);
    color: #ddf8e9;
  }

  .gm-ledger-filters b {
    margin-left: 5px;
    color: #f2fbf7;
  }

  .gm-ledger-pagination button {
    width: 30px;
    padding: 0;
    font-size: 1.15rem;
  }

  .gm-ledger-pagination button:disabled {
    cursor: not-allowed;
    opacity: 0.38;
  }

  .gm-ledger-pagination span {
    min-width: 70px;
    color: var(--gm-muted);
    font-size: 0.68rem;
    text-align: center;
  }

  .gm-vegetation-table-wrap {
    width: 100%;
    min-width: 0;
    max-width: 100%;
    flex: 1 1 auto;
    overflow: auto;
    overscroll-behavior-x: contain;
    scrollbar-width: thin;
  }

  .gm-vegetation-table {
    width: 100%;
    min-width: 500px;
    border-collapse: collapse;
    table-layout: fixed;
  }

  .gm-vegetation-table th,
  .gm-vegetation-table td {
    padding: 7px 6px;
    border-bottom: 1px solid rgba(150, 188, 175, 0.14);
    text-align: left;
    vertical-align: middle;
  }

  .gm-vegetation-table th {
    position: sticky;
    z-index: 2;
    top: 0;
    background: #061714;
    color: #90a9a0;
    font-size: 0.61rem;
    font-weight: 900;
    white-space: nowrap;
  }

  .gm-vegetation-table td {
    color: #d2e1dc;
    font-size: 0.64rem;
    line-height: 1.35;
  }

  .gm-vegetation-table th:nth-child(1) { width: 150px; }
  .gm-vegetation-table th:nth-child(2),
  .gm-vegetation-table th:nth-child(3) { width: 50px; }
  .gm-vegetation-table th:nth-child(4) { width: 58px; }
  .gm-vegetation-table th:nth-child(5) { width: 78px; }
  .gm-vegetation-table th:nth-child(6) { width: 66px; }
  .gm-vegetation-table th:nth-child(7) { width: 44px; }

  .gm-vegetation-table tbody tr {
    transition: background 140ms ease;
  }

  .gm-vegetation-table tbody tr:hover {
    background: rgba(30, 79, 65, 0.26);
  }

  .gm-vegetation-table tbody tr[data-selected="true"] {
    background: rgba(33, 119, 78, 0.32);
    box-shadow: inset 3px 0 0 var(--gm-green);
  }

  .gm-table-location {
    display: grid;
    gap: 2px;
    min-width: 0;
  }

  .gm-table-location strong,
  .gm-table-location small {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .gm-table-location strong {
    color: #edf7f2;
    font-size: 0.66rem;
  }

  .gm-table-location small {
    color: #829b92;
    font-size: 0.57rem;
  }

  .gm-veg-presence {
    gap: 4px;
    font-size: 0.6rem;
    white-space: nowrap;
  }

  .gm-veg-presence::before {
    width: 6px;
    height: 6px;
    flex: 0 0 auto;
    border-radius: 50%;
    background: #71877f;
    content: "";
  }

  .gm-veg-presence[data-state="present"] { color: #b8f0d0; }
  .gm-veg-presence[data-state="present"]::before { background: var(--gm-green); }
  .gm-veg-presence[data-state="absent"] { color: #849a92; }
  .gm-veg-presence[data-state="absent"]::before { background: #51665f; }
  .gm-veg-presence[data-state="unknown"] { color: #e7c77f; }
  .gm-veg-presence[data-state="unknown"]::before { background: var(--gm-amber); }

  .gm-table-metrics {
    display: grid;
    gap: 1px;
    white-space: nowrap;
  }

  .gm-table-metrics span {
    color: #8ea69d;
    font-size: 0.57rem;
  }

  .gm-table-metrics strong {
    color: #e5f5ef;
    font-size: 0.62rem;
  }

  .gm-table-status {
    color: #a9bdb6;
    font-size: 0.59rem !important;
    white-space: nowrap;
  }

  .gm-table-status[data-state="clear"] { color: #9de7bd; }
  .gm-table-status[data-state="attention"] { color: #f1cf83; }
  .gm-table-status[data-state="issue"] { color: #ffaaa3; }
  .gm-table-status[data-state="not_assessable"] { color: #aabbb5; }

  .gm-table-locate {
    width: 40px;
    padding: 0;
    border-color: rgba(67, 185, 216, 0.42);
    color: #bfeefd;
  }

  .gm-table-empty {
    height: 86px;
    color: #82988f !important;
    text-align: center !important;
  }

  .gm-visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    clip-path: inset(50%);
  }

  .gm-project-grid {
    gap: 8px;
  }

  .gm-project-grid article {
    min-height: 126px;
    border: 1px solid rgba(145, 180, 167, 0.16);
    border-top: 3px solid #71877f;
    border-radius: 4px;
    background: rgba(13, 36, 32, 0.58);
  }

  .gm-project-grid span,
  .gm-project-grid p {
    color: #91a8a0;
  }

  .gm-project-grid strong {
    color: #edf8f4;
  }

  .gm-preview {
    border: 1px solid rgba(151, 184, 173, 0.25);
    border-radius: 6px;
    background: #04100e;
    color: #f2faf7;
  }

  .gm-preview::backdrop {
    background: rgba(0, 6, 5, 0.86);
  }

  .gm-preview header {
    background: rgba(5, 20, 17, 0.96);
  }

  .gm-preview header span {
    color: #a4b9b1;
  }

  @media (max-width: 1380px) {
    .gm-overview {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .gm-progress-overview,
    .gm-distribution {
      grid-column: span 2;
    }

    .gm-overview-stat {
      min-height: 126px !important;
    }
  }

  @media (max-width: 1180px) {
    .gm-workspace {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    .gm-map-stage {
      height: 640px;
      min-height: 640px;
      max-height: 640px;
    }

    .gm-vegetation-ledger {
      height: 620px;
    }

    .gm-frame-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .gm-indicator-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .gm-toolbar {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .green-management {
      padding: 18px 12px 44px;
    }

    .gm-header {
      align-items: flex-start;
      flex-direction: column;
    }

    .gm-overview {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .gm-progress-overview,
    .gm-distribution {
      grid-column: 1 / -1;
    }

    .gm-overview > article {
      min-height: 130px;
    }

    .gm-overview-stat {
      min-height: 112px !important;
      padding: 14px;
    }

    .gm-overview-stat > strong {
      font-size: 2rem;
    }

    .gm-toolbar {
      grid-template-columns: 1fr;
    }

    .gm-context-metrics > span {
      padding: 8px 11px;
    }

    .gm-map-stage {
      height: 62vh;
      min-height: 62vh;
      max-height: 680px;
    }

    .gm-vegetation-ledger {
      height: 560px;
    }

    .gm-inspector,
    .gm-vegetation-ledger,
    .gm-flow-band {
      padding: 15px;
    }

    .gm-ledger-head,
    .gm-ledger-toolbar {
      align-items: flex-start;
      flex-direction: column;
    }

    .gm-ledger-head > p {
      max-width: none;
      text-align: left;
    }

    .gm-ledger-filters {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      width: 100%;
    }

    .gm-ledger-filters button {
      min-width: 0;
      padding: 0 8px;
    }

    .gm-health-panel {
      grid-template-columns: 1fr;
    }

    .gm-frame-grid,
    .gm-operation-note {
      grid-template-columns: 1fr;
    }

    .gm-operation-note > header,
    .gm-inspection-summary {
      grid-column: auto;
    }

    .gm-health-score {
      padding: 0 0 14px;
      border-right: 0;
      border-bottom: 1px solid var(--gm-line);
    }

    .gm-indicator-grid,
    .gm-finding-columns,
    .gm-project-grid {
      grid-template-columns: 1fr;
    }

    .gm-frame figcaption {
      min-height: 86px;
    }
  }

