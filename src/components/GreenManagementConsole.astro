  .gm-vegetation-table tbody tr[data-selected="true"] {
    background: rgba(33, 119, 78, 0.32);
    box-shadow: inset 3px 0 0 var(--gm-green);
  }

  .gm-table-location {
    display: grid;
    gap: 2px;
    min-width: 0;
  }

  .gm-table-location strong,
  .gm-table-location small {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .gm-table-location strong {
    color: #edf7f2;
    font-size: 0.72rem;
  }

  .gm-table-location small {
    color: #829b92;
    font-size: 0.62rem;
  }

  .gm-veg-presence {
    gap: 6px;
    white-space: nowrap;
  }

  .gm-veg-presence::before {
    width: 8px;
    height: 8px;
    flex: 0 0 auto;
    border-radius: 50%;
    background: #71877f;
    content: "";
  }

  .gm-veg-presence[data-state="present"] { color: #b8f0d0; }
  .gm-veg-presence[data-state="present"]::before { background: var(--gm-green); }
  .gm-veg-presence[data-state="absent"] { color: #849a92; }
  .gm-veg-presence[data-state="absent"]::before { background: #51665f; }
  .gm-veg-presence[data-state="unknown"] { color: #e7c77f; }
