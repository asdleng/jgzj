<style is:global>
  .green-management-main {
    min-height: 100vh;
    padding: calc(var(--gm-nav-height, 88px) + 14px) 0 0;
    overflow-x: hidden;
  }

  .green-management {
    margin: 0 auto;
  }

  .green-management *,
  .green-management *::before,
  .green-management *::after {
    box-sizing: border-box;
  }

  .gm-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--gm-line);
  }

  .gm-heading h1,
  .gm-heading p,
  .gm-inspector h2,
  .gm-vegetation-ledger h2,
  .gm-flow-band h2,
  .gm-operation-note h3,
  .gm-kicker {
    margin: 0;
  }

  .gm-heading h1 {
    margin-top: 5px;
    line-height: 1.08;
    font-weight: 800;
  }

  .gm-heading > p:last-child {
    margin-top: 9px;
    font-size: 0.92rem;
  }

  .gm-live-status {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    min-height: 36px;
    padding: 0 11px;
    border-radius: 4px;
    font-size: 0.78rem;
  }

  .gm-live-status > span {
    width: 8px;
    height: 8px;
    flex: 0 0 auto;
    border-radius: 50%;
  }

  .gm-live-status[data-state="ok"] > span {
    background: var(--gm-green);
    box-shadow: 0 0 0 5px rgba(57, 217, 138, 0.12);
  }

  .gm-live-status[data-state="error"] > span {
    background: var(--gm-red);
  }

  .gm-auth {
    margin: 14px 0;
    padding: 13px 14px;
    border-radius: 4px;
    font-weight: 700;
  }

  .gm-toolbar {
    display: grid;
    align-items: end;
  }

  .gm-field {
    display: grid;
    gap: 6px;
    min-width: 0;
  }

  .gm-field > span {
    font-size: 0.7rem;
    font-weight: 800;
  }

  .gm-field select {
    width: 100%;
    min-width: 0;
    height: 42px;
    padding: 0 38px 0 12px;
    border-width: 1px;
    border-style: solid;
    font: inherit;
  }

  .gm-field select:focus-visible,
  .gm-button:focus-visible,
  .gm-mode-switch button:focus-visible,
  .gm-frame-button:focus-visible,
  .gm-ledger-filters button:focus-visible,
  .gm-ledger-pagination button:focus-visible,
  .gm-table-locate:focus-visible {
    outline: 2px solid rgba(67, 185, 216, 0.8);
    outline-offset: 2px;
  }

  .gm-mode-switch {
    display: inline-grid;
    grid-template-columns: repeat(2, 1fr);
    height: 42px;
    padding: 3px;
    border-width: 1px;
    border-style: solid;
  }

