  .gm-context-metrics > span:last-child {
    border-right: 0;
  }

  .gm-context-metrics strong {
    margin-left: 6px;
    color: #e9f7f1;
    font-size: 0.83rem;
  }

  .gm-workspace {
    grid-template-columns: minmax(0, 1.6fr) minmax(420px, 0.9fr);
    gap: 12px;
    align-items: stretch;
  }

  .gm-map-stage,
  .gm-inspector,
  .gm-vegetation-ledger,
  .gm-flow-band {
    border: 1px solid var(--gm-line);
    border-radius: 6px;
    background: var(--gm-surface-strong);
    box-shadow: 0 20px 52px rgba(0, 0, 0, 0.22);
  }

  .gm-map-stage {
    min-height: 760px;
    max-height: 920px;
    background: #06120f;
  }

  .gm-map-canvas {
    background: #06120f;
  }

  .gm-node-hit:focus-visible {
    outline-color: #86efac;
  }

  .gm-map-loading,
  .gm-map-error {
    background: rgba(3, 13, 11, 0.88);
    color: #d8e9e2;
  }

  .gm-map-loading > span {
    border-color: rgba(90, 224, 151, 0.22);
    border-top-color: var(--gm-green);
  }

  .gm-load-progress {
    width: min(320px, 72vw);
    height: 7px;
    overflow: hidden;
    border-radius: 4px;
    background: rgba(151, 184, 173, 0.18);
  }

  .gm-load-progress > i {
    display: block;
    width: 0;
    height: 100%;
    border-radius: inherit;
    background: var(--gm-green);
    transition: width 180ms ease;
  }

  .gm-map-loading > small {
    color: #9fb4ad;
    font-size: 0.7rem;
    line-height: 1.4;
  }

  .gm-map-error {
    color: #ffb8b1;
  }

  .gm-map-topline > div,
  .gm-map-topline > p,
  .gm-map-source,
  .gm-map-tooltip {
    border: 1px solid rgba(151, 184, 173, 0.22);
    background: rgba(3, 14, 13, 0.82);
    color: #c7d8d2;
  }

  .gm-inspector {
    padding: 20px;
    color: #e9f5f1;
  }

  .gm-inspector h2,
  .gm-operation-note h3,
  .gm-vegetation-ledger h2,
  .gm-flow-band h2 {
    color: #f3faf7;
  }

  .gm-inspector-head > span {
    border-color: rgba(67, 185, 216, 0.34);
    background: rgba(35, 121, 145, 0.22);
    color: #bfeefd;
  }

  .gm-inspector-head > span[data-state="clear"] {
    border-color: rgba(57, 217, 138, 0.4);
    background: rgba(21, 112, 68, 0.25);
    color: #a7f3d0;
  }

  .gm-inspector-head > span[data-state="attention"] {
    border-color: rgba(241, 184, 75, 0.42);
    background: rgba(117, 73, 16, 0.3);
    color: #fde2a9;
  }

  .gm-inspector-head > span[data-state="issue"] {
    border-color: rgba(240, 113, 103, 0.46);
    background: rgba(103, 37, 34, 0.34);
    color: #ffd0cc;
  }

  .gm-frame-grid {
    gap: 8px;
  }

  .gm-frame {
    overflow: hidden;
    border: 1px solid var(--gm-line);
    border-radius: 4px;
    background: rgba(2, 11, 11, 0.82);
  }

  .gm-frame[data-state="good"] { border-color: rgba(57, 217, 138, 0.4); }
  .gm-frame[data-state="fair"] { border-color: rgba(241, 184, 75, 0.42); }
  .gm-frame[data-state="poor"] { border-color: rgba(240, 113, 103, 0.5); }

  .gm-frame-button {
    aspect-ratio: 4 / 3;
    background: #020a09;
  }

  .gm-frame img {
    object-fit: contain;
    background: #020a09;
  }

  .gm-frame figcaption {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3px 8px;
    min-height: 78px;
    padding: 8px 9px;
    border-top: 1px solid var(--gm-line);
    background: rgba(8, 26, 23, 0.96);
  }

  .gm-frame figcaption span {
    color: #93aaa2;
  }

  .gm-frame figcaption strong {
    color: #dff6ed;
  }

  .gm-frame figcaption small {
    display: -webkit-box;
    grid-column: 1 / -1;
    overflow: hidden;
    color: #b3c6c0;
    font-size: 0.66rem;
    line-height: 1.45;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .gm-frame-placeholder,
  .gm-empty {
    color: #8ba198;
  }

  .gm-health-panel {
    grid-template-columns: minmax(160px, 0.7fr) minmax(0, 1.6fr);
    gap: 18px;
    margin-top: 16px;
    padding: 18px 0;
    border: 0;
    border-top: 1px solid var(--gm-line);
    border-bottom: 1px solid var(--gm-line);
    border-radius: 0;
    background: transparent;
  }

  .gm-health-panel[data-state="clear"],
  .gm-health-panel[data-state="attention"],
  .gm-health-panel[data-state="issue"] {
    border-color: var(--gm-line);
    background: transparent;
  }

  .gm-health-score {
    padding-right: 18px;
    border-right-color: var(--gm-line);
  }

  .gm-health-score span,
  .gm-health-score em {
    color: var(--gm-muted);
  }

  .gm-health-score strong {
    color: #f6fcf9;
    font-size: clamp(3rem, 5vw, 4.8rem);
  }

  .gm-health-score p {
    margin: 12px 0 0;
    color: #a9bdb6;
    font-size: 0.7rem;
    line-height: 1.55;
  }

  .gm-indicator-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 7px;
  }

  .gm-indicator {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 5px 8px;
    align-content: start;
    min-height: 86px;
    padding: 9px 10px;
    border: 1px solid rgba(142, 178, 165, 0.16);
    border-left-width: 3px;
    border-radius: 3px;
    background: rgba(15, 40, 34, 0.46);
  }

  .gm-indicator span {
    color: #9eb3ac;
  }

  .gm-indicator strong {
    color: #f0f8f5;
  }

  .gm-indicator > i {
    grid-column: 1 / -1;
    height: 4px;
    overflow: hidden;
    border-radius: 2px;
    background: rgba(144, 177, 166, 0.14);
