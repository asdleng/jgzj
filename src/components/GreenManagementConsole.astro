  .gm-indicator > i > b {
    display: block;
    height: 100%;
    background: #7c918a;
  }

  .gm-indicator[data-state="good"] > i > b { background: var(--gm-green); }
  .gm-indicator[data-state="fair"] > i > b { background: var(--gm-amber); }
  .gm-indicator[data-state="poor"] > i > b { background: var(--gm-red); }

  .gm-indicator p {
    display: -webkit-box;
    grid-column: 1 / -1;
    overflow: hidden;
    margin: 0;
    color: #aec0ba;
    font-size: 0.65rem;
    line-height: 1.4;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .gm-operation-note {
    margin-top: 16px;
    padding: 0;
    border: 0;
    background: transparent;
  }

  .gm-inspection-summary {
    margin-top: 12px;
    padding: 11px 12px;
    border-left: 3px solid var(--gm-blue);
    background: rgba(22, 66, 73, 0.28);
    color: #d4e7e1;
  }

  .gm-observation-block {
    margin-top: 14px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--gm-line);
  }

  .gm-observation-block h4,
  .gm-finding-columns h4 {
    color: #c5d8d1;
  }

  .gm-observation-block ul,
  .gm-finding-columns ul {
    margin: 8px 0 0;
    padding: 0;
    list-style: none;
  }

  .gm-observation-block li,
  .gm-finding-columns li {
    position: relative;
    margin: 0 0 6px;
    padding: 8px 9px 8px 22px;
    border-left: 2px solid rgba(67, 185, 216, 0.64);
