    color: #91a9a1;
  }

  .gm-field select,
  .gm-button,
  .gm-mode-switch {
    border-color: rgba(119, 168, 153, 0.3);
    background: rgba(19, 45, 39, 0.72);
    color: #e5f1ed;
  }

  .gm-field select {
    border-radius: 4px;
  }

  .gm-mode-switch {
    border-radius: 4px;
  }

  .gm-mode-switch button {
    color: #9bb0a9;
  }

  .gm-mode-switch button[aria-pressed="true"] {
    background: #e5f6ee;
    color: #0b3d29;
  }

  .gm-button {
    border-radius: 4px;
  }

  .gm-button--primary {
    border-color: var(--gm-green-dark);
    background: var(--gm-green-dark);
    color: #f7fff9;
  }

  .gm-context-metrics {
    display: flex;
    align-items: center;
    gap: 0;
    overflow-x: auto;
    margin-bottom: 14px;
    border: 1px solid var(--gm-line);
