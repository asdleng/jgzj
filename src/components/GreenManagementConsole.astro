    gap: 3px;
  }

  .gm-preview header strong,
  .gm-preview header span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .gm-preview button {
    width: 36px;
    height: 36px;
    flex: 0 0 auto;
    border: 1px solid rgba(151, 184, 173, 0.35);
    border-radius: 3px;
    background: transparent;
    color: #fff;
    font-size: 1.4rem;
    cursor: pointer;
  }

  .gm-preview img {
    display: block;
    width: 100%;
    max-height: calc(100vh - 102px);
    object-fit: contain;
  }

  .green-management-main {
    background:
      linear-gradient(rgba(4, 19, 17, 0.9), rgba(7, 18, 24, 0.94)),
      url("/assets/fallback/hero-cloud-ops-1600.jpg") center / cover fixed;
    color: #edf7f2;
  }

  .green-management {
    --gm-green: #39d98a;
    --gm-green-dark: #1caf68;
    --gm-blue: #43b9d8;
    --gm-amber: #f1b84b;
    --gm-red: #f07167;
    --gm-ink: #edf7f2;
    --gm-muted: #9fb4ad;
    --gm-line: rgba(150, 188, 175, 0.2);
    --gm-surface: rgba(7, 24, 22, 0.88);
    --gm-surface-strong: rgba(6, 17, 20, 0.96);
    --gm-surface-soft: rgba(22, 47, 42, 0.68);
    box-sizing: border-box;
    width: min(1760px, 100%);
    min-width: 0;
    max-width: 100%;
    padding: 26px 28px 64px;
    overflow-x: hidden;
    color: var(--gm-ink);
  }

  .green-management *,
  .green-management *::before,
  .green-management *::after {
    letter-spacing: 0;
  }

  .gm-header {
    margin-bottom: 20px;
  }

  .gm-heading h1 {
    color: #f7fcf9;
    font-size: clamp(2rem, 3vw, 3.1rem);
  }

  .gm-heading > p:last-child,
  .gm-kicker,
  .gm-node-meta,
  .gm-privacy {
    color: var(--gm-muted);
  }

  .gm-kicker {
    font-size: 0.7rem;
    font-weight: 800;
  }

  .gm-live-status {
    border: 1px solid var(--gm-line);
    background: rgba(4, 18, 16, 0.74);
    color: #c8d9d3;
  }

  .gm-live-status > span {
    background: #7c918a;
  }

  .gm-auth {
    border: 1px solid rgba(240, 113, 103, 0.42);
    background: rgba(81, 26, 25, 0.64);
    color: #ffd6d2;
  }

  .gm-overview {
    display: grid;
    grid-template-columns: minmax(250px, 1.4fr) repeat(4, minmax(128px, 0.72fr)) minmax(280px, 1.55fr);
    gap: 10px;
    margin-bottom: 12px;
  }

  .gm-overview > article {
    min-width: 0;
    min-height: 154px;
    border: 1px solid var(--gm-line);
    border-radius: 6px;
    background: var(--gm-surface);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.16);
  }

  .gm-progress-overview {
    display: grid;
    align-content: center;
    padding: 20px;
    border-left: 3px solid var(--gm-green) !important;
  }

  .gm-overview-label,
  .gm-distribution header,
  .gm-distribution footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }

  .gm-overview-label span,
  .gm-distribution header span,
  .gm-overview-stat > span {
    color: #c6d8d1;
    font-size: 0.75rem;
    font-weight: 800;
  }

  .gm-overview-label em,
  .gm-distribution header em,
  .gm-overview-stat em,
  .gm-progress-overview p {
    margin: 0;
    color: var(--gm-muted);
    font-size: 0.68rem;
    font-style: normal;
    line-height: 1.5;
  }

  .gm-progress-overview > strong {
    margin: 7px 0 8px;
    color: #f7fcf9;
    font-size: clamp(2.15rem, 3.2vw, 3.35rem);
    line-height: 1;
  }

  .gm-progress-track {
    height: 8px;
    overflow: hidden;
    margin-bottom: 8px;
    border-radius: 4px;
    background: rgba(151, 184, 173, 0.17);
  }

  .gm-progress-track i {
    display: block;
    width: 0;
    height: 100%;
    border-radius: inherit;
    background: var(--gm-green);
    transition: width 260ms ease;
  }

  .gm-overview-stat {
    display: flex;
    min-width: 0;
    flex-direction: column;
    justify-content: center;
    padding: 18px 16px;
    border-top: 3px solid rgba(67, 185, 216, 0.76) !important;
  }

  .gm-overview-stat > strong {
    margin: 9px 0 8px;
    color: #f7fcf9;
    font-size: clamp(1.8rem, 2.4vw, 2.7rem);
    line-height: 1;
    overflow-wrap: anywhere;
  }

  .gm-overview-stat--clear { border-top-color: var(--gm-green) !important; }
  .gm-overview-stat--review { border-top-color: var(--gm-amber) !important; }
  .gm-overview-stat--issue { border-top-color: var(--gm-red) !important; }

  .gm-distribution {
    display: grid;
    align-content: center;
    gap: 6px;
    padding: 14px 16px;
  }

  .gm-band-row {
    display: grid;
    grid-template-columns: 76px minmax(50px, 1fr) 28px;
    align-items: center;
    gap: 8px;
    color: #bdd0c9;
    font-size: 0.66rem;
  }

  .gm-band-row > i {
    height: 5px;
    overflow: hidden;
    border-radius: 3px;
    background: rgba(153, 181, 172, 0.15);
  }

  .gm-band-row > i > b {
    display: block;
    width: 0;
    height: 100%;
    background: var(--gm-green);
    transition: width 260ms ease;
  }

  .gm-band-row[data-band="good"] > i > b { background: var(--gm-blue); }
  .gm-band-row[data-band="watch"] > i > b { background: var(--gm-amber); }
  .gm-band-row[data-band="poor"] > i > b { background: var(--gm-red); }

  .gm-band-row > strong {
    color: #edf7f2;
    text-align: right;
  }

  .gm-distribution footer {
    margin-top: 4px;
    padding-top: 7px;
    border-top: 1px solid var(--gm-line);
    color: var(--gm-muted);
    font-size: 0.65rem;
  }

  .gm-distribution footer b {
    color: #dff8ea;
  }

  .gm-toolbar {
    grid-template-columns: minmax(220px, 1.2fr) minmax(180px, 0.9fr) auto auto;
    gap: 10px;
    margin: 0;
    padding: 12px;
    border: 1px solid var(--gm-line);
    border-radius: 6px 6px 0 0;
    background: rgba(6, 19, 20, 0.9);
