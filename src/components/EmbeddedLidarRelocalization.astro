---
import scriptText from "../scripts/lidar-relocalization.js?raw";
import "../styles/lidar-relocalization-data.css";
---

<section
  id="lidar-relocalization-console"
  class="lidar-reloc-console embedded-panel"
  aria-live="polite"
  data-authenticated="false"
  data-requires-permission="vehicle:read"
>
  <div class="lidar-reloc-head">
    <div>
      <p class="section-kicker">LiDAR Relocalization</p>
      <h3>BEVPlace++ + LCR-Net 重定位</h3>
    </div>
    <p id="lidar-reloc-status" class="cloud-ops-inline-status" data-state="idle">待加载</p>
  </div>

  <div class="lidar-reloc-toolbar">
    <label class="cloud-ops-toolbar-field" for="lidar-reloc-vehicle">
      <span>车辆</span>
      <select id="lidar-reloc-vehicle">
        <option value="">加载车辆中...</option>
      </select>
      <small id="lidar-reloc-vehicle-readiness" class="lidar-reloc-vehicle-readiness" data-state="idle">
        正在核对检索库和车端链路
      </small>
    </label>
    <button id="lidar-reloc-refresh" class="cloud-ops-toolbar-button" type="button">刷新</button>
    <button id="lidar-reloc-capture" class="cloud-ops-toolbar-button" type="button" disabled>抓取当前帧</button>
    <button id="lidar-reloc-infer" class="cloud-ops-toolbar-button lidar-reloc-primary" type="button" disabled>运行重定位</button>
  </div>

  <section class="lidar-reloc-visual-panel">
    <div class="lidar-reloc-result-head">
      <div>
        <p class="lidar-reloc-panel-kicker">VISUALIZATION</p>
        <h4>全局地图与当前帧叠加</h4>
      </div>
      <p id="lidar-reloc-visual-state" class="cloud-ops-inline-status" data-state="idle">等待推理</p>
    </div>
    <div class="lidar-reloc-visual-wrap">
      <canvas id="lidar-reloc-bev" width="960" height="560" aria-label="BEV relocalization visualization"></canvas>
      <div id="lidar-reloc-legend" class="lidar-reloc-legend"></div>
    </div>
  </section>

  <div class="lidar-reloc-grid">
    <section class="lidar-reloc-panel">
      <div class="lidar-reloc-panel-head">
        <p class="lidar-reloc-panel-kicker">MAP</p>
        <h4>全局点云地图</h4>
      </div>
      <div id="lidar-reloc-map" class="lidar-reloc-meta-grid"></div>
    </section>

    <section class="lidar-reloc-panel">
      <div class="lidar-reloc-panel-head">
        <p class="lidar-reloc-panel-kicker">LOCALIZATION</p>
        <h4>NDT 当前状态</h4>
      </div>
      <div id="lidar-reloc-localization" class="lidar-reloc-meta-grid"></div>
    </section>

    <section class="lidar-reloc-panel">
      <div class="lidar-reloc-panel-head">
        <p class="lidar-reloc-panel-kicker">PIPELINE</p>
        <h4>采集与推理链路</h4>
      </div>
      <div id="lidar-reloc-pipeline" class="lidar-reloc-meta-grid"></div>
    </section>
  </div>

  <section class="lidar-reloc-result">
    <div class="lidar-reloc-result-head">
      <div>
        <p class="lidar-reloc-panel-kicker">RESULT</p>
        <h4>粗位姿结果</h4>
      </div>
      <p id="lidar-reloc-result-state" class="cloud-ops-inline-status" data-state="idle">等待推理</p>
    </div>
    <div id="lidar-reloc-result" class="lidar-reloc-result-body">
      <p class="lidar-reloc-empty">先选择车辆并刷新状态。</p>
    </div>
    <details class="lidar-reloc-raw">
      <summary>原始 JSON</summary>
      <pre id="lidar-reloc-json">等待执行...</pre>
    </details>
  </section>

  <section class="lidar-dataset-panel" aria-labelledby="lidar-dataset-title">
    <div class="lidar-reloc-result-head">
      <div>
        <p class="lidar-reloc-panel-kicker">CAPTURE DATASET</p>
        <h4 id="lidar-dataset-title">车端采集数据</h4>
      </div>
      <div class="lidar-dataset-head-actions">
        <p id="lidar-dataset-state" class="cloud-ops-inline-status" data-state="idle">待加载</p>
        <button
          id="lidar-dataset-refresh"
          class="lidar-dataset-icon-button"
          type="button"
          title="刷新采集数据"
          aria-label="刷新采集数据"
        >↻</button>
      </div>
    </div>

    <div id="lidar-dataset-summary" class="lidar-dataset-summary"></div>

    <div class="lidar-dataset-workspace">
      <div class="lidar-dataset-fleet">
        <div class="lidar-dataset-subhead">
          <h5>车辆数据</h5>
          <span id="lidar-dataset-vehicle-count">0 台</span>
        </div>
        <div class="lidar-dataset-table-wrap">
          <table class="lidar-dataset-table">
            <thead>
              <tr>
                <th>车辆</th>
                <th>完整帧</th>
                <th>Session</th>
                <th>最近采集</th>
              </tr>
            </thead>
            <tbody id="lidar-dataset-vehicles"></tbody>
          </table>
        </div>
      </div>

      <div class="lidar-dataset-preview">
        <div class="lidar-dataset-preview-toolbar">
          <label for="lidar-dataset-session">
            <span>Session</span>
            <select id="lidar-dataset-session" disabled>
              <option value="">暂无数据</option>
            </select>
          </label>
          <div class="lidar-dataset-frame-controls">
            <button id="lidar-dataset-prev" type="button" title="上一帧" aria-label="上一帧" disabled>‹</button>
            <output id="lidar-dataset-frame-label">-- / --</output>
            <button id="lidar-dataset-next" type="button" title="下一帧" aria-label="下一帧" disabled>›</button>
          </div>
        </div>
        <input id="lidar-dataset-frame" class="lidar-dataset-frame-range" type="range" min="0" max="0" value="0" disabled aria-label="采集帧序号" />
        <div class="lidar-dataset-canvas-wrap">
          <canvas id="lidar-dataset-pointcloud" width="960" height="520" aria-label="采集点云俯视预览"></canvas>
          <div id="lidar-dataset-cloud-badge" class="lidar-dataset-cloud-badge">等待点云</div>
        </div>
        <div id="lidar-dataset-preview-meta" class="lidar-dataset-preview-meta"></div>
      </div>
    </div>
  </section>
</section>

<script is:inline define:vars={{ scriptText }} set:html={scriptText}></script>
