---
const { mode = "controller" } = Astro.props;
const isPageMode = mode === "page";
---

{isPageMode ? (
  <section id="jgzj-auth-panel" class="site-auth-dialog site-auth-dialog--page" aria-label="账号与权限">
    <header class="site-auth-head">
      <div>
        <p class="site-auth-kicker">ACCOUNT</p>
        <h2>登录与权限</h2>
      </div>
    </header>

    <p id="jgzj-auth-current" class="site-auth-current">正在检查登录状态...</p>

    <div id="jgzj-auth-guest" class="site-auth-grid">
      <form id="jgzj-login-form" class="site-auth-form">
        <h3>登录</h3>
        <label>
          <span>用户名</span>
          <input id="jgzj-login-username" type="text" autocomplete="username" maxlength="64" />
        </label>
        <label>
          <span>密码</span>
          <input id="jgzj-login-password" type="password" autocomplete="current-password" maxlength="128" />
        </label>
        <button type="submit">登录</button>
      </form>

      <form id="jgzj-register-form" class="site-auth-form">
        <h3>注册新账号</h3>
        <label>
          <span>用户名</span>
          <input id="jgzj-register-username" type="text" autocomplete="username" maxlength="32" placeholder="3-32 位字母数字" />
        </label>
        <label>
          <span>邮箱</span>
          <input id="jgzj-register-email" type="email" autocomplete="email" maxlength="254" />
        </label>
        <label>
          <span>密码</span>
          <input id="jgzj-register-password" type="password" autocomplete="new-password" maxlength="128" />
        </label>
        <button type="submit">注册并登录</button>
      </form>
    </div>

    <div id="jgzj-auth-user" class="site-auth-user" hidden>
      <form id="jgzj-email-form" class="site-auth-email-form">
        <div>
          <p class="site-auth-muted">邮箱验证</p>
          <p id="jgzj-email-state" class="site-auth-email-state">未验证账号暂不具备任何权限。</p>
        </div>
        <label>
          <span>邮箱</span>
          <input id="jgzj-email-input" type="email" autocomplete="email" maxlength="254" />
        </label>
        <button id="jgzj-email-send" class="site-auth-secondary-button" type="submit">发送验证邮件</button>
      </form>
      <div id="jgzj-auth-permissions" class="site-auth-permissions"></div>
      <div class="site-auth-workspaces" data-private-workspace-list hidden></div>
      <button id="jgzj-logout" class="site-auth-secondary-button" type="button">退出登录</button>
    </div>

    <section id="jgzj-auth-admin" class="site-auth-admin" hidden>
      <div class="site-auth-admin-head">
        <div>
          <p class="site-auth-kicker">ADMIN</p>
          <h3>账号权限管理</h3>
        </div>
        <button id="jgzj-admin-refresh" class="site-auth-secondary-button" type="button">刷新</button>
      </div>
      <div class="site-auth-admin-grid">
        <div id="jgzj-admin-user-list" class="site-auth-user-list"></div>
        <form id="jgzj-admin-form" class="site-auth-admin-form">
          <p id="jgzj-admin-selected" class="site-auth-muted">选择一个账号后分配权限。</p>
          <label class="site-auth-active-row">
            <input id="jgzj-admin-active" type="checkbox" />
            <span>账号启用</span>
          </label>
          <div id="jgzj-admin-permission-list" class="site-auth-permission-list"></div>
          <button id="jgzj-admin-save" type="submit" disabled>保存权限</button>
        </form>
      </div>
    </section>

    <p id="jgzj-auth-status" class="site-auth-status" data-state="idle">新注册账号默认只能查看非公开页面，具体互动权限由超级管理员分配。</p>
  </section>
) : null}

<script is:inline src="/js/account-auth.js" defer data-auth-mode={mode}></script>
