<section
  id="yolo-review-panel"
  class="yolo-review-panel embedded-panel"
  aria-live="polite"
  data-requires-permission="ai:yolo:review"
>
  <header class="yolo-review-head">
    <div class="yolo-review-title-wrap">
      <p class="yolo-review-kicker">YOLO DATASET VIEWER</p>
      <h1>YOLO 训练标签浏览</h1>
    </div>
    <div class="yolo-review-head-actions">
      <p id="yolo-review-status" class="cloud-chat-status" data-state="idle">待加载</p>
      <button id="yolo-review-refresh" class="cloud-chat-close" type="button">刷新</button>
    </div>
  </header>

  <div class="yolo-review-toolbar">
    <label class="yolo-review-field" for="yolo-review-source">
      <span>来源</span>
      <select id="yolo-review-source">
        <option value="">全部</option>
        <option value="checker_archive">车端校核数据</option>
        <option value="vehicle_collection">车辆自采图片</option>
      </select>
    </label>
    <label class="yolo-review-field" for="yolo-review-dataset">
      <span>数据集</span>
      <select id="yolo-review-dataset"></select>
    </label>
    <label class="yolo-review-field" for="yolo-review-split">
      <span>Split</span>
      <select id="yolo-review-split">
        <option value="">全部</option>
      </select>
    </label>
    <label class="yolo-review-field" for="yolo-review-class">
      <span>AI标类别</span>
      <select id="yolo-review-class">
        <option value="">全部</option>
      </select>
    </label>
    <label class="yolo-review-field" for="yolo-review-answer">
      <span>AI答案</span>
      <select id="yolo-review-answer">
        <option value="">全部</option>
        <option value="YES">YES</option>
        <option value="NO">NO</option>
      </select>
    </label>
    <label class="yolo-review-field" for="yolo-review-qwen-label">
      <span>Qwen标签</span>
      <select id="yolo-review-qwen-label">
        <option value="">全部</option>
      </select>
    </label>
    <label class="yolo-review-field yolo-review-field--search" for="yolo-review-query">
      <span>搜索</span>
      <input id="yolo-review-query" type="search" maxlength="120" placeholder="request / task / 地点" />
    </label>
  </div>

  <div class="yolo-review-focus-slot">
    <section
      id="yolo-fire-smoke-card"
      class="yolo-review-focus-card yolo-review-focus-card--standalone"
      data-state="loading"
    >
      <div class="yolo-review-focus-main">
        <p class="yolo-review-focus-kicker">SPECIAL DATASET</p>
        <h2>烟雾火焰数据集</h2>
        <p class="yolo-review-focus-desc">正在读取数据集统计。</p>
      </div>
      <div class="yolo-review-focus-metrics"></div>
      <button id="yolo-fire-smoke-open" class="cloud-chat-close" type="button" disabled>查看</button>
    </section>
  </div>

  <div class="yolo-review-summary" id="yolo-review-summary"></div>

  <div class="yolo-review-body">
    <aside class="yolo-review-list-shell">
      <div id="yolo-review-list" class="yolo-review-list">
        <p class="yolo-review-empty">暂无数据。</p>
      </div>
      <div class="yolo-review-pagination">
        <button id="yolo-review-prev" class="cloud-chat-close" type="button">上一页</button>
        <p id="yolo-review-page" class="yolo-review-page">第 1 / 1 页</p>
        <button id="yolo-review-next" class="cloud-chat-close" type="button">下一页</button>
      </div>
    </aside>

    <section id="yolo-review-detail" class="yolo-review-detail" data-state="idle">
      <p class="yolo-review-empty">选择一条训练样本。</p>
    </section>
  </div>
</section>

<script is:inline data-cfasync="false" src="/js/yolo-label-review.js?v=20260625-8" defer></script>
