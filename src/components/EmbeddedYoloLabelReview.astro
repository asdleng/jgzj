<section
  id="yolo-review-panel"
  class="yolo-review-panel embedded-panel"
  aria-live="polite"
  data-requires-permission="ai:yolo:review"
>
  <header class="yolo-review-head">
    <div class="yolo-review-title-wrap">
      <p class="yolo-review-kicker">AI DETECTION CLOSED LOOP</p>
      <h1>AI检测数据闭环</h1>
      <p class="yolo-review-subtitle">跟踪车端与云端数据回流、标注质量、模型候选效果，并进入样本库复核具体图片。</p>
    </div>
    <div class="yolo-review-head-actions">
      <p id="yolo-review-status" class="cloud-chat-status" data-state="idle">待加载</p>
      <button id="yolo-review-refresh" class="cloud-chat-close" type="button">刷新</button>
    </div>
  </header>

  <section class="yolo-review-daily-strip" aria-label="每日上传、标注与模型指标">
    <div class="yolo-review-section-intro">
      <div>
        <p class="yolo-review-section-kicker">闭环看板</p>
        <h2>数据回流与模型训练</h2>
      </div>
      <p>先看每天进来的数据、标注状态和昨日以来的候选模型效果。</p>
    </div>
    <div id="yolo-review-daily-stats" class="yolo-review-daily-stats" aria-label="每日上传与标注统计">
      <div class="yolo-review-loading yolo-review-loading--compact">
        <span class="yolo-review-spinner"></span>
        <p>每日统计加载中...</p>
      </div>
    </div>
  </section>

  <section class="yolo-review-review-strip" aria-label="样本库查看">
    <div class="yolo-review-section-intro">
      <div>
        <p class="yolo-review-section-kicker">样本库查看</p>
        <h2>事件、来源与具体数据</h2>
      </div>
      <p>按事件类型、数据来源和数据集筛选，查看图片、框、Qwen标注和人工复核结果。</p>
    </div>
  </section>

  <section class="yolo-review-event-strip" aria-label="事件类型">
    <div class="yolo-review-event-strip-head">
      <p class="yolo-review-event-title">事件类型</p>
      <p id="yolo-review-event-status" class="yolo-review-event-status">全部图片</p>
    </div>
    <div class="yolo-review-event-grid">
      <button class="yolo-review-event-button is-active" type="button" data-yolo-review-event="all">
        <span>全部</span>
        <strong>框 / Yes/No</strong>
      </button>
      <button class="yolo-review-event-button yolo-review-event-button--audit" type="button" data-yolo-review-event="qwen_suspect">
        <span>可疑标注</span>
        <strong>待人工校核</strong>
      </button>
      <button class="yolo-review-event-button" type="button" data-yolo-review-event="person">
        <span>人员</span>
        <strong>框</strong>
      </button>
      <button class="yolo-review-event-button" type="button" data-yolo-review-event="vehicle">
        <span>车辆</span>
        <strong>框</strong>
      </button>
      <button class="yolo-review-event-button" type="button" data-yolo-review-event="license_plate">
        <span>车牌</span>
        <strong>框</strong>
      </button>
      <button class="yolo-review-event-button" type="button" data-yolo-review-event="phone">
        <span>手机</span>
        <strong>Yes/No</strong>
      </button>
      <button class="yolo-review-event-button" type="button" data-yolo-review-event="smoking">
        <span>吸烟</span>
        <strong>Yes/No</strong>
      </button>
      <button class="yolo-review-event-button" type="button" data-yolo-review-event="fire_smoke">
        <span>烟火</span>
        <strong>框</strong>
      </button>
      <button class="yolo-review-event-button" type="button" data-yolo-review-event="trash">
        <span>垃圾</span>
        <strong>框</strong>
      </button>
      <button class="yolo-review-event-button" type="button" data-yolo-review-event="stall">
        <span>摆摊</span>
        <strong>框</strong>
      </button>
      <button class="yolo-review-event-button" type="button" data-yolo-review-event="pet">
        <span>宠物</span>
        <strong>候选/框</strong>
      </button>
      <button class="yolo-review-event-button" type="button" data-yolo-review-event="fishing">
        <span>钓鱼</span>
        <strong>框</strong>
      </button>
    </div>
  </section>

  <section class="yolo-review-dataset-strip" aria-label="数据来源与数据集">
    <div class="yolo-review-dataset-strip-head">
      <div>
        <p class="yolo-review-dataset-title">数据来源与数据集</p>
        <p id="yolo-review-dataset-status" class="yolo-review-dataset-status">正在读取数据集。</p>
      </div>
    </div>
    <div id="yolo-review-source-cards" class="yolo-review-source-cards" aria-label="来源筛选">
      <div class="yolo-review-loading yolo-review-loading--compact">
        <span class="yolo-review-spinner"></span>
        <p>来源统计加载中...</p>
      </div>
    </div>
    <div id="yolo-review-dataset-cards" class="yolo-review-dataset-cards">
      <div class="yolo-review-loading">
        <span class="yolo-review-spinner"></span>
        <p>数据集加载中...</p>
      </div>
    </div>
  </section>

  <div class="yolo-review-toolbar">
    <label class="yolo-review-field yolo-review-field--state" for="yolo-review-source">
      <span>来源</span>
      <select id="yolo-review-source">
        <option value="">全部来源</option>
        <option value="vehicle_collection">车辆自采</option>
        <option value="web_crawler">网络搜索数据集</option>
        <option value="checker_archive">云端校核</option>
        <option value="public_dataset">公开数据集</option>
      </select>
    </label>
    <label class="yolo-review-field yolo-review-field--state" for="yolo-review-dataset">
      <span>数据集</span>
      <select id="yolo-review-dataset"></select>
    </label>
    <label class="yolo-review-field yolo-review-field--advanced" for="yolo-review-split">
      <span>Split</span>
      <select id="yolo-review-split">
        <option value="">全部</option>
      </select>
    </label>
    <label class="yolo-review-field yolo-review-field--advanced" for="yolo-review-class">
      <span>AI标类别</span>
      <select id="yolo-review-class">
        <option value="">全部</option>
      </select>
    </label>
    <label class="yolo-review-field yolo-review-field--advanced" for="yolo-review-answer">
      <span>AI答案</span>
      <select id="yolo-review-answer">
        <option value="">全部</option>
        <option value="YES">YES</option>
        <option value="NO">NO</option>
      </select>
    </label>
    <label class="yolo-review-field yolo-review-field--advanced" for="yolo-review-qwen-label">
      <span>Qwen标签</span>
      <select id="yolo-review-qwen-label">
        <option value="">全部</option>
      </select>
    </label>
    <label class="yolo-review-field yolo-review-field--advanced" for="yolo-review-qwen-audit">
      <span>质检状态</span>
      <select id="yolo-review-qwen-audit">
        <option value="">全部</option>
        <option value="suspect">可疑待校核</option>
        <option value="needs_human">需人工</option>
        <option value="pass">通过</option>
        <option value="pending">未质检</option>
      </select>
    </label>
    <label class="yolo-review-field yolo-review-field--toggle yolo-review-field--advanced" for="yolo-review-has-box">
      <span>框过滤</span>
      <span class="yolo-review-toggle-control">
        <input id="yolo-review-has-box" type="checkbox" />
        <span>隐藏无框</span>
      </span>
    </label>
    <label class="yolo-review-field yolo-review-field--search yolo-review-field--advanced" for="yolo-review-query">
      <span>搜索</span>
      <input id="yolo-review-query" type="search" maxlength="120" placeholder="request / task / 地点" />
    </label>
  </div>

  <div class="yolo-review-summary" id="yolo-review-summary"></div>

  <div class="yolo-review-body">
    <aside class="yolo-review-list-shell">
      <div id="yolo-review-list" class="yolo-review-list">
        <p class="yolo-review-empty">暂无数据。</p>
      </div>
      <div class="yolo-review-pagination">
        <button id="yolo-review-prev" class="cloud-chat-close" type="button">上一页</button>
        <p id="yolo-review-page" class="yolo-review-page">第 1 / 1 页</p>
        <button id="yolo-review-next" class="cloud-chat-close" type="button">下一页</button>
      </div>
    </aside>

    <section id="yolo-review-detail" class="yolo-review-detail" data-state="idle">
      <p class="yolo-review-empty">选择一条训练样本。</p>
    </section>
  </div>
</section>

<script is:inline data-cfasync="false" src="/js/yolo-label-review.js?v=20260714-5" defer></script>

<style is:global>
  @media (max-width: 720px) {
    .yolo-review-main + .back-to-top {
      display: none !important;
    }
  }
</style>
