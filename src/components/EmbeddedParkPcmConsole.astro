<section class="park-pcm-shell" data-park-pcm data-authenticated="false">
  <header class="park-pcm-head">
    <div>
      <p class="section-kicker">PARK PCM</p>
      <h1>园区人流 PCM</h1>
    </div>
    <div class="park-pcm-head-actions">
      <p class="park-pcm-status" data-park-pcm-status data-state="idle">初始化</p>
      <button type="button" class="park-pcm-button" data-park-pcm-refresh>刷新快照</button>
      <button type="button" class="park-pcm-button park-pcm-button--secondary" data-park-pcm-report>发送报告</button>
    </div>
  </header>

  <div class="park-pcm-controls">
    <label>
      <span>车辆上限</span>
      <input type="number" min="1" max="500" value="200" data-park-pcm-max-vehicles />
    </label>
    <label class="park-pcm-check">
      <input type="checkbox" checked data-park-pcm-include-obstacle />
      <span>障碍处理</span>
    </label>
    <label class="park-pcm-check">
      <input type="checkbox" data-park-pcm-include-perception />
      <span>感知状态</span>
    </label>
    <p data-park-pcm-report-state>报告状态待加载</p>
  </div>

  <div class="park-pcm-auth" data-park-pcm-auth hidden></div>

  <div class="park-pcm-metrics" data-park-pcm-metrics>
    <article>
      <span>纳管车辆</span>
      <strong data-park-pcm-metric="total">-</strong>
    </article>
    <article>
      <span>新鲜在线</span>
      <strong data-park-pcm-metric="fresh">-</strong>
    </article>
    <article>
      <span>告警车辆</span>
      <strong data-park-pcm-metric="warnings">-</strong>
    </article>
    <article>
      <span>人流拥挤</span>
      <strong data-park-pcm-metric="crowded">-</strong>
    </article>
  </div>

  <section class="park-pcm-band park-pcm-crowd-demo">
    <div class="park-pcm-band-head">
      <div>
        <p class="section-kicker">CROWD CAPTURE DEMO</p>
        <h2>4 路相机人流采样</h2>
      </div>
      <p data-park-pcm-crowd-status>等待车辆列表</p>
    </div>

    <div class="park-pcm-crowd-controls">
      <label>
        <span>车辆</span>
        <select data-park-pcm-crowd-vehicle>
          <option value="">加载中...</option>
        </select>
      </label>
      <label>
        <span>距离门槛 m</span>
        <input type="number" min="5" max="1000" value="60" data-park-pcm-crowd-distance />
      </label>
      <label>
        <span>质量</span>
        <input type="number" min="20" max="90" value="45" data-park-pcm-crowd-quality />
      </label>
      <label>
        <span>宽度</span>
        <input type="number" min="160" max="1280" value="480" data-park-pcm-crowd-width />
      </label>
      <button type="button" class="park-pcm-button" data-park-pcm-crowd-capture>4 路抓拍</button>
    </div>

    <div class="park-pcm-crowd-last" data-park-pcm-crowd-last>
      <p class="park-pcm-empty">还没有采样记录。</p>
    </div>

    <div class="park-pcm-crowd-gallery" data-park-pcm-crowd-samples>
      <p class="park-pcm-empty">等待采样图片。</p>
    </div>
  </section>

  <section class="park-pcm-band">
    <div class="park-pcm-band-head">
      <div>
        <p class="section-kicker">ALERTS</p>
        <h2>重点告警</h2>
      </div>
      <p data-park-pcm-updated>暂无快照</p>
    </div>
    <div class="park-pcm-alerts" data-park-pcm-alerts>
      <p class="park-pcm-empty">等待快照。</p>
    </div>
  </section>

  <section class="park-pcm-band">
    <div class="park-pcm-band-head">
      <div>
        <p class="section-kicker">VEHICLES</p>
        <h2>全车 PCM 明细</h2>
      </div>
      <p data-park-pcm-elapsed>-</p>
    </div>
    <div class="park-pcm-table" data-park-pcm-table>
      <div class="park-pcm-table-head">
        <span>车辆</span>
        <span>心跳</span>
        <span>任务</span>
        <span>流量</span>
        <span>健康</span>
        <span>关键数据</span>
      </div>
      <div data-park-pcm-rows>
        <p class="park-pcm-empty">等待快照。</p>
      </div>
    </div>
  </section>
</section>

