<section id="chat-panel" class="cloud-chat-panel embedded-panel" aria-live="polite">
  <header class="cloud-chat-head">
    <div class="cloud-chat-head-main">
      <p class="cloud-chat-title">AI对话体验</p>
      <p id="chat-status" class="cloud-chat-status" data-state="idle">就绪</p>
      <label class="cloud-chat-identity" for="chat-identity">
        <span>身份</span>
        <select id="chat-identity" aria-label="选择身份">
          <option value="car-web">car-web</option>
        </select>
      </label>
      <label class="qwen36-thinking-toggle" for="chat-thinking">
        <input id="chat-thinking" type="checkbox" />
        <span>thinking</span>
      </label>
    </div>
  </header>
  <div id="chat-messages" class="cloud-chat-messages"></div>
  <form id="chat-form" class="cloud-chat-form">
    <textarea id="chat-input" rows="3" maxlength="500" placeholder="输入消息，Enter 发送，Shift+Enter 换行"></textarea>
    <button id="chat-send" type="submit">发送</button>
  </form>
</section>
