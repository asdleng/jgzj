    };
    const routePointCoordinates = (point) => {
      if (Array.isArray(point)) {
        const x = finiteNumber(point[0]);
        const y = finiteNumber(point[1]);
        const z = finiteNumber(point[2]);
        return Number.isFinite(x) && Number.isFinite(y) ? { x, y, z: Number.isFinite(z) ? z : 0 } : null;
      }
      if (!point || typeof point !== "object") return null;
      const nested = point?.pose?.position || point?.position || point?.point || point?.pose || point;
      const x = finiteNumber(nested?.x ?? point?.map_x ?? point?.utm_x ?? point?.x_m);
      const y = finiteNumber(nested?.y ?? point?.map_y ?? point?.utm_y ?? point?.y_m);
      const z = finiteNumber(nested?.z ?? point?.map_z ?? point?.utm_z ?? point?.z_m);
      return Number.isFinite(x) && Number.isFinite(y) ? { x, y, z: Number.isFinite(z) ? z : 0 } : null;
    };
    const routePointsOfPayload = (payload) => {
      const result = toolResultOfPayload(payload);
