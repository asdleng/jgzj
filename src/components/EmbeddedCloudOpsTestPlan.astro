        const pose = result?.vehicle_pose?.position || {};
        const pixel = result?.vehicle_pose?.vehicle_pixel || {};
        const poseX = finiteNumber(pose?.x);
        const poseY = finiteNumber(pose?.y);
        const pixelX = finiteNumber(pixel?.x);
        const pixelY = finiteNumber(pixel?.y);
        const fallbackMargin = Math.max(
          0,
          (Math.min(width, height) - Math.max(extent.width, extent.height) * scale) / 2
