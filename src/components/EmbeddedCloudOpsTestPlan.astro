      renderParamDraft();
      if (notify) setStatus("已清空当前车辆的未保存参数草稿，未执行任何车端操作。", "ok");
    };
    const loadParamDraft = () => {
      resetParamDraft(false);
      try {
        const draft = JSON.parse(localStorage.getItem(paramDraftStorageKey()) || "{}");
        paramDraftInputs.forEach((input) => {
          if (!(input.dataset.paramKey in draft)) return;
          if (input.type === "checkbox") input.checked = Boolean(draft[input.dataset.paramKey]);
          else input.value = String(draft[input.dataset.paramKey] ?? "");
        });
      } catch (_error) {}
      renderParamDraft();
    };
    const saveParamDraft = () => {
      const draft = {};
      paramDraftInputs.forEach((input) => {
        draft[input.dataset.paramKey] = input.type === "checkbox" ? input.checked : input.value;
      });
      try {
        localStorage.setItem(paramDraftStorageKey(), JSON.stringify(draft));
        setStatus(`已为 ${selectedVehicleId() || "当前车辆"} 保存本地参数草稿，未写入车辆。`, "ok");
      } catch (_error) {
        setStatus("本地草稿保存失败，未写入车辆。", "error");
      }
    };
    const setParamDomain = (domain) => {
      paramDomainTabs.forEach((button) => button.classList.toggle("is-active", button.dataset.paramDomain === domain));
      paramDomainPanels.forEach((panel) => {
        const active = panel.dataset.paramPanel === domain;
        panel.classList.toggle("is-active", active);
        panel.hidden = !active;
      });
    };

    const setStatus = (text, state = "idle") => {
      if (!statusNode) return;
      statusNode.textContent = text;
      statusNode.dataset.state = state;
    };

    const setActive = (targetId) => {
      tabs.forEach((tab) => tab.classList.toggle("is-active", tab.dataset.target === targetId));
      pages.forEach((page) => {
        page.dataset.active = page.id === targetId ? "true" : "false";
      });
    };

    const vehicleIdOf = (vehicle) => String(vehicle?.vehicle_id || vehicle?.plate_number || vehicle?.id || "").trim();
    const lastSeenOf = (vehicle) => String(vehicle?.last_seen || vehicle?.last_seen_at || vehicle?.updated_at || "").trim();
    const toolCountOf = (vehicle) => Number(vehicle?.tool_count || vehicle?.tools_count || 0) || 0;
    const selectedVehicleId = () => String(currentVehicleId || vehicleSelect?.value || "").trim();
    const displayValue = (value, fallback = "--") => {
      if (value === null || value === undefined || value === "") return fallback;
      return String(value);
    };
    const finiteNumber = (value) => {
      if (value === null || value === undefined || value === "") return NaN;
      const num = Number(value);
      return Number.isFinite(num) ? num : NaN;
    };
    const boolText = (value, trueText = "是", falseText = "否", unknownText = "未知") => {
      if (value === true) return trueText;
      if (value === false) return falseText;
      return unknownText;
    };
    const percentText = (value) => {
      const num = finiteNumber(value);
      if (!Number.isFinite(num)) return "--";
      return `${num.toFixed(num >= 10 ? 0 : 1)}%`;
    };
    const numberText = (value, digits = 1) => {
      const num = finiteNumber(value);
      if (!Number.isFinite(num)) return "--";
      return num.toFixed(digits);
    };
    const msText = (value) => {
      const num = finiteNumber(value);
      if (!Number.isFinite(num)) return "--";
      return `${num.toFixed(num >= 10 ? 0 : 1)} ms`;
    };
    const formatAge = (iso) => {
      const ts = Date.parse(iso || "");
      if (!Number.isFinite(ts)) return "未知";
      const diff = Math.max(0, Date.now() - ts);
      const min = Math.round(diff / 60000);
      if (min < 1) return "刚刚";
      if (min < 60) return `${min} 分钟前`;
      const hr = Math.round(min / 60);
      if (hr < 48) return `${hr} 小时前`;
      return `${Math.round(hr / 24)} 天前`;
    };
    const isStale = (vehicle) => {
      const ts = Date.parse(lastSeenOf(vehicle));
      return !Number.isFinite(ts) || Date.now() - ts > 5 * 60 * 1000;
    };
    const vehicleHealthOf = (vehicle) => {
      if (isStale(vehicle)) return { label: "遥测过期", tone: "warn" };
      if (vehicle?.master_ping_ok === false) return { label: "主控不可达", tone: "danger" };
      if (!vehicle?.has_heartbeat) return { label: "无心跳", tone: "warn" };
      if (!vehicle?.has_telemetry) return { label: "无telemetry", tone: "warn" };
      return { label: "在线", tone: "ok" };
    };
    const stopDiagnosisOf = (vehicle) => {
      if (isStale(vehicle)) {
        return {
          label: "通信过期",
          tone: "warn",
          reason: "last_seen 已过期，不能判断自动驾驶停止。",
          next: "先查云端连接和车端 auto_ad_ai 心跳。"
        };
      }
      if (vehicle?.master_ping_ok === false || vehicle?.telemetry_master_ros_ok === false) {
        return {
          label: "主控链路异常",
          tone: "danger",
          reason: "media 到主控或 ROS 不可达，自动驾驶状态不可确认。",
          next: "先查主控网络、ROS master、关键节点。"
        };
      }
      if (vehicle?.emergency_stop_pressed === true) {
        return {
          label: "阻断：急停",
          tone: "danger",
          reason: "急停已触发，车辆停止是安全阻断。",
          next: "进入控制/底盘故障诊断，现场确认后处理。"
        };
      }
      if (vehicle?.collision_stop === true) {
        return {
          label: "阻断：碰撞停",
          tone: "danger",
          reason: "碰撞停已触发，车辆停止是安全阻断。",
          next: "进入感知/底盘安全链路诊断。"
        };
      }
      if (vehicle?.localization_reliable === false) {
        return {
          label: "阻断：定位不可靠",
          tone: "danger",
          reason: "location_topic_ 不可靠，自动驾驶应停止。",
          next: "进入定位故障树，区分组合导航模式和纯 LiDAR NDT。"
        };
      }
      if (vehicle?.trajectory_estop === true) {
        return {
          label: "阻断：规划estop",
          tone: "danger",
          reason: "planning trajectory estop=true。",
          next: "进入规划/障碍物故障诊断。"
        };
      }
      const speedKph = finiteNumber(vehicle?.speed_kph);
      const locSpeedMps = finiteNumber(vehicle?.localization_speed_mps);
      const targetSpeed = finiteNumber(vehicle?.control_target_speed);
      const runningMode = finiteNumber(vehicle?.running_mode);
      const plannerState = String(vehicle?.planner_state || "").trim().toLowerCase();
      const plannerRunning = finiteNumber(vehicle?.planner_running);
      const vehicleIdleStatus = finiteNumber(vehicle?.vehicle_idle_status);
      const longTimeStop = vehicle?.long_time_stop === true;
      const totalLoop = finiteNumber(vehicle?.total_loop_sum);
      const currentLoop = finiteNumber(vehicle?.current_loop_index);
      const totalRefline = finiteNumber(vehicle?.total_refline_sum);
      const currentRefline = finiteNumber(vehicle?.current_refline_index);
      const trajectoryPointCount = finiteNumber(vehicle?.trajectory_point_count);
      const trajectoryLength = finiteNumber(vehicle?.trajectory_total_length);
      const currentPathCount = finiteNumber(vehicle?.current_path_count);
      const stopped = Number.isFinite(speedKph)
        ? speedKph < 0.2
        : Number.isFinite(locSpeedMps) && Math.abs(locSpeedMps) < 0.05;
      const routeProgress = Number.isFinite(totalLoop) && Number.isFinite(currentLoop) &&
        Number.isFinite(totalRefline) && Number.isFinite(currentRefline) &&
        totalLoop > 0 && totalRefline > 0 && currentLoop >= 0 && currentRefline >= 0;
      const hasTrajectory = Number.isFinite(trajectoryPointCount) && trajectoryPointCount > 0 &&
        Number.isFinite(trajectoryLength) && trajectoryLength > 0;
      const plannerActive = plannerState === "running" || (Number.isFinite(plannerRunning) && plannerRunning > 0);
      const taskEvidence = plannerActive ||
        (Number.isFinite(currentPathCount) && currentPathCount > 0) ||
        routeProgress ||
        hasTrajectory ||
        (Number.isFinite(vehicleIdleStatus) && vehicleIdleStatus === 0);
      if (taskEvidence && !stopped) {
        return {
          label: "运行中",
          tone: "ok",
          reason: `有任务/规划证据，当前速度 ${numberText(speedKph)} km/h。`,
          next: "未发现停止入口。"
        };
      }
      if (stopped && taskEvidence) {
        return {
          label: "疑似停车故障",
          tone: "warn",
          reason: `有任务/规划证据但车速接近 0，当前速度 ${numberText(speedKph)} km/h，planner=${displayValue(vehicle?.planner_running, plannerState || "--")}。`,
          next: "还缺任务状态和 60 秒位移历史；接 fleet aggregator 后才能确认“自动驾驶停止故障”。"
        };
      }
      if (stopped) {
        return {
          label: "停止待确认",
          tone: "neutral",
          reason: `当前速度 ${numberText(speedKph)} km/h，但未看到任务运行证据；mode=${displayValue(runningMode)}，target=${numberText(targetSpeed)} m/s。`,
          next: "需要接任务计划/任务进度后区分正常等待、任务完成、异常停车。"
        };
      }
      if (Number.isFinite(speedKph) && speedKph >= 0.2) {
        return {
          label: "运行中",
          tone: "ok",
          reason: `当前速度 ${numberText(speedKph)} km/h，未触发停止入口。`,
          next: "未发现停止入口。"
        };
      }
      if (Number.isFinite(targetSpeed) && targetSpeed > 0.2 && longTimeStop) {
        return {
          label: "疑似控制未动",
          tone: "warn",
          reason: `long_time_stop=true 且控制目标速度 ${numberText(targetSpeed)} m/s。`,
          next: "需要结合 60 秒位移历史确认，再查控制/底盘链路。"
        };
      }
      return {
        label: "不可判定",
        tone: "neutral",
        reason: `running_mode=${displayValue(vehicle?.running_mode)}，当前缓存缺任务执行状态。`,
        next: "需接任务状态、路线进度和位移历史。"
      };
    };
    const vehicleFaultsOf = (vehicle) => {
      const faults = [];
      const add = (label, reason, tone = "warn") => {
        if (!faults.some((item) => item.label === label)) faults.push({ label, reason, tone });
      };
      if (isStale(vehicle)) add("遥测过期", `最近状态：${formatAge(lastSeenOf(vehicle))}。`, "warn");
      if (vehicle?.master_ping_ok === false) add("主控不可达", "media 到主控网络探测失败。", "danger");
      if (vehicle?.telemetry_master_ros_ok === false) add("ROS 链路异常", "主控 ROS 状态不可用。", "danger");
      if (vehicle?.has_heartbeat === false) add("车辆无心跳", "云端缓存未收到车辆心跳。", "warn");
      if (vehicle?.has_telemetry === false) add("遥测缺失", "云端缓存没有 telemetry 数据。", "warn");
      if (vehicle?.has_snapshot === false) add("状态快照缺失", "云端缓存没有车辆状态快照。", "warn");
      const stopDiag = stopDiagnosisOf(vehicle);
      if ((stopDiag.tone === "danger" || stopDiag.tone === "warn") && !["通信过期", "主控链路异常"].includes(stopDiag.label)) {
        add(stopDiag.label, stopDiag.reason, stopDiag.tone);
      }
      const cpu = finiteNumber(vehicle?.cpu_percent);
      const memory = finiteNumber(vehicle?.memory_percent);
      const disk = finiteNumber(vehicle?.disk_percent);
      if (Number.isFinite(cpu) && cpu >= 90) add("CPU 负载过高", `CPU ${percentText(cpu)}。`, "warn");
      if (Number.isFinite(memory) && memory >= 90) add("内存占用过高", `内存 ${percentText(memory)}。`, "warn");
      if (Number.isFinite(disk) && disk >= 90) add("磁盘占用过高", `磁盘 ${percentText(disk)}。`, "warn");
      return faults;
    };
    const faultToneOf = (faults) => faults.some((item) => item.tone === "danger") ? "danger" : "warn";

    const renderPill = (label, tone = "neutral") => (
      `<span class="cloud-ops-test-pill is-${escapeHtml(tone)}">${escapeHtml(label)}</span>`
    );
    const escapeHtml = (value) => String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;");
    const parseJsonDataset = (value, fallback = {}) => {
      const text = String(value || "").trim();
      if (!text) return fallback;
      try {
        return JSON.parse(text);
      } catch (_error) {
        return fallback;
      }
    };
    const toolNameOfPayload = (payload) => String(
      payload?.plan?.tool_name ||
      payload?.execution?.request?.tool_name ||
      payload?.request?.tool_name ||
      payload?.tool_name ||
      ""
    ).trim();
    const toolResultOfPayload = (payload) => {
      const execution = payload?.execution || payload;
      return execution?.data?.response?.result ?? execution?.data?.response ?? payload?.result ?? payload;
    };
    const looksLikeBase64Payload = (value) => {
      const text = String(value || "").replace(/\s+/g, "");
      return text.length > 120 && /^[A-Za-z0-9+/=]+$/.test(text);
    };
    const normalizedMediaMime = (value, kind = "image") => {
      const mime = String(value || "").toLowerCase().split(";", 1)[0].trim();
      if (kind === "video" && /^video\/(mp4|webm|ogg)$/.test(mime)) return mime;
      if (kind === "image" && /^image\/(jpeg|jpg|png|webp|gif)$/.test(mime)) return mime === "image/jpg" ? "image/jpeg" : mime;
      return kind === "video" ? "video/mp4" : "image/jpeg";
    };
    const toMediaDataUrl = (base64, mimeType, kind = "image") => {
      const data = String(base64 || "").replace(/\s+/g, "");
      if (!looksLikeBase64Payload(data)) return "";
      return `data:${normalizedMediaMime(mimeType, kind)};base64,${data}`;
    };
    const safeMediaUrl = (value, kind = "image", generic = false) => {
      const text = String(value || "").trim();
      if (!text) return "";
      const dataPattern = kind === "video"
        ? /^data:video\/(mp4|webm|ogg);base64,/i
        : /^data:image\/(jpeg|jpg|png|webp|gif);base64,/i;
      if (dataPattern.test(text)) return text;
      if (generic) {
        const path = text.split(/[?#]/, 1)[0];
        const extensionPattern = kind === "video" ? /\.(mp4|webm|ogg)$/i : /\.(jpe?g|png|webp|gif)$/i;
        if (!extensionPattern.test(path)) return "";
      }
      try {
        const parsed = new URL(text, window.location.origin);
        if (parsed.origin === window.location.origin || parsed.protocol === "https:") return parsed.href;
      } catch (_error) {}
      return "";
    };
    const mediaLabelOf = (source, toolName, kind) => {
      const camera = source?.camera_id || source?.camera || source?.requested || source?.channel || "";
      const base = toolName === "camera.capture"
        ? "实时抓拍"
        : toolName === "ai_detection.images"
          ? "AI检测图片"
          : toolName === "obstacle.preview"
            ? "障碍物预览"
            : toolName === "map.preview"
              ? "地图预览"
              : kind === "video" ? "实时视频" : "实时图像";
      return camera ? `${base} · ${camera}` : String(source?.label || source?.title || source?.name || base);
    };
    const extractToolMediaItems = (payload) => {
      const items = [];
      const seenObjects = new WeakSet();
      const seenSources = new Set();
      const toolName = toolNameOfPayload(payload);
      const addItem = (source, src, kind) => {
        if (!src || seenSources.has(src) || items.length >= 12) return;
        seenSources.add(src);
        items.push({
          src,
          kind,
          label: mediaLabelOf(source, toolName, kind),
          width: source?.width || source?.frame_width || null,
          height: source?.height || source?.frame_height || null,
          timestamp: source?.captured_at || source?.generated_at || source?.created_at || source?.ts || ""
        });
      };
      const visit = (value, depth = 0) => {
        if (!value || depth > 7 || items.length >= 12) return;
        if (Array.isArray(value)) {
          value.slice(0, 12).forEach((item) => visit(item, depth + 1));
          return;
        }
        if (typeof value !== "object" || seenObjects.has(value)) return;
        seenObjects.add(value);

        const mimeType = value?.mime_type || value?.image_mime_type || value?.video_mime_type || value?.format || "";
        const isVideoMime = String(mimeType).startsWith("video/");
        const videoBase64 = value?.video_base64 || value?.mp4_base64 || (isVideoMime ? value?.data_base64 || value?.base64 : "");
        const imageBase64 = value?.image_base64 || value?.jpeg_base64 || value?.jpg_base64 || value?.frame_base64 || (!isVideoMime ? value?.data_base64 || value?.base64 : "");
        const videoSrc = safeMediaUrl(value?.video_url || value?.playback_url || value?.stream_url, "video") || toMediaDataUrl(videoBase64, mimeType, "video");
        const imageSrc = safeMediaUrl(value?.image_url || value?.snapshot_url || value?.frame_url, "image") || toMediaDataUrl(imageBase64, mimeType, "image");
        const genericVideoSrc = safeMediaUrl(value?.url, "video", true);
        const genericImageSrc = safeMediaUrl(value?.url, "image", true);
        addItem(value, videoSrc || genericVideoSrc, "video");
        addItem(value, imageSrc || genericImageSrc, "image");

        Object.values(value).forEach((child) => {
          if (child && typeof child === "object") visit(child, depth + 1);
        });
      };
      visit(toolResultOfPayload(payload));
      return items;
    };
    const clearToolMedia = () => {
      if (toolMediaGrid) toolMediaGrid.replaceChildren();
      if (toolMediaCount) toolMediaCount.textContent = "--";
      if (toolMedia) toolMedia.hidden = true;
    };
    const showToolMediaLoading = (message = "正在获取实时画面...") => {
      if (!toolMedia || !toolMediaGrid) return;
      const empty = document.createElement("p");
      empty.className = "cloud-ops-test-media-empty is-loading";
      empty.textContent = message;
      toolMediaGrid.replaceChildren(empty);
      if (toolMediaCount) toolMediaCount.textContent = "读取中";
      toolMedia.hidden = false;
    };
    const renderToolMedia = (payloads, options = {}) => {
      if (!toolMedia || !toolMediaGrid) return 0;
      const items = [];
      const seen = new Set();
      (Array.isArray(payloads) ? payloads : [payloads]).filter(Boolean).forEach((payload) => {
        extractToolMediaItems(payload).forEach((item) => {
          if (!seen.has(item.src) && items.length < 12) {
            seen.add(item.src);
            items.push(item);
          }
        });
      });
      toolMediaGrid.replaceChildren();
      if (!items.length) {
        if (!options.expected && !options.error) {
          toolMedia.hidden = true;
          return 0;
        }
        const empty = document.createElement("p");
        empty.className = "cloud-ops-test-media-empty";
        empty.textContent = options.error || "本次检查未返回可展示的实时图像或视频。";
        toolMediaGrid.appendChild(empty);
        if (toolMediaCount) toolMediaCount.textContent = "0 项";
        toolMedia.hidden = false;
        return 0;
      }

      items.forEach((item, index) => {
        const card = document.createElement("article");
        card.className = `cloud-ops-test-media-card is-${item.kind}`;
        let media;
        if (item.kind === "video") {
          media = document.createElement("video");
          media.controls = true;
          media.muted = true;
          media.playsInline = true;
          media.preload = "metadata";
          media.src = item.src;
          media.setAttribute("aria-label", item.label);
          card.appendChild(media);
        } else {
          const link = document.createElement("a");
          link.href = item.src;
          link.target = "_blank";
          link.rel = "noreferrer noopener";
          link.title = `${item.label}，点击查看原图`;
          media = document.createElement("img");
          media.src = item.src;
          media.alt = item.label;
          media.loading = index < 4 ? "eager" : "lazy";
          media.decoding = "async";
          link.appendChild(media);
          card.appendChild(link);
        }
        media.addEventListener("error", () => card.classList.add("is-error"), { once: true });

        const caption = document.createElement("div");
        caption.className = "cloud-ops-test-media-caption";
        const title = document.createElement("strong");
        title.textContent = item.label;
        caption.appendChild(title);
        const metaParts = [];
        if (item.width && item.height) metaParts.push(`${item.width} × ${item.height}`);
        if (item.timestamp) metaParts.push(String(item.timestamp));
        if (metaParts.length) {
          const meta = document.createElement("small");
          meta.textContent = metaParts.join(" · ");
          caption.appendChild(meta);
        }
        card.appendChild(caption);
        toolMediaGrid.appendChild(card);
      });
      if (toolMediaCount) toolMediaCount.textContent = `${items.length} 项`;
      toolMedia.hidden = false;
      return items.length;
    };
    const setStat = (key, value, note, tone = "") => {
      const card = shell.querySelector(`[data-stat="${key}"]`);
      if (!card) return;
      const strong = card.querySelector("strong");
      const p = card.querySelector("p");
      if (strong) strong.textContent = String(value);
      if (note && p) p.textContent = note;
      card.classList.remove("is-ok", "is-warn", "is-danger");
      if (tone) card.classList.add(`is-${tone}`);
    };

    const selectedVehicle = () => {
      const id = selectedVehicleId();
      return vehicles.find((vehicle) => vehicleIdOf(vehicle) === id) || null;
    };

    const syncSelectedVehicleUi = () => {
      if (vehicleSelect && selectedVehicleId() && vehicleSelect.value !== selectedVehicleId()) {
        vehicleSelect.value = selectedVehicleId();
      }
      shell.querySelectorAll("[data-vehicle-id]").forEach((button) => {
        button.classList.toggle("is-selected", button.dataset.vehicleId === selectedVehicleId());
      });
      shell.querySelectorAll("[data-vehicle-row-id]").forEach((row) => {
        row.classList.toggle("is-selected", row.dataset.vehicleRowId === selectedVehicleId());
      });
      if (selectedVehicleTitle) selectedVehicleTitle.textContent = selectedVehicleId() || "--";
      if (paramVehicle) paramVehicle.textContent = selectedVehicleId() || "--";
      if (lastParamVehicleId !== selectedVehicleId()) {
        lastParamVehicleId = selectedVehicleId();
        loadParamDraft();
      }
    };

    const setSelectedVehicle = (vehicleId, options = {}) => {
      const normalized = String(vehicleId || "").trim();
      currentVehicleId = vehicles.some((vehicle) => vehicleIdOf(vehicle) === normalized)
        ? normalized
        : vehicleIdOf(vehicles[0] || {});
      syncSelectedVehicleUi();
      renderSummary();
      if (options.silent !== true) {
        setStatus(`当前车辆：${currentVehicleId || "--"}`, "ok");
      }
      updateAgentContext();
    };

    const renderSummary = () => {
      const vehicle = selectedVehicle();
      if (selectedVehicleChip) selectedVehicleChip.textContent = vehicle ? vehicleIdOf(vehicle) : "未选择";
      if (selectedVehicleTitle) selectedVehicleTitle.textContent = vehicle ? vehicleIdOf(vehicle) : "--";
      if (!vehicleSummary) return;
      if (!vehicle) {
        vehicleSummary.innerHTML = "<div><dt>车辆</dt><dd>--</dd></div><div><dt>真实身份</dt><dd>--</dd></div><div><dt>车端链路</dt><dd>--</dd></div><div><dt>主控/ROS</dt><dd>--</dd></div><div><dt>资源</dt><dd>--</dd></div><div><dt>状态判断</dt><dd>--</dd></div>";
        return;
      }
      const vid = vehicleIdOf(vehicle);
      const health = vehicleHealthOf(vehicle);
      const stopDiag = stopDiagnosisOf(vehicle);
      vehicleSummary.innerHTML = [
        ["车辆", `${vid} / ${displayValue(vehicle?.plate_number, vid)}`],
        ["真实身份", `VIN ${displayValue(vehicle?.vin)} · ${displayValue(vehicle?.role)}`],
        ["车端链路", `${displayValue(vehicle?.hostname)} · media ${displayValue(vehicle?.local_primary_ip)} · cloud ${displayValue(vehicle?.remote)}`],
        ["主控/ROS", `主控 ${displayValue(vehicle?.master_host)} · ping ${boolText(vehicle?.master_ping_ok, "可达", "不可达")} ${msText(vehicle?.master_ping_latency_ms)} · topic/node/service ${displayValue(vehicle?.topic_count)}/${displayValue(vehicle?.node_count)}/${displayValue(vehicle?.service_count)}`],
        ["资源", `CPU ${percentText(vehicle?.cpu_percent)} · 内存 ${percentText(vehicle?.memory_percent)} · 磁盘 ${percentText(vehicle?.disk_percent)} · tools ${toolCountOf(vehicle) || "未知"}`],
        ["自动驾驶停止", `${stopDiag.label} · ${stopDiag.reason}`],
        ["下一步", stopDiag.next],
        ["最近在线", `${formatAge(lastSeenOf(vehicle))} · ${lastSeenOf(vehicle) || "无时间戳"} · msg ${displayValue(vehicle?.message_count)}`],
        ["状态判断", health.label]
      ].map(([k, v]) => `<div><dt>${escapeHtml(k)}</dt><dd>${escapeHtml(v)}</dd></div>`).join("");
    };

    const sortVehiclesByAttention = (items) => {
      const rank = (vehicle) => {
        const diag = stopDiagnosisOf(vehicle);
        if (diag.tone === "danger") return 0;
        if (diag.label === "疑似停车故障" || diag.tone === "warn") return 1;
        if (diag.label === "停止待确认") return 2;
        if (isStale(vehicle)) return 3;
        return 4;
      };
      return [...items].sort((a, b) => rank(a) - rank(b) || vehicleIdOf(a).localeCompare(vehicleIdOf(b), "zh-Hans-CN", { numeric: true, sensitivity: "base" }));
    };
    const sortVehiclesById = (items) => [...items].sort((a, b) => vehicleIdOf(a).localeCompare(vehicleIdOf(b), "zh-Hans-CN", { numeric: true, sensitivity: "base" }));
    const sortVehiclesForList = (items) => vehicleSortMode === "id" ? sortVehiclesById(items) : sortVehiclesByAttention(items);

    const renderVehicles = () => {
      const abnormalVehicles = sortVehiclesForList(vehicles).filter((vehicle) => vehicleFaultsOf(vehicle).length > 0);
      if (vehicleCount) vehicleCount.textContent = `${abnormalVehicles.length} 台异常`;
      if (!vehicleList) return;
      if (!vehicles.length) {
        vehicleList.innerHTML = '<p class="cloud-ops-test-empty">没有读取到车辆，或当前账号未授权。</p>';
        return;
      }
      if (!abnormalVehicles.length) {
        vehicleList.innerHTML = '<div class="cloud-ops-test-all-clear"><strong>当前没有发现异常车辆</strong><span>已读取的车辆均未触发页面端异常规则。</span></div>';
        return;
      }
      vehicleList.innerHTML = abnormalVehicles.map((vehicle) => {
        const vid = vehicleIdOf(vehicle);
        const faults = vehicleFaultsOf(vehicle);
        const tone = faultToneOf(faults);
        const selected = vid === selectedVehicleId();
        const faultHtml = faults.map((fault) => `<li class="is-${escapeHtml(fault.tone)}"><strong>${escapeHtml(fault.label)}</strong><span>${escapeHtml(fault.reason)}</span></li>`).join("");
        return `<button type="button" class="cloud-ops-test-vehicle-row cloud-ops-test-abnormal-card is-${escapeHtml(tone)}${selected ? " is-selected" : ""}" data-vehicle-id="${escapeHtml(vid)}">
          <span class="cloud-ops-test-severity">${escapeHtml(tone === "danger" ? "严重异常" : "需要关注")}</span>
          <strong class="cloud-ops-test-vehicle-id">${escapeHtml(vid || "未知车辆")}</strong>
          <span class="cloud-ops-test-vehicle-meta">${escapeHtml(displayValue(vehicle?.hostname, "无主机名"))} · 最近状态 ${escapeHtml(formatAge(lastSeenOf(vehicle)))}</span>
          <ul class="cloud-ops-test-fault-list">${faultHtml}</ul>
        </button>`;
      }).join("");
    };

    const renderVehicleTable = () => {
      if (!vehicleTableBody) return;
      if (!vehicles.length) {
        vehicleTableBody.innerHTML = '<tr><td colspan="7">没有读取到车辆，或当前账号未授权。</td></tr>';
        return;
      }
      vehicleTableBody.innerHTML = sortVehiclesForList(vehicles).map((vehicle) => {
        const vid = vehicleIdOf(vehicle);
        const health = vehicleHealthOf(vehicle);
        const stopDiag = stopDiagnosisOf(vehicle);
        const selected = vid === selectedVehicleId();
        const signalHtml = [
          vehicle?.has_heartbeat ? renderPill("heartbeat", "ok") : renderPill("无心跳", "warn"),
          vehicle?.has_snapshot ? renderPill("snapshot", "ok") : renderPill("无snapshot", "warn"),
          vehicle?.has_telemetry ? renderPill("telemetry", "ok") : renderPill("无telemetry", "warn")
        ].join("");
        return `<tr class="${selected ? "is-selected" : ""}" data-vehicle-row-id="${escapeHtml(vid)}">
          <td>
            <button type="button" class="cloud-ops-test-row-select" data-vehicle-id="${escapeHtml(vid)}">${escapeHtml(vid)}</button>
            <div>${renderPill(health.label, health.tone)}</div>
          </td>
          <td>
            <strong>${renderPill(stopDiag.label, stopDiag.tone)}</strong>
            <small>${escapeHtml(stopDiag.reason)}</small>
            <small>${escapeHtml(stopDiag.next)}</small>
          </td>
          <td>
            <strong>${escapeHtml(displayValue(vehicle?.plate_number, vid))}</strong>
            <small>VIN ${escapeHtml(displayValue(vehicle?.vin))}</small>
          </td>
          <td>
            <strong>${escapeHtml(displayValue(vehicle?.hostname))}</strong>
            <small>media ${escapeHtml(displayValue(vehicle?.local_primary_ip))} · remote ${escapeHtml(displayValue(vehicle?.remote))}</small>
          </td>
          <td>
            <strong>${escapeHtml(displayValue(vehicle?.master_host))} · ${escapeHtml(boolText(vehicle?.master_ping_ok, "可达", "不可达"))}</strong>
            <small>ping ${escapeHtml(msText(vehicle?.master_ping_latency_ms))} · ROS ${escapeHtml(displayValue(vehicle?.topic_count))}/${escapeHtml(displayValue(vehicle?.node_count))}/${escapeHtml(displayValue(vehicle?.service_count))}</small>
          </td>
          <td>
            <strong>CPU ${escapeHtml(percentText(vehicle?.cpu_percent))} · MEM ${escapeHtml(percentText(vehicle?.memory_percent))}</strong>
            <small>DISK ${escapeHtml(percentText(vehicle?.disk_percent))} · tools ${escapeHtml(toolCountOf(vehicle) || "未知")}</small>
          </td>
          <td>
            <strong>${escapeHtml(formatAge(lastSeenOf(vehicle)))}</strong>
            <small>${escapeHtml(lastSeenOf(vehicle) || "无时间戳")} · msg ${escapeHtml(displayValue(vehicle?.message_count))}</small>
            <div class="cloud-ops-test-signal-row">${signalHtml}</div>
          </td>
        </tr>`;
      }).join("");
    };

    const renderStopFaultMonitor = () => {
      if (!stopFaultList) return;
      const diagnosed = vehicles.map((vehicle) => ({ vehicle, diag: stopDiagnosisOf(vehicle) }));
      const actionable = diagnosed.filter((item) => item.diag.tone === "danger" || item.diag.tone === "warn");
      const pending = diagnosed.filter((item) => item.diag.label === "停止待确认");
      if (stopFaultCount) {
        stopFaultCount.textContent = `疑似/阻断 ${actionable.length} 台 · 停止待确认 ${pending.length} 台`;
      }
      const displayItems = actionable.concat(pending);
      const cards = displayItems.map(({ vehicle, diag }) => {
        const vid = vehicleIdOf(vehicle);
        return `<button type="button" class="cloud-ops-test-stop-card is-${escapeHtml(diag.tone)}" data-vehicle-id="${escapeHtml(vid)}">
          <span>${escapeHtml(diag.label)}</span>
          <strong>${escapeHtml(vid || "未知车辆")}</strong>
          <small>${escapeHtml(diag.reason)}</small>
          <em>${escapeHtml(diag.next)}</em>
        </button>`;
      });
      stopFaultList.innerHTML = cards.length
        ? cards.join("")
        : '<p class="cloud-ops-test-empty">当前没有疑似/阻断或停止待确认车辆。</p>';
    };

    const renderVehicleOptions = () => {
      if (!vehicleSelect) return;
      const previous = String(vehicleSelect.value || "").trim();
      vehicleSelect.innerHTML = "";
      if (!vehicles.length) {
        vehicleSelect.innerHTML = '<option value="">暂无车辆</option>';
        if (vehiclePickerList) vehiclePickerList.innerHTML = '<p class="cloud-ops-test-empty">暂无车辆</p>';
        if (onlineVehicleCount) onlineVehicleCount.textContent = "0 台";
        renderSummary();
        return;
      }
      sortVehiclesById(vehicles).forEach((vehicle) => {
        const vid = vehicleIdOf(vehicle);
        const option = document.createElement("option");
        option.value = vid;
        option.textContent = `${vid}${isStale(vehicle) ? " · 离线" : " · 在线"}`;
        vehicleSelect.appendChild(option);
      });
      if (previous && vehicles.some((vehicle) => vehicleIdOf(vehicle) === previous)) {
        currentVehicleId = previous;
      }
      if (!currentVehicleId || !vehicles.some((vehicle) => vehicleIdOf(vehicle) === currentVehicleId)) {
        currentVehicleId = vehicleIdOf(vehicles.find((vehicle) => !isStale(vehicle)) || vehicles[0]);
      }
      vehicleSelect.value = currentVehicleId;
      if (vehiclePickerList) {
        const onlineVehicles = sortVehiclesByAttention(vehicles.filter((vehicle) => !isStale(vehicle)));
        if (onlineVehicleCount) onlineVehicleCount.textContent = `${onlineVehicles.length} 台`;
        vehiclePickerList.innerHTML = onlineVehicles.length
          ? onlineVehicles.map((vehicle) => {
              const vid = vehicleIdOf(vehicle);
              const faults = vehicleFaultsOf(vehicle);
              const health = vehicleHealthOf(vehicle);
              const tone = faults.length ? faultToneOf(faults) : health.tone;
              const label = faults[0]?.label || health.label;
              const detail = `${label} · ${formatAge(lastSeenOf(vehicle))}`;
              const title = `${vid} · ${faults.map((fault) => fault.label).join("、") || health.label} · ${formatAge(lastSeenOf(vehicle))}`;
              return `<button type="button" class="cloud-ops-test-vehicle-spine-item is-${escapeHtml(tone)}${vid === selectedVehicleId() ? " is-selected" : ""}" data-vehicle-id="${escapeHtml(vid)}" title="${escapeHtml(title)}" aria-label="选择车辆 ${escapeHtml(vid)}，${escapeHtml(detail)}">
                <i class="cloud-ops-test-vehicle-spine-node" aria-hidden="true"></i>
                <span class="cloud-ops-test-vehicle-spine-copy">
                  <strong>${escapeHtml(vid || "未知车辆")}</strong>
                  <small>${escapeHtml(detail)}</small>
                </span>
              </button>`;
            }).join("")
          : '<p class="cloud-ops-test-empty">当前无在线车辆</p>';
      }
      syncSelectedVehicleUi();
      renderSummary();
      updateAgentContext();
    };

    const updateStats = () => {
      const withTools = vehicles.filter((vehicle) => toolCountOf(vehicle) > 0).length;
      const staleCount = vehicles.filter(isStale).length;
      const onlineCount = vehicles.length - staleCount;
      const stopDiagnoses = vehicles.map(stopDiagnosisOf);
      const stopConcernCount = stopDiagnoses.filter((diag) => diag.tone === "danger" || String(diag.label || "").startsWith("疑似")).length;
      const stopWarnCount = stopDiagnoses.filter((diag) => diag.tone === "warn").length;
      const stopPendingCount = stopDiagnoses.filter((diag) => diag.label === "停止待确认").length;
      setStat("online", onlineCount, `总计 ${vehicles.length} 台真实车辆`, onlineCount ? "ok" : "");
      setStat("tool", withTools, "tool_count > 0 的车辆", withTools ? "ok" : "");
      setStat("stale", staleCount, "last_seen 超过 5 分钟或无时间戳", staleCount ? "warn" : "ok");
      setStat("stop", `${stopConcernCount}/${stopPendingCount}`, `疑似/阻断 ${stopConcernCount} 台，停止待确认 ${stopPendingCount} 台`, stopConcernCount ? "danger" : (stopPendingCount ? "warn" : (stopWarnCount ? "warn" : "ok")));
    };

    const updateAgentContext = () => {
      if (!agentContext) return;
      const contextText = `上下文：一体化 AI · 可识别 ${vehicles.length} 台车辆；在消息中写明车辆编号、车牌或 VIN 即可查询。`;
      agentContext.textContent = contextText;
      if (agentPageContext) agentPageContext.textContent = contextText;
    };

    const agentModelLabel = (model) => String(model || "")
      .replace(/^gpt-/i, "GPT-")
      .replace(/-terra$/i, " Terra")
      .replace(/-sol$/i, " Sol")
      .replace(/-mini$/i, " Mini");

    const selectedAgentModel = () => {
      const selected = String(agentModelSelects[0]?.value || "").trim();
      return agentAvailableModels.includes(selected) ? selected : agentDefaultModel;
    };

    const setAgentModelSelection = (model, persist = false) => {
      const next = agentAvailableModels.includes(model) ? model : agentDefaultModel;
      agentModelSelects.forEach((select) => { select.value = next; });
      if (agentModel) agentModel.textContent = next || "--";
      if (agentPageModel) agentPageModel.textContent = `模型 ${next || "--"}`;
      if (agentModelNote) agentModelNote.textContent = `当前 ${agentModelLabel(next)} · 服务端默认 ${agentModelLabel(agentDefaultModel)}`;
      if (persist) {
        try { localStorage.setItem(agentModelStorageKey, next); } catch (_error) {}
      }
      return next;
    };

    const configureAgentModelSelectors = (payload) => {
      const models = Array.isArray(payload?.available_models)
        ? payload.available_models.map((item) => String(item || "").trim()).filter(Boolean)
        : [];
      agentAvailableModels = models.length ? [...new Set(models)] : agentAvailableModels;
      agentDefaultModel = String(payload?.default_model || payload?.model || agentDefaultModel).trim();
      if (!agentAvailableModels.includes(agentDefaultModel)) agentAvailableModels.unshift(agentDefaultModel);
      agentModelSelects.forEach((select) => {
        const fragment = document.createDocumentFragment();
        agentAvailableModels.forEach((model) => {
          const option = document.createElement("option");
          option.value = model;
          option.textContent = agentModelLabel(model);
          fragment.appendChild(option);
        });
        select.replaceChildren(fragment);
      });
      let stored = "";
      try { stored = localStorage.getItem(agentModelStorageKey) || ""; } catch (_error) {}
      setAgentModelSelection(agentAvailableModels.includes(stored) ? stored : agentDefaultModel);
    };


    const setAgentComposerBusy = (busy) => {
      agentRequestInFlight = Boolean(busy);
      agentSendButtons.forEach((button) => {
        button.disabled = agentRequestInFlight;
        button.setAttribute("aria-busy", agentRequestInFlight ? "true" : "false");
      });
      agentComposers.forEach((composer) => composer.classList.toggle("is-busy", agentRequestInFlight));
    };

    const resizeAgentInput = (input) => {
      if (!input) return;
      input.style.height = "auto";
      input.style.height = `${Math.min(Math.max(input.scrollHeight, 74), 220)}px`;
    };

    const setAgentStatusCard = (payload) => {
      agentCanChat = Boolean(payload?.can_chat);
      const statusText = payload?.can_chat ? "可对话" : (payload?.enabled ? "待配置" : "已禁用");
      if (agentStatus) agentStatus.textContent = statusText;
      if (agentPageStatus) agentPageStatus.textContent = statusText;
      if (agentStatusNote) {
        agentStatusNote.textContent = payload?.can_chat
          ? "服务端 key 已配置"
          : (payload?.missing_config?.length ? `缺少 ${payload.missing_config.join(", ")}` : "服务端未启用");
      }
      configureAgentModelSelectors(payload);
      if (agentRoute) agentRoute.textContent = payload?.upstream_base_url || "JGZJ / subapi";
      const codex = payload?.codex || {};
      if (agentCodex) agentCodex.textContent = codex?.deployed ? "已部署" : "未就绪";
      if (agentCodexNote) {
        const cliVersion = codex?.cli?.version ? ` · ${codex.cli.version}` : "";
        agentCodexNote.textContent = codex?.listen ? `${codex.listen}${cliVersion}` : (codex?.app_server?.detail || "本机 App Server");
      }
      if (agentFleet) agentFleet.textContent = `${payload?.fleet?.vehicle_count ?? vehicles.length} 台`;
      if (agentFleetNote) {
        const fleet = payload?.fleet || {};
        agentFleetNote.textContent = `在线 ${fleet.online_count ?? "--"} · 疑似/阻断 ${fleet.stop_concern_count ?? "--"} · 待确认 ${fleet.stop_pending_count ?? "--"}`;
      }
      if (agentAudit && payload?.safeguards?.length) {
        agentAudit.textContent = [
          "自动调用清单：/api/cloud-ops/vehicles-lite、/api/cloud-ops-agent/status、/api/cloud-ops-agent/history",
          "禁止自动调用：/api/cloud-ops/execute、tool-list、vehicle_detail",
          "智能体对话：必须用户点击发送；后端只调用 subapi 兼容模型接口",
          "控制类动作：未绑定执行",
          "",
          "后端安全边界：",
          ...payload.safeguards.map((item) => `- ${item}`)
        ].join("\n");
      }
    };

    const loadAgentStatus = async () => {
      try {
        const response = await fetch(AGENT_STATUS_URL, { headers: { Accept: "application/json" }, cache: "no-store", credentials: "same-origin" });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok || payload?.ok === false) {
          throw new Error(payload?.detail || payload?.error || `HTTP ${response.status}`);
        }
        setAgentStatusCard(payload);
      } catch (error) {
        agentCanChat = false;
        if (agentStatus) agentStatus.textContent = "状态异常";
        if (agentPageStatus) agentPageStatus.textContent = "状态异常";
        if (agentStatusNote) agentStatusNote.textContent = error?.message || "读取失败";
        if (agentModel) agentModel.textContent = "--";
        if (agentCodex) agentCodex.textContent = "未知";
        if (agentCodexNote) agentCodexNote.textContent = "状态接口异常";
      }
      updateAgentContext();
    };

    const renderAgentHistory = (items) => {
      const list = Array.isArray(items) ? items : [];
      if (agentHistoryCount) agentHistoryCount.textContent = `${list.length} 条`;
      if (!agentHistory) return;
      if (!list.length) {
        agentHistory.innerHTML = '<p class="cloud-ops-test-empty">暂无智能体记录。</p>';
        return;
      }
      agentHistory.innerHTML = list.map((item) => {
        const ok = item?.ok !== false;
        return `<article class="cloud-ops-test-agent-history-item ${ok ? "is-ok" : "is-error"}">
          <span>${escapeHtml(ok ? "OK" : "ERR")} · ${escapeHtml(item?.vehicle_id || "全局")}</span>
          <strong>${escapeHtml(item?.prompt_snippet || "--")}</strong>
          <p>${escapeHtml(item?.answer_snippet || item?.error || "--")}</p>
          <small>${escapeHtml(item?.at || "")} · ${escapeHtml(item?.model || "--")} · ${escapeHtml(item?.latency_ms ? `${item.latency_ms}ms` : "--")}</small>
        </article>`;
      }).join("");
    };

    const loadAgentHistory = async () => {
      try {
        const response = await fetch(`${AGENT_HISTORY_URL}?limit=20`, { headers: { Accept: "application/json" }, cache: "no-store", credentials: "same-origin" });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok || payload?.ok === false) {
          throw new Error(payload?.detail || payload?.error || `HTTP ${response.status}`);
        }
        renderAgentHistory(payload.items || []);
      } catch (error) {
        if (agentHistoryCount) agentHistoryCount.textContent = "异常";
        if (agentHistory) agentHistory.innerHTML = `<p class="cloud-ops-test-empty">历史读取失败：${escapeHtml(error?.message || "未知错误")}</p>`;
      }
    };

    const syncAgentMessageViews = () => {
      if (!agentMessages || !agentPageMessages) return;
      agentPageMessages.innerHTML = agentMessages.innerHTML;
      agentPageMessages.scrollTop = agentPageMessages.scrollHeight;
    };

    const appendAgentMessage = (role, text, meta = "") => {
      if (!agentMessages) return;
      const node = document.createElement("div");
      node.className = `cloud-ops-test-agent-message is-${role}`;
      const title = role === "user" ? "你" : (role === "error" ? "接口错误" : "山海智枢");
      node.innerHTML = `<strong>${escapeHtml(title)}</strong><p>${escapeHtml(text || "")}</p>${meta ? `<small>${escapeHtml(meta)}</small>` : ""}`;
      agentMessages.appendChild(node);
      agentMessages.scrollTop = agentMessages.scrollHeight;
      syncAgentMessageViews();
    };

    const formatAgentDuration = (milliseconds) => {
      const value = Math.max(0, Number(milliseconds || 0));
      if (value < 1000) return `${Math.round(value)} 毫秒`;
      return `${(value / 1000).toFixed(value < 10000 ? 1 : 0)} 秒`;
    };

    const createAgentRunMessage = (model) => {
      if (!agentMessages) return null;
      const node = document.createElement("div");
      node.className = "cloud-ops-test-agent-message is-agent is-running";
      node.innerHTML = `<div class="cloud-ops-agent-run-head">
        <span class="cloud-ops-agent-run-spinner" aria-hidden="true"></span>
        <strong data-role="agent-run-title">正在思考</strong>
        <time data-role="agent-run-elapsed">0.0 秒</time>
      </div>
      <details class="cloud-ops-agent-run-trace" open>
        <summary>思考与执行过程</summary>
        <ol data-role="agent-run-steps"></ol>
      </details>
      <p data-role="agent-run-answer" hidden></p>
      <small data-role="agent-run-meta">${escapeHtml(agentModelLabel(model))} · 一体化 AI 运维</small>`;
      agentMessages.appendChild(node);
      agentMessages.scrollTop = agentMessages.scrollHeight;
      const run = {
        node,
        startedAt: Date.now(),
        lastElapsedMs: 0,
        seenSteps: new Set(),
        timer: null
      };
      run.timer = window.setInterval(() => {
        const elapsedMs = Date.now() - run.startedAt;
        run.lastElapsedMs = elapsedMs;
        const elapsed = run.node.querySelector('[data-role="agent-run-elapsed"]');
        if (elapsed) elapsed.textContent = formatAgentDuration(elapsedMs);
        syncAgentMessageViews();
      }, 500);
      syncAgentMessageViews();
      return run;
    };

    const updateAgentRunMessage = (run, event) => {
      if (!run?.node || !event) return;
      const elapsedMs = Number(event.elapsed_ms || (Date.now() - run.startedAt));
      run.lastElapsedMs = Math.max(run.lastElapsedMs, elapsedMs);
      const elapsed = run.node.querySelector('[data-role="agent-run-elapsed"]');
      if (elapsed) elapsed.textContent = formatAgentDuration(run.lastElapsedMs);
      if (event.title) {
        const title = run.node.querySelector('[data-role="agent-run-title"]');
        if (title) title.textContent = event.title;
      }
      if (event.stage || event.title) {
        const stepKey = `${event.stage || "step"}:${event.tool || event.title || ""}:${event.analysis_index ?? event.completed ?? ""}:${event.status || ""}`;
        if (!run.seenSteps.has(stepKey)) {
          run.seenSteps.add(stepKey);
          const list = run.node.querySelector('[data-role="agent-run-steps"]');
          if (list) {
            const item = document.createElement("li");
            item.className = `is-${event.status || "running"}`;
            if (event.stage === "model_analysis") item.classList.add("is-model-analysis");
            item.innerHTML = `<span>${escapeHtml(event.title || "处理中")}</span>${event.detail ? `<small>${escapeHtml(event.detail)}</small>` : ""}<time>${escapeHtml(formatAgentDuration(elapsedMs))}</time>`;
            list.appendChild(item);
          }
        }
      }
      agentMessages.scrollTop = agentMessages.scrollHeight;
      syncAgentMessageViews();
    };

    const finishAgentRunMessage = (run, payload) => {
      if (!run?.node) return;
      window.clearInterval(run.timer);
      const elapsedMs = Number(payload?.latency_ms || run.lastElapsedMs || (Date.now() - run.startedAt));
      run.lastElapsedMs = elapsedMs;
      run.node.classList.remove("is-running");
      run.node.classList.toggle("is-warning", Boolean(payload?.model_error));
      const title = run.node.querySelector('[data-role="agent-run-title"]');
      if (title) title.textContent = payload?.model_error ? "已完成，模型总结使用降级结果" : "已完成";
      const elapsed = run.node.querySelector('[data-role="agent-run-elapsed"]');
      if (elapsed) elapsed.textContent = formatAgentDuration(elapsedMs);
      const answer = run.node.querySelector('[data-role="agent-run-answer"]');
      if (answer) {
        answer.hidden = false;
        answer.textContent = payload?.answer || "模型没有返回文本。";
      }
      const trace = run.node.querySelector(".cloud-ops-agent-run-trace");
      if (trace) {
        trace.open = false;
        const summary = trace.querySelector("summary");
        if (summary) summary.textContent = `查看思考与执行过程 · ${formatAgentDuration(elapsedMs)}`;
      }
      const meta = run.node.querySelector('[data-role="agent-run-meta"]');
      if (meta) {
        const kind = payload?.run_kind === "vehicle_diagnosis" ? "自动车辆诊断" : "一体化对话";
        meta.textContent = `${agentModelLabel(payload?.model || selectedAgentModel())} · ${formatAgentDuration(elapsedMs)} · ${kind}`;
      }
      syncAgentMessageViews();
    };

    const failAgentRunMessage = (run, error) => {
      if (!run?.node) return;
      window.clearInterval(run.timer);
      const elapsedMs = Date.now() - run.startedAt;
      run.node.classList.remove("is-running");
      run.node.classList.add("is-error");
      const title = run.node.querySelector('[data-role="agent-run-title"]');
      if (title) title.textContent = "调用失败";
      const elapsed = run.node.querySelector('[data-role="agent-run-elapsed"]');
      if (elapsed) elapsed.textContent = formatAgentDuration(elapsedMs);
      const answer = run.node.querySelector('[data-role="agent-run-answer"]');
      if (answer) {
        answer.hidden = false;
        answer.textContent = error?.message || "智能体调用失败";
      }
      const trace = run.node.querySelector(".cloud-ops-agent-run-trace");
      if (trace) trace.open = true;
      syncAgentMessageViews();
    };

    const readAgentEventStream = async (response, onEvent) => {
      if (!response.body) throw new Error("浏览器不支持流式响应");
      const reader = response.body.getReader();
      const decoder = new TextDecoder();
      let buffer = "";
      const consumeBlock = (block) => {
        if (!block.trim() || block.trim().startsWith(":")) return;
        let eventName = "message";
        const dataLines = [];
        block.split(/\r?\n/).forEach((line) => {
          if (line.startsWith("event:")) eventName = line.slice(6).trim();
          if (line.startsWith("data:")) dataLines.push(line.slice(5).trim());
        });
        if (!dataLines.length) return;
        let data = {};
        try { data = JSON.parse(dataLines.join("\n")); } catch (_error) { data = { detail: dataLines.join("\n") }; }
        onEvent(eventName, data);
      };
      while (true) {
        const { value, done } = await reader.read();
        buffer += decoder.decode(value || new Uint8Array(), { stream: !done });
        const blocks = buffer.split(/\r?\n\r?\n/);
        buffer = blocks.pop() || "";
        blocks.forEach(consumeBlock);
        if (done) break;
      }
      if (buffer.trim()) consumeBlock(buffer);
    };

    const sendAgentMessage = async (message) => {
      const text = String(message || "").trim();
      if (!text) {
        setStatus("请输入智能体问题", "error");
        return;
      }
      if (agentRequestInFlight) {
        setStatus("山海智枢正在处理上一条消息，请稍候。", "loading");
        return;
      }
      if (!agentCanChat) {
        appendAgentMessage("error", "智能体模型链路还没有配置服务端 subapi key，不能发起对话。");
        setStatus("智能体未配置 CLOUD_OPS_AGENT_API_KEY", "error");
        return;
      }

      const priorHistory = agentConversationHistory.slice(-12);
      appendAgentMessage("user", text, "一体化 AI 运维");
      agentConversationHistory.push({ role: "user", content: text });
      if (agentInput) {
        agentInput.value = "";
        resizeAgentInput(agentInput);
      }
      if (agentPageInput) {
        agentPageInput.value = "";
        resizeAgentInput(agentPageInput);
      }
      if (agentLatency) agentLatency.textContent = "正在思考 · 0.0 秒";
      setStatus("山海智枢正在理解问题；如识别到车辆诊断意图，将自动调用只读工具。", "loading");
      setAgentComposerBusy(true);
      const run = createAgentRunMessage(selectedAgentModel());
      let finalPayload = null;
      let streamFailure = null;

      try {
        const response = await fetch(AGENT_RUN_URL, {
          method: "POST",
          headers: { "Content-Type": "application/json", Accept: "text/event-stream" },
          credentials: "same-origin",
          body: JSON.stringify({
            message: text,
            model: selectedAgentModel(),
            history: priorHistory
          })
        });
        if (!response.ok) {
          const payload = await response.json().catch(() => ({}));
          throw new Error(payload?.detail || payload?.error || `HTTP ${response.status}`);
        }
        await readAgentEventStream(response, (eventName, payload) => {
          if (eventName === "heartbeat") {
            if (agentLatency) agentLatency.textContent = `正在思考 · ${formatAgentDuration(payload?.elapsed_ms)}`;
            updateAgentRunMessage(run, { elapsed_ms: payload?.elapsed_ms });
            return;
          }
          if (eventName === "start" || eventName === "progress") {
            updateAgentRunMessage(run, payload);
            if (agentLatency) agentLatency.textContent = `${payload?.title || "正在思考"} · ${formatAgentDuration(payload?.elapsed_ms)}`;
            return;
          }
          if (eventName === "result") {
            finalPayload = payload;
            return;
          }
          if (eventName === "error") {
            streamFailure = new Error(payload?.detail || payload?.error || "智能体调用失败");
          }
        });
        if (streamFailure) throw streamFailure;
        if (!finalPayload) throw new Error("智能体流式响应未返回最终结果");

        const answer = finalPayload.answer || "模型没有返回文本。";
        agentConversationHistory.push({ role: "assistant", content: answer });
        finishAgentRunMessage(run, finalPayload);
        if (agentLatency) agentLatency.textContent = `${finalPayload?.model_error ? "证据摘要" : "完成"} · ${formatAgentDuration(finalPayload.latency_ms)}`;
        setStatus(
          finalPayload?.run_kind === "vehicle_diagnosis"
            ? (finalPayload?.model_error ? "车辆证据采集完成；模型总结未完成，已返回可审计摘要。" : "车辆诊断完成；未执行任何车辆变更。")
            : "山海智枢回复完成；车辆上下文由消息自动识别。",
          finalPayload?.model_error ? "loading" : "ok"
        );
        loadAgentHistory();
      } catch (error) {
        failAgentRunMessage(run, error);
        if (agentLatency) agentLatency.textContent = "调用失败";
        setStatus(`智能体调用失败：${error?.message || "未知错误"}`, "error");
        loadAgentHistory();
      } finally {
        setAgentComposerBusy(false);
      }
    };

    const loadVehicles = async () => {
      setStatus("读取真实车辆列表...", "loading");
      try {
        const response = await fetch(VEHICLES_URL, { headers: { Accept: "application/json" }, cache: "no-store", credentials: "same-origin" });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok || payload?.ok === false) {
          throw new Error(payload?.detail || payload?.error || `HTTP ${response.status}`);
        }
        vehicles = Array.isArray(payload.vehicles) ? payload.vehicles : [];
        if (interfaceSource) interfaceSource.textContent = payload.source || "cloud_agent_registry";
        if (lastRefresh) lastRefresh.textContent = new Date().toLocaleTimeString("zh-CN", { hour12: false });
        renderVehicleOptions();
        renderVehicles();
        renderStopFaultMonitor();
        renderVehicleTable();
        syncSelectedVehicleUi();
        updateStats();
        setStatus(`已更新 ${vehicles.length} 台车辆。`, "ok");
      } catch (error) {
        vehicles = [];
        currentVehicleId = "";
        renderVehicleOptions();
        renderVehicles();
        renderStopFaultMonitor();
        renderVehicleTable();
        updateStats();
        setStatus(`车辆列表读取失败：${error?.message || "未知错误"}`, "error");
      }
    };

    const extractNestedValues = (value, max = 200) => {
      const found = [];
      const walk = (node, prefix = "") => {
        if (found.length >= max || node === null || node === undefined) return;
        if (typeof node !== "object") {
          found.push([prefix, node]);
          return;
        }
        if (Array.isArray(node)) {
          node.slice(0, 8).forEach((item, index) => walk(item, `${prefix}[${index}]`));
          return;
        }
        Object.entries(node).forEach(([key, child]) => {
          const next = prefix ? `${prefix}.${key}` : key;
          if (/password|token|secret|key/i.test(next)) return;
          walk(child, next);
        });
      };
      walk(value);
      return found;
    };

    const findFirstByKey = (payload, names) => {
      const wanted = new Set(names.map((name) => String(name).toLowerCase()));
      for (const [path, value] of extractNestedValues(payload)) {
        const tail = String(path || "").split(".").pop().replace(/\[\d+\]$/, "").toLowerCase();
        if (wanted.has(tail) && value !== null && value !== undefined && value !== "") return value;
      }
      return undefined;
    };

    const resultLine = (label, value) => `<div><dt>${escapeHtml(label)}</dt><dd>${escapeHtml(displayValue(value))}</dd></div>`;

    const summarizeCombinedResults = (payload) => {
      const results = Array.isArray(payload?.results) ? payload.results : [];
      const okCount = results.filter((item) => item.ok).length;
      const lines = results.map((item) => `${item.label || item.tool_name}: ${item.ok ? "正常返回" : "返回异常"}`);
      return {
        title: payload?.ok === false ? "综合检查存在异常返回" : "综合检查已完成",
        tone: payload?.ok === false ? "warn" : "ok",
        lines: [`${okCount}/${results.length} 个子检查正常返回`, ...lines],
        kv: []
      };
    };

    const summarizeToolPayload = (toolName, payload, vehicleId, liveMediaPayload = null, liveMediaError = "") => {
      const normalizedTool = String(toolName || "");
      if (normalizedTool === "task.navigation_context" || normalizedTool === "communication.cloud_vehicle" || normalizedTool === "combined.snapshot") {
        return summarizeCombinedResults(payload);
      }
      const ok = payload?.ok !== false;
      const result = toolResultOfPayload(payload);
      const liveMediaCount = liveMediaPayload ? extractToolMediaItems(liveMediaPayload).length : 0;
      if (normalizedTool === "status.camera" && result && typeof result === "object") {
        const cameras = Array.isArray(result?.cameras) ? result.cameras : [];
        const offline = Array.isArray(result?.offline_cameras) ? result.offline_cameras : [];
        return {
          title: "相机状态与实时画面",
          tone: ok && !offline.length ? "ok" : "warn",
          kv: [
            ["车辆", vehicleId],
            ["在线相机", `${result?.online_camera_count ?? 0} / ${result?.expected_camera_count ?? cameras.length}`],
            ["离线相机", offline.length ? offline.join("、") : "无"],
            ["实时画面", liveMediaCount ? `${liveMediaCount} 路` : "未返回"]
          ],
          lines: liveMediaError ? [`实时抓拍失败：${liveMediaError}`] : []
        };
      }
      if (normalizedTool === "ai_detection.images" && result && typeof result === "object") {
        const detectionImages = Array.isArray(result?.images) ? result.images : [];
        const detectionMediaCount = extractToolMediaItems(payload).length;
        return {
          title: "AI检测图片与实时画面",
          tone: ok && (detectionMediaCount || liveMediaCount) ? "ok" : "warn",
          kv: [
            ["车辆", vehicleId],
            ["最近检测图", `${detectionMediaCount || detectionImages.length || 0} 张`],
            ["目录总数", `${result?.total_files ?? detectionImages.length ?? 0}`],
            ["实时画面", liveMediaCount ? `${liveMediaCount} 路` : "未返回"]
          ],
          lines: [
            ...(result?.save_path ? [`图片目录：${result.save_path}`] : []),
            ...(liveMediaError ? [`实时抓拍失败：${liveMediaError}`] : [])
          ]
        };
      }
      if (normalizedTool === "camera.upload_chain" && result && typeof result === "object") {
        return {
          title: "相机上传链路与实时画面",
          tone: ok && liveMediaCount ? "ok" : "warn",
          kv: [
            ["车辆", vehicleId],
            ["链路状态", result?.health || result?.status || "未知"],
            ["实时画面", liveMediaCount ? `${liveMediaCount} 路` : "未返回"]
          ],
          lines: liveMediaError ? [`实时抓拍失败：${liveMediaError}`] : []
        };
      }
      const status = findFirstByKey(payload, ["status", "state", "health", "result", "summary"]);
      const speed = findFirstByKey(payload, ["speed_kph", "speed", "vehicle_speed", "localization_speed_mps"]);
      const mode = findFirstByKey(payload, ["running_mode", "mode", "planner_state"]);
      const masterPing = findFirstByKey(payload, ["master_ping_ok", "ping_ok", "master_ok"]);
      const rosOk = findFirstByKey(payload, ["telemetry_master_ros_ok", "ros_ok", "master_ros_ok"]);
      const cpu = findFirstByKey(payload, ["cpu_percent", "cpu"]);
      const memory = findFirstByKey(payload, ["memory_percent", "memory"]);
      const disk = findFirstByKey(payload, ["disk_percent", "disk"]);
      const emergency = findFirstByKey(payload, ["emergency_stop_pressed", "emergency_stop"]);
      const collision = findFirstByKey(payload, ["collision_stop"]);
      const titleByTool = {
        "vehicle.current_state": "车辆当前状态摘要",
        "vehicle_detail": "车辆详情摘要",
        "health.autodrive_check": "自动驾驶健康摘要",
        "system.snapshot": "系统资源摘要",
        "ros.overview": "ROS 总览摘要",
        "network.master_probe": "主控链路摘要"
      };
      const kv = [];
      kv.push(["车辆", vehicleId]);
      if (speed !== undefined) kv.push(["速度", speed]);
      if (mode !== undefined) kv.push(["模式/状态", mode]);
      if (masterPing !== undefined) kv.push(["主控链路", boolText(masterPing, "可达", "不可达")]);
      if (rosOk !== undefined) kv.push(["ROS", boolText(rosOk, "正常", "异常")]);
      if (emergency !== undefined) kv.push(["急停", boolText(emergency, "触发", "未触发")]);
      if (collision !== undefined) kv.push(["碰撞停", boolText(collision, "触发", "未触发")]);
      if (cpu !== undefined) kv.push(["CPU", cpu]);
      if (memory !== undefined) kv.push(["内存", memory]);
      if (disk !== undefined) kv.push(["磁盘", disk]);
      const lines = [];
      const errorDetail = findFirstByKey(payload, ["detail", "error", "message", "error_message"]);
      if (status !== undefined) lines.push(`返回状态：${displayValue(status)}`);
      if (!ok && errorDetail !== undefined) lines.push(`错误：${displayValue(errorDetail)}`);
      return {
        title: titleByTool[normalizedTool] || `${normalizedTool} 检查摘要`,
        tone: ok ? "ok" : "warn",
        lines,
        kv
      };
    };

    const renderToolSummary = (toolName, payload, vehicleId, liveMediaPayload = null, liveMediaError = "") => {
      if (!toolSummary) return;
      const summary = summarizeToolPayload(toolName, payload, vehicleId, liveMediaPayload, liveMediaError);
      const kvHtml = summary.kv?.length
        ? `<dl class="cloud-ops-test-result-kv">${summary.kv.map(([k, v]) => resultLine(k, v)).join("")}</dl>`
        : "";
      const lineHtml = summary.lines?.length
        ? `<ul>${summary.lines.map((line) => `<li>${escapeHtml(line)}</li>`).join("")}</ul>`
        : "";
      toolSummary.innerHTML = `<strong>${escapeHtml(summary.title)}</strong>${kvHtml}${lineHtml}`;
      toolSummary.dataset.tone = summary.tone || "ok";
    };

    const requestReadOnlyToolPayload = async (vehicleId, toolName, args = {}, timeout_s = 30, requestKind = "readonly") => {
      const response = await fetch(EXECUTE_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json", Accept: "application/json" },
        credentials: "same-origin",
        body: JSON.stringify({
          action: "tool_call",
          vehicle_id: vehicleId,
          tool_name: toolName,
          args,
          timeout_s,
          request_id: `cloud-ops-test-${requestKind}-${toolName}-${Date.now()}`
        })
      });
      const payload = await response.json().catch(() => ({}));
      if (!response.ok || payload?.ok === false) {
        throw new Error(payload?.detail || payload?.error || `HTTP ${response.status}`);
      }
      return payload;
    };

    const runReadOnlyTool = async (button) => {
      const toolName = String(button?.dataset?.tool || "").trim();
      const toolAction = String(button?.dataset?.toolAction || "tool_call").trim();
      const args = parseJsonDataset(button?.dataset?.toolArgs, {});
      const timeout_s = Number.parseInt(button?.dataset?.timeoutS || "30", 10) || 30;
      const includeLiveMedia = button?.dataset?.includeLiveMedia === "true";
      const vehicle = selectedVehicle();
      const vehicleId = vehicleIdOf(vehicle);
      if (!vehicleId) {
        setStatus("请先选择车辆", "error");
        return;
      }
      if (!READONLY_TOOL_ALLOWLIST.has(toolName)) {
        setStatus(`工具 ${toolName} 不在只读白名单内`, "error");
        return;
      }
      if (lastToolLabel) lastToolLabel.textContent = `${vehicleId} · ${toolName}`;
      if (toolSummary) toolSummary.textContent = `正在对 ${vehicleId} 执行只读检查：${toolName}`;
      clearToolMedia();
      if (MEDIA_EXPECTED_TOOLS.has(toolName) || includeLiveMedia) showToolMediaLoading();
      setStatus(`点击触发只读工具：${toolName}`, "loading");
      try {
        let payload;
        if (toolAction === "task_context" || toolName === "task.navigation_context") {
          const contextTools = [
            { tool_name: "status.routing", label: "Routing 状态", args: {} },
            { tool_name: "status.planning", label: "Planning 状态", args: {} },
            { tool_name: "route.list", label: "路线列表", args: {} },
            { tool_name: "status.localization", label: "定位状态", args: {} },
            { tool_name: "status.can", label: "CAN 状态", args: {} },
            { tool_name: "status.obstacle_processor", label: "障碍物处理", args: {} }
          ];
          const results = [];
          for (const item of contextTools) {
            const response = await fetch(EXECUTE_URL, {
              method: "POST",
              headers: { "Content-Type": "application/json", Accept: "application/json" },
              credentials: "same-origin",
              body: JSON.stringify({ action: "tool_call", vehicle_id: vehicleId, tool_name: item.tool_name, args: item.args, timeout_s, request_id: `cloud-ops-test-task-${item.tool_name}-${Date.now()}` })
            });
            const data = await response.json().catch(() => ({}));
            results.push({ label: item.label, tool_name: item.tool_name, ok: response.ok && data?.ok !== false, response: data });
          }
          payload = { ok: results.every((item) => item.ok), vehicle_id: vehicleId, tool_name: "task.navigation_context", description: "Routing + Planning + 路线列表 + 定位/CAN/障碍物处理的停车/不动诊断上下文", results };
        } else if (toolAction === "communication_check" || toolName === "communication.cloud_vehicle") {
          const communicationTools = [
            { tool_name: "network.cloud_probe", label: "云端连通", args: {} },
            { tool_name: "network.master_probe", label: "主控探测", args: { include_ssh: true } },
            { tool_name: "ros.overview", label: "ROS 总览", args: {} }
          ];
          const results = [];
          for (const item of communicationTools) {
            const response = await fetch(EXECUTE_URL, {
              method: "POST",
              headers: { "Content-Type": "application/json", Accept: "application/json" },
              credentials: "same-origin",
              body: JSON.stringify({ action: "tool_call", vehicle_id: vehicleId, tool_name: item.tool_name, args: item.args, timeout_s, request_id: `cloud-ops-test-comm-${item.tool_name}-${Date.now()}` })
            });
            const data = await response.json().catch(() => ({}));
            results.push({ label: item.label, tool_name: item.tool_name, ok: response.ok && data?.ok !== false, response: data });
          }
          payload = { ok: results.every((item) => item.ok), vehicle_id: vehicleId, tool_name: "communication.cloud_vehicle", description: "云端 + 主控 + ROS 链路综合只读结果", results };
        } else if (toolAction === "combined_snapshot" || toolName === "combined.snapshot") {
          const snapshotTools = [
            { tool_name: "health.snapshot", label: "健康快照", args: {} },
            { tool_name: "system.snapshot", label: "系统快照", args: { include_processes: true } },
            { tool_name: "vehicle.snapshot", label: "整车快照", args: { include_topic_samples: true } }
          ];
          const results = [];
          for (const item of snapshotTools) {
            const response = await fetch(EXECUTE_URL, {
              method: "POST",
              headers: { "Content-Type": "application/json", Accept: "application/json" },
              credentials: "same-origin",
              body: JSON.stringify({
                action: "tool_call",
                vehicle_id: vehicleId,
                tool_name: item.tool_name,
                args: item.args,
                timeout_s,
                request_id: `cloud-ops-test-combined-${item.tool_name}-${Date.now()}`
              })
            });
            const data = await response.json().catch(() => ({}));
            results.push({ label: item.label, tool_name: item.tool_name, ok: response.ok && data?.ok !== false, response: data });
          }
          payload = {
            ok: results.every((item) => item.ok),
            vehicle_id: vehicleId,
            tool_name: "combined.snapshot",
            description: "健康快照 + 系统快照 + 整车快照的合并只读结果",
            results
          };
        } else if (toolAction === "tool_list" || toolName === "tool_list") {
          const response = await fetch(`/api/cloud-ops/vehicles/${encodeURIComponent(vehicleId)}/tool-list?timeout_s=${encodeURIComponent(timeout_s)}`, { headers: { Accept: "application/json" }, credentials: "same-origin" });
          payload = await response.json().catch(() => ({}));
          if (!response.ok || payload?.ok === false) throw new Error(payload?.detail || payload?.error || `HTTP ${response.status}`);
        } else if (toolAction === "vehicle_detail" || toolName === "vehicle_detail") {
          const response = await fetch(`/api/cloud-ops/vehicles/${encodeURIComponent(vehicleId)}`, { headers: { Accept: "application/json" }, credentials: "same-origin" });
          payload = await response.json().catch(() => ({}));
          if (!response.ok || payload?.ok === false) throw new Error(payload?.detail || payload?.error || `HTTP ${response.status}`);
        } else {
          payload = await requestReadOnlyToolPayload(vehicleId, toolName, args, timeout_s);
        }
        let liveMediaPayload = null;
        let liveMediaError = "";
        if (includeLiveMedia) {
          if (toolSummary) toolSummary.textContent = `状态检查完成，正在获取 ${vehicleId} 的实时画面...`;
          try {
            liveMediaPayload = await requestReadOnlyToolPayload(vehicleId, "camera.capture", LIVE_CAPTURE_ARGS, 40, "live-media");
          } catch (error) {
            liveMediaError = error?.message || "未知错误";
          }
        }
        renderToolSummary(toolName, payload, vehicleId, liveMediaPayload, liveMediaError);
        const mediaCount = renderToolMedia([payload, liveMediaPayload], {
          expected: MEDIA_EXPECTED_TOOLS.has(toolName) || includeLiveMedia,
          error: liveMediaError ? `实时画面获取失败：${liveMediaError}` : ""
        });
        setStatus(`只读检查完成：${toolName}${mediaCount ? ` · ${mediaCount} 项媒体` : ""}`, liveMediaError && !mediaCount ? "loading" : "ok");
      } catch (error) {
        const primaryError = error?.message || "未知错误";
        let fallbackLiveMedia = null;
        let fallbackMediaError = "";
        if (includeLiveMedia) {
          try {
            fallbackLiveMedia = await requestReadOnlyToolPayload(vehicleId, "camera.capture", LIVE_CAPTURE_ARGS, 40, "live-media-fallback");
          } catch (mediaError) {
            fallbackMediaError = mediaError?.message || "未知错误";
          }
        }
        const mediaCount = renderToolMedia([fallbackLiveMedia], {
          expected: MEDIA_EXPECTED_TOOLS.has(toolName) || includeLiveMedia,
          error: fallbackMediaError
            ? `检查失败：${primaryError}；实时画面获取失败：${fallbackMediaError}`
            : `检查失败：${primaryError}`
        });
        if (toolSummary) {
          toolSummary.textContent = mediaCount
            ? `状态检查失败：${primaryError}；已返回 ${mediaCount} 项实时媒体。`
            : `只读检查失败：${primaryError}`;
        }
        setStatus(`只读检查失败：${primaryError}${mediaCount ? ` · 已返回 ${mediaCount} 项实时媒体` : ""}`, "error");
      }
    };

    const setAgentRailOpen = (open) => {
      if (!agentRail) return;
      agentRail.classList.toggle("is-open", Boolean(open));
      agentToggle?.setAttribute("aria-expanded", open ? "true" : "false");
      if (agentPageOpenLabel) agentPageOpenLabel.textContent = open ? "收起右侧侧边栏" : "展开右侧侧边栏";
    };
    const setAgentPinned = (pinned) => {
      if (!agentRail) return;
      agentRail.classList.toggle("is-pinned", Boolean(pinned));
      shell.classList.toggle("has-agent-pinned", Boolean(pinned));
      agentPin?.setAttribute("aria-pressed", pinned ? "true" : "false");
      if (agentPin) agentPin.textContent = pinned ? "取消固定" : "固定";
      if (agentPagePinLabel) agentPagePinLabel.textContent = pinned ? "取消固定侧边栏" : "固定右侧侧边栏";
      setAgentRailOpen(Boolean(pinned));
      try { localStorage.setItem("cloudOpsTestAgentPinned", pinned ? "1" : "0"); } catch (_error) {}
    };
    const restoreAgentPinned = () => {
      try {
        setAgentPinned(localStorage.getItem("cloudOpsTestAgentPinned") === "1");
      } catch (_error) {
        setAgentPinned(false);
      }
    };
    const alignAgentRailToHero = () => {
      const hero = shell.querySelector(".cloud-ops-test-topbar");
      if (!hero || !agentRail) return;
      const top = Math.max(0, Math.round(hero.getBoundingClientRect().top + 56));
      agentRail.style.setProperty("--cloud-ops-test-agent-top", `${top}px`);
      agentRail.style.setProperty("--cloud-ops-test-agent-max-height", `calc(100vh - ${top + 20}px)`);
    };

    tabs.forEach((tab) => tab.addEventListener("click", () => setActive(tab.dataset.target)));
    shell.addEventListener("click", (event) => {
      const target = event.target;
      const vehicleButton = target?.closest?.("[data-vehicle-id]");
      if (vehicleButton && vehicleSelect) {
        setSelectedVehicle(vehicleButton.dataset.vehicleId || "");
        return;
      }
      const paramDomainButton = target?.closest?.("[data-param-domain]");
      if (paramDomainButton) {
        setParamDomain(paramDomainButton.dataset.paramDomain || "control");
        return;
      }
      const actionButton = target?.closest?.("[data-action]");
      if (!actionButton) return;
      const action = actionButton.dataset.action;
      if (action === "refresh-vehicles") {
        loadVehicles();
      } else if (action === "readonly-tool") {
        runReadOnlyTool(actionButton);
      } else if (action === "agent-toggle") {
        setAgentRailOpen(!agentRail?.classList.contains("is-open"));
      } else if (action === "agent-pin") {
        setAgentPinned(!agentRail?.classList.contains("is-pinned"));
      } else if (action === "agent-send") {
        const composerInput = actionButton.closest('[data-role="agent-composer"]')?.querySelector("textarea");
        sendAgentMessage(composerInput?.value || agentInput?.value || agentPageInput?.value || "");
      } else if (action === "agent-page-open") {
        setAgentRailOpen(!agentRail?.classList.contains("is-open"));
      } else if (action === "agent-page-pin") {
        setAgentPinned(!agentRail?.classList.contains("is-pinned"));
      } else if (action === "param-save-draft") {
        saveParamDraft();
      } else if (action === "param-reset-draft") {
        try { localStorage.removeItem(paramDraftStorageKey()); } catch (_error) {}
        resetParamDraft();
      }
    });
    paramDraftInputs.forEach((input) => {
      input.addEventListener("input", renderParamDraft);
      input.addEventListener("change", renderParamDraft);
    });
    vehicleSelect?.addEventListener("change", () => {
      setSelectedVehicle(vehicleSelect.value || "");
    });
    vehicleSortSelect?.addEventListener("change", () => {
      vehicleSortMode = vehicleSortSelect.value === "id" ? "id" : "status";
      renderVehicles();
      renderVehicleTable();
      setStatus(vehicleSortMode === "id" ? "车辆列表已按车辆编号排序。" : "车辆列表已按状态排序：异常在前，正常在后。", "ok");
    });
    const syncAgentInputs = (source, target) => {
      if (source && target && target.value !== source.value) {
        target.value = source.value;
        resizeAgentInput(target);
      }
      resizeAgentInput(source);
    };
    agentInput?.addEventListener("input", () => syncAgentInputs(agentInput, agentPageInput));
    agentPageInput?.addEventListener("input", () => syncAgentInputs(agentPageInput, agentInput));
    agentModelSelects.forEach((select) => {
      select.addEventListener("change", () => {
        const model = setAgentModelSelection(select.value, true);
        setStatus(`山海智枢后续请求将使用 ${agentModelLabel(model)}。`, "ok");
      });
    });
    const handleAgentComposerKeydown = (event, input) => {
      if (event.key === "Enter" && !event.shiftKey && !event.isComposing && event.keyCode !== 229) {
        event.preventDefault();
        sendAgentMessage(input?.value || "");
      }
    };
    agentInput?.addEventListener("keydown", (event) => handleAgentComposerKeydown(event, agentInput));
    agentPageInput?.addEventListener("keydown", (event) => handleAgentComposerKeydown(event, agentPageInput));
    agentToggle?.addEventListener("mouseenter", () => setAgentRailOpen(true));
    agentRail?.addEventListener("mouseleave", () => {
      if (!agentRail.classList.contains("is-pinned") && !agentRail.matches(":focus-within")) setAgentRailOpen(false);
    });
    agentRail?.addEventListener("focusin", () => setAgentRailOpen(true));
    agentRail?.addEventListener("focusout", () => {
      window.setTimeout(() => {
        if (!agentRail.classList.contains("is-pinned") && !agentRail.matches(":focus-within") && !agentRail.matches(":hover")) setAgentRailOpen(false);
      }, 80);
    });
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && agentRail && !agentRail.classList.contains("is-pinned")) {
        setAgentRailOpen(false);
      }
    });

    alignAgentRailToHero();
    window.addEventListener("resize", alignAgentRailToHero);
    restoreAgentPinned();
    resizeAgentInput(agentInput);
    resizeAgentInput(agentPageInput);
    setParamDomain("control");
    renderParamDraft();
    syncAgentMessageViews();
    loadVehicles();
    loadAgentStatus();
    loadAgentHistory();
  })();
</script>
