      context.lineWidth = 1;
      context.font = "12px ui-monospace, SFMono-Regular, Menlo, monospace";
      context.fillStyle = "#64748b";
      const gridStep = 5;
      for (let meters = -Math.floor(safeRange / gridStep) * gridStep; meters <= safeRange; meters += gridStep) {
