      const vehicleLength = 4.2 * scale;
      context.fillStyle = "rgba(59, 130, 246, 0.5)";
      context.strokeStyle = "#93c5fd";
      context.lineWidth = 2;
      context.fillRect(centerX - vehicleWidth / 2, centerY - vehicleLength / 2, vehicleWidth, vehicleLength);
      context.strokeRect(centerX - vehicleWidth / 2, centerY - vehicleLength / 2, vehicleWidth, vehicleLength);
      context.fillStyle = "#bfdbfe";
      context.beginPath();
      context.moveTo(centerX, centerY - vehicleLength / 2 - 13);
      context.lineTo(centerX - 7, centerY - vehicleLength / 2);
      context.lineTo(centerX + 7, centerY - vehicleLength / 2);
      context.closePath();
      context.fill();

      const sourceTopic = String(lidarResult?.topic || "点云");
      const obstacleCount = Number(obstacleResult?.summary?.drawn_obstacle_count ?? obstacles.length) || 0;
      context.fillStyle = "#f8fafc";
      context.font = "700 22px system-ui, sans-serif";
      context.fillText("实时俯视点云", 52, 34);
      context.fillStyle = "#94a3b8";
      context.font = "14px ui-monospace, SFMono-Regular, Menlo, monospace";
      context.fillText(`${sourceTopic} · ${points.length} points · ${obstacleCount} boxes · range +/-${safeRange}m`, 52, 60);
      context.fillStyle = "#67e8f9";
      context.fillText("x forward", centerX + 10, plotTop + 18);
      context.fillText("y left", plotLeft + 8, centerY - 10);
      context.fillStyle = "#94a3b8";
      context.fillText(`height ${lowZ.toFixed(2)}m`, 52, size - 24);
      palette.forEach((color, index) => {
        context.fillStyle = color;
        context.fillRect(180 + index * 24, size - 37, 24, 16);
      });
      context.fillStyle = "#94a3b8";
      context.fillText(`${highZ.toFixed(2)}m`, 385, size - 24);
      context.fillStyle = "#fbbf24";
      context.fillText("fusion obstacle boxes", 530, size - 24);

      return {
        tool_name: "obstacle.pointcloud.preview",
        result: {
          image_url: canvas.toDataURL("image/png"),
          mime_type: "image/png",
          label: "实时俯视点云 · 障碍物框",
          width: size,
          height: size,
          captured_at: lidarResult?.generated_at || obstacleResult?.generated_at || ""
        }
      };
    };
    const loadOverlaySourceImage = (src) => new Promise((resolve, reject) => {
      const image = new Image();
      image.onload = () => resolve(image);
      image.onerror = () => reject(new Error("实时相机图像无法解码"));
      image.src = src;
    });
    const invertRigidTransform = (matrix) => {
      if (!Array.isArray(matrix) || matrix.length < 3) return null;
      const rotation = matrix.slice(0, 3).map((row) => row.slice(0, 3).map(Number));
      const translation = matrix.slice(0, 3).map((row) => Number(row?.[3]));
      if (rotation.flat().some((value) => !Number.isFinite(value)) || translation.some((value) => !Number.isFinite(value))) {
        return null;
      }
      const inverseRotation = [0, 1, 2].map((row) => [0, 1, 2].map((column) => rotation[column][row]));
      const inverseTranslation = inverseRotation.map((row) => -(
        row[0] * translation[0] + row[1] * translation[1] + row[2] * translation[2]
      ));
      return inverseRotation.map((row, index) => [...row, inverseTranslation[index]]);
    };
    const transformPoint3d = (matrix, point) => {
      if (!matrix) return null;
      const x = Number(point?.x);
      const y = Number(point?.y);
      const z = Number(point?.z);
      if (![x, y, z].every(Number.isFinite)) return null;
      return {
        x: matrix[0][0] * x + matrix[0][1] * y + matrix[0][2] * z + matrix[0][3],
        y: matrix[1][0] * x + matrix[1][1] * y + matrix[1][2] * z + matrix[1][3],
        z: matrix[2][0] * x + matrix[2][1] * y + matrix[2][2] * z + matrix[2][3]
      };
    };
    const projectCameraPoint = (point, camera, width, height) => {
      if (!point || point.z <= 0.08) return null;
      const intrinsic = camera?.intrinsic || {};
      const sourceWidth = Math.max(1, Number(camera?.resolution?.width || width));
      const sourceHeight = Math.max(1, Number(camera?.resolution?.height || height));
      const fx = Number(intrinsic.fx) * width / sourceWidth;
      const fy = Number(intrinsic.fy) * height / sourceHeight;
      const cx = Number(intrinsic.cx) * width / sourceWidth;
      const cy = Number(intrinsic.cy) * height / sourceHeight;
      if (![fx, fy, cx, cy].every(Number.isFinite)) return null;
      const normalizedX = point.x / point.z;
      const normalizedY = point.y / point.z;
      if (Math.abs(normalizedX) > 5 || Math.abs(normalizedY) > 5) return null;
      const coeffs = Array.isArray(camera?.distortion?.coeffs) ? camera.distortion.coeffs.map(Number) : [];
      const [k1 = 0, k2 = 0, p1 = 0, p2 = 0, k3 = 0] = coeffs;
      const radius2 = normalizedX * normalizedX + normalizedY * normalizedY;
      const radial = 1 + k1 * radius2 + k2 * radius2 * radius2 + k3 * radius2 * radius2 * radius2;
      const distortedX = normalizedX * radial + 2 * p1 * normalizedX * normalizedY + p2 * (radius2 + 2 * normalizedX * normalizedX);
      const distortedY = normalizedY * radial + p1 * (radius2 + 2 * normalizedY * normalizedY) + 2 * p2 * normalizedX * normalizedY;
      const x = fx * distortedX + cx;
      const y = fy * distortedY + cy;
      return Number.isFinite(x) && Number.isFinite(y) ? { x, y, depth: point.z } : null;
    };
    const obstacleCorners3d = (obstacle) => {
      const center = obstacle?.center || {};
      const dimensions = obstacle?.dimensions || {};
      const centerZ = Number(center.z || 0);
      const height = Math.max(0.05, Math.abs(Number(dimensions.z || 0.1)));
      let footprint = Array.isArray(obstacle?.corners)
        ? obstacle.corners
            .map((corner) => ({ x: Number(corner?.x), y: Number(corner?.y) }))
            .filter((corner) => Number.isFinite(corner.x) && Number.isFinite(corner.y))
        : [];
      if (footprint.length < 4) {
        const centerX = Number(center.x);
        const centerY = Number(center.y);
        const length = Math.max(0.05, Math.abs(Number(dimensions.x || 0.1)));
        const width = Math.max(0.05, Math.abs(Number(dimensions.y || 0.1)));
        const yaw = Number(obstacle?.yaw_rad || 0);
        const cosine = Math.cos(yaw);
        const sine = Math.sin(yaw);
        footprint = [[1, 1], [1, -1], [-1, -1], [-1, 1]].map(([sx, sy]) => {
          const localX = sx * length / 2;
          const localY = sy * width / 2;
          return {
            x: centerX + localX * cosine - localY * sine,
            y: centerY + localX * sine + localY * cosine
          };
        });
      }
      return footprint.flatMap((corner) => [
        { x: corner.x, y: corner.y, z: centerZ - height / 2 },
        { x: corner.x, y: corner.y, z: centerZ + height / 2 }
      ]);
    };
    const renderObstacleCameraOverlayPayload = async (cameraPayload, obstaclePayload, calibrationPayload) => {
      const cameraResult = toolResultOfPayload(cameraPayload) || {};
      const obstacleResult = toolResultOfPayload(obstaclePayload) || {};
      const calibrationResult = toolResultOfPayload(calibrationPayload) || {};
      const cameraMedia = extractToolMediaItems(cameraPayload).filter((item) => item.kind === "image");
      const calibrations = Array.isArray(calibrationResult?.cameras) ? calibrationResult.cameras : [];
      const obstacles = Array.isArray(obstacleResult?.obstacles) ? obstacleResult.obstacles : [];
      if (!cameraMedia.length) throw new Error("车端未返回实时相机帧");
      if (!calibrations.length) throw new Error("车端未返回相机标定参数");

      const overlays = [];
      for (const item of cameraMedia) {
        const cameraId = String(item.cameraId || "").trim();
        const calibration = calibrations.find((camera) => String(camera?.camera_id || "") === cameraId);
        const cameraTransform = invertRigidTransform(calibration?.T_base_cam);
        if (!calibration || !cameraTransform || calibration?.canonical_calibration === false) continue;
        const sourceImage = await loadOverlaySourceImage(item.src);
        const width = sourceImage.naturalWidth || sourceImage.width;
        const height = sourceImage.naturalHeight || sourceImage.height;
        if (!width || !height) continue;
        const canvas = document.createElement("canvas");
        canvas.width = width;
        canvas.height = height;
        const context = canvas.getContext("2d");
        if (!context) continue;
        context.drawImage(sourceImage, 0, 0, width, height);

        const boxes = [];
        obstacles.slice(0, 120).forEach((obstacle) => {
          const pixels = obstacleCorners3d(obstacle)
            .map((corner) => transformPoint3d(cameraTransform, corner))
            .map((point) => projectCameraPoint(point, calibration, width, height))
            .filter(Boolean);
          if (pixels.length < 2) return;
          const rawMinX = Math.min(...pixels.map((point) => point.x));
          const rawMaxX = Math.max(...pixels.map((point) => point.x));
          const rawMinY = Math.min(...pixels.map((point) => point.y));
          const rawMaxY = Math.max(...pixels.map((point) => point.y));
          if (rawMaxX < 0 || rawMinX > width || rawMaxY < 0 || rawMinY > height) return;
          let minX = Math.max(0, rawMinX);
          let maxX = Math.min(width - 1, rawMaxX);
          let minY = Math.max(0, rawMinY);
          let maxY = Math.min(height - 1, rawMaxY);
          const centerX = (minX + maxX) / 2;
          const centerY = (minY + maxY) / 2;
          if (maxX - minX < 18) {
            minX = Math.max(0, centerX - 9);
            maxX = Math.min(width - 1, centerX + 9);
          }
          if (maxY - minY < 18) {
            minY = Math.max(0, centerY - 9);
            maxY = Math.min(height - 1, centerY + 9);
          }
          if (maxX - minX < 4 || maxY - minY < 4) return;
          boxes.push({ obstacle, minX, minY, maxX, maxY });
        });

        context.lineWidth = Math.max(2, Math.round(width / 480));
        context.font = `800 ${Math.max(12, Math.round(width / 70))}px system-ui, sans-serif`;
        context.textBaseline = "top";
        boxes.forEach(({ obstacle, minX, minY, maxX, maxY }) => {
          const color = "#fb7185";
          context.strokeStyle = color;
          context.fillStyle = "rgba(251, 113, 133, 0.1)";
          context.strokeRect(minX, minY, maxX - minX, maxY - minY);
          context.fillRect(minX, minY, maxX - minX, maxY - minY);
          const obstacleCenter = obstacle?.center || {};
          const reportedDistance = Number(obstacle?.distance_m ?? obstacleCenter?.distance_m);
          const derivedDistance = Math.hypot(Number(obstacleCenter?.x || 0), Number(obstacleCenter?.y || 0));
          const distance = Number.isFinite(reportedDistance) ? reportedDistance : derivedDistance;
          const label = `FUSION #${obstacle?.id ?? obstacle?.index ?? "-"}${Number.isFinite(distance) ? ` · ${distance.toFixed(1)}m` : ""}`;
          const metrics = context.measureText(label);
          const labelHeight = Math.max(18, Math.round(width / 45));
          const labelWidth = Math.min(width - minX, metrics.width + 12);
          const labelY = Math.max(0, minY - labelHeight);
          context.fillStyle = "rgba(136, 19, 55, 0.92)";
          context.fillRect(minX, labelY, labelWidth, labelHeight);
          context.fillStyle = "#fff1f2";
          context.fillText(label, minX + 6, labelY + 2);
        });

        const headerHeight = Math.max(30, Math.round(width / 24));
        context.fillStyle = "rgba(2, 6, 23, 0.76)";
        context.fillRect(0, 0, width, headerHeight);
        context.fillStyle = "#f8fafc";
        context.font = `900 ${Math.max(14, Math.round(width / 55))}px system-ui, sans-serif`;
        context.textBaseline = "middle";
        context.fillText(`FUSION · ${cameraId} · ${boxes.length} 个目标`, 12, headerHeight / 2);

        overlays.push({
          camera_id: cameraId,
          image_url: canvas.toDataURL("image/jpeg", 0.88),
          mime_type: "image/jpeg",
          label: `障碍物实景 · ${cameraId} · ${boxes.length} 个融合目标`,
          width,
          height,
          captured_at: cameraResult?.generated_at || obstacleResult?.generated_at || "",
          projected_obstacle_count: boxes.length,
          calibration_id: calibration?.calibration_id || calibrationResult?.sensor_rig_version || "",
          source_topic: obstacleResult?.source?.topic || "/fusion/objects"
        });
      }
      if (!overlays.length) throw new Error("当前车辆没有可用于投影的正式相机标定");
      return {
        tool_name: "obstacle.camera_overlay",
        result: {
          generated_at: cameraResult?.generated_at || obstacleResult?.generated_at || "",
          source_topic: obstacleResult?.source?.topic || "/fusion/objects",
          source_frame: obstacleResult?.source?.frame_id || obstacleResult?.summary?.frame_id || "vehicle",
          sensor_rig_id: calibrationResult?.sensor_rig_id || "",
          transform: "vehicle_base_to_camera",
          summary: {
            camera_count: overlays.length,
            fusion_object_count: Number(obstacleResult?.summary?.object_count ?? obstacles.length) || 0,
            projected_obstacle_count: overlays.reduce((sum, image) => sum + image.projected_obstacle_count, 0)
          },
          images: overlays
        }
      };
    };
    const mediaMetaText = (item) => {
      const parts = [];
      if (item?.width && item?.height) parts.push(`${item.width} x ${item.height}`);
      if (item?.timestamp) parts.push(String(item.timestamp));
      return parts.join(" · ");
    };
    const closeMediaViewer = () => {
      if (!mediaViewer) return;
      if (mediaViewer.open) mediaViewer.close();
      if (mediaViewerImage) {
        mediaViewerImage.removeAttribute("src");
        mediaViewerImage.alt = "";
      }
      activeViewerFollowLabel = "";
    };
    const openMediaViewer = (item) => {
      if (!mediaViewer || !mediaViewerImage || !item?.src) return;
      mediaViewerImage.src = item.src;
      mediaViewerImage.alt = item.label || "原图预览";
      if (mediaViewerTitle) mediaViewerTitle.textContent = item.label || "原图预览";
      if (mediaViewerMeta) mediaViewerMeta.textContent = mediaMetaText(item);
      activeViewerFollowLabel = ["camera.capture", "obstacle.camera_overlay"].includes(item.toolName) ? item.label : "";
      if (!mediaViewer.open) mediaViewer.showModal();
    };
    mediaViewer?.addEventListener("close", () => {
      if (mediaViewerImage) {
        mediaViewerImage.removeAttribute("src");
        mediaViewerImage.alt = "";
      }
      activeViewerFollowLabel = "";
    });
    mediaViewer?.addEventListener("click", (event) => {
      if (event.target === mediaViewer) closeMediaViewer();
    });
    const resetMapRouteControls = () => {
      mapRouteGeneration += 1;
      mapRouteState = null;
      if (mapRouteControls) mapRouteControls.hidden = true;
      if (mapRouteSelect) {
        mapRouteSelect.replaceChildren();
        mapRouteSelect.disabled = true;
      }
      if (mapRouteStatus) mapRouteStatus.textContent = "正在读取路线...";
    };
    const renderMapRouteControls = (state, message = "", loading = false) => {
      if (!mapRouteControls || !mapRouteSelect) return;
      const routes = Array.isArray(state?.routes) ? state.routes : [];
      mapRouteSelect.replaceChildren();
      if (!routes.length) {
        const option = document.createElement("option");
        option.value = "";
        option.textContent = loading ? "正在读取路线..." : "暂无可用路线";
        mapRouteSelect.appendChild(option);
      } else {
        routes.forEach((route) => {
          const option = document.createElement("option");
          option.value = route.routeId;
          option.textContent = `${route.name}${route.routeId === state.currentRouteId ? " · 当前" : ""}`;
          mapRouteSelect.appendChild(option);
        });
      }
      if (state?.selectedRouteId && routes.some((route) => route.routeId === state.selectedRouteId)) {
        mapRouteSelect.value = state.selectedRouteId;
      }
      mapRouteSelect.disabled = loading || routes.length < 2;
      mapRouteControls.hidden = false;
      mapRouteControls.classList.toggle(
        "is-current-route",
        Boolean(state?.selectedRouteId && state.selectedRouteId === state.currentRouteId)
      );
      if (mapRouteStatus) {
        mapRouteStatus.textContent = message || (routes.length ? `${routes.length} 条路线` : "基础地图已显示");
      }
    };
    const resetObstaclePreviewContext = () => {
      obstaclePreviewContext = null;
      if (obstacleOverlayState) {
        obstacleOverlayState.hidden = true;
        obstacleOverlayState.textContent = "障碍物实景待查询";
        obstacleOverlayState.removeAttribute("data-tone");
      }
    };
    const updateObstacleOverlayState = () => {
      const context = obstaclePreviewContext;
      if (!context || context.vehicleId !== selectedVehicleId()) {
        resetObstaclePreviewContext();
        return;
      }
      const overlayResult = context.overlayPayload ? toolResultOfPayload(context.overlayPayload) || {} : {};
      const cameraCount = context.overlayPayload ? extractToolMediaItems(context.overlayPayload).length : 0;
      const projectedCount = Number(overlayResult?.summary?.projected_obstacle_count || 0);
      const message = context.overlayError
        ? context.overlayError
        : cameraCount
          ? `${cameraCount} 路障碍物实景 · ${projectedCount} 个融合目标`
          : context.liveMediaError || "未返回障碍物实景";
      if (obstacleOverlayState) {
        obstacleOverlayState.hidden = false;
        obstacleOverlayState.textContent = message;
        obstacleOverlayState.dataset.tone = context.overlayError || context.liveMediaError
          ? "error"
          : projectedCount ? "ready" : "empty";
      }
    };
    const renderObstaclePreviewContext = () => {
      const context = obstaclePreviewContext;
      if (!context) return 0;
