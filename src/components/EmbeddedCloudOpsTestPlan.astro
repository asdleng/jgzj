    const normalizedMapExtent = (payload) => {
      const result = toolResultOfPayload(payload) || {};
      const candidates = [
        result?.map?.extent,
        result?.map?.bounds,
        result?.extent,
        result?.bounds,
        result?.image?.extent,
        result?.render?.extent
      ].filter((candidate) => candidate && typeof candidate === "object");
      for (const candidate of candidates) {
        const minX = finiteNumber(candidate?.min_x ?? candidate?.x_min ?? candidate?.xmin ?? candidate?.left);
        const maxX = finiteNumber(candidate?.max_x ?? candidate?.x_max ?? candidate?.xmax ?? candidate?.right);
        const minY = finiteNumber(candidate?.min_y ?? candidate?.y_min ?? candidate?.ymin ?? candidate?.bottom);
        const maxY = finiteNumber(candidate?.max_y ?? candidate?.y_max ?? candidate?.ymax ?? candidate?.top);
        if ([minX, maxX, minY, maxY].every(Number.isFinite) && maxX > minX && maxY > minY) {
          return {
            minX,
            maxX,
            minY,
            maxY,
            width: finiteNumber(candidate?.width_m) || maxX - minX,
            height: finiteNumber(candidate?.height_m) || maxY - minY,
