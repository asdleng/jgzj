      if (paramChangeList) {
        paramChangeList.innerHTML = changes.length
          ? changes.map((input) => `<article><strong>${escapeHtml(input.dataset.paramLabel || input.dataset.paramKey || "参数")}</strong><span>${escapeHtml(paramValueText(input, String(input.dataset.original ?? "")))} → ${escapeHtml(paramValueText(input, paramInputValue(input)))}</span></article>`).join("")
          : "<p>修改左侧草稿后，这里显示“原值 → 建议值”。</p>";
      }
      if (paramValidation) {
