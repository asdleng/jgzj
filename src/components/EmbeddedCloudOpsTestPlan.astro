---
const fleetStats = [
  { key: "online", label: "在线车辆", value: "--", note: "last_seen 5 分钟内" },
  { key: "tool", label: "工具可用", value: "--", note: "按 tool_count 判断" },
  { key: "stale", label: "遥测过期", value: "--", note: "按 last_seen 粗略判断" },
  { key: "stop", label: "停车故障", value: "--", note: "疑似停车/安全阻断" }
];

const tabs = [
  { id: "overview", label: "车辆总览", eyebrow: "发现故障", desc: "真实车辆列表 + 故障入口" },
  { id: "status", label: "车辆状态检查", eyebrow: "人工确认", desc: "点击后只读检查" },
  { id: "params", label: "参数设置", eyebrow: "安全变更", desc: "当前先展示 Schema" },
  { id: "map", label: "地图管理", eyebrow: "地图路径", desc: "只展示入口和状态" },
  { id: "agent", label: "智能体运维", eyebrow: "长期运营", desc: "事件队列原型" }
];

const readOnlyToolGroups = [
  {
    title: "核心诊断：按运维目的检查",
    tools: [
      { label: "车辆当前状态", tool: "vehicle.current_state", desc: "看车辆是否在线、速度/模式/安全状态是否正常", action: "vehicle_detail", purpose: "回答：这台车现在是什么状态？" },
      { label: "当前任务/导航", tool: "task.navigation_context", desc: "合并 routing、planning、路线列表，判断是否有任务或导航上下文", action: "task_context", timeout: 35, purpose: "回答：这台车现在有没有任务，为什么停着？" },
      { label: "自动驾驶健康", tool: "health.autodrive_check", desc: "定位、规划、底盘、阻断条件综合只读检查", timeout: 35, purpose: "回答：自动驾驶是否具备运行条件？" },
      { label: "云端通信链路", tool: "communication.cloud_vehicle", desc: "合并云端连通、主控链路、ROS 入口探测", action: "communication_check", timeout: 30, purpose: "回答：云端、media、主控、ROS 链路是否通？" },
      { label: "系统资源快照", tool: "system.snapshot", desc: "CPU、内存、磁盘、温度和关键进程资源", args: { include_processes: true }, timeout: 30, purpose: "回答：车辆电脑资源是否异常？" }
    ]
  }
];

const blockedActionGroups = [
  {
    title: "控制 / 重启",
    actions: [
      ["重启主控接口", "controller.reboot_master", "高风险：会中断主控 auto_ad_ai 接口"],
      ["重启 Media 接口", "controller.reboot_media", "高风险：会中断 media auto_ad_ai 接口"],
      ["碰撞停复位", "vehicle.clear_collision_stop", "需要现场安全确认"],
      ["广告屏/灯光控制", "vehicle.body_control", "测试页先不绑定执行"]
    ]
  },
  {
    title: "任务 / 地图 / 参数写入",
    actions: [
      ["启动巡逻", "route.start_patrol", "任务重发必须人工确认后单独接"],
      ["地图插件启动", "map_editor.start", "地图编辑会打开车端插件，当前禁用"],
      ["地图插件关闭", "map_editor.stop", "当前禁用"],
      ["参数写入", "param.write", "必须有白名单、差异预览、回滚和审计"]
    ]
  }
];

const paramSchemas = [
  ["定位", "ndt_score_threshold", "3.5", "NDT 接受阈值；高风险，当前测试页不写入。"],
  ["定位", "relocalization4.topk_L3", "160", "重定位候选数量；影响恢复速度和误匹配风险。"],
  ["规划", "max_speed", "按车辆配置", "速度上限；必须停车或安全状态下修改。"],
  ["控制", "collision_stop_reset", "人工确认", "碰撞停恢复；需要现场安全确认。"],
  ["感知", "camera_rate_min_hz", "按车型", "相机频率下限；只读监测优先。"]
];

const agentRules = [
  ["自动驾驶停止", "任务中 60 秒无有效位移", "触发故障诊断，不直接判具体故障"],
  ["定位不可靠", "location_topic_ reliable=false", "进入定位故障树"],
  ["规划阻塞", "planning/routing 无有效输出", "检查上游定位和任务"],
  ["通信异常", "车辆 last_seen 过期", "先查云端/主控链路"]
];
---

<section class="cloud-ops-test-shell" data-cloud-ops-test>
  <div class="cloud-ops-test-topbar">
    <div>
      <p class="cloud-ops-test-kicker">CLOUD OPS TEST · READ ONLY FIRST</p>
      <h1>云端智能运维(测试)</h1>
      <p>
        当前版本已接入真实车辆列表。页面加载只读取云端车辆注册列表，不自动执行任何车端工具；所有车端检查都必须由用户点击按钮触发，且测试页第一版只接只读检查。
      </p>
    </div>
    <a class="cloud-ops-test-doc" href="https://my.feishu.cn/docx/JFmYdxCvioqT2kxlIXocqMInnbh" target="_blank" rel="noreferrer">
      查看方案文档
    </a>
  </div>

  <div class="cloud-ops-test-safety-band">
    <strong>安全边界</strong>
    <span>自动加载：只调用 <code>/api/cloud-ops/vehicles-lite</code> 读取云端车辆注册列表</span>
    <span>不会自动调用：<code>/api/cloud-ops/execute</code>、tool-list、vehicle_detail</span>
    <span>点击执行：只读工具调用</span>
    <span>禁用：重启、写参数、任务重发、灯光/车身控制</span>
  </div>

  <div class="cloud-ops-test-stats">
    {fleetStats.map((item) => (
      <article class="cloud-ops-test-stat" data-stat={item.key}>
        <span>{item.label}</span>
        <strong>{item.value}</strong>
        <p>{item.note}</p>
      </article>
    ))}
  </div>
  <section class="cloud-ops-test-fleet-spine-shell" aria-labelledby="fleet-spine-title">
    <div class="cloud-ops-test-panel-head">
      <div>
        <h2 id="fleet-spine-title">车队状态脊柱</h2>
        <p>每个信号格代表一台真实车辆；点击只切换上下文，不触发车端工具。</p>
      </div>
      <span data-role="fleet-spine-count">等待车辆</span>
    </div>
    <div class="cloud-ops-test-fleet-spine" data-role="fleet-spine">
      <p class="cloud-ops-test-empty">等待车辆状态信号...</p>
    </div>
  </section>


  <aside class="cloud-ops-test-agent-rail" data-role="agent-rail" aria-label="智能体运维常驻侧边栏">
    <button class="cloud-ops-test-agent-tab" type="button" data-action="agent-toggle" aria-expanded="false" aria-controls="cloud-ops-agent-panel">
      <span class="cloud-ops-test-agent-tab-dot" aria-hidden="true"></span>
      <span class="cloud-ops-test-agent-logo" aria-hidden="true"><i></i><b></b></span>
      <strong>山海智枢</strong>
    </button>
    <div class="cloud-ops-test-agent-panel" id="cloud-ops-agent-panel">
      <div class="cloud-ops-test-agent-panel-head">
        <div>
          <p class="cloud-ops-test-kicker">SHANHAI OPS · READ ONLY</p>
          <h2>山海智枢</h2>
          <p>常驻只读运维参谋：随时提问，但不会自动调用车辆工具。</p>
        </div>
        <button class="cloud-ops-test-agent-pin" type="button" data-action="agent-pin" aria-pressed="false">固定</button>
      </div>

      <div class="cloud-ops-test-agent-mini-grid">
        <article>
          <span>状态</span>
          <strong data-role="agent-status">读取中</strong>
          <small data-role="agent-status-note">检查服务端配置</small>
        </article>
        <article>
          <span>模型</span>
          <strong data-role="agent-model">--</strong>
          <small data-role="agent-route">7791 / JGZJ / subapi</small>
        </article>
        <article>
          <span>Codex</span>
          <strong data-role="agent-codex">检查中</strong>
          <small data-role="agent-codex-note">本机 App Server</small>
        </article>
        <article>
          <span>车队</span>
          <strong data-role="agent-fleet">--</strong>
          <small data-role="agent-fleet-note">真实车辆缓存</small>
        </article>
      </div>

      <div class="cloud-ops-test-agent-context-bar">
        <span data-role="agent-context">上下文：当前车辆 --，车队 -- 台。</span>
        <span data-role="agent-latency">等待输入</span>
      </div>

      <div class="cloud-ops-test-agent-messages" data-role="agent-messages">
        <div class="cloud-ops-test-agent-message is-agent">
          <strong>山海智枢</strong>
          <p>我现在按只读参谋模式工作：可以结合真实车辆缓存分析停车、定位、规划、控制、通信类问题；不会自动控车。</p>
        </div>
      </div>
      <textarea
        class="cloud-ops-test-agent-input"
        data-role="agent-input"
        rows="4"
        placeholder="例如：分析当前车辆为什么停车；或：把需关注车辆按优先级排序。"
      ></textarea>
      <div class="cloud-ops-test-agent-toolbar">
        <button class="cloud-ops-test-command-button is-primary" type="button" data-action="agent-send">
          <strong>发送</strong>
          <span>只读分析</span>
        </button>
        <button class="cloud-ops-test-command-button" type="button" data-action="agent-analyze-current">
          <strong>分析当前车辆</strong>
          <span>车辆上下文</span>
        </button>
        <button class="cloud-ops-test-command-button is-primary" type="button" data-action="agent-deep-diagnose">
          <strong>深度诊断</strong>
          <span>WebSocket + SSH</span>
        </button>
        <button class="cloud-ops-test-command-button" type="button" data-action="agent-analyze-stops">
          <strong>分析停车车辆</strong>
          <span>停车/阻断入口</span>
        </button>
      </div>
      <details class="cloud-ops-test-disclosure">
        <summary>最近智能体记录与安全审计</summary>
        <div class="cloud-ops-test-agent-history" data-role="agent-history">
          <p class="cloud-ops-test-empty">读取历史中...</p>
        </div>
        <p class="cloud-ops-test-agent-history-count">历史：<span data-role="agent-history-count">--</span></p>
        <pre class="cloud-ops-test-json cloud-ops-test-json--compact" data-role="agent-audit">自动调用清单：/api/cloud-ops/vehicles-lite、/api/cloud-ops-agent/status、/api/cloud-ops-agent/history
禁止自动调用：/api/cloud-ops/execute、tool-list、vehicle_detail
智能体对话：必须用户点击发送；后端只调用 subapi 兼容模型接口
控制类动作：未绑定执行</pre>
      </details>
      <p class="cloud-ops-test-agent-safe-copy">只读诊断参谋：不调用车辆工具，不写参数，不重启服务，不下发任务。</p>
    </div>
  </aside>

  <div class="cloud-ops-test-layout">
    <nav class="cloud-ops-test-tabs" aria-label="云端智能运维测试子页面">
      {tabs.map((tab, index) => (
        <button type="button" class:list={{ "is-active": index === 0 }} data-target={`cloud-ops-test-${tab.id}`}>
          <span class="cloud-ops-tab-light" aria-hidden="true"></span>
          <span class="cloud-ops-tab-index">{String(index + 1).padStart(2, "0")}</span>
          <span class="cloud-ops-tab-copy">
            <span>{tab.eyebrow}</span>
            <strong>{tab.label}</strong>
            <small>{tab.desc}</small>
          </span>
          <span class="cloud-ops-tab-scan" aria-hidden="true"></span>
        </button>
      ))}
    </nav>

    <div class="cloud-ops-test-pages">
      <section id="cloud-ops-test-overview" class="cloud-ops-test-page" data-active="true">
        <div class="cloud-ops-test-page-head">
          <p class="cloud-ops-test-kicker">FLEET OVERVIEW</p>
          <h2>车辆总览：先看真实在线车辆，再进入故障判断</h2>
          <p>车辆列表来自真实云端接口。故障判断目前先做页面端粗略归类，后续再迁移成后端 fleet fault aggregator。</p>
        </div>

        <div class="cloud-ops-test-workbench cloud-ops-test-workbench--overview">
          <section class="cloud-ops-test-panel cloud-ops-test-panel--wide">
            <div class="cloud-ops-test-panel-head">
              <h3>真实车辆列表</h3>
              <span data-role="vehicle-count">--</span>
            </div>
            <div class="cloud-ops-test-list-controls">
              <button class="cloud-ops-test-command-button is-primary" type="button" data-action="refresh-vehicles">刷新列表</button>
              <label class="cloud-ops-test-select-field">
                当前车辆
                <select data-role="vehicle-select">
                  <option value="">加载车辆中...</option>
                </select>
              </label>
              <label class="cloud-ops-test-select-field">
                列表排序
                <select data-role="vehicle-sort-select">
                  <option value="status">按车辆状态：异常在前</option>
                  <option value="id">按车辆编号</option>
                </select>
              </label>
              <p class="cloud-ops-test-status" data-role="status">只读初始化中...</p>
            </div>
            <div class="cloud-ops-test-api-strip">
              <span>接口 <strong data-role="interface-source">--</strong></span>
              <span>刷新 <strong data-role="last-refresh">--</strong></span>
              <span data-role="api-note">只读车辆注册表</span>
            </div>
            <div class="cloud-ops-test-vehicle-list" data-role="vehicle-list">
              <p class="cloud-ops-test-empty">等待车辆列表...</p>
            </div>
          </section>

          <section class="cloud-ops-test-panel">
            <div class="cloud-ops-test-panel-head">
              <h3>选中车辆摘要</h3>
              <span data-role="selected-vehicle-chip">未选择</span>
            </div>
            <dl class="cloud-ops-test-kv" data-role="vehicle-summary">
              <div><dt>车辆</dt><dd>--</dd></div>
              <div><dt>工具数</dt><dd>--</dd></div>
              <div><dt>最近在线</dt><dd>--</dd></div>
              <div><dt>状态判断</dt><dd>--</dd></div>
            </dl>
          </section>
        </div>

        <section class="cloud-ops-test-stop-monitor">
          <div class="cloud-ops-test-panel-head">
            <div>
              <h3>自动驾驶停止故障监控</h3>
              <p>先用真实缓存做入口预判；最终故障必须接任务状态和 60 秒位移历史后确认。</p>
            </div>
            <span data-role="stop-fault-count">--</span>
          </div>
          <div class="cloud-ops-test-stop-grid" data-role="stop-fault-list">
            <p class="cloud-ops-test-empty">等待车辆停止故障判断...</p>
          </div>
        </section>

        <details class="cloud-ops-test-disclosure cloud-ops-test-disclosure--fleet">
          <summary>展开完整车辆明细表（ROS、资源、原始链路字段）</summary>
          <div class="cloud-ops-test-table-shell cloud-ops-test-table-shell--fleet">
            <table class="cloud-ops-test-table cloud-ops-test-fleet-table">
            <thead>
              <tr>
                <th>车辆</th>
                <th>自动驾驶停止</th>
                <th>真实身份</th>
                <th>车端链路</th>
                <th>主控/ROS</th>
                <th>资源</th>
                <th>最近状态</th>
              </tr>
            </thead>
            <tbody data-role="vehicle-table-body">
              <tr><td colspan="7">等待真实车辆信息...</td></tr>
            </tbody>
            </table>
          </div>
        </details>

        <details class="cloud-ops-test-disclosure">
          <summary>展开事件入口说明</summary>
          <div class="cloud-ops-test-table-shell">
            <table class="cloud-ops-test-table">
            <thead><tr><th>事件入口</th><th>真实数据来源</th><th>当前页面处理</th></tr></thead>
            <tbody>
              <tr><td>车辆离线/遥测过期</td><td>云端车辆列表 last_seen</td><td>页面端标记“遥测过期”，后续进入通信故障诊断。</td></tr>
              <tr><td>自动驾驶停止</td><td>需要任务状态 + 位移历史</td><td>当前仅展示诊断入口，后续接 fleet aggregator。</td></tr>
              <tr><td>定位不可靠</td><td>status.localization 点击后返回</td><td>用户点击后读真实结果，不自动查车。</td></tr>
            </tbody>
            </table>
          </div>
        </details>
      </section>

      <section id="cloud-ops-test-status" class="cloud-ops-test-page" data-active="false">
        <div class="cloud-ops-test-page-head">
          <p class="cloud-ops-test-kicker">READ ONLY TOOLS</p>
          <h2>车辆状态检查：按老版云端运维整理按钮，点击后才查车</h2>
          <p>只读检查按钮已经接到真实接口；控制、重启、写参数、任务重发先展示但禁用。</p>
        </div>

        <div class="cloud-ops-test-status-split">
          <div class="cloud-ops-test-status-left">
            {readOnlyToolGroups.map((group) => (
              <section class="cloud-ops-test-tool-group">
                <div class="cloud-ops-test-tool-group-head">
                  <h3>{group.title}</h3>
                  <span>点击后右侧立即显示结果</span>
                </div>
                <div class="cloud-ops-test-command-grid cloud-ops-test-command-grid--core">
                  {group.tools.map((item) => (
                    <button
                      class="cloud-ops-test-command-button"
                      type="button"
                      data-action="readonly-tool"
                      data-tool={item.tool}
                      data-tool-action={"action" in item ? item.action : "tool_call"}
                      data-tool-args={JSON.stringify("args" in item ? item.args : {})}
                      data-timeout-s={String("timeout" in item ? item.timeout : 30)}
                      data-purpose={"purpose" in item ? item.purpose : ""}
                    >
                      <strong>{item.label}</strong>
                      <span>{item.tool}</span>
                      <small>{item.desc}</small>
                      {"purpose" in item && <em>{item.purpose}</em>}
                    </button>
                  ))}
                </div>
              </section>
            ))}

            {blockedActionGroups.map((group) => (
              <details class="cloud-ops-test-disclosure cloud-ops-test-disabled-disclosure">
                <summary>{group.title}：禁用动作说明</summary>
                <div class="cloud-ops-test-command-grid cloud-ops-test-command-grid--blocked">
                  {group.actions.map(([label, tool, desc]) => (
                    <button class="cloud-ops-test-command-button is-disabled" type="button" disabled>
                      <strong>{label}</strong>
                      <span>{tool}</span>
                      <small>{desc}</small>
                    </button>
                  ))}
                </div>
              </details>
            ))}
          </div>

          <section class="cloud-ops-test-panel cloud-ops-test-panel--result cloud-ops-test-sticky-result">
            <div class="cloud-ops-test-panel-head">
              <div>
                <h3>查询结果</h3>
                <p>点击左侧任一核心检查后，结果会在这里更新。</p>
              </div>
              <span data-role="last-tool-label">等待点击</span>
            </div>
            <div class="cloud-ops-test-result-summary" data-role="tool-summary">选择车辆后点击左侧核心诊断按钮，这里会立即显示直观摘要；完整返回默认折叠。</div>
            <details class="cloud-ops-test-disclosure">
              <summary>展开原始返回 JSON</summary>
              <pre class="cloud-ops-test-json" data-role="tool-result">选择车辆后点击左侧只读工具，这里显示真实返回。</pre>
            </details>
          </section>
        </div>
      </section>

      <section id="cloud-ops-test-params" class="cloud-ops-test-page" data-active="false">
        <div class="cloud-ops-test-page-head">
          <p class="cloud-ops-test-kicker">PARAMETER SCHEMA</p>
          <h2>参数设置：当前只展示 Schema，不写入车辆</h2>
          <p>这里先验证参数分类、默认值、风险提示和回滚闭环。真实写入必须另做白名单、确认和审计。</p>
        </div>
        <div class="cloud-ops-test-table-shell">
          <table class="cloud-ops-test-table">
            <thead><tr><th>域</th><th>参数名</th><th>默认/当前</th><th>含义和风险</th></tr></thead>
            <tbody>{paramSchemas.map((row) => <tr>{row.map((cell) => <td>{cell}</td>)}</tr>)}</tbody>
          </table>
        </div>
        <div class="cloud-ops-test-disabled-actions">
          <button type="button" disabled>读取当前参数（待接）</button>
          <button type="button" disabled>生成差异预览（待接）</button>
          <button type="button" disabled>写入参数（禁用）</button>
          <button type="button" disabled>回滚参数（禁用）</button>
        </div>
      </section>

      <section id="cloud-ops-test-map" class="cloud-ops-test-page" data-active="false">
        <div class="cloud-ops-test-page-head">
          <p class="cloud-ops-test-kicker">MAP MANAGEMENT</p>
          <h2>地图管理：当前不自动启动地图编辑器</h2>
          <p>现有真实地图编辑器入口仍在“地图管理”页面。本测试页只展示未来合并后的操作面板，不自动调用 map_editor.start。</p>
        </div>
        <div class="cloud-ops-test-card-grid">
          <article class="cloud-ops-test-card"><h3>车端插件桥接</h3><p>map_editor.start / status / stop / http</p></article>
          <article class="cloud-ops-test-card"><h3>边界路径</h3><p>运营边界、禁行区、巡逻路径、检查点、停车点。</p></article>
          <article class="cloud-ops-test-card"><h3>版本管理</h3><p>地图版本、车辆使用版本、发布记录、回滚点。</p></article>
        </div>
        <div class="cloud-ops-test-disabled-actions">
          <button type="button" disabled>启动并打开插件（禁用）</button>
          <button type="button" disabled>检查插件状态（待接只读）</button>
          <button type="button" disabled>关闭插件（禁用）</button>
        </div>
      </section>

      <section id="cloud-ops-test-agent" class="cloud-ops-test-page" data-active="false">
        <div class="cloud-ops-test-page-head">
          <p class="cloud-ops-test-kicker">AGENT OPS</p>
          <h2>山海智枢：主入口已移到右侧常驻侧边栏</h2>
          <p>这个页面保留为智能体模式说明和规则边界。山海智枢现在常驻在页面右侧，切换子页面、选择车辆或展开详情都不会自动发起对话。</p>
        </div>

        <div class="cloud-ops-test-card-grid cloud-ops-test-agent-explain-grid">
          <article class="cloud-ops-test-card">
            <h3>常驻侧边栏</h3>
            <p>桌面端右侧窄栏常驻，悬停或键盘聚焦时展开；点击“固定”后占位显示。移动端作为底部抽屉使用。</p>
          </article>
          <article class="cloud-ops-test-card">
            <h3>只读参谋</h3>
            <p>智能体可读取车辆缓存和用户提供的问题做归纳，不自动调用车端工具，不写参数，不重启，不下发任务。</p>
          </article>
          <article class="cloud-ops-test-card">
            <h3>上下文同步</h3>
            <p>选择车辆只更新智能体上下文 chip；只有点击发送、分析当前车辆、深度诊断等按钮才会请求智能体接口。</p>
          </article>
        </div>

        <section class="cloud-ops-test-panel">
          <div class="cloud-ops-test-panel-head">
            <h3>规则边界</h3>
            <span>当前版本</span>
          </div>
          <div class="cloud-ops-test-table-shell cloud-ops-test-table-shell--compact">
            <table class="cloud-ops-test-table">
              <thead><tr><th>规则</th><th>触发条件</th><th>处理边界</th></tr></thead>
              <tbody>{agentRules.map((row) => <tr>{row.map((cell) => <td>{cell}</td>)}</tr>)}</tbody>
            </table>
          </div>
        </section>
      </section>      </section>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const shell = document.querySelector("[data-cloud-ops-test]");
    if (!shell) return;

    const VEHICLES_URL = "/api/cloud-ops/vehicles-lite";
    const EXECUTE_URL = "/api/cloud-ops/execute";
    const AGENT_STATUS_URL = "/api/cloud-ops-agent/status";
    const AGENT_HISTORY_URL = "/api/cloud-ops-agent/history";
    const AGENT_CHAT_URL = "/api/cloud-ops-agent/chat";
    const AGENT_DIAGNOSE_URL = "/api/cloud-ops-agent/diagnose";
    const READONLY_TOOL_ALLOWLIST = new Set([
      "status.key_nodes",
      "health.autodrive_check",
      "tool_list",
      "vehicle_detail",
      "combined.snapshot",
      "vehicle.current_state",
      "task.navigation_context",
      "communication.cloud_vehicle",
      "health.snapshot",
      "network.cloud_probe",
      "network.master_probe",
      "status.localization",
      "status.planning",
      "status.routing",
      "status.can",
      "status.body_control",
      "status.camera",
      "status.obstacle_processor",
      "ros.overview",
      "system.snapshot",
      "vehicle.snapshot",
      "camera.upload_chain",
      "ai_detection.config",
      "ai_detection.images",
      "map.preview",
      "obstacle.preview",
      "route.list"
    ]);

    const tabs = [...shell.querySelectorAll(".cloud-ops-test-tabs button")];
    const pages = [...shell.querySelectorAll(".cloud-ops-test-page")];
    const statusNode = shell.querySelector('[data-role="status"]');
    const vehicleSelect = shell.querySelector('[data-role="vehicle-select"]');
    const vehicleSortSelect = shell.querySelector('[data-role="vehicle-sort-select"]');
    const vehicleList = shell.querySelector('[data-role="vehicle-list"]');
    const fleetSpine = shell.querySelector('[data-role="fleet-spine"]');
    const fleetSpineCount = shell.querySelector('[data-role="fleet-spine-count"]');
    const agentRail = shell.querySelector('[data-role="agent-rail"]');
    const agentToggle = shell.querySelector('[data-action="agent-toggle"]');
    const agentPin = shell.querySelector('[data-action="agent-pin"]');
    const toolSummary = shell.querySelector('[data-role="tool-summary"]');
    const vehicleCount = shell.querySelector('[data-role="vehicle-count"]');
    const vehicleTableBody = shell.querySelector('[data-role="vehicle-table-body"]');
    const stopFaultCount = shell.querySelector('[data-role="stop-fault-count"]');
    const stopFaultList = shell.querySelector('[data-role="stop-fault-list"]');
    const selectedVehicleChip = shell.querySelector('[data-role="selected-vehicle-chip"]');
    const selectedVehicleTitle = shell.querySelector('[data-role="selected-vehicle-title"]');
    const vehicleSummary = shell.querySelector('[data-role="vehicle-summary"]');
    const toolResult = shell.querySelector('[data-role="tool-result"]');
    const lastToolLabel = shell.querySelector('[data-role="last-tool-label"]');
    const interfaceSource = shell.querySelector('[data-role="interface-source"]');
    const lastRefresh = shell.querySelector('[data-role="last-refresh"]');
    const apiNote = shell.querySelector('[data-role="api-note"]');
    const agentStatus = shell.querySelector('[data-role="agent-status"]');
    const agentStatusNote = shell.querySelector('[data-role="agent-status-note"]');
    const agentModel = shell.querySelector('[data-role="agent-model"]');
    const agentRoute = shell.querySelector('[data-role="agent-route"]');
    const agentCodex = shell.querySelector('[data-role="agent-codex"]');
    const agentCodexNote = shell.querySelector('[data-role="agent-codex-note"]');
    const agentFleet = shell.querySelector('[data-role="agent-fleet"]');
    const agentFleetNote = shell.querySelector('[data-role="agent-fleet-note"]');
    const agentContext = shell.querySelector('[data-role="agent-context"]');
    const agentLatency = shell.querySelector('[data-role="agent-latency"]');
    const agentMessages = shell.querySelector('[data-role="agent-messages"]');
    const agentInput = shell.querySelector('[data-role="agent-input"]');
    const agentHistory = shell.querySelector('[data-role="agent-history"]');
    const agentHistoryCount = shell.querySelector('[data-role="agent-history-count"]');
    const agentAudit = shell.querySelector('[data-role="agent-audit"]');
    let vehicles = [];
    let currentVehicleId = "";
    let vehicleSortMode = "status";
    let agentCanChat = false;

    const setStatus = (text, state = "idle") => {
      if (!statusNode) return;
      statusNode.textContent = text;
      statusNode.dataset.state = state;
    };

    const setActive = (targetId) => {
      tabs.forEach((tab) => tab.classList.toggle("is-active", tab.dataset.target === targetId));
      pages.forEach((page) => {
        page.dataset.active = page.id === targetId ? "true" : "false";
      });
    };

    const vehicleIdOf = (vehicle) => String(vehicle?.vehicle_id || vehicle?.plate_number || vehicle?.id || "").trim();
    const lastSeenOf = (vehicle) => String(vehicle?.last_seen || vehicle?.last_seen_at || vehicle?.updated_at || "").trim();
    const toolCountOf = (vehicle) => Number(vehicle?.tool_count || vehicle?.tools_count || 0) || 0;
    const selectedVehicleId = () => String(currentVehicleId || vehicleSelect?.value || "").trim();
    const displayValue = (value, fallback = "--") => {
      if (value === null || value === undefined || value === "") return fallback;
      return String(value);
    };
    const finiteNumber = (value) => {
      if (value === null || value === undefined || value === "") return NaN;
      const num = Number(value);
      return Number.isFinite(num) ? num : NaN;
    };
    const boolText = (value, trueText = "是", falseText = "否", unknownText = "未知") => {
      if (value === true) return trueText;
      if (value === false) return falseText;
      return unknownText;
    };
    const percentText = (value) => {
      const num = finiteNumber(value);
      if (!Number.isFinite(num)) return "--";
      return `${num.toFixed(num >= 10 ? 0 : 1)}%`;
    };
    const numberText = (value, digits = 1) => {
      const num = finiteNumber(value);
      if (!Number.isFinite(num)) return "--";
      return num.toFixed(digits);
    };
    const msText = (value) => {
      const num = finiteNumber(value);
      if (!Number.isFinite(num)) return "--";
      return `${num.toFixed(num >= 10 ? 0 : 1)} ms`;
    };
    const formatAge = (iso) => {
      const ts = Date.parse(iso || "");
      if (!Number.isFinite(ts)) return "未知";
      const diff = Math.max(0, Date.now() - ts);
      const min = Math.round(diff / 60000);
      if (min < 1) return "刚刚";
      if (min < 60) return `${min} 分钟前`;
      const hr = Math.round(min / 60);
      if (hr < 48) return `${hr} 小时前`;
      return `${Math.round(hr / 24)} 天前`;
    };
    const isStale = (vehicle) => {
      const ts = Date.parse(lastSeenOf(vehicle));
      return !Number.isFinite(ts) || Date.now() - ts > 5 * 60 * 1000;
    };
    const vehicleHealthOf = (vehicle) => {
      if (isStale(vehicle)) return { label: "遥测过期", tone: "warn" };
      if (vehicle?.master_ping_ok === false) return { label: "主控不可达", tone: "danger" };
      if (!vehicle?.has_heartbeat) return { label: "无心跳", tone: "warn" };
      if (!vehicle?.has_telemetry) return { label: "无telemetry", tone: "warn" };
      return { label: "在线", tone: "ok" };
    };
    const stopDiagnosisOf = (vehicle) => {
      if (isStale(vehicle)) {
        return {
          label: "通信过期",
          tone: "warn",
          reason: "last_seen 已过期，不能判断自动驾驶停止。",
          next: "先查云端连接和车端 auto_ad_ai 心跳。"
        };
      }
      if (vehicle?.master_ping_ok === false || vehicle?.telemetry_master_ros_ok === false) {
        return {
          label: "主控链路异常",
          tone: "danger",
          reason: "media 到主控或 ROS 不可达，自动驾驶状态不可确认。",
          next: "先查主控网络、ROS master、关键节点。"
        };
      }
      if (vehicle?.emergency_stop_pressed === true) {
        return {
          label: "阻断：急停",
          tone: "danger",
          reason: "急停已触发，车辆停止是安全阻断。",
          next: "进入控制/底盘故障诊断，现场确认后处理。"
        };
      }
      if (vehicle?.collision_stop === true) {
        return {
          label: "阻断：碰撞停",
          tone: "danger",
          reason: "碰撞停已触发，车辆停止是安全阻断。",
          next: "进入感知/底盘安全链路诊断。"
        };
      }
      if (vehicle?.localization_reliable === false) {
        return {
          label: "阻断：定位不可靠",
          tone: "danger",
          reason: "location_topic_ 不可靠，自动驾驶应停止。",
          next: "进入定位故障树，区分组合导航模式和纯 LiDAR NDT。"
        };
      }
      if (vehicle?.trajectory_estop === true) {
        return {
          label: "阻断：规划estop",
          tone: "danger",
          reason: "planning trajectory estop=true。",
          next: "进入规划/障碍物故障诊断。"
        };
      }
      const speedKph = finiteNumber(vehicle?.speed_kph);
      const locSpeedMps = finiteNumber(vehicle?.localization_speed_mps);
      const targetSpeed = finiteNumber(vehicle?.control_target_speed);
      const runningMode = finiteNumber(vehicle?.running_mode);
      const plannerState = String(vehicle?.planner_state || "").trim().toLowerCase();
      const plannerRunning = finiteNumber(vehicle?.planner_running);
      const vehicleIdleStatus = finiteNumber(vehicle?.vehicle_idle_status);
      const longTimeStop = vehicle?.long_time_stop === true;
      const totalLoop = finiteNumber(vehicle?.total_loop_sum);
      const currentLoop = finiteNumber(vehicle?.current_loop_index);
      const totalRefline = finiteNumber(vehicle?.total_refline_sum);
      const currentRefline = finiteNumber(vehicle?.current_refline_index);
      const trajectoryPointCount = finiteNumber(vehicle?.trajectory_point_count);
      const trajectoryLength = finiteNumber(vehicle?.trajectory_total_length);
      const currentPathCount = finiteNumber(vehicle?.current_path_count);
      const stopped = Number.isFinite(speedKph)
        ? speedKph < 0.2
        : Number.isFinite(locSpeedMps) && Math.abs(locSpeedMps) < 0.05;
      const routeProgress = Number.isFinite(totalLoop) && Number.isFinite(currentLoop) &&
        Number.isFinite(totalRefline) && Number.isFinite(currentRefline) &&
        totalLoop > 0 && totalRefline > 0 && currentLoop >= 0 && currentRefline >= 0;
      const hasTrajectory = Number.isFinite(trajectoryPointCount) && trajectoryPointCount > 0 &&
        Number.isFinite(trajectoryLength) && trajectoryLength > 0;
      const plannerActive = plannerState === "running" || (Number.isFinite(plannerRunning) && plannerRunning > 0);
      const taskEvidence = plannerActive ||
        (Number.isFinite(currentPathCount) && currentPathCount > 0) ||
        routeProgress ||
        hasTrajectory ||
        (Number.isFinite(vehicleIdleStatus) && vehicleIdleStatus === 0);
      if (taskEvidence && !stopped) {
        return {
          label: "运行中",
          tone: "ok",
          reason: `有任务/规划证据，当前速度 ${numberText(speedKph)} km/h。`,
          next: "未发现停止入口。"
        };
      }
      if (stopped && taskEvidence) {
        return {
          label: "疑似停车故障",
          tone: "warn",
          reason: `有任务/规划证据但车速接近 0，当前速度 ${numberText(speedKph)} km/h，planner=${displayValue(vehicle?.planner_running, plannerState || "--")}。`,
          next: "还缺任务状态和 60 秒位移历史；接 fleet aggregator 后才能确认“自动驾驶停止故障”。"
        };
      }
      if (stopped) {
        return {
          label: "停止待确认",
          tone: "neutral",
          reason: `当前速度 ${numberText(speedKph)} km/h，但未看到任务运行证据；mode=${displayValue(runningMode)}，target=${numberText(targetSpeed)} m/s。`,
          next: "需要接任务计划/任务进度后区分正常等待、任务完成、异常停车。"
        };
      }
      if (Number.isFinite(speedKph) && speedKph >= 0.2) {
        return {
          label: "运行中",
          tone: "ok",
          reason: `当前速度 ${numberText(speedKph)} km/h，未触发停止入口。`,
          next: "未发现停止入口。"
        };
      }
      if (Number.isFinite(targetSpeed) && targetSpeed > 0.2 && longTimeStop) {
        return {
          label: "疑似控制未动",
          tone: "warn",
          reason: `long_time_stop=true 且控制目标速度 ${numberText(targetSpeed)} m/s。`,
          next: "需要结合 60 秒位移历史确认，再查控制/底盘链路。"
        };
      }
      return {
        label: "不可判定",
        tone: "neutral",
        reason: `running_mode=${displayValue(vehicle?.running_mode)}，当前缓存缺任务执行状态。`,
        next: "需接任务状态、路线进度和位移历史。"
      };
    };
    const renderPill = (label, tone = "neutral") => (
      `<span class="cloud-ops-test-pill is-${escapeHtml(tone)}">${escapeHtml(label)}</span>`
    );
    const escapeHtml = (value) => String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;");
    const parseJsonDataset = (value, fallback = {}) => {
      const text = String(value || "").trim();
      if (!text) return fallback;
      try {
        return JSON.parse(text);
      } catch (_error) {
        return fallback;
      }
    };
    const setStat = (key, value, note, tone = "") => {
      const card = shell.querySelector(`[data-stat="${key}"]`);
      if (!card) return;
      const strong = card.querySelector("strong");
      const p = card.querySelector("p");
      if (strong) strong.textContent = String(value);
      if (note && p) p.textContent = note;
      card.classList.remove("is-ok", "is-warn", "is-danger");
      if (tone) card.classList.add(`is-${tone}`);
    };

    const selectedVehicle = () => {
      const id = selectedVehicleId();
      return vehicles.find((vehicle) => vehicleIdOf(vehicle) === id) || null;
    };

    const syncSelectedVehicleUi = () => {
      if (vehicleSelect && selectedVehicleId() && vehicleSelect.value !== selectedVehicleId()) {
        vehicleSelect.value = selectedVehicleId();
      }
      shell.querySelectorAll("[data-vehicle-id]").forEach((button) => {
        button.classList.toggle("is-selected", button.dataset.vehicleId === selectedVehicleId());
      });
      shell.querySelectorAll("[data-vehicle-row-id]").forEach((row) => {
        row.classList.toggle("is-selected", row.dataset.vehicleRowId === selectedVehicleId());
      });
      if (selectedVehicleTitle) selectedVehicleTitle.textContent = selectedVehicleId() || "--";
    };

    const setSelectedVehicle = (vehicleId, options = {}) => {
      const normalized = String(vehicleId || "").trim();
      currentVehicleId = vehicles.some((vehicle) => vehicleIdOf(vehicle) === normalized)
        ? normalized
        : vehicleIdOf(vehicles[0] || {});
      syncSelectedVehicleUi();
      renderSummary();
      renderFleetSpine();
      if (options.silent !== true) {
        setStatus(`已选择 ${currentVehicleId || "车辆"}，未执行任何车端工具。`, "ok");
      }
      updateAgentContext();
    };

    const renderSummary = () => {
      const vehicle = selectedVehicle();
      if (selectedVehicleChip) selectedVehicleChip.textContent = vehicle ? vehicleIdOf(vehicle) : "未选择";
      if (selectedVehicleTitle) selectedVehicleTitle.textContent = vehicle ? vehicleIdOf(vehicle) : "--";
      if (!vehicleSummary) return;
      if (!vehicle) {
        vehicleSummary.innerHTML = "<div><dt>车辆</dt><dd>--</dd></div><div><dt>真实身份</dt><dd>--</dd></div><div><dt>车端链路</dt><dd>--</dd></div><div><dt>主控/ROS</dt><dd>--</dd></div><div><dt>资源</dt><dd>--</dd></div><div><dt>状态判断</dt><dd>--</dd></div>";
        return;
      }
      const vid = vehicleIdOf(vehicle);
      const health = vehicleHealthOf(vehicle);
      const stopDiag = stopDiagnosisOf(vehicle);
      vehicleSummary.innerHTML = [
        ["车辆", `${vid} / ${displayValue(vehicle?.plate_number, vid)}`],
        ["真实身份", `VIN ${displayValue(vehicle?.vin)} · ${displayValue(vehicle?.role)}`],
        ["车端链路", `${displayValue(vehicle?.hostname)} · media ${displayValue(vehicle?.local_primary_ip)} · cloud ${displayValue(vehicle?.remote)}`],
        ["主控/ROS", `主控 ${displayValue(vehicle?.master_host)} · ping ${boolText(vehicle?.master_ping_ok, "可达", "不可达")} ${msText(vehicle?.master_ping_latency_ms)} · topic/node/service ${displayValue(vehicle?.topic_count)}/${displayValue(vehicle?.node_count)}/${displayValue(vehicle?.service_count)}`],
        ["资源", `CPU ${percentText(vehicle?.cpu_percent)} · 内存 ${percentText(vehicle?.memory_percent)} · 磁盘 ${percentText(vehicle?.disk_percent)} · tools ${toolCountOf(vehicle) || "未知"}`],
        ["自动驾驶停止", `${stopDiag.label} · ${stopDiag.reason}`],
        ["下一步", stopDiag.next],
        ["最近在线", `${formatAge(lastSeenOf(vehicle))} · ${lastSeenOf(vehicle) || "无时间戳"} · msg ${displayValue(vehicle?.message_count)}`],
        ["状态判断", health.label]
      ].map(([k, v]) => `<div><dt>${escapeHtml(k)}</dt><dd>${escapeHtml(v)}</dd></div>`).join("");
    };

    const renderFleetSpine = () => {
      if (fleetSpineCount) fleetSpineCount.textContent = vehicles.length ? `${vehicles.length} 台信号` : "等待车辆";
      if (!fleetSpine) return;
      if (!vehicles.length) {
        fleetSpine.innerHTML = '<p class="cloud-ops-test-empty">没有读取到车辆信号。</p>';
        return;
      }
      const sorted = sortVehiclesByAttention(vehicles);
      fleetSpine.innerHTML = sorted.map((vehicle) => {
        const vid = vehicleIdOf(vehicle);
        const diag = stopDiagnosisOf(vehicle);
        const health = vehicleHealthOf(vehicle);
        const tone = diag.tone === "danger" || diag.tone === "warn" ? diag.tone : health.tone;
        const label = diag.tone === "danger" || diag.tone === "warn" ? diag.label : health.label;
        return `<button type="button" class="cloud-ops-test-signal-cell is-${escapeHtml(tone)}${vid === selectedVehicleId() ? " is-selected" : ""}" data-vehicle-id="${escapeHtml(vid)}" title="${escapeHtml(vid)} · ${escapeHtml(label)} · ${escapeHtml(formatAge(lastSeenOf(vehicle)))}">
          <span>${escapeHtml(label)}</span>
          <strong>${escapeHtml(vid || "未知")}</strong>
        </button>`;
      }).join("");
    };

    const sortVehiclesByAttention = (items) => {
      const rank = (vehicle) => {
        const diag = stopDiagnosisOf(vehicle);
        if (diag.tone === "danger") return 0;
        if (diag.label === "疑似停车故障" || diag.tone === "warn") return 1;
        if (diag.label === "停止待确认") return 2;
        if (isStale(vehicle)) return 3;
        return 4;
      };
      return [...items].sort((a, b) => rank(a) - rank(b) || vehicleIdOf(a).localeCompare(vehicleIdOf(b), "zh-Hans-CN", { numeric: true, sensitivity: "base" }));
    };
    const sortVehiclesById = (items) => [...items].sort((a, b) => vehicleIdOf(a).localeCompare(vehicleIdOf(b), "zh-Hans-CN", { numeric: true, sensitivity: "base" }));
    const sortVehiclesForList = (items) => vehicleSortMode === "id" ? sortVehiclesById(items) : sortVehiclesByAttention(items);

    const renderVehicles = () => {
      if (vehicleCount) vehicleCount.textContent = `${vehicles.length} 台`;
      if (!vehicleList) return;
      if (!vehicles.length) {
        vehicleList.innerHTML = '<p class="cloud-ops-test-empty">没有读取到车辆，或当前账号未授权。</p>';
        return;
      }
      const sortedVehicles = sortVehiclesForList(vehicles);
      vehicleList.innerHTML = sortedVehicles.map((vehicle) => {
        const vid = vehicleIdOf(vehicle);
        const health = vehicleHealthOf(vehicle);
        const stopDiag = stopDiagnosisOf(vehicle);
        const toolCount = toolCountOf(vehicle);
        const host = vehicle?.hostname || vehicle?.host || "";
        const selected = vid === selectedVehicleId();
        const rowTone = stopDiag.tone === "danger" || stopDiag.tone === "warn" ? stopDiag.tone : health.tone;
        return `<button type="button" class="cloud-ops-test-vehicle-row is-${escapeHtml(rowTone)}${selected ? " is-selected" : ""}" data-vehicle-id="${escapeHtml(vid)}" title="${escapeHtml(`${vid} · ${stopDiag.label} · ${stopDiag.reason}`)}">
          <span class="cloud-ops-test-severity">${escapeHtml(health.label)}</span>
          <strong class="cloud-ops-test-vehicle-id">${escapeHtml(vid || "未知车辆")}</strong>
          <span class="cloud-ops-test-stop-inline is-${escapeHtml(stopDiag.tone)}">${escapeHtml(stopDiag.label)}</span>
          <span class="cloud-ops-test-vehicle-meta">${escapeHtml(host || "无主机名")} · media ${escapeHtml(displayValue(vehicle?.local_primary_ip))} · master ${escapeHtml(boolText(vehicle?.master_ping_ok, "可达", "不可达"))} · speed ${escapeHtml(numberText(vehicle?.speed_kph))} km/h · ${escapeHtml(formatAge(lastSeenOf(vehicle)))} · tools ${escapeHtml(toolCount || "?")}</span>
          <span class="cloud-ops-test-vehicle-reason">${escapeHtml(stopDiag.reason)}</span>
        </button>`;
      }).join("");
    };

    const renderVehicleTable = () => {
      if (!vehicleTableBody) return;
      if (!vehicles.length) {
        vehicleTableBody.innerHTML = '<tr><td colspan="7">没有读取到车辆，或当前账号未授权。</td></tr>';
        return;
      }
      vehicleTableBody.innerHTML = sortVehiclesForList(vehicles).map((vehicle) => {
        const vid = vehicleIdOf(vehicle);
        const health = vehicleHealthOf(vehicle);
        const stopDiag = stopDiagnosisOf(vehicle);
        const selected = vid === selectedVehicleId();
        const signalHtml = [
          vehicle?.has_heartbeat ? renderPill("heartbeat", "ok") : renderPill("无心跳", "warn"),
          vehicle?.has_snapshot ? renderPill("snapshot", "ok") : renderPill("无snapshot", "warn"),
          vehicle?.has_telemetry ? renderPill("telemetry", "ok") : renderPill("无telemetry", "warn")
        ].join("");
        return `<tr class="${selected ? "is-selected" : ""}" data-vehicle-row-id="${escapeHtml(vid)}">
          <td>
            <button type="button" class="cloud-ops-test-row-select" data-vehicle-id="${escapeHtml(vid)}">${escapeHtml(vid)}</button>
            <div>${renderPill(health.label, health.tone)}</div>
          </td>
          <td>
            <strong>${renderPill(stopDiag.label, stopDiag.tone)}</strong>
            <small>${escapeHtml(stopDiag.reason)}</small>
            <small>${escapeHtml(stopDiag.next)}</small>
          </td>
          <td>
            <strong>${escapeHtml(displayValue(vehicle?.plate_number, vid))}</strong>
            <small>VIN ${escapeHtml(displayValue(vehicle?.vin))}</small>
          </td>
          <td>
            <strong>${escapeHtml(displayValue(vehicle?.hostname))}</strong>
            <small>media ${escapeHtml(displayValue(vehicle?.local_primary_ip))} · remote ${escapeHtml(displayValue(vehicle?.remote))}</small>
          </td>
          <td>
            <strong>${escapeHtml(displayValue(vehicle?.master_host))} · ${escapeHtml(boolText(vehicle?.master_ping_ok, "可达", "不可达"))}</strong>
            <small>ping ${escapeHtml(msText(vehicle?.master_ping_latency_ms))} · ROS ${escapeHtml(displayValue(vehicle?.topic_count))}/${escapeHtml(displayValue(vehicle?.node_count))}/${escapeHtml(displayValue(vehicle?.service_count))}</small>
          </td>
          <td>
            <strong>CPU ${escapeHtml(percentText(vehicle?.cpu_percent))} · MEM ${escapeHtml(percentText(vehicle?.memory_percent))}</strong>
            <small>DISK ${escapeHtml(percentText(vehicle?.disk_percent))} · tools ${escapeHtml(toolCountOf(vehicle) || "未知")}</small>
          </td>
          <td>
            <strong>${escapeHtml(formatAge(lastSeenOf(vehicle)))}</strong>
            <small>${escapeHtml(lastSeenOf(vehicle) || "无时间戳")} · msg ${escapeHtml(displayValue(vehicle?.message_count))}</small>
            <div class="cloud-ops-test-signal-row">${signalHtml}</div>
          </td>
        </tr>`;
      }).join("");
    };

    const renderStopFaultMonitor = () => {
      if (!stopFaultList) return;
      const diagnosed = vehicles.map((vehicle) => ({ vehicle, diag: stopDiagnosisOf(vehicle) }));
      const actionable = diagnosed.filter((item) => item.diag.tone === "danger" || item.diag.tone === "warn");
      const pending = diagnosed.filter((item) => item.diag.label === "停止待确认");
      if (stopFaultCount) {
        stopFaultCount.textContent = `疑似/阻断 ${actionable.length} 台 · 停止待确认 ${pending.length} 台`;
      }
      const displayItems = actionable.concat(pending);
      const cards = displayItems.map(({ vehicle, diag }) => {
        const vid = vehicleIdOf(vehicle);
        return `<button type="button" class="cloud-ops-test-stop-card is-${escapeHtml(diag.tone)}" data-vehicle-id="${escapeHtml(vid)}">
          <span>${escapeHtml(diag.label)}</span>
          <strong>${escapeHtml(vid || "未知车辆")}</strong>
          <small>${escapeHtml(diag.reason)}</small>
          <em>${escapeHtml(diag.next)}</em>
        </button>`;
      });
      stopFaultList.innerHTML = cards.length
        ? cards.join("")
        : '<p class="cloud-ops-test-empty">当前没有疑似/阻断或停止待确认车辆。</p>';
    };

    const renderVehicleOptions = () => {
      if (!vehicleSelect) return;
      const previous = String(vehicleSelect.value || "").trim();
      vehicleSelect.innerHTML = "";
      if (!vehicles.length) {
        vehicleSelect.innerHTML = '<option value="">暂无车辆</option>';
        renderSummary();
        return;
      }
      vehicles.forEach((vehicle) => {
        const vid = vehicleIdOf(vehicle);
        const option = document.createElement("option");
        option.value = vid;
        option.textContent = `${vid}${isStale(vehicle) ? " · 待确认" : " · 在线"}`;
        vehicleSelect.appendChild(option);
      });
      if (previous && vehicles.some((vehicle) => vehicleIdOf(vehicle) === previous)) {
        currentVehicleId = previous;
      }
      if (!currentVehicleId || !vehicles.some((vehicle) => vehicleIdOf(vehicle) === currentVehicleId)) {
        currentVehicleId = vehicleIdOf(vehicles[0]);
      }
      vehicleSelect.value = currentVehicleId;
      syncSelectedVehicleUi();
      renderSummary();
      updateAgentContext();
    };

    const updateStats = () => {
      const withTools = vehicles.filter((vehicle) => toolCountOf(vehicle) > 0).length;
      const staleCount = vehicles.filter(isStale).length;
      const onlineCount = vehicles.length - staleCount;
      const stopDiagnoses = vehicles.map(stopDiagnosisOf);
      const stopConcernCount = stopDiagnoses.filter((diag) => diag.tone === "danger" || String(diag.label || "").startsWith("疑似")).length;
      const stopWarnCount = stopDiagnoses.filter((diag) => diag.tone === "warn").length;
      const stopPendingCount = stopDiagnoses.filter((diag) => diag.label === "停止待确认").length;
      setStat("online", onlineCount, `总计 ${vehicles.length} 台真实车辆`, onlineCount ? "ok" : "");
      setStat("tool", withTools, "tool_count > 0 的车辆", withTools ? "ok" : "");
      setStat("stale", staleCount, "last_seen 超过 5 分钟或无时间戳", staleCount ? "warn" : "ok");
      setStat("stop", `${stopConcernCount}/${stopPendingCount}`, `疑似/阻断 ${stopConcernCount} 台，停止待确认 ${stopPendingCount} 台`, stopConcernCount ? "danger" : (stopPendingCount ? "warn" : (stopWarnCount ? "warn" : "ok")));
    };

    const updateAgentContext = () => {
      if (!agentContext) return;
      const vehicle = selectedVehicle();
      const stopDiagnoses = vehicles.map(stopDiagnosisOf);
      const concern = stopDiagnoses.filter((diag) => diag.tone === "danger" || diag.label === "疑似停车故障").length;
      const pending = stopDiagnoses.filter((diag) => diag.label === "停止待确认").length;
      agentContext.textContent = `上下文：当前车辆 ${vehicle ? vehicleIdOf(vehicle) : "--"}，车队 ${vehicles.length} 台，疑似/阻断 ${concern} 台，停止待确认 ${pending} 台。`;
    };

    const setAgentStatusCard = (payload) => {
      agentCanChat = Boolean(payload?.can_chat);
      if (agentStatus) agentStatus.textContent = payload?.can_chat ? "可对话" : (payload?.enabled ? "待配置" : "已禁用");
      if (agentStatusNote) {
        agentStatusNote.textContent = payload?.can_chat
          ? "服务端 key 已配置"
          : (payload?.missing_config?.length ? `缺少 ${payload.missing_config.join(", ")}` : "服务端未启用");
      }
      if (agentModel) agentModel.textContent = payload?.model || "--";
      if (agentRoute) agentRoute.textContent = payload?.upstream_base_url || "JGZJ / subapi";
      const codex = payload?.codex || {};
      if (agentCodex) agentCodex.textContent = codex?.deployed ? "已部署" : "未就绪";
      if (agentCodexNote) {
        const cliVersion = codex?.cli?.version ? ` · ${codex.cli.version}` : "";
        agentCodexNote.textContent = codex?.listen ? `${codex.listen}${cliVersion}` : (codex?.app_server?.detail || "本机 App Server");
      }
      if (agentFleet) agentFleet.textContent = `${payload?.fleet?.vehicle_count ?? vehicles.length} 台`;
      if (agentFleetNote) {
        const fleet = payload?.fleet || {};
        agentFleetNote.textContent = `在线 ${fleet.online_count ?? "--"} · 疑似/阻断 ${fleet.stop_concern_count ?? "--"} · 待确认 ${fleet.stop_pending_count ?? "--"}`;
      }
      if (agentAudit && payload?.safeguards?.length) {
        agentAudit.textContent = [
          "自动调用清单：/api/cloud-ops/vehicles-lite、/api/cloud-ops-agent/status、/api/cloud-ops-agent/history",
          "禁止自动调用：/api/cloud-ops/execute、tool-list、vehicle_detail",
          "智能体对话：必须用户点击发送；后端只调用 subapi 兼容模型接口",
          "控制类动作：未绑定执行",
          "",
          "后端安全边界：",
          ...payload.safeguards.map((item) => `- ${item}`)
        ].join("\n");
      }
    };

    const loadAgentStatus = async () => {
      try {
        const response = await fetch(AGENT_STATUS_URL, { headers: { Accept: "application/json" }, cache: "no-store", credentials: "same-origin" });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok || payload?.ok === false) {
          throw new Error(payload?.detail || payload?.error || `HTTP ${response.status}`);
        }
        setAgentStatusCard(payload);
      } catch (error) {
        agentCanChat = false;
        if (agentStatus) agentStatus.textContent = "状态异常";
        if (agentStatusNote) agentStatusNote.textContent = error?.message || "读取失败";
        if (agentModel) agentModel.textContent = "--";
        if (agentCodex) agentCodex.textContent = "未知";
        if (agentCodexNote) agentCodexNote.textContent = "状态接口异常";
      }
      updateAgentContext();
    };

    const renderAgentHistory = (items) => {
      const list = Array.isArray(items) ? items : [];
      if (agentHistoryCount) agentHistoryCount.textContent = `${list.length} 条`;
      if (!agentHistory) return;
      if (!list.length) {
        agentHistory.innerHTML = '<p class="cloud-ops-test-empty">暂无智能体记录。</p>';
        return;
      }
      agentHistory.innerHTML = list.map((item) => {
        const ok = item?.ok !== false;
        return `<article class="cloud-ops-test-agent-history-item ${ok ? "is-ok" : "is-error"}">
          <span>${escapeHtml(ok ? "OK" : "ERR")} · ${escapeHtml(item?.vehicle_id || "全局")}</span>
          <strong>${escapeHtml(item?.prompt_snippet || "--")}</strong>
          <p>${escapeHtml(item?.answer_snippet || item?.error || "--")}</p>
          <small>${escapeHtml(item?.at || "")} · ${escapeHtml(item?.model || "--")} · ${escapeHtml(item?.latency_ms ? `${item.latency_ms}ms` : "--")}</small>
        </article>`;
      }).join("");
    };

    const loadAgentHistory = async () => {
      try {
        const response = await fetch(`${AGENT_HISTORY_URL}?limit=20`, { headers: { Accept: "application/json" }, cache: "no-store", credentials: "same-origin" });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok || payload?.ok === false) {
          throw new Error(payload?.detail || payload?.error || `HTTP ${response.status}`);
        }
        renderAgentHistory(payload.items || []);
      } catch (error) {
        if (agentHistoryCount) agentHistoryCount.textContent = "异常";
        if (agentHistory) agentHistory.innerHTML = `<p class="cloud-ops-test-empty">历史读取失败：${escapeHtml(error?.message || "未知错误")}</p>`;
      }
    };

    const appendAgentMessage = (role, text, meta = "") => {
      if (!agentMessages) return;
      const node = document.createElement("div");
      node.className = `cloud-ops-test-agent-message is-${role}`;
      const title = role === "user" ? "运维人员" : (role === "error" ? "接口错误" : "山海智枢");
      node.innerHTML = `<strong>${escapeHtml(title)}</strong><p>${escapeHtml(text || "")}</p>${meta ? `<small>${escapeHtml(meta)}</small>` : ""}`;
      agentMessages.appendChild(node);
      agentMessages.scrollTop = agentMessages.scrollHeight;
    };

    const sendAgentMessage = async (message) => {
      const text = String(message || "").trim();
      if (!text) {
        setStatus("请输入智能体问题", "error");
        return;
      }
      if (!agentCanChat) {
        appendAgentMessage("error", "智能体模型链路还没有配置服务端 subapi key，不能发起对话。");
        setStatus("智能体未配置 CLOUD_OPS_AGENT_API_KEY", "error");
        return;
      }
      const vehicleId = selectedVehicleId();
      appendAgentMessage("user", text, vehicleId ? `车辆 ${vehicleId}` : "全局上下文");
      if (agentInput) agentInput.value = "";
      if (agentLatency) agentLatency.textContent = "分析中...";
      setStatus("智能体只读分析中，不执行车端工具。", "loading");
      try {
        const response = await fetch(AGENT_CHAT_URL, {
          method: "POST",
          headers: { "Content-Type": "application/json", Accept: "application/json" },
          credentials: "same-origin",
          body: JSON.stringify({
            message: text,
            vehicle_id: vehicleId,
            include_fleet_context: true
          })
        });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok || payload?.ok === false) {
          throw new Error(payload?.detail || payload?.error || `HTTP ${response.status}`);
        }
        appendAgentMessage("agent", payload.answer || "模型没有返回文本。", `${payload.model || "--"} · ${payload.latency_ms || "--"}ms · ${payload.mode || "只读"}`);
        if (agentLatency) agentLatency.textContent = `${payload.latency_ms || "--"} ms`;
        setStatus("智能体分析完成。未执行任何车端工具。", "ok");
        loadAgentHistory();
      } catch (error) {
        appendAgentMessage("error", error?.message || "智能体调用失败");
        if (agentLatency) agentLatency.textContent = "调用失败";
        setStatus(`智能体调用失败：${error?.message || "未知错误"}`, "error");
        loadAgentHistory();
      }
    };

    const analyzeCurrentVehicle = () => {
      const vehicle = selectedVehicle();
      if (!vehicle) {
        setStatus("请先选择车辆", "error");
        return;
      }
      const diag = stopDiagnosisOf(vehicle);
      sendAgentMessage(`请基于当前缓存分析车辆 ${vehicleIdOf(vehicle)} 的云端运维状态，重点看自动驾驶停止入口、定位、规划、控制/底盘、通信链路。当前页面初判：${diag.label}，原因：${diag.reason}`);
    };

    const deepDiagnoseCurrentVehicle = async () => {
      const vehicle = selectedVehicle();
      const vehicleId = vehicleIdOf(vehicle);
      const question = String(agentInput?.value || "").trim() || `请深度诊断 ${vehicleId} 车辆现在状态如何，有没有故障或潜在问题。`;
      if (!vehicleId) {
        setStatus("请先选择车辆", "error");
        return;
      }
      if (!agentCanChat) {
        appendAgentMessage("error", "智能体模型链路还没有配置服务端 subapi key，不能发起深度诊断。");
        setStatus("智能体未配置 CLOUD_OPS_AGENT_API_KEY", "error");
        return;
      }
      appendAgentMessage("user", question, `深度诊断车辆 ${vehicleId}`);
      if (agentInput) agentInput.value = "";
      if (agentLatency) agentLatency.textContent = "深度诊断中...";
      if (toolResult) toolResult.textContent = "正在执行 WebSocket 只读工具和 SSH 只读巡检...";
      setStatus("深度诊断中：优先 auto_ad_ai WebSocket，只读 SSH 作为补充。", "loading");
      try {
        const response = await fetch(AGENT_DIAGNOSE_URL, {
          method: "POST",
          headers: { "Content-Type": "application/json", Accept: "application/json" },
          credentials: "same-origin",
          body: JSON.stringify({
            vehicle_id: vehicleId,
            question,
            include_ssh: true
          })
        });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok || payload?.ok === false) {
          throw new Error(payload?.detail || payload?.error || `HTTP ${response.status}`);
        }
        appendAgentMessage("agent", payload.answer || "深度诊断没有返回文本。", `${payload.model || "--"} · ${payload.latency_ms || "--"}ms · ${payload.mode || "深度诊断"}`);
        if (toolResult) {
          toolResult.textContent = JSON.stringify({
            audit_id: payload.audit_id,
            mode: payload.mode,
            evidence: payload.evidence
          }, null, 2);
        }
        if (agentLatency) agentLatency.textContent = `${payload.latency_ms || "--"} ms`;
        setStatus("深度诊断完成。未执行重启、控车、写参数或任务重发。", "ok");
        loadAgentHistory();
      } catch (error) {
        appendAgentMessage("error", error?.message || "深度诊断调用失败");
        if (agentLatency) agentLatency.textContent = "诊断失败";
        if (toolResult) toolResult.textContent = `深度诊断失败：${error?.message || "未知错误"}`;
        setStatus(`深度诊断失败：${error?.message || "未知错误"}`, "error");
        loadAgentHistory();
      }
    };

    const analyzeStopVehicles = () => {
      const diagnosed = vehicles.map((vehicle) => ({ vehicle, diag: stopDiagnosisOf(vehicle) }));
      const targets = diagnosed
        .filter((item) => item.diag.tone === "danger" || item.diag.tone === "warn" || item.diag.label === "停止待确认")
        .slice(0, 12)
        .map((item) => `${vehicleIdOf(item.vehicle)}:${item.diag.label}`)
        .join("，");
      sendAgentMessage(`请分析当前车队里的自动驾驶停止/停车待确认车辆，按故障优先级排序，并给出下一步只读诊断建议。候选车辆：${targets || "当前页面未发现明显候选"}`);
    };

    const loadVehicles = async () => {
      setStatus("读取真实车辆列表...", "loading");
      try {
        const response = await fetch(VEHICLES_URL, { headers: { Accept: "application/json" }, cache: "no-store", credentials: "same-origin" });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok || payload?.ok === false) {
          throw new Error(payload?.detail || payload?.error || `HTTP ${response.status}`);
        }
        vehicles = Array.isArray(payload.vehicles) ? payload.vehicles : [];
        if (interfaceSource) interfaceSource.textContent = payload.source || "cloud_agent_registry";
        if (lastRefresh) lastRefresh.textContent = new Date().toLocaleTimeString("zh-CN", { hour12: false });
        if (apiNote) apiNote.textContent = payload.note || "只读车辆注册表";
        renderVehicleOptions();
        renderFleetSpine();
        renderVehicles();
        renderStopFaultMonitor();
        renderVehicleTable();
        syncSelectedVehicleUi();
        updateStats();
        setStatus(`已读取 ${vehicles.length} 台真实车辆。未自动执行任何车端工具。`, "ok");
      } catch (error) {
        vehicles = [];
        currentVehicleId = "";
        renderVehicleOptions();
        renderFleetSpine();
        renderVehicles();
        renderStopFaultMonitor();
        renderVehicleTable();
        updateStats();
        setStatus(`车辆列表读取失败：${error?.message || "未知错误"}`, "error");
      }
    };

    const extractNestedValues = (value, max = 200) => {
      const found = [];
      const walk = (node, prefix = "") => {
        if (found.length >= max || node === null || node === undefined) return;
        if (typeof node !== "object") {
          found.push([prefix, node]);
          return;
        }
        if (Array.isArray(node)) {
          node.slice(0, 8).forEach((item, index) => walk(item, `${prefix}[${index}]`));
          return;
        }
        Object.entries(node).forEach(([key, child]) => {
          const next = prefix ? `${prefix}.${key}` : key;
          if (/password|token|secret|key/i.test(next)) return;
          walk(child, next);
        });
      };
      walk(value);
      return found;
    };

    const findFirstByKey = (payload, names) => {
      const wanted = new Set(names.map((name) => String(name).toLowerCase()));
      for (const [path, value] of extractNestedValues(payload)) {
        const tail = String(path || "").split(".").pop().replace(/\[\d+\]$/, "").toLowerCase();
        if (wanted.has(tail) && value !== null && value !== undefined && value !== "") return value;
      }
      return undefined;
    };

    const resultLine = (label, value) => `<div><dt>${escapeHtml(label)}</dt><dd>${escapeHtml(displayValue(value))}</dd></div>`;

    const summarizeCombinedResults = (payload) => {
      const results = Array.isArray(payload?.results) ? payload.results : [];
      const okCount = results.filter((item) => item.ok).length;
      const lines = results.map((item) => `${item.label || item.tool_name}: ${item.ok ? "正常返回" : "返回异常"}`);
      return {
        title: payload?.ok === false ? "综合检查存在异常返回" : "综合检查已完成",
        tone: payload?.ok === false ? "warn" : "ok",
        lines: [`${okCount}/${results.length} 个子检查正常返回`, ...lines],
        kv: []
      };
    };

    const summarizeToolPayload = (toolName, payload, vehicleId) => {
      const normalizedTool = String(toolName || "");
      if (normalizedTool === "task.navigation_context" || normalizedTool === "communication.cloud_vehicle" || normalizedTool === "combined.snapshot") {
        return summarizeCombinedResults(payload);
      }
      const ok = payload?.ok !== false;
      const status = findFirstByKey(payload, ["status", "state", "health", "result", "summary"]);
      const speed = findFirstByKey(payload, ["speed_kph", "speed", "vehicle_speed", "localization_speed_mps"]);
      const mode = findFirstByKey(payload, ["running_mode", "mode", "planner_state"]);
      const masterPing = findFirstByKey(payload, ["master_ping_ok", "ping_ok", "master_ok"]);
      const rosOk = findFirstByKey(payload, ["telemetry_master_ros_ok", "ros_ok", "master_ros_ok"]);
      const cpu = findFirstByKey(payload, ["cpu_percent", "cpu"]);
      const memory = findFirstByKey(payload, ["memory_percent", "memory"]);
      const disk = findFirstByKey(payload, ["disk_percent", "disk"]);
      const emergency = findFirstByKey(payload, ["emergency_stop_pressed", "emergency_stop"]);
      const collision = findFirstByKey(payload, ["collision_stop"]);
      const titleByTool = {
        "vehicle.current_state": "车辆当前状态摘要",
        "vehicle_detail": "车辆详情摘要",
        "health.autodrive_check": "自动驾驶健康摘要",
        "system.snapshot": "系统资源摘要",
        "ros.overview": "ROS 总览摘要",
        "network.master_probe": "主控链路摘要"
      };
      const kv = [];
      kv.push(["车辆", vehicleId]);
      if (speed !== undefined) kv.push(["速度", speed]);
      if (mode !== undefined) kv.push(["模式/状态", mode]);
      if (masterPing !== undefined) kv.push(["主控链路", boolText(masterPing, "可达", "不可达")]);
      if (rosOk !== undefined) kv.push(["ROS", boolText(rosOk, "正常", "异常")]);
      if (emergency !== undefined) kv.push(["急停", boolText(emergency, "触发", "未触发")]);
      if (collision !== undefined) kv.push(["碰撞停", boolText(collision, "触发", "未触发")]);
      if (cpu !== undefined) kv.push(["CPU", cpu]);
      if (memory !== undefined) kv.push(["内存", memory]);
      if (disk !== undefined) kv.push(["磁盘", disk]);
      const lines = [];
      if (status !== undefined) lines.push(`返回状态：${displayValue(status)}`);
      lines.push(ok ? "接口正常返回，下面是根据返回字段提取的关键结果。" : "接口返回异常，请展开原始 JSON 查看错误详情。");
      return {
        title: titleByTool[normalizedTool] || `${normalizedTool} 检查摘要`,
        tone: ok ? "ok" : "warn",
        lines,
        kv
      };
    };

    const renderToolSummary = (toolName, payload, vehicleId) => {
      if (!toolSummary) return;
      const summary = summarizeToolPayload(toolName, payload, vehicleId);
      const kvHtml = summary.kv?.length
        ? `<dl class="cloud-ops-test-result-kv">${summary.kv.map(([k, v]) => resultLine(k, v)).join("")}</dl>`
        : "";
      const lineHtml = summary.lines?.length
        ? `<ul>${summary.lines.map((line) => `<li>${escapeHtml(line)}</li>`).join("")}</ul>`
        : "";
      toolSummary.innerHTML = `<strong>${escapeHtml(summary.title)}</strong>${kvHtml}${lineHtml}<p>完整原始返回已折叠在下方，需要排障时再展开。</p>`;
      toolSummary.dataset.tone = summary.tone || "ok";
    };

    const runReadOnlyTool = async (button) => {
      const toolName = String(button?.dataset?.tool || "").trim();
      const toolAction = String(button?.dataset?.toolAction || "tool_call").trim();
      const args = parseJsonDataset(button?.dataset?.toolArgs, {});
      const timeout_s = Number.parseInt(button?.dataset?.timeoutS || "30", 10) || 30;
      const vehicle = selectedVehicle();
      const vehicleId = vehicleIdOf(vehicle);
      if (!vehicleId) {
        setStatus("请先选择车辆", "error");
        return;
      }
      if (!READONLY_TOOL_ALLOWLIST.has(toolName)) {
        setStatus(`工具 ${toolName} 未在测试页只读白名单内`, "error");
        return;
      }
      if (lastToolLabel) lastToolLabel.textContent = `${vehicleId} · ${toolName}`;
      if (toolSummary) toolSummary.textContent = `正在对 ${vehicleId} 执行只读检查：${toolName}`;
      if (toolResult) toolResult.textContent = "正在执行只读检查...";
      setStatus(`点击触发只读工具：${toolName}`, "loading");
      try {
        let payload;
        if (toolAction === "task_context" || toolName === "task.navigation_context") {
          const contextTools = [
            { tool_name: "status.routing", label: "Routing 状态", args: {} },
            { tool_name: "status.planning", label: "Planning 状态", args: {} },
            { tool_name: "route.list", label: "路线列表", args: {} }
          ];
          const results = [];
          for (const item of contextTools) {
            const response = await fetch(EXECUTE_URL, {
              method: "POST",
              headers: { "Content-Type": "application/json", Accept: "application/json" },
              credentials: "same-origin",
              body: JSON.stringify({ action: "tool_call", vehicle_id: vehicleId, tool_name: item.tool_name, args: item.args, timeout_s, request_id: `cloud-ops-test-task-${item.tool_name}-${Date.now()}` })
            });
            const data = await response.json().catch(() => ({}));
            results.push({ label: item.label, tool_name: item.tool_name, ok: response.ok && data?.ok !== false, response: data });
          }
          payload = { ok: results.every((item) => item.ok), vehicle_id: vehicleId, tool_name: "task.navigation_context", description: "Routing + Planning + 路线列表的任务/导航上下文", results };
        } else if (toolAction === "communication_check" || toolName === "communication.cloud_vehicle") {
          const communicationTools = [
            { tool_name: "network.cloud_probe", label: "云端连通", args: {} },
            { tool_name: "network.master_probe", label: "主控探测", args: { include_ssh: true } },
            { tool_name: "ros.overview", label: "ROS 总览", args: {} }
          ];
          const results = [];
          for (const item of communicationTools) {
            const response = await fetch(EXECUTE_URL, {
              method: "POST",
              headers: { "Content-Type": "application/json", Accept: "application/json" },
              credentials: "same-origin",
              body: JSON.stringify({ action: "tool_call", vehicle_id: vehicleId, tool_name: item.tool_name, args: item.args, timeout_s, request_id: `cloud-ops-test-comm-${item.tool_name}-${Date.now()}` })
            });
            const data = await response.json().catch(() => ({}));
            results.push({ label: item.label, tool_name: item.tool_name, ok: response.ok && data?.ok !== false, response: data });
          }
          payload = { ok: results.every((item) => item.ok), vehicle_id: vehicleId, tool_name: "communication.cloud_vehicle", description: "云端 + 主控 + ROS 链路综合只读结果", results };
        } else if (toolAction === "combined_snapshot" || toolName === "combined.snapshot") {
          const snapshotTools = [
            { tool_name: "health.snapshot", label: "健康快照", args: {} },
            { tool_name: "system.snapshot", label: "系统快照", args: { include_processes: true } },
            { tool_name: "vehicle.snapshot", label: "整车快照", args: { include_topic_samples: true } }
          ];
          const results = [];
          for (const item of snapshotTools) {
            const response = await fetch(EXECUTE_URL, {
              method: "POST",
              headers: { "Content-Type": "application/json", Accept: "application/json" },
              credentials: "same-origin",
              body: JSON.stringify({
                action: "tool_call",
                vehicle_id: vehicleId,
                tool_name: item.tool_name,
                args: item.args,
                timeout_s,
                request_id: `cloud-ops-test-combined-${item.tool_name}-${Date.now()}`
              })
            });
            const data = await response.json().catch(() => ({}));
            results.push({ label: item.label, tool_name: item.tool_name, ok: response.ok && data?.ok !== false, response: data });
          }
          payload = {
            ok: results.every((item) => item.ok),
            vehicle_id: vehicleId,
            tool_name: "combined.snapshot",
            description: "健康快照 + 系统快照 + 整车快照的合并只读结果",
            results
          };
        } else if (toolAction === "tool_list" || toolName === "tool_list") {
          const response = await fetch(`/api/cloud-ops/vehicles/${encodeURIComponent(vehicleId)}/tool-list?timeout_s=${encodeURIComponent(timeout_s)}`, { headers: { Accept: "application/json" }, credentials: "same-origin" });
          payload = await response.json().catch(() => ({}));
          if (!response.ok || payload?.ok === false) throw new Error(payload?.detail || payload?.error || `HTTP ${response.status}`);
        } else if (toolAction === "vehicle_detail" || toolName === "vehicle_detail") {
          const response = await fetch(`/api/cloud-ops/vehicles/${encodeURIComponent(vehicleId)}`, { headers: { Accept: "application/json" }, credentials: "same-origin" });
          payload = await response.json().catch(() => ({}));
          if (!response.ok || payload?.ok === false) throw new Error(payload?.detail || payload?.error || `HTTP ${response.status}`);
        } else {
          const response = await fetch(EXECUTE_URL, {
            method: "POST",
            headers: { "Content-Type": "application/json", Accept: "application/json" },
            credentials: "same-origin",
            body: JSON.stringify({
              action: "tool_call",
              vehicle_id: vehicleId,
              tool_name: toolName,
              args,
              timeout_s,
              request_id: `cloud-ops-test-readonly-${Date.now()}`
            })
          });
          payload = await response.json().catch(() => ({}));
          if (!response.ok || payload?.ok === false) throw new Error(payload?.detail || payload?.error || `HTTP ${response.status}`);
        }
        renderToolSummary(toolName, payload, vehicleId);
        if (toolResult) toolResult.textContent = JSON.stringify(payload, null, 2);
        setStatus(`只读检查完成：${toolName}`, "ok");
      } catch (error) {
        if (toolSummary) toolSummary.textContent = `只读检查失败：${error?.message || "未知错误"}`;
        if (toolResult) toolResult.textContent = `执行失败：${error?.message || "未知错误"}`;
        setStatus(`只读检查失败：${error?.message || "未知错误"}`, "error");
      }
    };

    const setAgentRailOpen = (open) => {
      if (!agentRail) return;
      agentRail.classList.toggle("is-open", Boolean(open));
      agentToggle?.setAttribute("aria-expanded", open ? "true" : "false");
    };
    const setAgentPinned = (pinned) => {
      if (!agentRail) return;
      agentRail.classList.toggle("is-pinned", Boolean(pinned));
      shell.classList.toggle("has-agent-pinned", Boolean(pinned));
      agentPin?.setAttribute("aria-pressed", pinned ? "true" : "false");
      if (agentPin) agentPin.textContent = pinned ? "取消固定" : "固定";
      setAgentRailOpen(Boolean(pinned));
      try { localStorage.setItem("cloudOpsTestAgentPinned", pinned ? "1" : "0"); } catch (_error) {}
    };
    const restoreAgentPinned = () => {
      try {
        setAgentPinned(localStorage.getItem("cloudOpsTestAgentPinned") === "1");
      } catch (_error) {
        setAgentPinned(false);
      }
    };
    const alignAgentRailToHero = () => {
      const hero = shell.querySelector(".cloud-ops-test-topbar");
      if (!hero || !agentRail) return;
      const top = Math.max(0, Math.round(hero.getBoundingClientRect().top + 56));
      agentRail.style.setProperty("--cloud-ops-test-agent-top", `${top}px`);
      agentRail.style.setProperty("--cloud-ops-test-agent-max-height", `calc(100vh - ${top + 20}px)`);
    };

    tabs.forEach((tab) => tab.addEventListener("click", () => setActive(tab.dataset.target)));
    shell.addEventListener("click", (event) => {
      const target = event.target;
      const vehicleButton = target?.closest?.("[data-vehicle-id]");
      if (vehicleButton && vehicleSelect) {
        setSelectedVehicle(vehicleButton.dataset.vehicleId || "");
        return;
      }
      const actionButton = target?.closest?.("[data-action]");
      if (!actionButton) return;
      const action = actionButton.dataset.action;
      if (action === "refresh-vehicles") {
        loadVehicles();
      } else if (action === "readonly-tool") {
        runReadOnlyTool(actionButton);
      } else if (action === "agent-toggle") {
        setAgentRailOpen(!agentRail?.classList.contains("is-open"));
      } else if (action === "agent-pin") {
        setAgentPinned(!agentRail?.classList.contains("is-pinned"));
      } else if (action === "agent-send") {
        sendAgentMessage(agentInput?.value || "");
      } else if (action === "agent-analyze-current") {
        analyzeCurrentVehicle();
      } else if (action === "agent-deep-diagnose") {
        deepDiagnoseCurrentVehicle();
      } else if (action === "agent-analyze-stops") {
        analyzeStopVehicles();
      }
    });
    vehicleSelect?.addEventListener("change", () => {
      setSelectedVehicle(vehicleSelect.value || "");
    });
    vehicleSortSelect?.addEventListener("change", () => {
      vehicleSortMode = vehicleSortSelect.value === "id" ? "id" : "status";
      renderVehicles();
      renderVehicleTable();
      setStatus(vehicleSortMode === "id" ? "车辆列表已按车辆编号排序。" : "车辆列表已按状态排序：异常在前，正常在后。", "ok");
    });
    agentInput?.addEventListener("keydown", (event) => {
      if ((event.metaKey || event.ctrlKey) && event.key === "Enter") {
        event.preventDefault();
        sendAgentMessage(agentInput.value || "");
      }
    });
    agentRail?.addEventListener("mouseenter", () => setAgentRailOpen(true));
    agentRail?.addEventListener("mouseleave", () => {
      if (!agentRail.classList.contains("is-pinned") && !agentRail.matches(":focus-within")) setAgentRailOpen(false);
    });
    agentRail?.addEventListener("focusin", () => setAgentRailOpen(true));
    agentRail?.addEventListener("focusout", () => {
      window.setTimeout(() => {
        if (!agentRail.classList.contains("is-pinned") && !agentRail.matches(":focus-within") && !agentRail.matches(":hover")) setAgentRailOpen(false);
      }, 80);
    });
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && agentRail && !agentRail.classList.contains("is-pinned")) {
        setAgentRailOpen(false);
      }
    });

    alignAgentRailToHero();
    window.addEventListener("resize", alignAgentRailToHero);
    restoreAgentPinned();
    loadVehicles();
    loadAgentStatus();
    loadAgentHistory();
  })();
</script>
