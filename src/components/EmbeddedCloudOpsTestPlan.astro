        bucket.forEach((point) => {
          const pixel = screenPoint(point.x, point.y);
          context.rect(pixel.x - 1, pixel.y - 1, 2, 2);
        });
        context.fillStyle = palette[bucketIndex];
        context.fill();
      });

      const obstacles = Array.isArray(obstacleResult?.obstacles) ? obstacleResult.obstacles : [];
      obstacles.forEach((obstacle) => {
        const corners = Array.isArray(obstacle?.corners) ? obstacle.corners : [];
        if (corners.length < 3) return;
        const pixels = corners
          .map((corner) => screenPoint(Number(corner?.x), Number(corner?.y)))
          .filter((pixel) => Number.isFinite(pixel.x) && Number.isFinite(pixel.y));
        if (pixels.length < 3) return;
        context.beginPath();
        context.moveTo(pixels[0].x, pixels[0].y);
        pixels.slice(1).forEach((pixel) => context.lineTo(pixel.x, pixel.y));
        context.closePath();
        context.fillStyle = obstacle?.valid === false ? "rgba(251, 191, 36, 0.12)" : "rgba(74, 222, 128, 0.16)";
        context.strokeStyle = obstacle?.valid === false ? "rgba(251, 191, 36, 0.92)" : "rgba(74, 222, 128, 0.95)";
        context.lineWidth = 2;
