      image.src = src;
    });
    const composeMapRoutePayload = async (mapPayload, routeDetailPayload, route, currentRouteId) => {
      const mapImage = extractToolMediaItems(mapPayload).find((item) => item.kind === "image");
      if (!mapImage?.src) throw new Error("基础地图没有可用图像");
      const extent = normalizedMapExtent(mapPayload);
      if (!extent) throw new Error("基础地图没有返回坐标范围");
      const points = routePointsOfPayload(routeDetailPayload);
      if (points.length < 2) throw new Error("路线详情没有返回可绘制轨迹点");

      const sourceImage = await loadCanvasImage(mapImage.src);
      const width = sourceImage.naturalWidth || sourceImage.width || 1024;
      const height = sourceImage.naturalHeight || sourceImage.height || 1024;
      const canvas = document.createElement("canvas");
      canvas.width = width;
      canvas.height = height;
