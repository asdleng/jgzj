        const paddingRatio = 0.05;
        const paddedWorldWidth = extent.width * (1 + paddingRatio * 2);
        const paddedWorldHeight = extent.height * (1 + paddingRatio * 2);
        const scale = Math.min(width / paddedWorldWidth, height / paddedWorldHeight);
