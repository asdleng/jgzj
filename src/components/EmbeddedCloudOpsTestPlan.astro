    const paramInputValue = (input) => input.type === "checkbox" ? String(input.checked) : String(input.value || "");
    const paramValueText = (input, value) => {
      if (input.type === "checkbox") return value === "true" ? "开启" : "关闭";
      return value || "未设置";
    };
    const paramDraftStorageKey = () => `cloudOpsParamDraft:${selectedVehicleId() || "unselected"}`;
    const syncParamDependencies = () => {
      paramDraftInputs.forEach((input) => {
