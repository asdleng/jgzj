---
const tabs = [
  { id: "overview", label: "车辆总览", desc: "在线车辆与异常故障" },
  { id: "status", label: "车辆状态检查", desc: "核心与专项诊断" },
  { id: "params", label: "参数设置", desc: "节点配置与变更预览" },
  { id: "map", label: "地图管理", desc: "地图路径与版本管理" },
  { id: "agent", label: "智能体运维", desc: "智能诊断与协作" }
];

const readOnlyToolGroups = [
  {
    title: "核心诊断",
    tools: [
      { label: "车辆当前状态", tool: "vehicle.current_state", desc: "看车辆是否在线、速度/模式/安全状态是否正常", action: "vehicle_detail", purpose: "回答：这台车现在是什么状态？" },
      { label: "自动驾驶健康", tool: "health.autodrive_check", desc: "定位、规划、底盘、阻断条件综合只读检查", timeout: 35, purpose: "回答：自动驾驶是否具备运行条件？" },
      { label: "云车通信链路", tool: "communication.cloud_vehicle", desc: "合并云端连通、主控链路、ROS 入口探测", action: "communication_check", timeout: 30, purpose: "回答：云端、media、主控、ROS 链路是否通？" },
      { label: "主控 / ROS 状态", tool: "ros.overview", desc: "检查 ROS master、topic、node 和服务概览", timeout: 30, purpose: "回答：主控 ROS 环境是否正常？" },
      { label: "停车 / 不动诊断", tool: "task.navigation_context", desc: "合并 routing、planning、路线、定位和避障上下文", action: "task_context", timeout: 35, purpose: "回答：这台车为什么停着或不动？" }
    ]
  }
];

const specialistDiagnosticGroups = [
  {
    title: "感知与相机",
    desc: "相机、上传链路、AI 检测和障碍物处理。",
    tools: [
      { label: "相机状态", tool: "status.camera", desc: "检查相机在线、帧率并打开连续监控", args: { include_rate: true, sample_seconds: 1 }, timeout: 18, includeLiveMedia: true },
      { label: "上传链路", tool: "camera.upload_chain", desc: "检查图片/视频上传链路并打开连续监控", timeout: 25, includeLiveMedia: true },
      { label: "AI检测配置", tool: "ai_detection.config", desc: "查看 AI 检测配置和落盘路径", timeout: 20 },
      { label: "AI标注实景", tool: "ai_detection.images", desc: "查看已标注障碍物的实景图并对照连续监控", args: { limit: 6 }, timeout: 35, includeLiveMedia: true },
      { label: "障碍物处理状态", tool: "status.obstacle_processor", desc: "检查 obstacle processor 心跳和输入", timeout: 25 },
      { label: "障碍物预览", tool: "obstacle.preview", desc: "查看俯视点云和融合障碍物实景", args: { topic: "/fusion/objects", range_m: 25, image_size: 768, save_file: false, include_base64: true, timeout_s: 3, max_obstacles: 120, include_invalid: true }, timeout: 40, includeLiveMedia: true }
    ]
  },
  {
    title: "定位与地图",
    desc: "定位可靠性、地图预览和地图版本入口。",
    tools: [
      { label: "定位状态", tool: "status.localization", desc: "检查 NDT/ESKF/GPS/IMU 相关状态", timeout: 25 },
      { label: "地图查看", tool: "map.preview", desc: "查看点云地图并叠加可切换路线", args: { image_size: 1024, include_base64: true }, timeout: 40 }
    ]
  },
  {
    title: "规划与任务",
    desc: "规划、Routing 和路线库上下文。",
    tools: [
      { label: "规划状态", tool: "status.planning", desc: "检查 planner 状态、轨迹和急停信息", timeout: 25 },
      { label: "Routing状态", tool: "status.routing", desc: "检查当前 routing、路径选择和路线可用性", timeout: 25 },
      { label: "路线列表", tool: "route.list", desc: "列出车辆保存路线", timeout: 25 }
    ]
  },
  {
    title: "底层控制",
    desc: "CAN、控制链路和车身状态。",
    tools: [
      { label: "CAN状态", tool: "status.can", desc: "检查底盘 CAN 和 chassis 状态", timeout: 25 },
      { label: "控制状态", tool: "status.control", desc: "检查 control 模块和目标速度输出", timeout: 25 },
      { label: "车身控制状态", tool: "status.body_control", desc: "只读查看灯光、屏幕、车身控制状态", timeout: 25 }
    ]
  },
  {
    title: "系统与调试",
    desc: "关键节点、系统资源、原始快照和工具列表。",
    tools: [
      { label: "关键节点", tool: "status.key_nodes", desc: "检查关键 ROS 节点在线情况", timeout: 25 },
      { label: "系统快照", tool: "system.snapshot", desc: "CPU、内存、磁盘、温度和进程", args: { include_processes: true }, timeout: 30 },
      { label: "车辆快照", tool: "vehicle.snapshot", desc: "整车快照和 topic 采样", args: { include_topic_samples: true }, timeout: 25 },
      { label: "健康快照", tool: "health.snapshot", desc: "健康状态缓存摘要", timeout: 25 },
      { label: "车辆详情", tool: "vehicle_detail", desc: "查看 cloud-agent 车辆详情", action: "vehicle_detail", timeout: 20 },
      { label: "工具列表", tool: "tool_list", desc: "查看该车可用只读工具", action: "tool_list", timeout: 20 }
    ]
  }
];

const blockedActionGroups = [
  {
    title: "控制 / 重启",
    actions: [
      ["重启主控接口", "controller.reboot_master", "高风险：会中断主控 auto_ad_ai 接口"],
      ["重启 Media 接口", "controller.reboot_media", "高风险：会中断 media auto_ad_ai 接口"],
      ["碰撞停复位", "vehicle.clear_collision_stop", "需要现场安全确认"],
      ["广告屏/灯光控制", "vehicle.body_control", "需人工确认"]
    ]
  },
  {
    title: "任务 / 地图 / 参数写入",
    actions: [
      ["启动巡逻", "route.start_patrol", "任务重发必须人工确认后单独接"],
      ["地图插件启动", "map_editor.start", "地图编辑会打开车端插件，当前禁用"],
      ["地图插件关闭", "map_editor.stop", "当前禁用"],
      ["参数写入", "param.write", "必须有白名单、差异预览、回滚和审计"]
    ]
  }
];

const agentRules = [
  ["自动驾驶停止", "任务中 60 秒无有效位移", "触发故障诊断，不直接判具体故障"],
  ["定位不可靠", "location_topic_ reliable=false", "进入定位故障树"],
  ["规划阻塞", "planning/routing 无有效输出", "检查上游定位和任务"],
  ["通信异常", "车辆 last_seen 过期", "先查云端/主控链路"]
];
---

<section class="cloud-ops-test-shell" data-cloud-ops-test>
  <div class="cloud-ops-test-topbar">
    <div>
      <p class="cloud-ops-test-kicker">CLOUD OPERATIONS</p>
      <h1>云端智能运维(测试)</h1>
    </div>
  </div>


  <aside class="cloud-ops-test-agent-rail" data-role="agent-rail" aria-label="智能体运维常驻侧边栏">
    <button class="cloud-ops-test-agent-tab" type="button" data-action="agent-toggle" aria-expanded="false" aria-controls="cloud-ops-agent-panel">
      <span class="cloud-ops-test-agent-tab-dot" aria-hidden="true"></span>
      <span class="cloud-ops-test-agent-logo" aria-hidden="true"><i></i><b></b></span>
      <strong>山海智枢</strong>
    </button>
    <div class="cloud-ops-test-agent-panel" id="cloud-ops-agent-panel">
      <div class="cloud-ops-test-agent-panel-head">
        <div>
          <p class="cloud-ops-test-kicker">INTEGRATED AI OPS</p>
          <h2>山海智枢</h2>
        </div>
        <button class="cloud-ops-test-agent-pin" type="button" data-action="agent-pin" aria-pressed="false">固定</button>
      </div>

      <div class="cloud-ops-test-agent-mini-grid">
        <article>
          <span>状态</span>
          <strong data-role="agent-status">读取中</strong>
          <small data-role="agent-status-note">检查服务端配置</small>
        </article>
        <article>
          <span>模型</span>
          <strong data-role="agent-model">--</strong>
          <small data-role="agent-route">7791 / JGZJ / subapi</small>
        </article>
        <article>
          <span>Codex</span>
          <strong data-role="agent-codex">检查中</strong>
          <small data-role="agent-codex-note">本机 App Server</small>
        </article>
        <article>
          <span>车队</span>
          <strong data-role="agent-fleet">--</strong>
          <small data-role="agent-fleet-note">真实车辆缓存</small>
        </article>
      </div>

      <div class="cloud-ops-test-agent-context-bar">
        <span data-role="agent-context">上下文：一体化 AI · 在消息中点名车辆即可读取对应缓存。</span>
        <span data-role="agent-latency">等待输入</span>
      </div>

      <div class="cloud-ops-test-agent-messages" data-role="agent-messages">
        <div class="cloud-ops-test-agent-message is-agent">
          <strong>山海智枢</strong>
          <p>你好，我是山海智枢。</p>
        </div>
      </div>
      <div class="cloud-ops-agent-composer" data-role="agent-composer">
        <textarea
          class="cloud-ops-test-agent-input"
          data-role="agent-input"
          rows="3"
          placeholder="直接输入问题；提到车辆编号、车牌或 VIN 时会自动读取数据并按需诊断。"
        ></textarea>
        <div class="cloud-ops-agent-composer-footer">
          <div class="cloud-ops-agent-composer-options">
            <span class="cloud-ops-agent-composer-scope" title="自动理解对话或车辆运维意图；涉及车辆变更时仍需人工确认">
              <i aria-hidden="true"></i>
              一体化自动上下文
            </span>
            <label class="cloud-ops-agent-composer-select">
              <span>模型</span>
              <select data-role="agent-model-select" aria-label="选择山海智枢推理模型">
                <option value="gpt-5.6-terra" selected>GPT-5.6 Terra</option>
                <option value="gpt-5.6-sol">GPT-5.6 Sol</option>
                <option value="gpt-5.6">GPT-5.6</option>
                <option value="gpt-5.5">GPT-5.5</option>
                <option value="gpt-5.4">GPT-5.4</option>
                <option value="gpt-5.4-mini">GPT-5.4 Mini</option>
              </select>
            </label>
          </div>
          <span class="cloud-ops-agent-composer-hint">Enter 发送 · Shift+Enter 换行</span>
          <button class="cloud-ops-agent-composer-send" type="button" data-action="agent-send" aria-label="发送消息" title="发送消息">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
          </button>
        </div>
      </div>
      <details class="cloud-ops-test-disclosure">
        <summary>最近智能体记录与安全审计</summary>
        <div class="cloud-ops-test-agent-history" data-role="agent-history">
          <p class="cloud-ops-test-empty">读取历史中...</p>
        </div>
        <p class="cloud-ops-test-agent-history-count">历史：<span data-role="agent-history-count">--</span></p>
        <pre class="cloud-ops-test-json cloud-ops-test-json--compact" data-role="agent-audit">自动调用清单：/api/cloud-ops/vehicles-lite、/api/cloud-ops-agent/status、/api/cloud-ops-agent/history
禁止自动调用：/api/cloud-ops/execute、tool-list、vehicle_detail
智能体对话：必须用户点击发送；后端只调用 subapi 兼容模型接口
控制类动作：未绑定执行</pre>
      </details>
    </div>
  </aside>

  <div class="cloud-ops-test-layout">
    <aside class="cloud-ops-test-vehicle-picker-rail cloud-ops-test-vehicle-picker-rail--global" aria-label="全局车辆选择">
      <div class="cloud-ops-test-vehicle-picker-head">
        <div>
          <span>全局车辆选择</span>
          <strong data-role="selected-vehicle-title">--</strong>
        </div>
        <button type="button" data-action="refresh-vehicles">刷新</button>
      </div>
      <label class="cloud-ops-test-select-field cloud-ops-test-vehicle-picker-select">
        快速选择
        <select data-role="vehicle-select">
          <option value="">加载车辆中...</option>
        </select>
      </label>
      <div class="cloud-ops-test-vehicle-picker-list-head">
        <span>在线车辆</span>
        <small data-role="online-vehicle-count">--</small>
      </div>
      <div class="cloud-ops-test-vehicle-picker-list cloud-ops-test-vehicle-spine" data-role="vehicle-picker-list">
        <p class="cloud-ops-test-empty">正在读取车辆...</p>
      </div>
    </aside>

    <nav class="cloud-ops-test-tabs" aria-label="云端智能运维测试子页面">
      {tabs.map((tab, index) => (
        <button type="button" class:list={{ "is-active": index === 0 }} data-target={`cloud-ops-test-${tab.id}`}>
          <span class="cloud-ops-tab-light" aria-hidden="true"></span>
          <span class="cloud-ops-tab-index">{String(index + 1).padStart(2, "0")}</span>
          <span class="cloud-ops-tab-copy">
            <strong>{tab.label}</strong>
            <small>{tab.desc}</small>
          </span>
          <span class="cloud-ops-tab-scan" aria-hidden="true"></span>
        </button>
      ))}
    </nav>

    <div class="cloud-ops-test-pages">
      <section id="cloud-ops-test-overview" class="cloud-ops-test-page" data-active="true">
        <div class="cloud-ops-test-page-head">
          <p class="cloud-ops-test-kicker">FAULT OVERVIEW</p>
          <h2>车辆总览</h2>
        </div>

        <section class="cloud-ops-test-panel cloud-ops-test-abnormal-panel">
          <div class="cloud-ops-test-panel-head">
            <div>
              <h3>异常车辆与故障</h3>
            </div>
            <span data-role="vehicle-count">--</span>
          </div>
          <div class="cloud-ops-test-list-controls cloud-ops-test-list-controls--abnormal">
            <button class="cloud-ops-test-command-button is-primary" type="button" data-action="refresh-vehicles">刷新异常状态</button>
            <p class="cloud-ops-test-status" data-role="status">只读初始化中...</p>
          </div>
          <div class="cloud-ops-test-api-strip">
            <span>接口 <strong data-role="interface-source">--</strong></span>
            <span>刷新 <strong data-role="last-refresh">--</strong></span>
          </div>
          <div class="cloud-ops-test-vehicle-list cloud-ops-test-abnormal-list" data-role="vehicle-list">
            <p class="cloud-ops-test-empty">等待异常车辆判断...</p>
          </div>
        </section>
      </section>

      <section id="cloud-ops-test-status" class="cloud-ops-test-page" data-active="false">
        <div class="cloud-ops-test-page-head">
          <p class="cloud-ops-test-kicker">READ ONLY TOOLS</p>
          <h2>车辆状态检查</h2>
        </div>

        <div class="cloud-ops-test-status-split">
          <div class="cloud-ops-test-status-left">
            <div class="cloud-ops-test-core-layout">
              {readOnlyToolGroups.map((group) => (
                <section class="cloud-ops-test-tool-group cloud-ops-test-tool-group--core">
                  <div class="cloud-ops-test-tool-group-head">
                    <div>
                      <h3>{group.title}</h3>
                    </div>
                    <span>核心诊断</span>
                  </div>
                  <div class="cloud-ops-test-command-grid cloud-ops-test-command-grid--core">
                    {group.tools.map((item) => (
                      <button
                        class="cloud-ops-test-command-button cloud-ops-test-command-button--core"
                        type="button"
                        data-action="readonly-tool"
                        data-tool={item.tool}
                        data-tool-action={"action" in item ? item.action : "tool_call"}
                        data-tool-args={JSON.stringify("args" in item ? item.args : {})}
                        data-timeout-s={String("timeout" in item ? item.timeout : 30)}
                        data-purpose={"purpose" in item ? item.purpose : ""}
                      >
                        <strong>{item.label}</strong>
                        <span>{item.tool}</span>
                        <small>{item.desc}</small>
                        {"purpose" in item && <em>{item.purpose}</em>}
                      </button>
                    ))}
                  </div>
                </section>
              ))}

            </div>

            <details class="cloud-ops-test-disclosure cloud-ops-test-specialist-disclosure">
              <summary>
                <span>专项诊断</span>
              </summary>
              <div class="cloud-ops-test-specialist-stack">
                {specialistDiagnosticGroups.map((group) => (
                  <details class="cloud-ops-test-specialist-group">
                    <summary>
                      <span>{group.title}</span>
                    </summary>
                    <div class="cloud-ops-test-command-grid cloud-ops-test-command-grid--specialist">
                      {group.tools.map((item) => (
                        <button
                          class="cloud-ops-test-command-button cloud-ops-test-command-button--specialist"
                          type="button"
                          data-action="readonly-tool"
                          data-tool={item.tool}
                          data-tool-action={"action" in item ? item.action : "tool_call"}
                          data-tool-args={JSON.stringify("args" in item ? item.args : {})}
                          data-timeout-s={String("timeout" in item ? item.timeout : 25)}
                          data-purpose={"purpose" in item ? item.purpose : ""}
                          data-include-live-media={String("includeLiveMedia" in item ? item.includeLiveMedia : false)}
                        >
                          <strong>{item.label}</strong>
                          <span>{item.tool}</span>
                          <small>{item.desc}</small>
                        </button>
                      ))}
                    </div>
                  </details>
                ))}
              </div>
            </details>

            {blockedActionGroups.map((group) => (
              <details class="cloud-ops-test-disclosure cloud-ops-test-disabled-disclosure">
                <summary>{group.title}</summary>
                <div class="cloud-ops-test-command-grid cloud-ops-test-command-grid--blocked">
                  {group.actions.map(([label, tool, desc]) => (
                    <button class="cloud-ops-test-command-button is-disabled" type="button" disabled>
                      <strong>{label}</strong>
                      <span>{tool}</span>
                      <small>{desc}</small>
                    </button>
                  ))}
                </div>
              </details>
            ))}
          </div>

          <section class="cloud-ops-test-panel cloud-ops-test-panel--result cloud-ops-test-sticky-result">
            <div class="cloud-ops-test-panel-head">
              <div>
                <h3>查询结果</h3>
              </div>
              <span data-role="last-tool-label">未查询</span>
            </div>
            <div class="cloud-ops-test-result-summary" data-role="tool-summary">暂无查询结果</div>
            <section class="cloud-ops-test-media" data-role="tool-media" hidden aria-live="polite">
              <div class="cloud-ops-test-media-head">
                <h4 data-role="tool-media-title">图像与视频</h4>
                <div class="cloud-ops-test-media-head-actions">
                  <span data-role="tool-media-count">--</span>
                  <span class="cloud-ops-test-obstacle-state" data-role="obstacle-overlay-state" hidden>障碍物实景待查询</span>
                  <span class="cloud-ops-test-monitor-state" data-role="live-monitor-state" hidden>单次抓拍</span>
                  <button
                    type="button"
                    class="cloud-ops-test-monitor-toggle"
                    data-action="live-monitor-toggle"
                    data-role="live-monitor-toggle"
                    aria-pressed="false"
                    hidden
                  >开始监控</button>
                </div>
              </div>
              <div class="cloud-ops-test-map-route-controls" data-role="map-route-controls" hidden>
                <label>
                  <span>显示路线</span>
                  <select data-role="map-route-select" aria-label="切换地图显示路线"></select>
                </label>
                <div class="cloud-ops-test-map-route-meta">
                  <span class="cloud-ops-test-map-route-legend"><i aria-hidden="true"></i>路线</span>
                  <small data-role="map-route-status">正在读取路线...</small>
                </div>
              </div>
              <div class="cloud-ops-test-media-grid" data-role="tool-media-grid"></div>
            </section>
          </section>
        </div>
      </section>

      <dialog class="cloud-ops-test-media-viewer" data-role="media-viewer" aria-labelledby="cloud-ops-test-media-viewer-title">
        <div class="cloud-ops-test-media-viewer-shell">
          <div class="cloud-ops-test-media-viewer-head">
            <strong id="cloud-ops-test-media-viewer-title" data-role="media-viewer-title">原图预览</strong>
            <button type="button" data-action="media-viewer-close" aria-label="关闭原图预览" title="关闭">&times;</button>
          </div>
          <figure>
            <img data-role="media-viewer-image" alt="" />
            <figcaption data-role="media-viewer-meta"></figcaption>
          </figure>
        </div>
      </dialog>

      <section id="cloud-ops-test-params" class="cloud-ops-test-page" data-active="false">
        <div class="cloud-ops-test-page-head cloud-ops-param-page-head">
          <div>
            <p class="cloud-ops-test-kicker">PARAMETER CENTER</p>
            <h2>车辆参数中心</h2>
          </div>
          <div class="cloud-ops-param-safety-note"><strong>只读模式</strong></div>
        </div>

        <div class="cloud-ops-param-context" aria-label="参数上下文">
          <div><span>当前车辆</span><strong data-role="param-vehicle">--</strong></div>
          <div><span>参数读取</span><strong>未开放</strong></div>
          <div><span>配置版本</span><strong>未读取</strong></div>
          <div><span>草稿变更</span><strong><b data-role="param-changed-count">0</b> 项</strong></div>
          <button type="button" disabled>读取当前参数</button>
        </div>

        <div class="cloud-ops-param-layout">
          <nav class="cloud-ops-param-nav" aria-label="参数节点分类">
