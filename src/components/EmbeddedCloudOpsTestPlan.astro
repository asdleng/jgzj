        if (metaText) {
          const meta = document.createElement("small");
          meta.textContent = metaText;
          caption.appendChild(meta);
        }
        card.appendChild(caption);
        toolMediaGrid.appendChild(card);
      });
      if (toolMediaCount) toolMediaCount.textContent = `${items.length} 项`;
      toolMedia.hidden = false;
      if (mediaViewer?.open && activeViewerFollowLabel) {
        const nextViewerItem = items.find((item) => item.label === activeViewerFollowLabel && item.kind === "image");
        if (nextViewerItem && mediaViewerImage) {
          mediaViewerImage.src = nextViewerItem.src;
          if (mediaViewerMeta) mediaViewerMeta.textContent = mediaMetaText(nextViewerItem);
        }
      }
      return items.length;
    };
    const formatMonitorTime = (timestamp) => new Date(timestamp).toLocaleTimeString("zh-CN", {
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
      hour12: false
    });
    const updateLiveMonitorUi = (message = "单次抓拍") => {
      shell.classList.toggle("is-live-monitoring", liveMonitorRunning);
      if (liveMonitorToggle) {
