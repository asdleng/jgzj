      heights.sort((a, b) => a - b);
      const lowZ = heights[Math.floor((heights.length - 1) * 0.05)] ?? -2;
      const highZ = heights[Math.floor((heights.length - 1) * 0.95)] ?? 2;
      const zSpan = Math.max(0.2, highZ - lowZ);
      const size = 900;
      const canvas = document.createElement("canvas");
      canvas.width = size;
      canvas.height = size;
      const context = canvas.getContext("2d");
      if (!context) throw new Error("浏览器无法创建点云画布");

      const plotLeft = 52;
      const plotTop = 82;
      const plotSize = size - 126;
      const centerX = plotLeft + plotSize / 2;
