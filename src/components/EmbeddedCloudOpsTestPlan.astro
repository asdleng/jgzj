        "rgba(14, 165, 233, 0.46)",
        "rgba(34, 211, 238, 0.56)",
        "rgba(45, 212, 191, 0.62)",
        "rgba(163, 230, 53, 0.7)",
        "rgba(250, 204, 21, 0.76)",
        "rgba(251, 146, 60, 0.82)",
        "rgba(248, 113, 113, 0.88)"
      ];
      const buckets = Array.from({ length: palette.length }, () => []);
      points.forEach((point) => {
        const heightRatio = Math.max(0, Math.min(0.999, (point.z - lowZ) / zSpan));
