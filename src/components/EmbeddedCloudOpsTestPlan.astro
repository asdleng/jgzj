    const renderObstaclePointCloudPayload = async (pointCloudPayload, obstaclePayload, rangeM = 25) => {
      const lidarResult = toolResultOfPayload(pointCloudPayload) || {};
      const obstacleResult = toolResultOfPayload(obstaclePayload) || {};
      const pointcloud = lidarResult?.pointcloud || {};
      const buffer = await inflatePointCloudBuffer(pointcloud);
      const declaredPointCount = Number(pointcloud?.point_count || lidarResult?.point_count || 0);
      const pointCount = Math.min(declaredPointCount, Math.floor(buffer.byteLength / 12));
      if (!pointCount) throw new Error("当前点云帧没有有效 XYZ 点");

