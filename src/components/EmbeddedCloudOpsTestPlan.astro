        [
          result?.points,
          result?.route_points,
          result?.path_points,
          result?.sampled_points,
          result?.sample_points,
          result?.poses,
          result?.trajectory,
          Array.isArray(result?.path) ? result.path : null,
          result?.route?.points,
          result?.route?.sampled_points,
          result?.route?.path,
          result?.data?.points,
          result?.detail?.points
        ].forEach((candidate) => {
