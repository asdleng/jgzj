        result?.current_route_id,
        result?.active_route_id,
        result?.selected_route_id,
        result?.current_path_id,
        result?.current_path,
        result?.summary?.current_route_id,
        result?.summary?.active_route_id,
        result?.summary?.current_path_string_ids?.[0],
        result?.routing?.current_route_id,
        result?.routing?.active_route_id,
        result?.current_route?.route_id,
