        paramValidation.classList.toggle("is-warn", unresolved.length > 0);
        if (strong) strong.textContent = unresolved.length ? "存在待确认项" : (changes.length ? "草稿校验通过" : "当前状态");
        if (span) span.textContent = unresolved.length ? `${unresolved.length} 项缺少后端单位或安全范围，仅可保存本地草稿` : (changes.length ? "可保存本地草稿；真实应用仍被禁用" : "没有草稿变更");
      }
    };
    const resetParamDraft = (notify = true) => {
      paramDraftInputs.forEach((input) => {
