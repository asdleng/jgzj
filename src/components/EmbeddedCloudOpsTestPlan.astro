---
const fleetStats = [
  { key: "online", label: "在线车辆", value: "--", note: "last_seen 5 分钟内" },
  { key: "tool", label: "工具可用", value: "--", note: "按 tool_count 判断" },
  { key: "stale", label: "遥测过期", value: "--", note: "按 last_seen 粗略判断" },
  { key: "stop", label: "停车故障", value: "--", note: "疑似停车/安全阻断" }
];

const tabs = [
  { id: "overview", label: "车辆总览", eyebrow: "发现故障", desc: "真实车辆列表 + 故障入口" },
  { id: "status", label: "车辆状态检查", eyebrow: "人工确认", desc: "点击后只读检查" },
  { id: "params", label: "参数设置", eyebrow: "安全变更", desc: "当前先展示 Schema" },
  { id: "map", label: "地图管理", eyebrow: "地图路径", desc: "只展示入口和状态" },
  { id: "agent", label: "智能体运维", eyebrow: "长期运营", desc: "事件队列原型" }
];

const readOnlyToolGroups = [
  {
    title: "核心诊断",
    tools: [
      { label: "关键节点", tool: "status.key_nodes", desc: "自动驾驶关键节点在线状态", timeout: 35 },
      { label: "一键健康检查", tool: "health.autodrive_check", desc: "定位/规划/底盘综合只读检查", timeout: 35 },
      { label: "单车详情", tool: "vehicle_detail", desc: "读取云端车辆详情和遥测快照", action: "vehicle_detail" },
      { label: "工具列表", tool: "tool_list", desc: "查看当前车辆 auto_ad_ai 工具能力", action: "tool_list", timeout: 35 },
      { label: "健康快照", tool: "health.snapshot", desc: "车端资源、ROS、主控状态快照", timeout: 30 },
      { label: "云端连通", tool: "network.cloud_probe", desc: "车端到云端链路检查", timeout: 30 },
      { label: "主控探测", tool: "network.master_probe", desc: "media 到主控网络/SSH 探测", args: { include_ssh: true }, timeout: 25 },
      { label: "ROS 总览", tool: "ros.overview", desc: "ROS 节点、topic、service 概览", timeout: 30 },
      { label: "系统快照", tool: "system.snapshot", desc: "CPU/内存/磁盘/温度和进程", args: { include_processes: true }, timeout: 30 },
      { label: "整车快照", tool: "vehicle.snapshot", desc: "车辆运行状态和 topic 样本", args: { include_topic_samples: true }, timeout: 25 }
    ]
  },
  {
    title: "感知 / 定位 / 规划",
    tools: [
      { label: "相机状态", tool: "status.camera", desc: "相机在线、频率和图像链路", args: { include_rate: true, sample_seconds: 1.0 }, timeout: 30 },
      { label: "上传链路", tool: "camera.upload_chain", desc: "相机上传链路状态", timeout: 35 },
      { label: "AI检测配置", tool: "ai_detection.config", desc: "AI 检测开关和模型配置", timeout: 30 },
      { label: "AI检测图片", tool: "ai_detection.images", desc: "最近检测图片列表", args: { limit: 6 }, timeout: 35 },
      { label: "地图查看", tool: "map.preview", desc: "当前地图预览图", args: { image_size: 1024, include_base64: true }, timeout: 40 },
      { label: "定位状态", tool: "status.localization", desc: "location_topic_、NDT、融合状态", timeout: 30 },
      { label: "底盘 CAN", tool: "status.can", desc: "速度、档位、底盘反馈", timeout: 30 },
      { label: "车身状态", tool: "status.body_control", desc: "灯光、广告屏反馈状态", timeout: 30 },
      { label: "规划状态", tool: "status.planning", desc: "planning 输出和阻塞状态", timeout: 30 },
      { label: "Routing 状态", tool: "status.routing", desc: "route/task 是否正常", timeout: 30 },
      { label: "障碍处理", tool: "status.obstacle_processor", desc: "障碍物处理链路", timeout: 30 },
      { label: "障碍俯视图", tool: "obstacle.preview", desc: "融合障碍物俯视预览", args: { topic: "/fusion/objects", range_m: 15, image_size: 768, save_file: true, include_base64: true }, timeout: 40 },
      { label: "路线列表", tool: "route.list", desc: "车端可用巡逻路线", timeout: 30 }
    ]
  }
];

const blockedActionGroups = [
  {
    title: "控制 / 重启",
    actions: [
      ["重启主控接口", "controller.reboot_master", "高风险：会中断主控 auto_ad_ai 接口"],
      ["重启 Media 接口", "controller.reboot_media", "高风险：会中断 media auto_ad_ai 接口"],
      ["碰撞停复位", "vehicle.clear_collision_stop", "需要现场安全确认"],
      ["广告屏/灯光控制", "vehicle.body_control", "测试页先不绑定执行"]
    ]
  },
  {
    title: "任务 / 地图 / 参数写入",
    actions: [
      ["启动巡逻", "route.start_patrol", "任务重发必须人工确认后单独接"],
      ["地图插件启动", "map_editor.start", "地图编辑会打开车端插件，当前禁用"],
      ["地图插件关闭", "map_editor.stop", "当前禁用"],
      ["参数写入", "param.write", "必须有白名单、差异预览、回滚和审计"]
    ]
  }
];

const paramSchemas = [
  ["定位", "ndt_score_threshold", "3.5", "NDT 接受阈值；高风险，当前测试页不写入。"],
  ["定位", "relocalization4.topk_L3", "160", "重定位候选数量；影响恢复速度和误匹配风险。"],
  ["规划", "max_speed", "按车辆配置", "速度上限；必须停车或安全状态下修改。"],
  ["控制", "collision_stop_reset", "人工确认", "碰撞停恢复；需要现场安全确认。"],
  ["感知", "camera_rate_min_hz", "按车型", "相机频率下限；只读监测优先。"]
];

const agentRules = [
  ["自动驾驶停止", "任务中 60 秒无有效位移", "触发故障诊断，不直接判具体故障"],
  ["定位不可靠", "location_topic_ reliable=false", "进入定位故障树"],
  ["规划阻塞", "planning/routing 无有效输出", "检查上游定位和任务"],
  ["通信异常", "车辆 last_seen 过期", "先查云端/主控链路"]
];
---

<section class="cloud-ops-test-shell" data-cloud-ops-test>
  <div class="cloud-ops-test-topbar">
    <div>
      <p class="cloud-ops-test-kicker">CLOUD OPS TEST · READ ONLY FIRST</p>
      <h1>云端智能运维(测试)</h1>
      <p>
        当前版本已接入真实车辆列表。页面加载只读取云端车辆注册列表，不自动执行任何车端工具；所有车端检查都必须由用户点击按钮触发，且测试页第一版只接只读检查。
      </p>
    </div>
    <a class="cloud-ops-test-doc" href="https://my.feishu.cn/docx/JFmYdxCvioqT2kxlIXocqMInnbh" target="_blank" rel="noreferrer">
      查看方案文档
    </a>
  </div>

  <div class="cloud-ops-test-safety-band">
    <strong>安全边界</strong>
    <span>自动加载：只调用 <code>/api/cloud-ops/vehicles-lite</code> 读取云端车辆注册列表</span>
    <span>不会自动调用：<code>/api/cloud-ops/execute</code>、tool-list、vehicle_detail</span>
    <span>点击执行：只读工具调用</span>
    <span>禁用：重启、写参数、任务重发、灯光/车身控制</span>
  </div>

  <div class="cloud-ops-test-global-controls">
    <button class="cloud-ops-test-command-button is-primary" type="button" data-action="refresh-vehicles">刷新车辆列表</button>
    <label class="cloud-ops-test-select-field">
      当前车辆
      <select data-role="vehicle-select">
        <option value="">加载车辆中...</option>
      </select>
    </label>
    <div class="cloud-ops-test-selected-strip">
      <span>已选车辆</span>
      <strong data-role="selected-vehicle-title">--</strong>
      <small>切换车辆只更新页面上下文，不会自动执行任何车端工具。</small>
    </div>
    <p class="cloud-ops-test-status" data-role="status">只读初始化中...</p>
  </div>

  <div class="cloud-ops-test-stats">
    {fleetStats.map((item) => (
      <article class="cloud-ops-test-stat" data-stat={item.key}>
        <span>{item.label}</span>
        <strong>{item.value}</strong>
        <p>{item.note}</p>
      </article>
    ))}
  </div>

  <div class="cloud-ops-test-layout">
    <nav class="cloud-ops-test-tabs" aria-label="云端智能运维测试子页面">
      {tabs.map((tab, index) => (
        <button type="button" class:list={{ "is-active": index === 0 }} data-target={`cloud-ops-test-${tab.id}`}>
          <span class="cloud-ops-tab-light" aria-hidden="true"></span>
          <span class="cloud-ops-tab-index">{String(index + 1).padStart(2, "0")}</span>
          <span class="cloud-ops-tab-copy">
            <span>{tab.eyebrow}</span>
            <strong>{tab.label}</strong>
            <small>{tab.desc}</small>
          </span>
          <span class="cloud-ops-tab-scan" aria-hidden="true"></span>
        </button>
      ))}
    </nav>

    <div class="cloud-ops-test-pages">
      <section id="cloud-ops-test-overview" class="cloud-ops-test-page" data-active="true">
        <div class="cloud-ops-test-page-head">
          <p class="cloud-ops-test-kicker">FLEET OVERVIEW</p>
          <h2>车辆总览：先看真实在线车辆，再进入故障判断</h2>
          <p>车辆列表来自真实云端接口。故障判断目前先做页面端粗略归类，后续再迁移成后端 fleet fault aggregator。</p>
        </div>

        <div class="cloud-ops-test-workbench cloud-ops-test-workbench--overview">
          <section class="cloud-ops-test-panel cloud-ops-test-panel--wide">
            <div class="cloud-ops-test-panel-head">
              <h3>真实车辆列表</h3>
              <span data-role="vehicle-count">--</span>
            </div>
            <div class="cloud-ops-test-api-strip">
              <span>接口 <strong data-role="interface-source">--</strong></span>
              <span>刷新 <strong data-role="last-refresh">--</strong></span>
              <span data-role="api-note">只读车辆注册表</span>
            </div>
            <div class="cloud-ops-test-vehicle-list" data-role="vehicle-list">
              <p class="cloud-ops-test-empty">等待车辆列表...</p>
            </div>
          </section>

          <section class="cloud-ops-test-panel">
            <div class="cloud-ops-test-panel-head">
              <h3>选中车辆摘要</h3>
              <span data-role="selected-vehicle-chip">未选择</span>
            </div>
            <dl class="cloud-ops-test-kv" data-role="vehicle-summary">
              <div><dt>车辆</dt><dd>--</dd></div>
              <div><dt>工具数</dt><dd>--</dd></div>
              <div><dt>最近在线</dt><dd>--</dd></div>
              <div><dt>状态判断</dt><dd>--</dd></div>
            </dl>
          </section>
        </div>

        <section class="cloud-ops-test-stop-monitor">
          <div class="cloud-ops-test-panel-head">
            <div>
              <h3>自动驾驶停止故障监控</h3>
              <p>先用真实缓存做入口预判；最终故障必须接任务状态和 60 秒位移历史后确认。</p>
            </div>
            <span data-role="stop-fault-count">--</span>
          </div>
          <div class="cloud-ops-test-stop-grid" data-role="stop-fault-list">
            <p class="cloud-ops-test-empty">等待车辆停止故障判断...</p>
          </div>
        </section>

        <div class="cloud-ops-test-table-shell cloud-ops-test-table-shell--fleet">
          <table class="cloud-ops-test-table cloud-ops-test-fleet-table">
            <thead>
              <tr>
                <th>车辆</th>
                <th>自动驾驶停止</th>
                <th>真实身份</th>
                <th>车端链路</th>
                <th>主控/ROS</th>
                <th>资源</th>
                <th>最近状态</th>
              </tr>
            </thead>
            <tbody data-role="vehicle-table-body">
              <tr><td colspan="7">等待真实车辆信息...</td></tr>
            </tbody>
          </table>
        </div>

        <div class="cloud-ops-test-table-shell">
          <table class="cloud-ops-test-table">
            <thead><tr><th>事件入口</th><th>真实数据来源</th><th>当前页面处理</th></tr></thead>
            <tbody>
              <tr><td>车辆离线/遥测过期</td><td>云端车辆列表 last_seen</td><td>页面端标记“遥测过期”，后续进入通信故障诊断。</td></tr>
              <tr><td>自动驾驶停止</td><td>需要任务状态 + 位移历史</td><td>当前仅展示诊断入口，后续接 fleet aggregator。</td></tr>
              <tr><td>定位不可靠</td><td>status.localization 点击后返回</td><td>用户点击后读真实结果，不自动查车。</td></tr>
            </tbody>
          </table>
        </div>
      </section>

      <section id="cloud-ops-test-status" class="cloud-ops-test-page" data-active="false">
        <div class="cloud-ops-test-page-head">
          <p class="cloud-ops-test-kicker">READ ONLY TOOLS</p>
          <h2>车辆状态检查：按老版云端运维整理按钮，点击后才查车</h2>
          <p>只读检查按钮已经接到真实接口；控制、重启、写参数、任务重发先展示但禁用。</p>
        </div>

        {readOnlyToolGroups.map((group) => (
          <section class="cloud-ops-test-tool-group">
            <div class="cloud-ops-test-tool-group-head">
              <h3>{group.title}</h3>
              <span>点击执行只读接口</span>
            </div>
            <div class="cloud-ops-test-command-grid">
              {group.tools.map((item) => (
                <button
                  class="cloud-ops-test-command-button"
                  type="button"
                  data-action="readonly-tool"
                  data-tool={item.tool}
                  data-tool-action={"action" in item ? item.action : "tool_call"}
                  data-tool-args={JSON.stringify("args" in item ? item.args : {})}
                  data-timeout-s={String("timeout" in item ? item.timeout : 30)}
                >
                  <strong>{item.label}</strong>
                  <span>{item.tool}</span>
                  <small>{item.desc}</small>
                </button>
              ))}
            </div>
          </section>
        ))}

        {blockedActionGroups.map((group) => (
          <section class="cloud-ops-test-tool-group is-disabled">
            <div class="cloud-ops-test-tool-group-head">
              <h3>{group.title}</h3>
              <span>当前只做界面，不绑定执行</span>
            </div>
            <div class="cloud-ops-test-command-grid">
              {group.actions.map(([label, tool, desc]) => (
                <button class="cloud-ops-test-command-button is-disabled" type="button" disabled>
                  <strong>{label}</strong>
                  <span>{tool}</span>
                  <small>{desc}</small>
                </button>
              ))}
            </div>
          </section>
        ))}

        <section class="cloud-ops-test-panel cloud-ops-test-panel--result">
          <div class="cloud-ops-test-panel-head">
            <h3>真实检查结果</h3>
            <span data-role="last-tool-label">等待点击</span>
          </div>
          <pre class="cloud-ops-test-json" data-role="tool-result">选择车辆后点击上方只读工具，这里显示真实返回。</pre>
        </section>
      </section>

      <section id="cloud-ops-test-params" class="cloud-ops-test-page" data-active="false">
        <div class="cloud-ops-test-page-head">
          <p class="cloud-ops-test-kicker">PARAMETER SCHEMA</p>
          <h2>参数设置：当前只展示 Schema，不写入车辆</h2>
          <p>这里先验证参数分类、默认值、风险提示和回滚闭环。真实写入必须另做白名单、确认和审计。</p>
        </div>
        <div class="cloud-ops-test-table-shell">
          <table class="cloud-ops-test-table">
            <thead><tr><th>域</th><th>参数名</th><th>默认/当前</th><th>含义和风险</th></tr></thead>
            <tbody>{paramSchemas.map((row) => <tr>{row.map((cell) => <td>{cell}</td>)}</tr>)}</tbody>
          </table>
        </div>
        <div class="cloud-ops-test-disabled-actions">
          <button type="button" disabled>读取当前参数（待接）</button>
          <button type="button" disabled>生成差异预览（待接）</button>
          <button type="button" disabled>写入参数（禁用）</button>
          <button type="button" disabled>回滚参数（禁用）</button>
        </div>
      </section>

      <section id="cloud-ops-test-map" class="cloud-ops-test-page" data-active="false">
        <div class="cloud-ops-test-page-head">
          <p class="cloud-ops-test-kicker">MAP MANAGEMENT</p>
          <h2>地图管理：当前不自动启动地图编辑器</h2>
          <p>现有真实地图编辑器入口仍在“地图管理”页面。本测试页只展示未来合并后的操作面板，不自动调用 map_editor.start。</p>
        </div>
        <div class="cloud-ops-test-card-grid">
          <article class="cloud-ops-test-card"><h3>车端插件桥接</h3><p>map_editor.start / status / stop / http</p></article>
          <article class="cloud-ops-test-card"><h3>边界路径</h3><p>运营边界、禁行区、巡逻路径、检查点、停车点。</p></article>
          <article class="cloud-ops-test-card"><h3>版本管理</h3><p>地图版本、车辆使用版本、发布记录、回滚点。</p></article>
        </div>
        <div class="cloud-ops-test-disabled-actions">
          <button type="button" disabled>启动并打开插件（禁用）</button>
          <button type="button" disabled>检查插件状态（待接只读）</button>
          <button type="button" disabled>关闭插件（禁用）</button>
        </div>
      </section>

      <section id="cloud-ops-test-agent" class="cloud-ops-test-page" data-active="false">
        <div class="cloud-ops-test-page-head">
          <p class="cloud-ops-test-kicker">AGENT OPS</p>
          <h2>智能体运维：先展示规则和事件，执行动作必须人工确认</h2>
          <p>智能体可以自动做只读检查；写参数、重启、任务重发必须人工确认。</p>
        </div>
        <div class="cloud-ops-test-table-shell">
          <table class="cloud-ops-test-table">
            <thead><tr><th>规则</th><th>触发条件</th><th>处理边界</th></tr></thead>
            <tbody>{agentRules.map((row) => <tr>{row.map((cell) => <td>{cell}</td>)}</tr>)}</tbody>
          </table>
        </div>
        <section class="cloud-ops-test-panel cloud-ops-test-panel--result">
          <div class="cloud-ops-test-panel-head"><h3>页面安全审计</h3><span>当前版本</span></div>
          <pre class="cloud-ops-test-json">自动调用清单：/api/cloud-ops/vehicles-lite\n禁止自动调用：/api/cloud-ops/execute、tool-list、vehicle_detail\n只读工具调用：必须点击按钮\n控制类动作：未绑定执行</pre>
        </section>
      </section>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const shell = document.querySelector("[data-cloud-ops-test]");
    if (!shell) return;

    const VEHICLES_URL = "/api/cloud-ops/vehicles-lite";
    const EXECUTE_URL = "/api/cloud-ops/execute";
    const READONLY_TOOL_ALLOWLIST = new Set([
      "status.key_nodes",
      "health.autodrive_check",
      "tool_list",
      "vehicle_detail",
      "health.snapshot",
      "network.cloud_probe",
      "network.master_probe",
      "status.localization",
      "status.planning",
      "status.routing",
      "status.can",
      "status.body_control",
      "status.camera",
      "status.obstacle_processor",
      "ros.overview",
      "system.snapshot",
      "vehicle.snapshot",
      "camera.upload_chain",
      "ai_detection.config",
      "ai_detection.images",
      "map.preview",
      "obstacle.preview",
      "route.list"
    ]);

    const tabs = [...shell.querySelectorAll(".cloud-ops-test-tabs button")];
    const pages = [...shell.querySelectorAll(".cloud-ops-test-page")];
    const statusNode = shell.querySelector('[data-role="status"]');
    const vehicleSelect = shell.querySelector('[data-role="vehicle-select"]');
    const vehicleList = shell.querySelector('[data-role="vehicle-list"]');
    const vehicleCount = shell.querySelector('[data-role="vehicle-count"]');
    const vehicleTableBody = shell.querySelector('[data-role="vehicle-table-body"]');
    const stopFaultCount = shell.querySelector('[data-role="stop-fault-count"]');
    const stopFaultList = shell.querySelector('[data-role="stop-fault-list"]');
    const selectedVehicleChip = shell.querySelector('[data-role="selected-vehicle-chip"]');
    const selectedVehicleTitle = shell.querySelector('[data-role="selected-vehicle-title"]');
    const vehicleSummary = shell.querySelector('[data-role="vehicle-summary"]');
    const toolResult = shell.querySelector('[data-role="tool-result"]');
    const lastToolLabel = shell.querySelector('[data-role="last-tool-label"]');
    const interfaceSource = shell.querySelector('[data-role="interface-source"]');
    const lastRefresh = shell.querySelector('[data-role="last-refresh"]');
    const apiNote = shell.querySelector('[data-role="api-note"]');
    let vehicles = [];
    let currentVehicleId = "";

    const setStatus = (text, state = "idle") => {
      if (!statusNode) return;
      statusNode.textContent = text;
      statusNode.dataset.state = state;
    };

    const setActive = (targetId) => {
      tabs.forEach((tab) => tab.classList.toggle("is-active", tab.dataset.target === targetId));
      pages.forEach((page) => {
        page.dataset.active = page.id === targetId ? "true" : "false";
      });
    };

    const vehicleIdOf = (vehicle) => String(vehicle?.vehicle_id || vehicle?.plate_number || vehicle?.id || "").trim();
    const lastSeenOf = (vehicle) => String(vehicle?.last_seen || vehicle?.last_seen_at || vehicle?.updated_at || "").trim();
    const toolCountOf = (vehicle) => Number(vehicle?.tool_count || vehicle?.tools_count || 0) || 0;
    const selectedVehicleId = () => String(currentVehicleId || vehicleSelect?.value || "").trim();
    const displayValue = (value, fallback = "--") => {
      if (value === null || value === undefined || value === "") return fallback;
      return String(value);
    };
    const finiteNumber = (value) => {
      if (value === null || value === undefined || value === "") return NaN;
      const num = Number(value);
      return Number.isFinite(num) ? num : NaN;
    };
    const boolText = (value, trueText = "是", falseText = "否", unknownText = "未知") => {
      if (value === true) return trueText;
      if (value === false) return falseText;
      return unknownText;
    };
    const percentText = (value) => {
      const num = finiteNumber(value);
      if (!Number.isFinite(num)) return "--";
      return `${num.toFixed(num >= 10 ? 0 : 1)}%`;
    };
    const numberText = (value, digits = 1) => {
      const num = finiteNumber(value);
      if (!Number.isFinite(num)) return "--";
      return num.toFixed(digits);
    };
    const msText = (value) => {
      const num = finiteNumber(value);
      if (!Number.isFinite(num)) return "--";
      return `${num.toFixed(num >= 10 ? 0 : 1)} ms`;
    };
    const formatAge = (iso) => {
      const ts = Date.parse(iso || "");
      if (!Number.isFinite(ts)) return "未知";
      const diff = Math.max(0, Date.now() - ts);
      const min = Math.round(diff / 60000);
      if (min < 1) return "刚刚";
      if (min < 60) return `${min} 分钟前`;
      const hr = Math.round(min / 60);
      if (hr < 48) return `${hr} 小时前`;
      return `${Math.round(hr / 24)} 天前`;
    };
    const isStale = (vehicle) => {
      const ts = Date.parse(lastSeenOf(vehicle));
      return !Number.isFinite(ts) || Date.now() - ts > 5 * 60 * 1000;
    };
    const vehicleHealthOf = (vehicle) => {
      if (isStale(vehicle)) return { label: "遥测过期", tone: "warn" };
      if (vehicle?.master_ping_ok === false) return { label: "主控不可达", tone: "danger" };
      if (!vehicle?.has_heartbeat) return { label: "无心跳", tone: "warn" };
      if (!vehicle?.has_telemetry) return { label: "无telemetry", tone: "warn" };
      return { label: "在线", tone: "ok" };
    };
    const stopDiagnosisOf = (vehicle) => {
      if (isStale(vehicle)) {
        return {
          label: "通信过期",
          tone: "warn",
          reason: "last_seen 已过期，不能判断自动驾驶停止。",
          next: "先查云端连接和车端 auto_ad_ai 心跳。"
        };
      }
      if (vehicle?.master_ping_ok === false || vehicle?.telemetry_master_ros_ok === false) {
        return {
          label: "主控链路异常",
          tone: "danger",
          reason: "media 到主控或 ROS 不可达，自动驾驶状态不可确认。",
          next: "先查主控网络、ROS master、关键节点。"
        };
      }
      if (vehicle?.emergency_stop_pressed === true) {
        return {
          label: "阻断：急停",
          tone: "danger",
          reason: "急停已触发，车辆停止是安全阻断。",
          next: "进入控制/底盘故障诊断，现场确认后处理。"
        };
      }
      if (vehicle?.collision_stop === true) {
        return {
          label: "阻断：碰撞停",
          tone: "danger",
          reason: "碰撞停已触发，车辆停止是安全阻断。",
          next: "进入感知/底盘安全链路诊断。"
        };
      }
      if (vehicle?.localization_reliable === false) {
        return {
          label: "阻断：定位不可靠",
          tone: "danger",
          reason: "location_topic_ 不可靠，自动驾驶应停止。",
          next: "进入定位故障树，区分组合导航模式和纯 LiDAR NDT。"
        };
      }
      if (vehicle?.trajectory_estop === true) {
        return {
          label: "阻断：规划estop",
          tone: "danger",
          reason: "planning trajectory estop=true。",
          next: "进入规划/障碍物故障诊断。"
        };
      }
      const speedKph = finiteNumber(vehicle?.speed_kph);
      const locSpeedMps = finiteNumber(vehicle?.localization_speed_mps);
      const targetSpeed = finiteNumber(vehicle?.control_target_speed);
      const runningMode = finiteNumber(vehicle?.running_mode);
      const plannerState = String(vehicle?.planner_state || "").trim().toLowerCase();
      const plannerRunning = finiteNumber(vehicle?.planner_running);
      const vehicleIdleStatus = finiteNumber(vehicle?.vehicle_idle_status);
      const longTimeStop = vehicle?.long_time_stop === true;
      const totalLoop = finiteNumber(vehicle?.total_loop_sum);
      const currentLoop = finiteNumber(vehicle?.current_loop_index);
      const totalRefline = finiteNumber(vehicle?.total_refline_sum);
      const currentRefline = finiteNumber(vehicle?.current_refline_index);
      const trajectoryPointCount = finiteNumber(vehicle?.trajectory_point_count);
      const trajectoryLength = finiteNumber(vehicle?.trajectory_total_length);
      const currentPathCount = finiteNumber(vehicle?.current_path_count);
      const stopped = Number.isFinite(speedKph)
        ? speedKph < 0.2
        : Number.isFinite(locSpeedMps) && Math.abs(locSpeedMps) < 0.05;
      const routeProgress = Number.isFinite(totalLoop) && Number.isFinite(currentLoop) &&
        Number.isFinite(totalRefline) && Number.isFinite(currentRefline) &&
        totalLoop > 0 && totalRefline > 0 && currentLoop >= 0 && currentRefline >= 0;
      const hasTrajectory = Number.isFinite(trajectoryPointCount) && trajectoryPointCount > 0 &&
        Number.isFinite(trajectoryLength) && trajectoryLength > 0;
      const plannerActive = plannerState === "running" || (Number.isFinite(plannerRunning) && plannerRunning > 0);
      const taskEvidence = plannerActive ||
        (Number.isFinite(currentPathCount) && currentPathCount > 0) ||
        routeProgress ||
        hasTrajectory ||
        (Number.isFinite(vehicleIdleStatus) && vehicleIdleStatus === 0);
      if (taskEvidence && !stopped) {
        return {
          label: "运行中",
          tone: "ok",
          reason: `有任务/规划证据，当前速度 ${numberText(speedKph)} km/h。`,
          next: "未发现停止入口。"
        };
      }
      if (stopped && taskEvidence) {
        return {
          label: "疑似停车故障",
          tone: "warn",
          reason: `有任务/规划证据但车速接近 0，当前速度 ${numberText(speedKph)} km/h，planner=${displayValue(vehicle?.planner_running, plannerState || "--")}。`,
          next: "还缺任务状态和 60 秒位移历史；接 fleet aggregator 后才能确认“自动驾驶停止故障”。"
        };
      }
      if (stopped) {
        return {
          label: "停止待确认",
          tone: "neutral",
          reason: `当前速度 ${numberText(speedKph)} km/h，但未看到任务运行证据；mode=${displayValue(runningMode)}，target=${numberText(targetSpeed)} m/s。`,
          next: "需要接任务计划/任务进度后区分正常等待、任务完成、异常停车。"
        };
      }
      if (Number.isFinite(speedKph) && speedKph >= 0.2) {
        return {
          label: "运行中",
          tone: "ok",
          reason: `当前速度 ${numberText(speedKph)} km/h，未触发停止入口。`,
          next: "未发现停止入口。"
        };
      }
      if (Number.isFinite(targetSpeed) && targetSpeed > 0.2 && longTimeStop) {
        return {
          label: "疑似控制未动",
          tone: "warn",
          reason: `long_time_stop=true 且控制目标速度 ${numberText(targetSpeed)} m/s。`,
          next: "需要结合 60 秒位移历史确认，再查控制/底盘链路。"
        };
      }
      return {
        label: "不可判定",
        tone: "neutral",
        reason: `running_mode=${displayValue(vehicle?.running_mode)}，当前缓存缺任务执行状态。`,
        next: "需接任务状态、路线进度和位移历史。"
      };
    };
    const renderPill = (label, tone = "neutral") => (
      `<span class="cloud-ops-test-pill is-${escapeHtml(tone)}">${escapeHtml(label)}</span>`
    );
    const escapeHtml = (value) => String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;");
    const parseJsonDataset = (value, fallback = {}) => {
      const text = String(value || "").trim();
      if (!text) return fallback;
      try {
        return JSON.parse(text);
      } catch (_error) {
        return fallback;
      }
    };
    const setStat = (key, value, note, tone = "") => {
      const card = shell.querySelector(`[data-stat="${key}"]`);
      if (!card) return;
      const strong = card.querySelector("strong");
      const p = card.querySelector("p");
      if (strong) strong.textContent = String(value);
      if (note && p) p.textContent = note;
      card.classList.remove("is-ok", "is-warn", "is-danger");
      if (tone) card.classList.add(`is-${tone}`);
    };

    const selectedVehicle = () => {
      const id = selectedVehicleId();
      return vehicles.find((vehicle) => vehicleIdOf(vehicle) === id) || null;
    };

    const syncSelectedVehicleUi = () => {
      if (vehicleSelect && selectedVehicleId() && vehicleSelect.value !== selectedVehicleId()) {
        vehicleSelect.value = selectedVehicleId();
      }
      shell.querySelectorAll("[data-vehicle-id]").forEach((button) => {
        button.classList.toggle("is-selected", button.dataset.vehicleId === selectedVehicleId());
      });
      shell.querySelectorAll("[data-vehicle-row-id]").forEach((row) => {
        row.classList.toggle("is-selected", row.dataset.vehicleRowId === selectedVehicleId());
      });
      if (selectedVehicleTitle) selectedVehicleTitle.textContent = selectedVehicleId() || "--";
    };

    const setSelectedVehicle = (vehicleId, options = {}) => {
      const normalized = String(vehicleId || "").trim();
      currentVehicleId = vehicles.some((vehicle) => vehicleIdOf(vehicle) === normalized)
        ? normalized
        : vehicleIdOf(vehicles[0] || {});
      syncSelectedVehicleUi();
      renderSummary();
      if (options.silent !== true) {
        setStatus(`已选择 ${currentVehicleId || "车辆"}，未执行任何车端工具。`, "ok");
      }
    };

    const renderSummary = () => {
      const vehicle = selectedVehicle();
      if (selectedVehicleChip) selectedVehicleChip.textContent = vehicle ? vehicleIdOf(vehicle) : "未选择";
      if (selectedVehicleTitle) selectedVehicleTitle.textContent = vehicle ? vehicleIdOf(vehicle) : "--";
      if (!vehicleSummary) return;
      if (!vehicle) {
        vehicleSummary.innerHTML = "<div><dt>车辆</dt><dd>--</dd></div><div><dt>真实身份</dt><dd>--</dd></div><div><dt>车端链路</dt><dd>--</dd></div><div><dt>主控/ROS</dt><dd>--</dd></div><div><dt>资源</dt><dd>--</dd></div><div><dt>状态判断</dt><dd>--</dd></div>";
        return;
      }
      const vid = vehicleIdOf(vehicle);
      const health = vehicleHealthOf(vehicle);
      const stopDiag = stopDiagnosisOf(vehicle);
      vehicleSummary.innerHTML = [
        ["车辆", `${vid} / ${displayValue(vehicle?.plate_number, vid)}`],
        ["真实身份", `VIN ${displayValue(vehicle?.vin)} · ${displayValue(vehicle?.role)}`],
        ["车端链路", `${displayValue(vehicle?.hostname)} · media ${displayValue(vehicle?.local_primary_ip)} · cloud ${displayValue(vehicle?.remote)}`],
        ["主控/ROS", `主控 ${displayValue(vehicle?.master_host)} · ping ${boolText(vehicle?.master_ping_ok, "可达", "不可达")} ${msText(vehicle?.master_ping_latency_ms)} · topic/node/service ${displayValue(vehicle?.topic_count)}/${displayValue(vehicle?.node_count)}/${displayValue(vehicle?.service_count)}`],
        ["资源", `CPU ${percentText(vehicle?.cpu_percent)} · 内存 ${percentText(vehicle?.memory_percent)} · 磁盘 ${percentText(vehicle?.disk_percent)} · tools ${toolCountOf(vehicle) || "未知"}`],
        ["自动驾驶停止", `${stopDiag.label} · ${stopDiag.reason}`],
        ["下一步", stopDiag.next],
        ["最近在线", `${formatAge(lastSeenOf(vehicle))} · ${lastSeenOf(vehicle) || "无时间戳"} · msg ${displayValue(vehicle?.message_count)}`],
        ["状态判断", health.label]
      ].map(([k, v]) => `<div><dt>${escapeHtml(k)}</dt><dd>${escapeHtml(v)}</dd></div>`).join("");
    };

    const renderVehicles = () => {
      if (vehicleCount) vehicleCount.textContent = `${vehicles.length} 台`;
      if (!vehicleList) return;
      if (!vehicles.length) {
        vehicleList.innerHTML = '<p class="cloud-ops-test-empty">没有读取到车辆，或当前账号未授权。</p>';
        return;
      }
      vehicleList.innerHTML = vehicles.map((vehicle) => {
        const vid = vehicleIdOf(vehicle);
        const health = vehicleHealthOf(vehicle);
        const stopDiag = stopDiagnosisOf(vehicle);
        const toolCount = toolCountOf(vehicle);
        const host = vehicle?.hostname || vehicle?.host || "";
        const selected = vid === selectedVehicleId();
        const rowTone = stopDiag.tone === "danger" || stopDiag.tone === "warn" ? stopDiag.tone : health.tone;
        return `<button type="button" class="cloud-ops-test-vehicle-row is-${escapeHtml(rowTone)}${selected ? " is-selected" : ""}" data-vehicle-id="${escapeHtml(vid)}">
          <span class="cloud-ops-test-severity">${escapeHtml(health.label)}</span>
          <strong>${escapeHtml(vid || "未知车辆")}</strong>
          <span class="cloud-ops-test-stop-inline is-${escapeHtml(stopDiag.tone)}">${escapeHtml(stopDiag.label)}</span>
          <small>
            ${escapeHtml(host || "无主机名")} · media ${escapeHtml(displayValue(vehicle?.local_primary_ip))} · master ${escapeHtml(boolText(vehicle?.master_ping_ok, "可达", "不可达"))} · speed ${escapeHtml(numberText(vehicle?.speed_kph))} km/h · mode ${escapeHtml(displayValue(vehicle?.running_mode))} · ${escapeHtml(formatAge(lastSeenOf(vehicle)))} · tools ${escapeHtml(toolCount || "?")}
            <span>${escapeHtml(stopDiag.reason)}</span>
          </small>
        </button>`;
      }).join("");
    };

    const renderVehicleTable = () => {
      if (!vehicleTableBody) return;
      if (!vehicles.length) {
        vehicleTableBody.innerHTML = '<tr><td colspan="7">没有读取到车辆，或当前账号未授权。</td></tr>';
        return;
      }
      vehicleTableBody.innerHTML = vehicles.map((vehicle) => {
        const vid = vehicleIdOf(vehicle);
        const health = vehicleHealthOf(vehicle);
        const stopDiag = stopDiagnosisOf(vehicle);
        const selected = vid === selectedVehicleId();
        const signalHtml = [
          vehicle?.has_heartbeat ? renderPill("heartbeat", "ok") : renderPill("无心跳", "warn"),
          vehicle?.has_snapshot ? renderPill("snapshot", "ok") : renderPill("无snapshot", "warn"),
          vehicle?.has_telemetry ? renderPill("telemetry", "ok") : renderPill("无telemetry", "warn")
        ].join("");
        return `<tr class="${selected ? "is-selected" : ""}" data-vehicle-row-id="${escapeHtml(vid)}">
          <td>
            <button type="button" class="cloud-ops-test-row-select" data-vehicle-id="${escapeHtml(vid)}">${escapeHtml(vid)}</button>
            <div>${renderPill(health.label, health.tone)}</div>
          </td>
          <td>
            <strong>${renderPill(stopDiag.label, stopDiag.tone)}</strong>
            <small>${escapeHtml(stopDiag.reason)}</small>
            <small>${escapeHtml(stopDiag.next)}</small>
          </td>
          <td>
            <strong>${escapeHtml(displayValue(vehicle?.plate_number, vid))}</strong>
            <small>VIN ${escapeHtml(displayValue(vehicle?.vin))}</small>
          </td>
          <td>
            <strong>${escapeHtml(displayValue(vehicle?.hostname))}</strong>
            <small>media ${escapeHtml(displayValue(vehicle?.local_primary_ip))} · remote ${escapeHtml(displayValue(vehicle?.remote))}</small>
          </td>
          <td>
            <strong>${escapeHtml(displayValue(vehicle?.master_host))} · ${escapeHtml(boolText(vehicle?.master_ping_ok, "可达", "不可达"))}</strong>
            <small>ping ${escapeHtml(msText(vehicle?.master_ping_latency_ms))} · ROS ${escapeHtml(displayValue(vehicle?.topic_count))}/${escapeHtml(displayValue(vehicle?.node_count))}/${escapeHtml(displayValue(vehicle?.service_count))}</small>
          </td>
          <td>
            <strong>CPU ${escapeHtml(percentText(vehicle?.cpu_percent))} · MEM ${escapeHtml(percentText(vehicle?.memory_percent))}</strong>
            <small>DISK ${escapeHtml(percentText(vehicle?.disk_percent))} · tools ${escapeHtml(toolCountOf(vehicle) || "未知")}</small>
          </td>
          <td>
            <strong>${escapeHtml(formatAge(lastSeenOf(vehicle)))}</strong>
            <small>${escapeHtml(lastSeenOf(vehicle) || "无时间戳")} · msg ${escapeHtml(displayValue(vehicle?.message_count))}</small>
            <div class="cloud-ops-test-signal-row">${signalHtml}</div>
          </td>
        </tr>`;
      }).join("");
    };

    const renderStopFaultMonitor = () => {
      if (!stopFaultList) return;
      const diagnosed = vehicles.map((vehicle) => ({ vehicle, diag: stopDiagnosisOf(vehicle) }));
      const actionable = diagnosed.filter((item) => item.diag.tone === "danger" || item.diag.tone === "warn");
      const pending = diagnosed.filter((item) => item.diag.label === "停止待确认");
      if (stopFaultCount) {
        stopFaultCount.textContent = `疑似/阻断 ${actionable.length} 台 · 停止待确认 ${pending.length} 台`;
      }
      const displayItems = actionable.length
        ? actionable.concat(pending.slice(0, Math.max(0, 6 - actionable.length)))
        : pending.length
          ? pending.slice(0, 6)
          : diagnosed.slice(0, 6);
      const cards = displayItems.map(({ vehicle, diag }) => {
        const vid = vehicleIdOf(vehicle);
        return `<button type="button" class="cloud-ops-test-stop-card is-${escapeHtml(diag.tone)}" data-vehicle-id="${escapeHtml(vid)}">
          <span>${escapeHtml(diag.label)}</span>
          <strong>${escapeHtml(vid || "未知车辆")}</strong>
          <small>${escapeHtml(diag.reason)}</small>
          <em>${escapeHtml(diag.next)}</em>
        </button>`;
      });
      stopFaultList.innerHTML = cards.length
        ? cards.join("")
        : '<p class="cloud-ops-test-empty">暂无车辆数据，无法判断自动驾驶停止故障。</p>';
    };

    const renderVehicleOptions = () => {
      if (!vehicleSelect) return;
      const previous = String(vehicleSelect.value || "").trim();
      vehicleSelect.innerHTML = "";
      if (!vehicles.length) {
        vehicleSelect.innerHTML = '<option value="">暂无车辆</option>';
        renderSummary();
        return;
      }
      vehicles.forEach((vehicle) => {
        const vid = vehicleIdOf(vehicle);
        const option = document.createElement("option");
        option.value = vid;
        option.textContent = `${vid}${isStale(vehicle) ? " · 待确认" : " · 在线"}`;
        vehicleSelect.appendChild(option);
      });
      if (previous && vehicles.some((vehicle) => vehicleIdOf(vehicle) === previous)) {
        currentVehicleId = previous;
      }
      if (!currentVehicleId || !vehicles.some((vehicle) => vehicleIdOf(vehicle) === currentVehicleId)) {
        currentVehicleId = vehicleIdOf(vehicles[0]);
      }
      vehicleSelect.value = currentVehicleId;
      syncSelectedVehicleUi();
      renderSummary();
    };

    const updateStats = () => {
      const withTools = vehicles.filter((vehicle) => toolCountOf(vehicle) > 0).length;
      const staleCount = vehicles.filter(isStale).length;
      const onlineCount = vehicles.length - staleCount;
      const stopDiagnoses = vehicles.map(stopDiagnosisOf);
      const stopConcernCount = stopDiagnoses.filter((diag) => diag.tone === "danger" || String(diag.label || "").startsWith("疑似")).length;
      const stopWarnCount = stopDiagnoses.filter((diag) => diag.tone === "warn").length;
      const stopPendingCount = stopDiagnoses.filter((diag) => diag.label === "停止待确认").length;
      setStat("online", onlineCount, `总计 ${vehicles.length} 台真实车辆`, onlineCount ? "ok" : "");
      setStat("tool", withTools, "tool_count > 0 的车辆", withTools ? "ok" : "");
      setStat("stale", staleCount, "last_seen 超过 5 分钟或无时间戳", staleCount ? "warn" : "ok");
      setStat("stop", `${stopConcernCount}/${stopPendingCount}`, `疑似/阻断 ${stopConcernCount} 台，停止待确认 ${stopPendingCount} 台`, stopConcernCount ? "danger" : (stopPendingCount ? "warn" : (stopWarnCount ? "warn" : "ok")));
    };

    const loadVehicles = async () => {
      setStatus("读取真实车辆列表...", "loading");
      try {
        const response = await fetch(VEHICLES_URL, { headers: { Accept: "application/json" }, cache: "no-store", credentials: "same-origin" });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok || payload?.ok === false) {
          throw new Error(payload?.detail || payload?.error || `HTTP ${response.status}`);
        }
        vehicles = Array.isArray(payload.vehicles) ? payload.vehicles : [];
        if (interfaceSource) interfaceSource.textContent = payload.source || "cloud_agent_registry";
        if (lastRefresh) lastRefresh.textContent = new Date().toLocaleTimeString("zh-CN", { hour12: false });
        if (apiNote) apiNote.textContent = payload.note || "只读车辆注册表";
        renderVehicleOptions();
        renderVehicles();
        renderStopFaultMonitor();
        renderVehicleTable();
        syncSelectedVehicleUi();
        updateStats();
        setStatus(`已读取 ${vehicles.length} 台真实车辆。未自动执行任何车端工具。`, "ok");
      } catch (error) {
        vehicles = [];
        currentVehicleId = "";
        renderVehicleOptions();
        renderVehicles();
        renderStopFaultMonitor();
        renderVehicleTable();
        updateStats();
        setStatus(`车辆列表读取失败：${error?.message || "未知错误"}`, "error");
      }
    };

    const runReadOnlyTool = async (button) => {
      const toolName = String(button?.dataset?.tool || "").trim();
      const toolAction = String(button?.dataset?.toolAction || "tool_call").trim();
      const args = parseJsonDataset(button?.dataset?.toolArgs, {});
      const timeout_s = Number.parseInt(button?.dataset?.timeoutS || "30", 10) || 30;
      const vehicle = selectedVehicle();
      const vehicleId = vehicleIdOf(vehicle);
      if (!vehicleId) {
        setStatus("请先选择车辆", "error");
        return;
      }
      if (!READONLY_TOOL_ALLOWLIST.has(toolName)) {
        setStatus(`工具 ${toolName} 未在测试页只读白名单内`, "error");
        return;
      }
      if (lastToolLabel) lastToolLabel.textContent = `${vehicleId} · ${toolName}`;
      if (toolResult) toolResult.textContent = "正在执行只读检查...";
      setStatus(`点击触发只读工具：${toolName}`, "loading");
      try {
        let payload;
        if (toolAction === "tool_list" || toolName === "tool_list") {
          const response = await fetch(`/api/cloud-ops/vehicles/${encodeURIComponent(vehicleId)}/tool-list?timeout_s=${encodeURIComponent(timeout_s)}`, { headers: { Accept: "application/json" }, credentials: "same-origin" });
          payload = await response.json().catch(() => ({}));
          if (!response.ok || payload?.ok === false) throw new Error(payload?.detail || payload?.error || `HTTP ${response.status}`);
        } else if (toolAction === "vehicle_detail" || toolName === "vehicle_detail") {
          const response = await fetch(`/api/cloud-ops/vehicles/${encodeURIComponent(vehicleId)}`, { headers: { Accept: "application/json" }, credentials: "same-origin" });
          payload = await response.json().catch(() => ({}));
          if (!response.ok || payload?.ok === false) throw new Error(payload?.detail || payload?.error || `HTTP ${response.status}`);
        } else {
          const response = await fetch(EXECUTE_URL, {
            method: "POST",
            headers: { "Content-Type": "application/json", Accept: "application/json" },
            credentials: "same-origin",
            body: JSON.stringify({
              action: "tool_call",
              vehicle_id: vehicleId,
              tool_name: toolName,
              args,
              timeout_s,
              request_id: `cloud-ops-test-readonly-${Date.now()}`
            })
          });
          payload = await response.json().catch(() => ({}));
          if (!response.ok || payload?.ok === false) throw new Error(payload?.detail || payload?.error || `HTTP ${response.status}`);
        }
        if (toolResult) toolResult.textContent = JSON.stringify(payload, null, 2);
        setStatus(`只读检查完成：${toolName}`, "ok");
      } catch (error) {
        if (toolResult) toolResult.textContent = `执行失败：${error?.message || "未知错误"}`;
        setStatus(`只读检查失败：${error?.message || "未知错误"}`, "error");
      }
    };

    tabs.forEach((tab) => tab.addEventListener("click", () => setActive(tab.dataset.target)));
    shell.addEventListener("click", (event) => {
      const target = event.target;
      const vehicleButton = target?.closest?.("[data-vehicle-id]");
      if (vehicleButton && vehicleSelect) {
        setSelectedVehicle(vehicleButton.dataset.vehicleId || "");
        return;
      }
      const actionButton = target?.closest?.("[data-action]");
      if (!actionButton) return;
      const action = actionButton.dataset.action;
      if (action === "refresh-vehicles") {
        loadVehicles();
      } else if (action === "readonly-tool") {
        runReadOnlyTool(actionButton);
      }
    });
    vehicleSelect?.addEventListener("change", () => {
      setSelectedVehicle(vehicleSelect.value || "");
    });

    loadVehicles();
  })();
</script>
