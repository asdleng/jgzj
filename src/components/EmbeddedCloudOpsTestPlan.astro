      const result = toolResultOfPayload(payload) || {};
      const mapExtent = result?.map?.extent || result?.extent || {};
      return {
        width: finiteNumber(mapExtent?.width_m),
        height: finiteNumber(mapExtent?.height_m)
      };
    };
    const normalizedMapPixelBounds = (payload, width, height) => {
      const result = toolResultOfPayload(payload) || {};
      const extent = normalizedMapExtent(payload);
      const candidates = [
        result?.image?.plot_bounds,
        result?.image?.pixel_bounds,
        result?.render?.plot_bounds,
        result?.render?.pixel_bounds,
        result?.render?.plot,
        result?.map?.pixel_bounds,
        result?.map?.render_bounds
      ].filter((candidate) => candidate && typeof candidate === "object");
      for (const candidate of candidates) {
        const left = finiteNumber(candidate?.left ?? candidate?.min_x ?? candidate?.x_min ?? candidate?.x);
        const top = finiteNumber(candidate?.top ?? candidate?.min_y ?? candidate?.y_min ?? candidate?.y);
        const rightValue = finiteNumber(candidate?.right ?? candidate?.max_x ?? candidate?.x_max);
        const bottomValue = finiteNumber(candidate?.bottom ?? candidate?.max_y ?? candidate?.y_max);
        const plotWidth = finiteNumber(candidate?.width) || (Number.isFinite(rightValue) ? rightValue - left : NaN);
        const plotHeight = finiteNumber(candidate?.height) || (Number.isFinite(bottomValue) ? bottomValue - top : NaN);
        if ([left, top, plotWidth, plotHeight].every(Number.isFinite) && plotWidth > 0 && plotHeight > 0) {
          return { left, top, width: plotWidth, height: plotHeight };
        }
      }
      if (extent && Number.isFinite(extent.metersPerPixel) && extent.metersPerPixel > 0) {
