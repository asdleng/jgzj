---
import OptimizedImage from "../components/OptimizedImage.astro";
import SiteLayout from "../components/SiteLayout.astro";
---

<SiteLayout
  title="云端智能运维"
  description="展示吉光智界云端智能运维体系，涵盖车辆状态、车端工具、服务器节点和统一运维链路。"
  currentPath="/cloud-operations"
>
  <header class="page-hero ops-hero">
    <OptimizedImage
      src="/assets/fallback/hero-cloud-ops-1600.jpg"
      webp="/assets/optimized/hero-cloud-ops-1600.webp"
      alt="云端智能运维场景"
      class="hero-media"
      data-parallax
    />
    <div class="hero-overlay"></div>
    <div class="hero-grid"></div>
    <div class="page-hero-shell">
      <div class="page-hero-copy reveal" data-reveal>
        <p class="page-kicker">PAGE 06 · CLOUD OPS</p>
        <h1 class="page-title">云端智能运维</h1>
        <p class="page-subtitle">
          面向多车现场和云端节点的运维体系，涵盖车辆状态、车端工具、服务器节点和统一运维链路。
        </p>
      </div>
    </div>
  </header>

  <main class="page-main grid-bg">
    <section class="page-section">
      <div class="glass-card section-card reveal" data-reveal>
        <p class="section-kicker">运维体系</p>
        <h2 class="section-title">车辆、工具与服务器节点统一管理</h2>
        <p class="section-copy">
          把车辆状态、工具调用、服务器节点和现场任务纳入统一视图，减少跨系统排查和人工沟通成本。
        </p>
        <div class="page-grid-three">
          <article class="page-card">
            <h3>车辆状态</h3>
            <p>按车辆汇总在线状态、关键节点、传感器和任务链路，用于远程排查现场问题。</p>
          </article>
          <article class="page-card">
            <h3>车端工具</h3>
            <p>通过受控工具调用完成健康检查、日志读取、截图采集和必要的远程协助。</p>
          </article>
          <article class="page-card">
            <h3>服务器节点</h3>
            <p>把官网、对话、检测、tunnel 和转发节点纳入统一状态面板，减少人工排障成本。</p>
          </article>
        </div>
        <div class="chip-list">
          <a class="chip-item" href="/app/cloud-operations">进入运维工作台</a>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
