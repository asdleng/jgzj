---
import OptimizedImage from "../components/OptimizedImage.astro";
import SiteLayout from "../components/SiteLayout.astro";
import { awards, cases, sceneCaseGallery } from "../data/site-content.js";
---

<SiteLayout
  title="案例与奖项"
  description="展示吉光智界的场景案例与奖项认可。"
  currentPath="/cases-awards"
>
  <header class="page-hero awards-hero">
    <OptimizedImage
      src="/assets/fallback/cases-hero-1600.jpg"
      webpSrcset="/assets/optimized/cases-hero-900.webp 900w, /assets/optimized/cases-hero-1600.webp 1600w"
      sizes="100vw"
      alt="案例与奖项"
      class="hero-media"
      data-parallax
    />
    <div class="hero-overlay"></div>
    <div class="hero-grid"></div>
    <div class="page-hero-shell">
      <div class="page-hero-copy reveal" data-reveal>
        <p class="page-kicker">PAGE 03 · CASES & AWARDS</p>
        <h1 class="page-title">案例与奖项</h1>
        <p class="page-subtitle">
          这一页集中展示项目案例、落地场景和设计与产品奖项。后续如果你再补更多项目照片或客户案例，可以继续往这页扩。
        </p>
      </div>
    </div>
  </header>

  <main class="page-main grid-bg">
    <!-- 顶部锚点导航 -->
    <section class="page-section">
      <nav class="anchor-nav reveal" data-reveal>
        <a href="#case-gallery" class="anchor-nav-item">场景图览</a>
        <a href="#cases" class="anchor-nav-item">应用案例</a>
        <a href="#certs" class="anchor-nav-item">证书认证</a>
        <a href="#awards" class="anchor-nav-item">奖项荣誉</a>
      </nav>
    </section>

    <section class="page-section" id="case-gallery">
      <div class="glass-card section-card scene-gallery-section reveal" data-reveal>
        <div class="scene-gallery-head">
          <div>
            <p class="section-kicker">近期场景图览</p>
            <h2 class="section-title">白泽智 AI 服务机器人真实应用场景</h2>
            <p class="section-copy">
              精选政务机关、城市地标、文旅景区、体育场馆、产业园区、城市公园与校园等落地点位。
            </p>
          </div>
          <div class="scene-gallery-tags" aria-label="覆盖场景类型">
            <span>政务</span>
            <span>文旅</span>
            <span>园区</span>
            <span>公园</span>
            <span>校园</span>
          </div>
        </div>
        <div class="scene-gallery-grid">
          {sceneCaseGallery.map((item) => (
            <article class="scene-case-card">
              <div class="scene-case-media">
                <span class="scene-case-type">{item.type}</span>
                <OptimizedImage src={item.img} webp={item.webp} alt={item.alt} class="scene-case-image" loading="lazy" decoding="async" />
              </div>
              <div class="scene-case-body">
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section" id="cases">
      <div class="glass-card section-card reveal" data-reveal>
        <p class="section-kicker">应用案例</p>
        <h2 class="section-title">覆盖场馆、园区、校园与公共空间</h2>
        <div class="page-grid-two">
          {cases.map((item) => (
            <article class="page-card case-card">
              <div class="case-card-img-wrap">
                <span class="case-status-tag">已交付</span>
                <OptimizedImage src={item.img} webp={item.webp} alt={item.title} class="case-card-img" loading="lazy" decoding="async" />
              </div>
              <div class="case-card-body">
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section" id="certs">
      <div class="glass-card section-card reveal" data-reveal>
        <p class="section-kicker">证书认证</p>
        <h2 class="section-title">权威设计与产品奖项证书</h2>
        <div class="cert-grid">
          <figure class="cert-frame">
            <OptimizedImage src="/assets/fallback/cert-muse-1000.jpg" webp="/assets/optimized/cert-muse-1000.webp" alt="国际设计奖项证书" loading="lazy" decoding="async" />
            <figcaption>国际设计奖项证书</figcaption>
          </figure>
          <figure class="cert-frame">
            <OptimizedImage src="/assets/fallback/cert-product-1000.jpg" webp="/assets/optimized/cert-product-1000.webp" alt="产品设计奖项海报" loading="lazy" decoding="async" />
            <figcaption>产品设计奖项海报</figcaption>
          </figure>
        </div>
      </div>
    </section>

    <section class="page-section" id="awards">
      <div class="glass-card section-card reveal" data-reveal>
        <p class="section-kicker">奖项荣誉</p>
        <h2 class="section-title">设计与产品能力持续获得行业认可</h2>
        <div class="award-timeline">
          {awards.map((item) => (
            <article class="award-card">
              <div class="award-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M6 9V4h12v5a6 6 0 0 1-12 0z"/>
                  <path d="M6 4H3v2a3 3 0 0 0 3 3M18 4h3v2a3 3 0 0 1-3 3"/>
                  <path d="M9 18h6M12 14v4M9 22h6"/>
                </svg>
              </div>
              <div class="award-body">
                <h3>{item}</h3>
                <p>奖项详细年份、主办机构、获奖说明和项目关联案例可在此扩展。</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</SiteLayout>

<style>
  .awards-hero .hero-overlay {
    background:
      linear-gradient(100deg, rgba(2, 6, 23, 0.92), rgba(2, 6, 23, 0.55)),
      radial-gradient(circle at 85% 35%, rgba(252, 211, 77, 0.28), transparent 45%);
  }
  .awards-hero .page-kicker {
    border-color: rgba(252, 211, 77, 0.38);
    background: rgba(252, 211, 77, 0.08);
    color: #fef3c7;
  }
  .awards-hero .page-subtitle {
    border-left-color: #fcd34d;
  }
</style>
