---
import OptimizedImage from "../components/OptimizedImage.astro";
import SiteLayout from "../components/SiteLayout.astro";
import { visualScenes } from "../data/site-content.js";
---

<SiteLayout
  title="智能AI对话交互"
  description="展示 ASR、LLM、TTS 构成的智能 AI 对话交互能力，以及车端 UI 与云端理解链路。"
  currentPath="/intelligent-ai-dialogue"
>
  <header class="page-hero dialogue-hero">
    <OptimizedImage
      src="/assets/fallback/hero-ai-dialogue-1600.jpg"
      webp="/assets/optimized/hero-ai-dialogue-1600.webp"
      alt="智能 AI 对话交互场景"
      class="hero-media"
      data-parallax
    />
    <div class="hero-overlay"></div>
    <div class="hero-grid"></div>
    <div class="page-hero-shell">
      <div class="page-hero-copy reveal" data-reveal>
        <p class="page-kicker">PAGE 05 · AI DIALOGUE</p>
        <h1 class="page-title">智能AI对话交互</h1>
        <p class="page-subtitle">
          从车端语音采集到云端理解、生成与播报，形成 ASR、LLM、TTS 一体化交互链路。
        </p>
      </div>
    </div>
  </header>

  <main class="page-main grid-bg">
    <section class="page-section">
      <div class="glass-card section-card reveal" data-reveal>
        <p class="section-kicker">交互闭环</p>
        <h2 class="section-title">车端 ASR、云端 LLM、云端 TTS 组成完整智能交互闭环</h2>
        <div class="page-grid-three">
          <article class="page-card">
            <h3>车端实时采集</h3>
            <p>完成拾音、唤醒和实时转写，把现场语音稳定转成可理解的文本输入。</p>
          </article>
          <article class="page-card">
            <h3>云端统一理解</h3>
            <p>结合项目身份、知识库、历史上下文和现场状态生成可执行回复。</p>
          </article>
          <article class="page-card">
            <h3>语音播报回传</h3>
            <p>把回复送回车端屏幕和语音链路，形成用户可听、可看、可追问的闭环。</p>
          </article>
        </div>
        <div class="chip-list">
          <a class="chip-item" href="/app/intelligent-ai-dialogue">进入 AI 对话工作台</a>
        </div>
      </div>
    </section>

    <section class="page-section">
      <div class="glass-card section-card reveal" data-reveal>
        <p class="section-kicker">车端界面</p>
        <h2 class="section-title">不同地点的车端 UI 可视化页面</h2>
        <div class="scene-grid-wrap">
          <div class="visual-stack">
            {visualScenes.map((item) => (
              <figure class="visual-scene">
                <OptimizedImage src={item.src} webp={item.webp} alt={item.alt} class="visual-scene-image" loading="lazy" decoding="async" />
                <figcaption class="visual-scene-caption">{item.title}</figcaption>
              </figure>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>

<style>
  .dialogue-hero .hero-overlay {
    background:
      linear-gradient(100deg, rgba(2, 6, 23, 0.92), rgba(2, 6, 23, 0.55)),
      radial-gradient(circle at 85% 35%, rgba(52, 211, 153, 0.28), transparent 45%);
  }
  .dialogue-hero .page-kicker {
    border-color: rgba(52, 211, 153, 0.38);
    background: rgba(52, 211, 153, 0.08);
    color: #a7f3d0;
  }
  .dialogue-hero .page-subtitle {
    border-left-color: #34d399;
  }
</style>
