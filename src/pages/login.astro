---
import AccountAuth from "../components/AccountAuth.astro";
import SiteLayout from "../components/SiteLayout.astro";
---

<SiteLayout
  title="登录"
  description="吉光智界内部工作台登录入口。登录并完成权限分配后可访问云端运维、AI 检测、建图、3DGS 与地图管理页面。"
  currentPath="/login"
  authMode="none"
  noindex={true}
>
  <main class="page-main grid-bg auth-page-main">
    <section class="auth-page-shell">
      <div class="auth-page-copy reveal" data-reveal>
        <p class="page-kicker">PAGE 04 · ACCOUNT</p>
        <h1 class="page-title auth-page-title">内部工作台登录</h1>
        <p class="page-subtitle">
          游客只开放公司首页、L4 级园区自动驾驶和案例奖项页面。登录并完成权限分配后，才能看到云端运维、AI 检测、建图、3DGS 和地图管理等内部页面。
        </p>
      </div>

      <AccountAuth mode="page" />
    </section>
  </main>
</SiteLayout>
