---
import AccountAuth from "../components/AccountAuth.astro";
import SiteLayout from "../components/SiteLayout.astro";
---

<SiteLayout
  title="登录"
  description="深圳吉光智界科技有限公司登录入口。"
  currentPath="/login"
  authMode="none"
  noindex={true}
>
  <main class="page-main grid-bg auth-page-main">
    <section class="auth-page-shell">
      <div class="auth-page-copy reveal" data-reveal>
        <p class="page-kicker">PAGE 04 · LOGIN</p>
        <h1 class="page-title auth-page-title">登录</h1>
        <p class="page-subtitle">
          请输入用户名或邮箱继续。
        </p>
      </div>

      <AccountAuth mode="page" />
    </section>
  </main>
</SiteLayout>
