---
import OptimizedImage from "../components/OptimizedImage.astro";
import SiteLayout from "../components/SiteLayout.astro";
---

<SiteLayout
  title="车辆代码维护"
  description="展示吉光智界面向无人车辆的集中代码维护体系，覆盖 Repo、分支、Commit、编译和日志追踪。"
  currentPath="/vehicle-devops"
>
  <header class="page-hero ops-hero vehicle-devops-hero">
    <OptimizedImage
      src="/assets/fallback/hero-cloud-ops-1600.jpg"
      webp="/assets/optimized/hero-cloud-ops-1600.webp"
      alt="车辆代码维护工作台"
      class="hero-media"
      data-parallax
    />
    <div class="hero-overlay"></div>
    <div class="hero-grid"></div>
    <div class="page-hero-shell">
      <div class="page-hero-copy reveal" data-reveal>
        <p class="page-kicker">PAGE 07 · CODE MAINTENANCE</p>
        <h1 class="page-title">车辆代码维护</h1>
        <p class="page-subtitle">
          车辆代码维护能力用于按车辆选择仓库、分支、Commit 和编译目标，统一追踪更新、编译和日志结果。
        </p>
      </div>
    </div>
  </header>

  <main class="page-main grid-bg">
    <section class="page-section">
      <div class="glass-card section-card reveal" data-reveal>
        <p class="section-kicker">代码维护</p>
        <h2 class="section-title">代码更新、编译与日志追踪</h2>
        <div class="page-grid-three">
          <article class="page-card">
            <h3>版本选择</h3>
            <p>按车辆、仓库、分支和 Commit 定位代码版本，避免现场车辆误更新。</p>
          </article>
          <article class="page-card">
            <h3>编译执行</h3>
            <p>受控触发车端编译任务，并保留状态、日志和失败分析入口。</p>
          </article>
          <article class="page-card">
            <h3>上下文追问</h3>
            <p>把执行结果带入运维助手，继续定位编译失败、依赖缺失或环境异常。</p>
          </article>
        </div>
        <div class="chip-list">
          <a class="chip-item" href="/app/vehicle-devops">进入代码维护工作台</a>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
