---
import OptimizedImage from "../components/OptimizedImage.astro";
import SiteLayout from "../components/SiteLayout.astro";
---

<SiteLayout
  title="分布地图云端统一管理"
  description="展示吉光智界分布地图云端统一管理能力，覆盖车辆地图、路线编辑、地图预览和远程同步。"
  currentPath="/distributed-map-management"
>
  <header class="page-hero distributed-map-hero">
    <OptimizedImage
      src="/assets/fallback/hero-l4-autonomy-1600.jpg"
      webp="/assets/optimized/hero-l4-autonomy-1600.webp"
      alt="分布地图云端统一管理"
      class="hero-media"
      data-parallax
    />
    <div class="hero-overlay"></div>
    <div class="hero-grid"></div>
    <div class="page-hero-shell">
      <div class="page-hero-copy reveal" data-reveal>
        <p class="page-kicker">PAGE 10 · MAP MANAGEMENT</p>
        <h1 class="page-title">分布地图云端统一管理</h1>
        <p class="page-subtitle">
          面向多车、多园区、多地图版本的云端管理能力，覆盖路线编辑、地图预览和车端同步。
        </p>
      </div>
    </div>
  </header>

  <main class="page-main grid-bg">
    <section class="page-section">
      <div class="glass-card section-card reveal" data-reveal>
        <p class="section-kicker">地图管理</p>
        <h2 class="section-title">地图、路线和车端同步集中管理</h2>
        <div class="page-grid-three">
          <article class="page-card">
            <h3>地图版本</h3>
            <p>按车辆和项目维护地图版本，避免现场车辆使用错误地图。</p>
          </article>
          <article class="page-card">
            <h3>路线编辑</h3>
            <p>通过受控编辑器修改巡逻路线、导览路线和局部路径配置。</p>
          </article>
          <article class="page-card">
            <h3>远程同步</h3>
            <p>将云端确认后的地图和路径同步到车端，并保留操作边界。</p>
          </article>
        </div>
        <div class="chip-list">
          <a class="chip-item" href="/app/distributed-map-management">进入地图管理工作台</a>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
