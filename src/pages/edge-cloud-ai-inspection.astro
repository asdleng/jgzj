---
import EmbeddedAiCheckHistory from "../components/EmbeddedAiCheckHistory.astro";
import EmbeddedQwen36MmCheck from "../components/EmbeddedQwen36MmCheck.astro";
import InteractiveScripts from "../components/InteractiveScripts.astro";
import SiteLayout from "../components/SiteLayout.astro";
---

<SiteLayout
  title="端云协同的AI检测"
  description="展示车端小模型与云端大模型协同的 AI 检测能力，支持网页上传体验、历史检测回看与按车辆地点筛选。"
  currentPath="/edge-cloud-ai-inspection"
>
  <header class="page-hero inspection-hero">
    <img
      src="/assets/hero-ai-inspection.png"
      alt="端云协同 AI 检测场景"
      class="hero-media"
      data-parallax
    />
    <div class="hero-overlay"></div>
    <div class="hero-grid"></div>
    <div class="page-hero-shell">
      <div class="page-hero-copy reveal" data-reveal>
        <p class="page-kicker">PAGE 03 · AI INSPECTION</p>
        <h1 class="page-title">端云协同的AI检测</h1>
        <p class="page-subtitle">
          车端小模型负责前置感知和快速上报，云端大模型负责复核、归档和持续优化。这里保留直接可操作的检测体验与历史回放，用来做现场验证、误报复盘和数据闭环。
        </p>
      </div>
    </div>
  </header>

  <main class="page-main grid-bg">
    <section class="page-section">
      <div class="glass-card section-card reveal" data-reveal>
        <p class="section-kicker">能力说明</p>
        <h2 class="section-title">从前置感知，到云端复核，再到数据闭环</h2>
        <div class="capability-flow-grid">
          <article class="page-card capability-card">
            <div class="capability-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                <circle cx="12" cy="12" r="3.5"/>
                <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"/>
              </svg>
            </div>
            <h3>车端小模型前置判断</h3>
            <p>车端先做轻量识别和事件触发，把真正有价值的图像与事件上送云端，减少无效流量和无效告警。</p>
          </article>
          <div class="capability-arrow" aria-hidden="true">→</div>
          <article class="page-card capability-card">
            <div class="capability-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                <path d="M7 18a5 5 0 1 1 1.6-9.74A6 6 0 0 1 19 13a4 4 0 0 1 0 8H7z"/>
                <path d="M12 13v4M10 15l2 2 2-2"/>
              </svg>
            </div>
            <h3>云端大模型复核</h3>
            <p>云端对事件进行更强的语义复核与结果确认，适合做复杂场景判定、跨场景统一校验与效果评估。</p>
          </article>
          <div class="capability-arrow" aria-hidden="true">→</div>
          <article class="page-card capability-card">
            <div class="capability-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                <path d="M21 12a9 9 0 1 1-3-6.7"/>
                <polyline points="21 4 21 10 15 10"/>
              </svg>
            </div>
            <h3>数据闭环持续优化</h3>
            <p>每次检测会保留原图、ROI、时间、地点和结果，支持按车辆地点筛选，方便做复盘、统计和模型迭代。</p>
          </article>
        </div>
      </div>
    </section>

    <section class="page-section">
      <div class="glass-card section-card reveal" data-reveal>
        <p class="section-kicker">车云对比</p>
        <h2 class="section-title">为什么要"小模型 + 大模型"分工</h2>
        <div class="compare-table-wrap">
          <table class="compare-table">
            <thead>
              <tr>
                <th>能力维度</th>
                <th><span class="compare-tag compare-tag--cyan">车端小模型</span></th>
                <th><span class="compare-tag compare-tag--purple">云端大模型</span></th>
              </tr>
            </thead>
            <tbody>
              <tr><td>响应延迟</td><td>毫秒级，本地直出</td><td>秒级，需上传</td></tr>
              <tr><td>识别精度</td><td>聚焦核心类别</td><td>覆盖长尾、复杂语义</td></tr>
              <tr><td>能耗</td><td>低，常驻车端</td><td>高，弹性算力</td></tr>
              <tr><td>典型角色</td><td>事件触发 / 实时告警</td><td>复核 / 统计 / 持续训练</td></tr>
              <tr><td>网络依赖</td><td>断网仍可工作</td><td>需稳定回传</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="page-section reveal" data-reveal>
      <div class="glass-card section-card">
        <p class="section-kicker">Qwen3.6-27B 多模态检测</p>
        <h2 class="section-title">直接用 Qwen3.6-27B 判断图片事件</h2>
        <p class="section-copy">
          上传图片，输入事件名称（或留空），模型直接返回 是 / 否。由 A100 上的 Qwen3.6-27B-MM 多模态模型提供推理。
        </p>
        <div class="qwen36mm-check-shell">
          <EmbeddedQwen36MmCheck />
        </div>
      </div>
    </section>

    <section class="page-section reveal" data-reveal>
      <EmbeddedAiCheckHistory />
    </section>
  </main>

  <InteractiveScripts />
</SiteLayout>

<style>
  .inspection-hero .hero-overlay {
    background:
      linear-gradient(100deg, rgba(2, 6, 23, 0.92), rgba(2, 6, 23, 0.55)),
      radial-gradient(circle at 85% 35%, rgba(251, 146, 60, 0.28), transparent 45%);
  }
  .inspection-hero .page-kicker {
    border-color: rgba(251, 146, 60, 0.38);
    background: rgba(251, 146, 60, 0.08);
    color: #fed7aa;
  }
  .inspection-hero .page-subtitle {
    border-left-color: #fb923c;
  }
</style>
