---
import SiteLayout from "../components/SiteLayout.astro";
---

<SiteLayout
  title="三维高斯泼溅场景渲染"
  description="面向车端 camera1/camera4 与 /ndt_pose 的 3DGS 数据采集、COLMAP 数据规整、点云初始化和 A100 训练工作台。"
  currentPath="/three-dgs"
>
  <header class="page-hero three-dgs-hero">
    <img src="/assets/hero-cloud-ops.png" alt="三维高斯泼溅场景渲染" class="hero-media" data-parallax />
    <div class="hero-overlay"></div>
    <div class="hero-grid"></div>
    <div class="page-hero-shell">
      <div class="page-hero-copy reveal" data-reveal>
        <p class="page-kicker">PAGE 09 · 3D GAUSSIAN SPLATTING</p>
        <h1 class="page-title">三维高斯泼溅场景渲染</h1>
        <p class="page-subtitle">
          通过车端有正式外参的相机和 /ndt_pose 采集图像-位姿关键帧，使用 GlobalMap.pcd 初始化高斯点，云端规整为 COLMAP 格式后在 A100 上启动 3DGS 训练。
        </p>
      </div>
    </div>
  </header>

  <main class="page-main grid-bg">
    <section class="page-section">
      <div class="glass-card section-card three-dgs-shell" data-requires-permission="three-dgs:run">
        <div class="three-dgs-head">
          <div>
            <p class="section-kicker">3DGS 工作台</p>
            <h2 class="section-title">采集、上传、规整和训练</h2>
            <p id="three-dgs-auth-hint" class="section-copy">当前未登录，仅可查看状态；请从右上角账号入口登录。</p>
          </div>
          <button id="three-dgs-refresh" class="three-dgs-button three-dgs-button--ghost" type="button">刷新状态</button>
        </div>

        <div class="three-dgs-status-card">
          <div>
            <p class="three-dgs-status-kicker">全局状态</p>
            <h3 id="three-dgs-status-title">等待加载</h3>
            <p id="three-dgs-status-copy">正在读取 3DGS 链路状态。</p>
          </div>
          <span id="three-dgs-status-badge" class="three-dgs-badge" data-state="idle">idle</span>
        </div>

        <div class="three-dgs-grid">
          <section class="three-dgs-panel">
            <div class="three-dgs-panel-head">
              <div>
                <p class="section-kicker">车端采集</p>
                <h3>有外参相机图像与 /ndt_pose 位姿</h3>
              </div>
              <p id="three-dgs-capture-note" class="three-dgs-note">点击开始采集后，车端所有 enabled=true 的正式标定相机会一起工作。BIT-0041 现阶段是 camera1 和 camera4。</p>
            </div>

            <div class="three-dgs-form-grid">
              <label class="three-dgs-field">
                <span>在线车辆</span>
                <select id="three-dgs-vehicle">
                  <option value="">加载中...</option>
                </select>
              </label>
              <div class="three-dgs-field three-dgs-readonly">
                <span>将采集相机</span>
                <strong id="three-dgs-enabled-cameras">camera1、camera4</strong>
              </div>
              <label class="three-dgs-field">
                <span>最小平移 m</span>
                <input id="three-dgs-min-translation" type="number" min="0.05" step="0.05" value="0.5" />
              </label>
              <label class="three-dgs-field">
                <span>最小旋转 deg</span>
                <input id="three-dgs-min-rotation" type="number" min="1" step="1" value="10" />
              </label>
              <label class="three-dgs-field">
                <span>最小间隔 s</span>
                <input id="three-dgs-min-interval" type="number" min="0.05" step="0.05" value="0.2" />
              </label>
            </div>

            <div class="three-dgs-actions">
              <button id="three-dgs-capabilities" class="three-dgs-button three-dgs-button--ghost" type="button">读取相机能力</button>
              <button id="three-dgs-start-capture" class="three-dgs-button three-dgs-button--primary" type="button">开始采集</button>
              <button id="three-dgs-capture-status" class="three-dgs-button" type="button">采集状态</button>
              <button id="three-dgs-stop-capture" class="three-dgs-button three-dgs-button--danger" type="button">停止采集</button>
              <button id="three-dgs-read-manifest" class="three-dgs-button three-dgs-button--ghost" type="button">读取清单</button>
            </div>

            <div class="three-dgs-mini-grid">
              <div>
                <span>相机</span>
                <strong id="three-dgs-capture-camera">-</strong>
              </div>
              <div>
                <span>采集车辆</span>
                <strong id="three-dgs-capture-vehicle">-</strong>
              </div>
              <div>
                <span>Session</span>
                <strong id="three-dgs-capture-session">-</strong>
              </div>
              <div>
                <span>已保存帧</span>
                <strong id="three-dgs-capture-frames">0</strong>
              </div>
            </div>
            <div class="three-dgs-capture-live">
              <div class="three-dgs-capture-live-head">
                <span>长连接监控</span>
                <strong id="three-dgs-capture-stream">未连接</strong>
              </div>
              <div id="three-dgs-capture-camera-counts" class="three-dgs-camera-counts">等待采集数据。</div>
            </div>
          </section>

          <section class="three-dgs-panel">
            <div class="three-dgs-panel-head">
              <div>
                <p class="section-kicker">车端数据同步</p>
                <h3>GlobalMap.pcd 与图像-位姿包</h3>
              </div>
              <p class="three-dgs-note">车端地图固定路径为 map/GlobalMap.pcd；图像-位姿来自当前 3DGS 采集 session。</p>
            </div>

            <div class="three-dgs-actions">
              <button id="three-dgs-update-map" class="three-dgs-button three-dgs-button--primary" type="button">更新地图</button>
              <button id="three-dgs-pull-image-pose" class="three-dgs-button three-dgs-button--primary" type="button">上传图片数据</button>
            </div>

            <div id="three-dgs-upload-progress" class="three-dgs-upload-progress" hidden>
              <div class="three-dgs-upload-progress-track">
                <span id="three-dgs-upload-progress-fill"></span>
              </div>
              <div class="three-dgs-upload-progress-meta">
                <span id="three-dgs-upload-progress-label">0%</span>
                <span id="three-dgs-upload-progress-detail">等待上传</span>
              </div>
            </div>

            <div class="three-dgs-upload-grid">
              <div class="three-dgs-dropzone" data-kind="pointcloud">
                <p class="three-dgs-dropzone-title">云端点云地图</p>
                <p id="three-dgs-pointcloud-name" class="three-dgs-dropzone-copy">等待更新 map/GlobalMap.pcd</p>
                <input id="three-dgs-pointcloud-input" type="file" accept=".pcd,.ply" hidden />
                <button id="three-dgs-pointcloud-button" class="three-dgs-button three-dgs-button--ghost" type="button">手动选择点云</button>
              </div>
              <div class="three-dgs-dropzone" data-kind="image-pose">
                <p class="three-dgs-dropzone-title">云端图像-位姿</p>
                <p id="three-dgs-image-pose-name" class="three-dgs-dropzone-copy">等待上传当前采集 session</p>
                <input id="three-dgs-image-pose-input" type="file" accept=".zip,.tar,.tgz,.gz,.json,.jsonl" hidden />
                <button id="three-dgs-image-pose-button" class="three-dgs-button three-dgs-button--ghost" type="button">手动选择图像包</button>
              </div>
            </div>

            <div class="three-dgs-map-grid">
              <div>
                <span>车端地图版本</span>
                <strong id="three-dgs-map-version">-</strong>
              </div>
              <div>
                <span>车端点数</span>
                <strong id="three-dgs-map-points">-</strong>
              </div>
              <div>
                <span>车端大小</span>
                <strong id="three-dgs-map-size">-</strong>
              </div>
              <div>
                <span>云端落盘</span>
                <strong id="three-dgs-map-cloud">-</strong>
              </div>
              <div class="three-dgs-map-grid__wide">
                <span>地图范围</span>
                <strong id="three-dgs-map-extent">-</strong>
              </div>
            </div>

            <div class="three-dgs-pointcloud-preview">
              <div class="three-dgs-preview-head">
                <span>点云地图预览</span>
                <strong id="three-dgs-pointcloud-preview-status">等待点云落盘</strong>
              </div>
              <canvas id="three-dgs-pointcloud-canvas" height="260"></canvas>
            </div>

            <div class="three-dgs-actions">
              <button id="three-dgs-upload-pointcloud" class="three-dgs-button" type="button" disabled>手动上传点云</button>
              <button id="three-dgs-upload-image-pose" class="three-dgs-button" type="button" disabled>手动上传图像包</button>
            </div>
          </section>
        </div>

        <section class="three-dgs-panel">
          <div class="three-dgs-panel-head">
            <div>
              <p class="section-kicker">COLMAP 与训练</p>
              <h3>规整数据并在 A100 上启动训练</h3>
            </div>
            <p id="three-dgs-dataset-note" class="three-dgs-note">点云会写成 sparse/0/points3D.ply，图像位姿会写成 cameras.txt / images.txt。</p>
          </div>

          <div class="three-dgs-data-check">
            <div class="three-dgs-viewer-head">
              <div>
                <span>训练数据检查</span>
                <strong id="three-dgs-data-check-status">等待检查当前 COLMAP 数据集</strong>
              </div>
              <button id="three-dgs-check-dataset" class="three-dgs-button three-dgs-button--ghost" type="button">检查训练数据</button>
            </div>
            <div class="three-dgs-data-check-grid">
              <div class="three-dgs-data-map">
                <canvas id="three-dgs-dataset-canvas" height="360"></canvas>
                <p id="three-dgs-dataset-map-hint">点云地图和相机轨迹会显示在这里。</p>
              </div>
              <div class="three-dgs-data-photo">
                <div id="three-dgs-dataset-empty" class="three-dgs-data-empty">点击轨迹点查看对应照片。</div>
                <img id="three-dgs-dataset-image" alt="轨迹点对应照片" hidden />
                <div id="three-dgs-dataset-frame-meta" class="three-dgs-data-meta">未选择关键帧。</div>
              </div>
            </div>
            <div class="three-dgs-mini-grid three-dgs-data-stats">
              <div>
                <span>检查图片</span>
                <strong id="three-dgs-check-images">-</strong>
              </div>
              <div>
                <span>初始化点</span>
                <strong id="three-dgs-check-points">-</strong>
              </div>
              <div>
                <span>轨迹长度</span>
                <strong id="three-dgs-check-distance">-</strong>
              </div>
              <div>
                <span>最大帧间距</span>
                <strong id="three-dgs-check-gap">-</strong>
              </div>
            </div>
          </div>

          <div class="three-dgs-form-grid three-dgs-form-grid--train">
            <label class="three-dgs-field">
              <span>场景名</span>
              <input id="three-dgs-scene-name" type="text" placeholder="futian-park-3dgs" />
            </label>
            <label class="three-dgs-field">
              <span>最大初始化点数</span>
              <input id="three-dgs-max-points" type="number" min="10000" step="10000" value="500000" />
            </label>
            <label class="three-dgs-field">
              <span>A100 GPU</span>
              <input id="three-dgs-gpu" type="number" min="0" max="5" step="1" value="3" />
            </label>
            <label class="three-dgs-field">
              <span>训练迭代</span>
              <input id="three-dgs-iterations" type="number" min="100" step="100" value="7000" />
            </label>
            <label class="three-dgs-field">
              <span>图像缩放 -r</span>
              <input id="three-dgs-resolution" type="number" min="1" step="1" value="4" />
            </label>
            <label class="three-dgs-check">
              <input id="three-dgs-undistort" type="checkbox" checked />
              <span>使用标定内参去畸变</span>
            </label>
          </div>

          <div class="three-dgs-actions">
            <button id="three-dgs-prepare" class="three-dgs-button three-dgs-button--primary" type="button">规整 COLMAP 数据</button>
            <button id="three-dgs-start-train" class="three-dgs-button three-dgs-button--primary" type="button">开始训练</button>
            <button id="three-dgs-load-prepare-log" class="three-dgs-button three-dgs-button--ghost" type="button">准备日志</button>
            <button id="three-dgs-load-train-log" class="three-dgs-button three-dgs-button--ghost" type="button">训练日志</button>
          </div>

          <div class="three-dgs-mini-grid">
            <div>
              <span>数据集</span>
              <strong id="three-dgs-dataset-path">-</strong>
            </div>
            <div>
              <span>图片 / 点数</span>
              <strong id="three-dgs-dataset-summary">-</strong>
            </div>
            <div>
              <span>训练 Run</span>
              <strong id="three-dgs-train-run">-</strong>
            </div>
            <div>
              <span>A100 输出</span>
              <strong id="three-dgs-remote-run">-</strong>
            </div>
          </div>

          <div class="three-dgs-viewer-card">
            <div class="three-dgs-viewer-head">
              <div>
                <span>浏览器渲染结果</span>
                <strong id="three-dgs-viewer-status">等待同步训练结果</strong>
              </div>
              <div class="three-dgs-actions three-dgs-actions--compact">
                <button id="three-dgs-sync-result" class="three-dgs-button three-dgs-button--primary" type="button">同步训练结果</button>
                <a id="three-dgs-open-viewer" class="three-dgs-button three-dgs-button--ghost" href="#" target="_blank" rel="noreferrer">新窗口查看</a>
              </div>
            </div>
            <iframe id="three-dgs-viewer-frame" title="3DGS SuperSplat Viewer" hidden></iframe>
          </div>

          <p id="three-dgs-feedback" class="three-dgs-feedback">等待操作。</p>
          <pre id="three-dgs-log" class="three-dgs-log">日志会显示在这里。</pre>
        </section>
      </div>
    </section>
  </main>
</SiteLayout>

<script>
  // @ts-nocheck
  const STATUS_URL = "/api/three-dgs/status";
  const api = {
    capabilities: "/api/three-dgs/capture/capabilities",
    startCapture: "/api/three-dgs/capture/start",
    captureStatus: "/api/three-dgs/capture/status",
    captureStream: "/api/three-dgs/capture/stream",
    stopCapture: "/api/three-dgs/capture/stop",
    manifest: "/api/three-dgs/capture/manifest",
    updateMap: "/api/three-dgs/map/update",
    pullImagePose: "/api/three-dgs/capture/package",
    uploadPointcloud: "/api/three-dgs/upload/pointcloud",
    uploadImagePose: "/api/three-dgs/upload/image-pose",
    pointcloudPreview: "/api/three-dgs/pointcloud/preview",
    datasetInspection: "/api/three-dgs/dataset/inspection",
    prepare: "/api/three-dgs/prepare",
    train: "/api/three-dgs/train/start",
    viewerSync: "/api/three-dgs/viewer/sync",
    prepareLog: "/api/three-dgs/logs/prepare",
    trainLocalLog: "/api/three-dgs/logs/train-local",
    trainRemoteLog: "/api/three-dgs/logs/train-remote"
  };

  const el = (id) => document.getElementById(id);
  const vehicleSelect = el("three-dgs-vehicle");
  const enabledCamerasText = el("three-dgs-enabled-cameras");
  const statusTitle = el("three-dgs-status-title");
  const statusCopy = el("three-dgs-status-copy");
  const statusBadge = el("three-dgs-status-badge");
  const authHint = el("three-dgs-auth-hint");
  const feedback = el("three-dgs-feedback");
  const logNode = el("three-dgs-log");
  const pointcloudInput = el("three-dgs-pointcloud-input");
  const imagePoseInput = el("three-dgs-image-pose-input");
  const pointcloudName = el("three-dgs-pointcloud-name");
  const imagePoseName = el("three-dgs-image-pose-name");
  const pointcloudCanvas = el("three-dgs-pointcloud-canvas");
  const pointcloudPreviewStatus = el("three-dgs-pointcloud-preview-status");
  const viewerFrame = el("three-dgs-viewer-frame");
  const viewerStatus = el("three-dgs-viewer-status");
  const viewerOpen = el("three-dgs-open-viewer");
  const captureStreamText = el("three-dgs-capture-stream");
  const captureCameraCounts = el("three-dgs-capture-camera-counts");
  const uploadProgress = el("three-dgs-upload-progress");
  const uploadProgressFill = el("three-dgs-upload-progress-fill");
  const uploadProgressLabel = el("three-dgs-upload-progress-label");
  const uploadProgressDetail = el("three-dgs-upload-progress-detail");
  const datasetCanvas = el("three-dgs-dataset-canvas");
  const datasetCheckStatus = el("three-dgs-data-check-status");
  const datasetMapHint = el("three-dgs-dataset-map-hint");
  const datasetImage = el("three-dgs-dataset-image");
  const datasetEmpty = el("three-dgs-dataset-empty");
  const datasetFrameMeta = el("three-dgs-dataset-frame-meta");

  let statusData = null;
  let pointcloudFile = null;
  let imagePoseFile = null;
  let busy = false;
  let vehicleManuallyChanged = false;
  let pointcloudPreviewKey = "";
  let captureEventSource = null;
  let datasetInspection = null;
  let datasetHitPoints = [];
  let selectedDatasetFrameIndex = -1;

  function formatSize(bytes) {
    const value = Number(bytes || 0);
    if (value >= 1073741824) return `${(value / 1073741824).toFixed(2)} GB`;
    if (value >= 1048576) return `${(value / 1048576).toFixed(1)} MB`;
    if (value > 0) return `${(value / 1024).toFixed(0)} KB`;
    return "-";
  }

  function formatCount(value) {
    const number = Number(value || 0);
    return number > 0 ? number.toLocaleString("zh-CN") : "-";
  }

  function formatFrameCount(value) {
    const number = Number(value || 0);
    return Number.isFinite(number) ? number.toLocaleString("zh-CN") : "0";
  }

  function formatMeters(value) {
    const number = Number(value || 0);
    if (!Number.isFinite(number)) return "-";
    if (Math.abs(number) >= 1000) return `${(number / 1000).toFixed(2)} km`;
    return `${number.toFixed(2)} m`;
  }

  function viewerUrlFor(pointCloudUrl) {
    if (!pointCloudUrl) return "";
    const state = statusData?.state || {};
    const settingsKey = [
      state.dataset?.prepared_at_ms || 0,
      state.viewer?.synced_at_ms || 0,
      state.train?.run_id || ""
    ].join("-");
    const settingsUrl = `/api/three-dgs/viewer/settings?key=${encodeURIComponent(settingsKey)}`;
    return `/supersplat-viewer/?webgl&content=${encodeURIComponent(pointCloudUrl)}&settings=${encodeURIComponent(settingsUrl)}`;
  }

  function currentVehicleId() {
    return vehicleSelect.value || statusData?.default_vehicle_id || "BIT-0041";
  }

  function unwrapToolResult(payload) {
    return payload?.response?.result || payload?.result || payload?.data || payload?.response || null;
  }

  function mapFileFromInfo(info) {
    const files = Array.isArray(info?.files) ? info.files : [];
    return files.find((item) => item?.name === "GlobalMap.pcd" || String(item?.path || "").endsWith("/GlobalMap.pcd")) || null;
  }

  function formatExtent(extent) {
    if (!extent) return "-";
    const values = ["min_x", "max_x", "min_y", "max_y", "min_z", "max_z"].map((key) => Number(extent[key]));
    if (values.some((value) => !Number.isFinite(value))) return "-";
    return `X ${values[0].toFixed(1)}~${values[1].toFixed(1)} m / Y ${values[2].toFixed(1)}~${values[3].toFixed(1)} m / Z ${values[4].toFixed(1)}~${values[5].toFixed(1)} m`;
  }

  function mapStatusFromState(state) {
    const vehicleData = state?.vehicle_data || {};
    const meta = unwrapToolResult(vehicleData.map_meta) || {};
    const info = unwrapToolResult(vehicleData.map_info) || {};
    const file = mapFileFromInfo(info);
    return {
      version: meta.map_version || info.map_version || "-",
      point_count: meta.point_count || info.point_count || 0,
      size_bytes: meta.size_bytes || file?.size_bytes || 0,
      extent: meta.extent || info.extent || null,
      upload_pending: Boolean(vehicleData.map_upload_pending)
    };
  }

  function drawPointcloudPreview(preview) {
    if (!pointcloudCanvas) return;
    const points = Array.isArray(preview?.points) ? preview.points : [];
    const rect = pointcloudCanvas.getBoundingClientRect();
    const dpr = window.devicePixelRatio || 1;
    const width = Math.max(320, Math.floor(rect.width || pointcloudCanvas.clientWidth || 640));
    const height = Math.max(220, Math.floor(rect.height || 260));
    pointcloudCanvas.width = Math.floor(width * dpr);
    pointcloudCanvas.height = Math.floor(height * dpr);
    const ctx = pointcloudCanvas.getContext("2d");
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    ctx.fillStyle = "#020617";
    ctx.fillRect(0, 0, width, height);
    if (!points.length) {
      pointcloudPreviewStatus.textContent = "点云无可预览采样";
      return;
    }
    const extent = preview.extent || {};
    const minX = Number(extent.min_x);
    const maxX = Number(extent.max_x);
    const minY = Number(extent.min_y);
    const maxY = Number(extent.max_y);
    const minZ = Number(extent.min_z);
    const maxZ = Number(extent.max_z);
    const rangeX = Math.max(0.001, maxX - minX);
    const rangeY = Math.max(0.001, maxY - minY);
    const pad = 14;
    const scale = Math.min((width - pad * 2) / rangeX, (height - pad * 2) / rangeY);
    const drawW = rangeX * scale;
    const drawH = rangeY * scale;
    const offsetX = (width - drawW) / 2;
    const offsetY = (height - drawH) / 2;
    ctx.fillStyle = "rgba(103, 232, 249, 0.85)";
    for (const point of points) {
      const x = (Number(point[0]) - minX) * scale + offsetX;
      const y = height - ((Number(point[1]) - minY) * scale + offsetY);
      const z = Number(point[2]);
      const zNorm = Number.isFinite(z) && maxZ > minZ ? Math.max(0, Math.min(1, (z - minZ) / (maxZ - minZ))) : 0.5;
      ctx.fillStyle = `rgba(${Math.round(80 + 120 * zNorm)}, ${Math.round(180 + 45 * zNorm)}, 255, 0.78)`;
      ctx.fillRect(x, y, 1.6, 1.6);
    }
    pointcloudPreviewStatus.textContent = `${formatCount(preview.sampled_points)} / ${formatCount(preview.total_points)} 点采样`;
  }

  function mergeExtents(...extents) {
    const result = {
      min_x: Infinity,
      max_x: -Infinity,
      min_y: Infinity,
      max_y: -Infinity,
      min_z: Infinity,
      max_z: -Infinity
    };
    extents.filter(Boolean).forEach((extent) => {
      ["min_x", "max_x", "min_y", "max_y", "min_z", "max_z"].forEach((key) => {
        const value = Number(extent[key]);
        if (!Number.isFinite(value)) return;
        if (key.startsWith("min_")) result[key] = Math.min(result[key], value);
        if (key.startsWith("max_")) result[key] = Math.max(result[key], value);
      });
    });
    Object.keys(result).forEach((key) => {
      if (!Number.isFinite(result[key])) result[key] = 0;
    });
    return result;
  }

  function drawDatasetInspection() {
    if (!datasetCanvas || !datasetInspection) return;
    const points = Array.isArray(datasetInspection.pointcloud?.points) ? datasetInspection.pointcloud.points : [];
    const frames = Array.isArray(datasetInspection.trajectory?.frames) ? datasetInspection.trajectory.frames : [];
    const rect = datasetCanvas.getBoundingClientRect();
    const dpr = window.devicePixelRatio || 1;
    const width = Math.max(420, Math.floor(rect.width || datasetCanvas.clientWidth || 760));
    const height = Math.max(320, Math.floor(rect.height || 360));
    datasetCanvas.width = Math.floor(width * dpr);
    datasetCanvas.height = Math.floor(height * dpr);
    const ctx = datasetCanvas.getContext("2d");
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    ctx.fillStyle = "#020617";
    ctx.fillRect(0, 0, width, height);

    datasetHitPoints = [];
    if (!points.length && !frames.length) {
      datasetMapHint.textContent = "当前数据集没有可显示的点云或轨迹。";
      return;
    }

    const extent = mergeExtents(datasetInspection.pointcloud?.extent, datasetInspection.trajectory?.summary?.extent);
    const minX = Number(extent.min_x);
    const maxX = Number(extent.max_x);
    const minY = Number(extent.min_y);
    const maxY = Number(extent.max_y);
    const minZ = Number(extent.min_z);
    const maxZ = Number(extent.max_z);
    const rangeX = Math.max(0.001, maxX - minX);
    const rangeY = Math.max(0.001, maxY - minY);
    const pad = 22;
    const scale = Math.min((width - pad * 2) / rangeX, (height - pad * 2) / rangeY);
    const drawW = rangeX * scale;
    const drawH = rangeY * scale;
    const offsetX = (width - drawW) / 2;
    const offsetY = (height - drawH) / 2;
    const project = (position) => ({
      x: (Number(position[0]) - minX) * scale + offsetX,
      y: height - ((Number(position[1]) - minY) * scale + offsetY)
    });

    for (const point of points) {
      const screen = project(point);
      const z = Number(point[2]);
      const zNorm = Number.isFinite(z) && maxZ > minZ ? Math.max(0, Math.min(1, (z - minZ) / (maxZ - minZ))) : 0.5;
      ctx.fillStyle = `rgba(${Math.round(72 + 95 * zNorm)}, ${Math.round(122 + 80 * zNorm)}, 170, 0.34)`;
      ctx.fillRect(screen.x, screen.y, 1.4, 1.4);
    }

    if (frames.length) {
      ctx.lineWidth = 2;
      ctx.strokeStyle = "rgba(45, 212, 191, 0.9)";
      ctx.beginPath();
      frames.forEach((frame, index) => {
        const screen = project(frame.position);
        if (index === 0) ctx.moveTo(screen.x, screen.y);
        else ctx.lineTo(screen.x, screen.y);
      });
      ctx.stroke();

      frames.forEach((frame, index) => {
        const screen = project(frame.position);
        datasetHitPoints.push({ ...screen, index });
        const selected = index === selectedDatasetFrameIndex;
        ctx.beginPath();
        ctx.arc(screen.x, screen.y, selected ? 6 : 3.5, 0, Math.PI * 2);
        ctx.fillStyle = selected ? "#fde047" : "#67e8f9";
        ctx.fill();
        ctx.lineWidth = selected ? 2 : 1;
        ctx.strokeStyle = selected ? "rgba(254, 240, 138, 0.9)" : "rgba(2, 6, 23, 0.8)";
        ctx.stroke();
      });
    }

    datasetMapHint.textContent = `${formatCount(points.length)} 个采样点 · ${formatCount(frames.length)} 个轨迹点，点击轨迹点查看照片。`;
  }

  function selectDatasetFrame(index) {
    const frames = Array.isArray(datasetInspection?.trajectory?.frames) ? datasetInspection.trajectory.frames : [];
    const frame = frames[index];
    if (!frame) return;
    selectedDatasetFrameIndex = index;
    if (datasetImage) {
      datasetImage.src = `${frame.image_url}?v=${encodeURIComponent(datasetInspection?.dataset?.scene_name || "")}`;
      datasetImage.hidden = false;
    }
    if (datasetEmpty) datasetEmpty.hidden = true;
    if (datasetFrameMeta) {
      const pos = Array.isArray(frame.position) ? frame.position.map((value) => Number(value).toFixed(2)).join(", ") : "-";
      datasetFrameMeta.textContent = `#${frame.image_id} · ${frame.name} · camera ${frame.camera_id} · 位置 [${pos}]`;
    }
    drawDatasetInspection();
  }

  function updateDatasetCheckStats(inspection) {
    const summary = inspection?.trajectory?.summary || {};
    el("three-dgs-check-images").textContent = formatCount(summary.frame_count);
    el("three-dgs-check-points").textContent = formatCount(inspection?.pointcloud?.total_points);
    el("three-dgs-check-distance").textContent = formatMeters(summary.total_distance_m);
    el("three-dgs-check-gap").textContent = formatMeters(summary.max_gap_m);
  }

  async function loadDatasetInspection() {
    if (!isAuthed() || !hasRunPermission()) {
      throw new Error("permission_required");
    }
    if (datasetCheckStatus) datasetCheckStatus.textContent = "正在读取当前 COLMAP 数据集...";
    const response = await fetch(`${api.datasetInspection}?max_points=26000`, {
      credentials: "same-origin",
      cache: "no-store"
    });
    const data = await response.json().catch(() => ({}));
    if (!response.ok || !data.ok) {
      throw new Error(data.error || "dataset_inspection_failed");
    }
    datasetInspection = data.inspection;
    selectedDatasetFrameIndex = -1;
    updateDatasetCheckStats(datasetInspection);
    const checks = datasetInspection.checks || {};
    const warnings = [];
    if (!checks.image_count_matches) warnings.push("图片数和 summary 不一致");
    if (!checks.point_count_matches) warnings.push("点数和 summary 不一致");
    if (!checks.has_images_dir) warnings.push("images 目录缺失");
    datasetCheckStatus.textContent = warnings.length
      ? `检查完成：${warnings.join("；")}`
      : `检查完成：${datasetInspection.dataset?.scene_name || "当前数据集"}`;
    drawDatasetInspection();
    if (datasetInspection.trajectory?.frames?.length) {
      selectDatasetFrame(0);
    }
  }

  async function loadPointcloudPreview(force = false) {
    const pointcloud = statusData?.state?.uploads?.pointcloud;
    if (!pointcloud?.path) {
      pointcloudPreviewKey = "";
      if (pointcloudPreviewStatus) pointcloudPreviewStatus.textContent = "等待点云落盘";
      return;
    }
    if (!isAuthed() || !hasRunPermission()) {
      if (pointcloudPreviewStatus) pointcloudPreviewStatus.textContent = "登录后显示点云预览";
      return;
    }
    const key = `${pointcloud.path}:${pointcloud.size_bytes}:${pointcloud.updated_at_ms}`;
    if (!force && key === pointcloudPreviewKey) return;
    pointcloudPreviewKey = key;
    pointcloudPreviewStatus.textContent = "正在加载点云采样";
    const response = await fetch(`${api.pointcloudPreview}?max_points=12000`, {
      credentials: "same-origin",
      cache: "no-store"
    });
    const data = await response.json().catch(() => ({}));
    if (!response.ok || !data.ok) {
      pointcloudPreviewStatus.textContent = data.error || "点云预览加载失败";
      return;
    }
    drawPointcloudPreview(data.preview);
  }

  function activeLogUrl() {
    const state = statusData?.state || {};
    const train = state.train || {};
    if (state.prepare?.running || state.phase === "preparing") return api.prepareLog;
    if (train.phase === "syncing") return api.trainLocalLog;
    if (train.phase === "training") return api.trainRemoteLog;
    if (state.phase === "error" && state.prepare?.completed_at_ms && !state.dataset?.prepared) return api.prepareLog;
    if (state.phase === "error" && train.error_message) return train.phase === "training" ? api.trainRemoteLog : api.trainLocalLog;
    return "";
  }

  async function refreshLiveLog() {
    const url = activeLogUrl();
    if (!url || !isAuthed() || !hasRunPermission()) return;
    await loadLog(url, true);
  }

  function refreshBackgroundViews() {
    loadPointcloudPreview().catch(() => {
      if (pointcloudPreviewStatus) pointcloudPreviewStatus.textContent = "点云预览加载失败";
    });
    refreshLiveLog().catch(() => {});
  }

  function setFeedback(text, state = "idle") {
    feedback.textContent = text;
    feedback.dataset.state = state;
  }

  function setUploadProgress(percent, detail, options = {}) {
    if (!uploadProgress || !uploadProgressFill || !uploadProgressLabel || !uploadProgressDetail) return;
    if (options.hidden) {
      uploadProgress.hidden = true;
      uploadProgressFill.style.width = "0%";
      uploadProgressFill.dataset.state = "idle";
      uploadProgressLabel.textContent = "0%";
      uploadProgressDetail.textContent = "等待上传";
      return;
    }
    const pct = Number(percent);
    const hasPct = Number.isFinite(pct);
    uploadProgress.hidden = false;
    uploadProgressFill.style.width = hasPct ? `${Math.max(0, Math.min(100, pct))}%` : "35%";
    uploadProgressFill.dataset.state = options.state || (hasPct ? "active" : "indeterminate");
    uploadProgressLabel.textContent = hasPct ? `${Math.max(0, Math.min(100, pct)).toFixed(1)}%` : "接收中";
    uploadProgressDetail.textContent = detail || "正在上传";
  }

  function renderVehicleUploadProgress(state = {}) {
    const uploads = state.vehicle_uploads || {};
    const progress =
      uploads.image_pose && ["waiting_vehicle", "uploading", "completed", "failed"].includes(uploads.image_pose.status)
        ? uploads.image_pose
        : uploads.pointcloud && ["waiting_vehicle", "uploading", "completed", "failed"].includes(uploads.pointcloud.status)
          ? uploads.pointcloud
          : null;
    if (!progress) {
      if (!busy) setUploadProgress(0, "", { hidden: true });
      return;
    }
    const kindText = progress.kind === "pointcloud" ? "点云地图" : "图像-位姿包";
    const statusText = {
      waiting_vehicle: "等待车端打包",
      uploading: "云端接收中",
      completed: "上传完成",
      failed: "上传失败"
    }[progress.status] || "上传中";
    const received = formatSize(progress.received_bytes);
    const total = Number(progress.total_bytes || 0) > 0 ? ` / ${formatSize(progress.total_bytes)}` : "";
    const detail = progress.error_message
      ? `${kindText} ${statusText}：${progress.error_message}`
      : `${kindText} ${statusText} · ${received}${total}`;
    setUploadProgress(progress.progress_pct, detail, {
      state: progress.status === "failed" ? "error" : progress.status === "completed" ? "success" : "active"
    });
  }

  function isAuthed() {
    return Boolean(statusData?.auth?.authenticated);
  }

  function hasRunPermission() {
    return Array.isArray(statusData?.auth?.permissions) && statusData.auth.permissions.includes("three-dgs:run");
  }

  function setCaptureStreamState(text, state = "idle") {
    if (!captureStreamText) return;
    captureStreamText.textContent = text;
    captureStreamText.dataset.state = state;
  }

  function renderCaptureCameraCounts(capture = {}) {
    if (!captureCameraCounts) return;
    const statuses = Array.isArray(capture.camera_statuses) ? capture.camera_statuses : [];
    captureCameraCounts.innerHTML = "";
    if (!statuses.length) {
      captureCameraCounts.textContent = capture.monitor_error
        ? `监控异常：${capture.monitor_error}`
        : capture.active
          ? "等待车端返回相机帧数。"
          : "等待采集数据。";
      return;
    }
    statuses.forEach((item) => {
      const row = document.createElement("div");
      row.className = "three-dgs-camera-count";
      row.dataset.state = item.error ? "error" : item.active === true ? "active" : item.active === false ? "idle" : "unknown";

      const camera = document.createElement("span");
      camera.textContent = item.camera || "-";
      const count = document.createElement("strong");
      const stateText = item.error
        ? `错误：${item.error}`
        : `${formatFrameCount(item.saved_frames)} 张${item.active === true ? " · 采集中" : item.active === false ? " · 已停止" : ""}`;
      count.textContent = stateText;

      row.append(camera, count);
      captureCameraCounts.appendChild(row);
    });
  }

  function closeCaptureStream() {
    if (!captureEventSource) return;
    captureEventSource.close();
    captureEventSource = null;
    setCaptureStreamState("已关闭", "idle");
  }

  function mergeCaptureStreamPayload(data) {
    if (!data?.capture || !statusData?.state) return;
    statusData = {
      ...statusData,
      state: {
        ...statusData.state,
        phase: data.phase || statusData.state.phase,
        stage_text: data.stage_text || statusData.state.stage_text,
        uploads: data.uploads || statusData.state.uploads,
        vehicle_uploads: data.vehicle_uploads || statusData.state.vehicle_uploads,
        capture: {
          ...(statusData.state.capture || {}),
          ...data.capture
        }
      }
    };
    applyStatus();
  }

  function connectCaptureStream() {
    if (!isAuthed() || !hasRunPermission()) {
      closeCaptureStream();
      return;
    }
    if (captureEventSource || !window.EventSource) {
      if (!window.EventSource) setCaptureStreamState("浏览器不支持", "error");
      return;
    }
    setCaptureStreamState("连接中", "idle");
    captureEventSource = new EventSource(api.captureStream, { withCredentials: true });
    captureEventSource.addEventListener("open", () => {
      setCaptureStreamState("已连接", "success");
    });
    captureEventSource.addEventListener("capture_status", (event) => {
      try {
        const data = JSON.parse(event.data || "{}");
        setCaptureStreamState(data.capture?.active ? "监控中" : "已连接", data.capture?.monitor_error ? "error" : "success");
        mergeCaptureStreamPayload(data);
      } catch (_error) {
        setCaptureStreamState("数据解析失败", "error");
      }
    });
    captureEventSource.onerror = () => {
      setCaptureStreamState("重连中", "error");
    };
  }

  function isTaskBusy() {
    const state = statusData?.state || {};
    return ["uploading", "preparing", "training", "updating_map", "pulling_image_pose", "starting_capture"].includes(state.phase) || state.prepare?.running || state.train?.running;
  }

  function refreshButtons() {
    const allow = isAuthed() && hasRunPermission() && !busy;
    const taskBusy = isTaskBusy();
    [
      "three-dgs-capabilities",
      "three-dgs-start-capture",
      "three-dgs-capture-status",
      "three-dgs-stop-capture",
      "three-dgs-read-manifest",
      "three-dgs-update-map",
      "three-dgs-pull-image-pose",
      "three-dgs-start-train",
      "three-dgs-sync-result",
      "three-dgs-load-prepare-log",
      "three-dgs-load-train-log"
    ].forEach((id) => {
      const button = el(id);
      if (button) button.disabled = !allow || taskBusy;
    });
    el("three-dgs-check-dataset").disabled = !allow || !statusData?.state?.dataset?.prepared;
    el("three-dgs-upload-pointcloud").disabled = !allow || taskBusy || !pointcloudFile;
    el("three-dgs-upload-image-pose").disabled = !allow || taskBusy || !imagePoseFile;
    el("three-dgs-prepare").disabled = !allow || taskBusy || !statusData?.state?.uploads?.pointcloud || !statusData?.state?.uploads?.image_pose;
    el("three-dgs-start-train").disabled =
      !allow || taskBusy || (!statusData?.state?.dataset?.prepared && (!statusData?.state?.uploads?.pointcloud || !statusData?.state?.uploads?.image_pose));
    el("three-dgs-sync-result").disabled = !allow || taskBusy || !statusData?.state?.train?.remote_run_path;
  }

  function applyVehicles(vehicles) {
    const previous = vehicleSelect.value;
    const preferred = statusData?.default_vehicle_id || "BIT-0041";
    const allowed = Array.isArray(statusData?.allowed_vehicle_ids) ? statusData.allowed_vehicle_ids : [preferred];
    const items = Array.isArray(vehicles) ? vehicles : [];
    vehicleSelect.innerHTML = "";
    if (!items.length) {
      const option = document.createElement("option");
      option.value = preferred;
      option.textContent = `${preferred} · 等待在线`;
      vehicleSelect.appendChild(option);
      return;
    }
    items.forEach((vehicle) => {
      const id = vehicle.vehicle_id || vehicle.plate_number || vehicle.vin || "";
      if (!id) return;
      const option = document.createElement("option");
      option.value = id;
      if (allowed.length && !allowed.includes(id)) {
        option.disabled = true;
      }
      const flags = [];
      if (allowed.includes(id)) flags.push("3DGS");
      if (vehicle.last_seen) flags.push(vehicle.last_seen);
      option.textContent = `${id}${flags.length ? ` · ${flags.join(" · ")}` : ""}`;
      vehicleSelect.appendChild(option);
    });
    const options = [...vehicleSelect.options];
    const preferredOption = options.find((option) => option.value === preferred && !option.disabled);
    const previousOption = options.find((option) => option.value === previous && !option.disabled);
    if (preferredOption && (!vehicleManuallyChanged || !previousOption)) {
      vehicleSelect.value = preferred;
    } else if (previousOption) {
      vehicleSelect.value = previous;
    } else if (preferredOption) {
      vehicleSelect.value = preferred;
    }
  }

  function enabledCameraNames() {
    const vehicleData = statusData?.state?.vehicle_data || {};
    const configured = statusData?.configured_camera_ids || ["camera1", "camera2", "camera3", "camera4"];
    const cachedMatchesVehicle = !vehicleData.vehicle_id || vehicleData.vehicle_id === vehicleSelect.value;
    const capabilities = cachedMatchesVehicle && vehicleData.capabilities?.cameras ? vehicleData.capabilities.cameras : configured.map((camera) => ({
      camera,
      enabled: (statusData?.fallback_calibrated_cameras || ["camera1", "camera4"]).includes(camera),
      reason: (statusData?.fallback_calibrated_cameras || ["camera1", "camera4"]).includes(camera)
        ? "formal_camera_lidar_calibration_available"
        : "formal_camera_lidar_calibration_missing"
    }));
    return capabilities.filter((item) => item.enabled).map((item) => item.camera);
  }

  function applyStatus() {
    const state = statusData?.state || {};
    const phase = state.phase || "idle";
    statusTitle.textContent = phase === "idle" ? "等待操作" : phase;
    statusCopy.textContent = state.stage_text || "等待操作。";
    statusBadge.textContent = phase;
    statusBadge.dataset.state = phase;
    authHint.textContent = isAuthed()
      ? `已登录：${statusData.auth.username}${hasRunPermission() ? "" : "，但缺少 3DGS 场景训练权限。"}`
      : "当前未登录，仅可查看状态；请从右上角账号入口登录。";
    authHint.dataset.state = isAuthed() && hasRunPermission() ? "success" : "idle";

    const capture = state.capture || {};
    el("three-dgs-capture-camera").textContent = Array.isArray(capture.cameras) && capture.cameras.length ? capture.cameras.join("、") : "-";
    el("three-dgs-capture-vehicle").textContent = capture.vehicle_id || "-";
    el("three-dgs-capture-session").textContent = capture.session_id || "-";
    el("three-dgs-capture-frames").textContent = formatFrameCount(capture.saved_frames);
    renderCaptureCameraCounts(capture);

    const uploads = state.uploads || {};
    const mapStatus = mapStatusFromState(state);
    renderVehicleUploadProgress(state);
    pointcloudName.textContent = uploads.pointcloud
      ? `${uploads.pointcloud.name} · ${formatSize(uploads.pointcloud.size_bytes)}`
      : pointcloudFile
        ? `${pointcloudFile.name} · ${formatSize(pointcloudFile.size)}`
        : mapStatus.size_bytes
          ? `车端已加载 GlobalMap.pcd · ${formatSize(mapStatus.size_bytes)}`
          : "等待更新 map/GlobalMap.pcd";
    imagePoseName.textContent = uploads.image_pose
      ? `${uploads.image_pose.name} · ${formatSize(uploads.image_pose.size_bytes)}`
      : imagePoseFile
        ? `${imagePoseFile.name} · ${formatSize(imagePoseFile.size)}`
        : "等待上传当前采集 session";
    el("three-dgs-map-version").textContent = mapStatus.version;
    el("three-dgs-map-points").textContent = formatCount(mapStatus.point_count);
    el("three-dgs-map-size").textContent = formatSize(mapStatus.size_bytes);
    el("three-dgs-map-cloud").textContent = uploads.pointcloud
      ? `已落盘 ${formatSize(uploads.pointcloud.size_bytes)}`
      : mapStatus.upload_pending
        ? "等待车端上传"
        : "未落盘";
    el("three-dgs-map-extent").textContent = formatExtent(mapStatus.extent);

    const dataset = state.dataset || {};
    el("three-dgs-dataset-path").textContent = dataset.path || "-";
    el("three-dgs-dataset-summary").textContent = dataset.summary
      ? `${dataset.summary.image_count || 0} 张 / ${dataset.summary.point_count || 0} 点`
      : "-";

    const train = state.train || {};
    el("three-dgs-train-run").textContent = train.run_id || "-";
    el("three-dgs-remote-run").textContent = train.remote_run_path || "-";

    const viewer = state.viewer || {};
    const viewerUrl = viewerUrlFor(viewer.point_cloud_url);
    if (viewerUrl) {
      viewerStatus.textContent = `${viewer.run_id || train.run_id || "-"} · ${formatSize(viewer.size_bytes)} · 已同步`;
      viewerOpen.href = viewerUrl;
      viewerOpen.removeAttribute("aria-disabled");
      const absoluteViewerUrl = new URL(viewerUrl, window.location.origin).href;
      if (viewerFrame.src !== absoluteViewerUrl) {
        viewerFrame.src = viewerUrl;
      }
      viewerFrame.hidden = false;
    } else {
      viewerStatus.textContent = train.remote_run_path ? "可同步当前训练结果" : "等待训练输出";
      viewerOpen.href = "#";
      viewerOpen.setAttribute("aria-disabled", "true");
      viewerFrame.hidden = true;
    }

    const enabledNames = enabledCameraNames();
    enabledCamerasText.textContent = enabledNames.length ? enabledNames.join("、") : "暂无 enabled 相机";
    refreshButtons();
  }

  async function fetchStatus() {
    const response = await fetch(STATUS_URL, { credentials: "same-origin", cache: "no-store" });
    statusData = await response.json();
    applyVehicles(statusData.vehicles);
    if (statusData.default_train_gpu && !el("three-dgs-gpu").dataset.touched) {
      el("three-dgs-gpu").value = statusData.default_train_gpu;
    }
    applyStatus();
    connectCaptureStream();
    refreshBackgroundViews();
  }

  async function postJson(url, payload = {}) {
    const response = await fetch(url, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      credentials: "same-origin",
      body: JSON.stringify(payload)
    });
    const data = await response.json().catch(() => ({}));
    if (!response.ok) {
      throw new Error(data.detail || data.error || "request_failed");
    }
    statusData = data;
    applyStatus();
    connectCaptureStream();
    return data;
  }

  function selectedVehiclePayload() {
    return {
      vehicle_id: currentVehicleId(),
      min_translation_m: Number(el("three-dgs-min-translation").value || 0.5),
      min_rotation_deg: Number(el("three-dgs-min-rotation").value || 10),
      min_interval_s: Number(el("three-dgs-min-interval").value || 0.2)
    };
  }

  function trainPayload() {
    return {
      gpu: Number(el("three-dgs-gpu").value || 3),
      iterations: Number(el("three-dgs-iterations").value || 7000),
      resolution: Number(el("three-dgs-resolution").value || 4)
    };
  }

  function preparePayload() {
    return {
      scene_name: el("three-dgs-scene-name").value,
      max_points: Number(el("three-dgs-max-points").value || 500000),
      undistort: el("three-dgs-undistort").checked
    };
  }

  async function waitForPrepared() {
    for (let i = 0; i < 240; i += 1) {
      await new Promise((resolve) => window.setTimeout(resolve, 3000));
      await fetchStatus();
      const state = statusData?.state || {};
      if (state.dataset?.prepared) return;
      if (state.phase === "error" || state.prepare?.running === false && state.prepare?.completed_at_ms && !state.dataset?.prepared) {
        throw new Error(state.error_message || "prepare_failed");
      }
    }
    throw new Error("prepare_timeout");
  }

  async function prepareThenTrain() {
    if (!statusData?.state?.dataset?.prepared) {
      await postJson(api.prepare, preparePayload());
      await waitForPrepared();
    }
    await postJson(api.train, trainPayload());
  }

  async function runAction(label, fn) {
    busy = true;
    refreshButtons();
    setFeedback(`${label}...`);
    try {
      await fn();
      await fetchStatus();
      if (statusData?.state?.phase === "starting_capture") {
        setFeedback(`${label}已下发，等待车端返回。`, "success");
      } else {
        setFeedback(`${label}完成。`, "success");
      }
    } catch (error) {
      setFeedback(`${label}失败：${error.message}`, "error");
    } finally {
      busy = false;
      refreshButtons();
    }
  }

  function uploadFile(url, file, label) {
    return new Promise((resolve, reject) => {
      if (!file) {
        reject(new Error("file_required"));
        return;
      }
      const xhr = new XMLHttpRequest();
      xhr.open("POST", url, true);
      xhr.withCredentials = true;
      xhr.setRequestHeader("Content-Type", "application/octet-stream");
      xhr.setRequestHeader("X-File-Name", encodeURIComponent(file.name));
      xhr.setRequestHeader("X-File-Size", String(file.size));
      xhr.upload.onprogress = (event) => {
        if (!event.lengthComputable) return;
        const pct = ((event.loaded / event.total) * 100).toFixed(1);
        setUploadProgress(Number(pct), `${label} · ${formatSize(event.loaded)} / ${formatSize(event.total)}`);
        setFeedback(`${label}：${pct}%`);
      };
      xhr.onload = () => {
        try {
          const data = JSON.parse(xhr.responseText || "{}");
          if (xhr.status < 200 || xhr.status >= 300) {
            setUploadProgress(0, `${label}失败：${data.detail || data.error || "upload_failed"}`, { state: "error" });
            reject(new Error(data.detail || data.error || "upload_failed"));
            return;
          }
          statusData = data;
          applyStatus();
          connectCaptureStream();
          setUploadProgress(100, `${label}完成。`, { state: "success" });
          resolve(data);
        } catch (error) {
          reject(error);
        }
      };
      xhr.onerror = () => {
        setUploadProgress(0, `${label}失败。`, { state: "error" });
        reject(new Error("upload_failed"));
      };
      xhr.send(file);
    });
  }

  async function loadLog(url, silent = false) {
    const response = await fetch(`${url}?tail=260`, { credentials: "same-origin", cache: "no-store" });
    if (!response.ok) {
      if (!silent) throw new Error("log_load_failed");
      return;
    }
    const text = await response.text();
    logNode.textContent = text || "暂无日志。";
  }

  el("three-dgs-refresh").addEventListener("click", () => runAction("刷新状态", fetchStatus));
  vehicleSelect.addEventListener("change", () => {
    vehicleManuallyChanged = true;
    applyStatus();
  });
  el("three-dgs-capabilities").addEventListener("click", () =>
    runAction("读取相机能力", () => postJson(api.capabilities, { vehicle_id: currentVehicleId() }))
  );
  el("three-dgs-start-capture").addEventListener("click", () =>
    runAction("开始采集", () => postJson(api.startCapture, selectedVehiclePayload()))
  );
  el("three-dgs-gpu").addEventListener("input", () => {
    el("three-dgs-gpu").dataset.touched = "true";
  });
  el("three-dgs-capture-status").addEventListener("click", () =>
    runAction("读取采集状态", () => postJson(api.captureStatus, { vehicle_id: currentVehicleId() }))
  );
  el("three-dgs-stop-capture").addEventListener("click", () =>
    runAction("停止采集", () => postJson(api.stopCapture, { vehicle_id: currentVehicleId() }))
  );
  el("three-dgs-read-manifest").addEventListener("click", () =>
    runAction("读取清单", () => postJson(api.manifest, { vehicle_id: currentVehicleId(), include_records: true, max_records: 100 }))
  );
  el("three-dgs-update-map").addEventListener("click", () =>
    runAction("更新地图", () => postJson(api.updateMap, { vehicle_id: currentVehicleId() }))
  );
  el("three-dgs-pull-image-pose").addEventListener("click", () =>
    runAction("上传图片数据", () => postJson(api.pullImagePose, { vehicle_id: currentVehicleId() }))
  );

  el("three-dgs-pointcloud-button").addEventListener("click", () => pointcloudInput.click());
  el("three-dgs-image-pose-button").addEventListener("click", () => imagePoseInput.click());
  pointcloudInput.addEventListener("change", () => {
    pointcloudFile = pointcloudInput.files?.[0] || null;
    applyStatus();
  });
  imagePoseInput.addEventListener("change", () => {
    imagePoseFile = imagePoseInput.files?.[0] || null;
    applyStatus();
  });
  el("three-dgs-upload-pointcloud").addEventListener("click", () =>
    runAction("上传点云地图", () => uploadFile(api.uploadPointcloud, pointcloudFile, "上传点云地图"))
  );
  el("three-dgs-upload-image-pose").addEventListener("click", () =>
    runAction("上传图像-位姿", () => uploadFile(api.uploadImagePose, imagePoseFile, "上传图像-位姿"))
  );

  el("three-dgs-check-dataset").addEventListener("click", () =>
    runAction("检查训练数据", loadDatasetInspection)
  );
  datasetCanvas?.addEventListener("click", (event) => {
    if (!datasetHitPoints.length) return;
    const rect = datasetCanvas.getBoundingClientRect();
    const x = event.clientX - rect.left;
    const y = event.clientY - rect.top;
    let best = null;
    for (const item of datasetHitPoints) {
      const distance = Math.hypot(item.x - x, item.y - y);
      if (!best || distance < best.distance) {
        best = { ...item, distance };
      }
    }
    if (best && best.distance <= 18) {
      selectDatasetFrame(best.index);
    }
  });
  window.addEventListener("resize", () => drawDatasetInspection());

  el("three-dgs-prepare").addEventListener("click", () =>
    runAction("规整 COLMAP 数据", () => postJson(api.prepare, preparePayload()))
  );
  el("three-dgs-start-train").addEventListener("click", () =>
    runAction("开始训练", prepareThenTrain)
  );
  el("three-dgs-sync-result").addEventListener("click", () =>
    runAction("同步训练结果", () => postJson(api.viewerSync, { run_id: statusData?.state?.train?.run_id }))
  );
  el("three-dgs-load-prepare-log").addEventListener("click", () => runAction("读取准备日志", () => loadLog(api.prepareLog)));
  el("three-dgs-load-train-log").addEventListener("click", () =>
    runAction("读取训练日志", async () => {
      await loadLog(statusData?.state?.train?.phase === "training" ? api.trainRemoteLog : api.trainLocalLog);
    })
  );

  fetchStatus().catch((error) => setFeedback(`状态读取失败：${error.message}`, "error"));
  window.setInterval(() => fetchStatus().catch(() => {}), 10000);
  window.addEventListener("jgzj:auth-change", () => {
    closeCaptureStream();
    fetchStatus().catch(() => {});
  });
  window.addEventListener("beforeunload", closeCaptureStream);
</script>

