---
import "../../styles/app.css";
import EmbeddedCloudOpsConsole from "../../components/EmbeddedCloudOpsConsole.astro";
import EmbeddedCloudOpsRuntime from "../../components/EmbeddedCloudOpsRuntime.astro";
import InteractiveScripts from "../../components/InteractiveScripts.astro";
import OptimizedImage from "../../components/OptimizedImage.astro";
import SiteLayout from "../../components/SiteLayout.astro";
---

<SiteLayout
  title="云端智能运维"
  description="展示云端智能运维页面，包括登录保护的车端运维、服务器节点状态、端口链路图和统一重启控制台。"
  currentPath="/app/cloud-operations"
  noindex={true}
>
  <header class="page-hero ops-hero">
    <OptimizedImage
      src="/assets/fallback/hero-cloud-ops-1600.jpg"
      webp="/assets/optimized/hero-cloud-ops-1600.webp"
      alt="云端智能运维场景"
      class="hero-media"
      data-parallax
    />
    <div class="hero-overlay"></div>
    <div class="hero-grid"></div>
    <div class="page-hero-shell">
      <div class="page-hero-copy reveal" data-reveal>
        <p class="page-kicker">PAGE 06 · CLOUD OPS</p>
        <h1 class="page-title">云端智能运维</h1>
        <p class="page-subtitle">
          面向实际服务器和多车现场的运维工作台。车辆状态、车端工具调用、自然语言运维、服务器节点状态和重启操作统一放在这一页。
        </p>
      </div>
    </div>
  </header>

  <main class="page-main grid-bg">
    <section class="page-section">
      <div class="glass-card section-card">
        <p class="section-kicker">云端智能运维工作台</p>
        <h2 class="section-title">车辆与服务器运维统一工作台</h2>
        <p class="section-copy">
          车辆列表、车端工具、自然语言运维、服务器端口拓扑和重启面板在同一工作台内统一操作。
        </p>
        <div class="ops-openclaw-shell">
          <EmbeddedCloudOpsConsole />
        </div>
      </div>
    </section>

    <section class="page-section" data-cloud-ops-protected>
      <div class="glass-card section-card">
        <p class="section-kicker">服务器端运维</p>
        <h2 class="section-title">架构图直接承载端口、节点和重启操作</h2>
        <p class="section-copy">
          架构图只保留节点功能、端口、链路方向、运行状态和重启按钮，不展示探活延迟和冗余检查明细。未授权时面板保持虚化锁定。
        </p>
        <EmbeddedCloudOpsRuntime />
      </div>
    </section>
  </main>

  <InteractiveScripts />
</SiteLayout>

<style is:global>
  .server-port-map {
    display: grid;
    grid-template-columns: minmax(150px, 0.22fr) minmax(0, 1fr);
    gap: 18px;
    margin-top: 24px;
  }

  .server-port-spine {
    display: grid;
    align-content: center;
    gap: 12px;
    min-height: 100%;
    padding: 22px;
    border-radius: 24px;
    border: 1px solid rgba(96, 165, 250, 0.38);
    background:
      radial-gradient(circle at 50% 0%, rgba(56, 189, 248, 0.24), transparent 50%),
      linear-gradient(180deg, rgba(15, 23, 42, 0.86), rgba(2, 6, 23, 0.78));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .server-port-spine span,
  .server-port-service p,
  .server-port-state,
  .server-runtime-extra-card p {
    margin: 0;
    color: #cbd5e1;
    line-height: 1.68;
  }

  .server-port-lane.is-ok,
  .server-runtime-extra-card.is-ok {
    border-color: rgba(52, 211, 153, 0.26);
  }

  .server-port-lane.is-warn,
  .server-runtime-extra-card.is-warn {
    border-color: rgba(251, 191, 36, 0.32);
  }

  .server-port-lane.is-error,
  .server-runtime-extra-card.is-error {
    border-color: rgba(248, 113, 113, 0.36);
  }

  .server-port-spine.is-ok {
    border-color: rgba(52, 211, 153, 0.28);
  }

  .server-port-spine.is-warn {
    border-color: rgba(251, 191, 36, 0.36);
  }

  .server-port-spine.is-error {
    border-color: rgba(248, 113, 113, 0.42);
  }

  .server-port-spine strong {
    color: #fff;
    font-family: "Orbitron", "Noto Sans SC", sans-serif;
    font-size: clamp(2rem, 5vw, 4.2rem);
    line-height: 1;
    letter-spacing: 0.08em;
  }

  .server-port-lanes {
    display: grid;
    gap: 12px;
  }

  .server-port-lane {
    display: grid;
    grid-template-columns: minmax(118px, 0.16fr) auto minmax(190px, 0.3fr) auto minmax(220px, 1fr);
    gap: 12px;
    align-items: center;
    padding: 16px;
  }

  .server-port-public {
    display: grid;
    gap: 4px;
    color: #cbd5e1;
    font-weight: 800;
  }

  .server-port-number {
    font-family: "Orbitron", "Noto Sans SC", sans-serif;
    font-size: 1.7rem;
    color: #67e8f9;
    letter-spacing: 0.04em;
  }

  .server-port-arrow {
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: 999px;
    color: #0f172a;
    background: linear-gradient(135deg, #67e8f9, #60a5fa);
    box-shadow: 0 0 18px rgba(56, 189, 248, 0.38);
    font-weight: 900;
  }

  .server-port-service {
    display: grid;
    gap: 8px;
  }

  .server-port-service strong {
    color: #fff;
    line-height: 1.45;
  }

  .server-port-chip-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .server-port-chip,
  .server-port-state-chip,
  .server-port-status-inline {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    width: fit-content;
    padding: 5px 9px;
    border-radius: 999px;
    color: #dbeafe;
    background: rgba(14, 165, 233, 0.1);
    border: 1px solid rgba(125, 211, 252, 0.18);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .server-port-state-chip.is-ok {
    color: #bbf7d0;
    background: rgba(16, 185, 129, 0.12);
    border-color: rgba(52, 211, 153, 0.3);
  }

  .server-port-state-chip.is-warn {
    color: #fde68a;
    background: rgba(245, 158, 11, 0.12);
    border-color: rgba(251, 191, 36, 0.34);
  }

  .server-port-state-chip.is-error {
    color: #fecaca;
    background: rgba(239, 68, 68, 0.12);
    border-color: rgba(248, 113, 113, 0.36);
  }

  .server-port-ops {
    display: grid;
    gap: 8px;
  }

  .server-port-ops-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }

  .server-port-status {
    margin: 0;
    color: #cbd5e1;
    line-height: 1.6;
    font-size: 0.9rem;
  }

  .server-port-restart {
    border: none;
    border-radius: 999px;
    padding: 8px 14px;
    color: #04111d;
    background: linear-gradient(135deg, #67e8f9, #60a5fa);
    box-shadow: 0 10px 24px rgba(14, 165, 233, 0.24);
    font-weight: 900;
    cursor: pointer;
  }

  .server-port-restart:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 14px 28px rgba(14, 165, 233, 0.34);
  }

  .server-port-restart-inline {
    padding: 6px 10px;
    font-size: 0.78rem;
    min-width: 60px;
    box-shadow: 0 6px 16px rgba(14, 165, 233, 0.18);
  }

  .server-port-restart:disabled {
    cursor: not-allowed;
    opacity: 0.55;
    transform: none;
    box-shadow: none;
  }

  .server-port-node-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .server-port-node-list span {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 6px 10px;
    border-radius: 999px;
    color: #dbeafe;
    background: rgba(14, 165, 233, 0.1);
    border: 1px solid rgba(125, 211, 252, 0.18);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .server-runtime-extra-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-top: 14px;
  }

  .server-runtime-extra-card {
    display: grid;
    gap: 10px;
  }

  .server-runtime-extra-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }

  .server-runtime-extra-card h3 {
    margin: 0;
    color: #fff;
    font-size: 1rem;
  }

  @media (max-width: 980px) {
    .server-port-map,
    .server-port-lane,
    .server-runtime-extra-grid {
      grid-template-columns: 1fr;
    }

    .server-port-arrow {
      transform: rotate(90deg);
    }
  }

  .ops-hero .hero-overlay {
    background:
      linear-gradient(100deg, rgba(2, 6, 23, 0.92), rgba(2, 6, 23, 0.55)),
      radial-gradient(circle at 85% 35%, rgba(167, 139, 250, 0.28), transparent 45%);
  }
  .ops-hero .page-kicker {
    border-color: rgba(167, 139, 250, 0.38);
    background: rgba(167, 139, 250, 0.08);
    color: #ddd6fe;
  }
  .ops-hero .page-subtitle {
    border-left-color: #a78bfa;
  }
</style>
