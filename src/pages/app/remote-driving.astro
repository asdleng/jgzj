---
import "../../styles/app.css";
import SiteLayout from "../../components/SiteLayout.astro";
---

<SiteLayout
  title="远程驾驶"
  description="BIT-0041 实车环视监看与安全远程驾驶工作台。"
  currentPath="/app/remote-driving"
  noindex={true}
  showContact={false}
>
  <main class="remote-driving-main">
    <iframe
      class="remote-driving-frame"
      src="/remote-drive/index.html?vehicle=BIT-0041"
      title="BIT-0041 远程驾驶控制台"
      allow="autoplay"
    ></iframe>
  </main>

<script is:inline data-cfasync="false">
  (() => {
    const frame = document.querySelector(".remote-driving-frame");
    const mobileLayout = window.matchMedia("(max-width: 900px)");
    let resizeObserver;
    let animationFrame;

    const syncFrameHeight = () => {
      cancelAnimationFrame(animationFrame);
      animationFrame = requestAnimationFrame(() => {
        if (!(frame instanceof HTMLIFrameElement)) return;
        if (!mobileLayout.matches) {
          frame.style.removeProperty("height");
          return;
        }
        const content = frame.contentDocument?.querySelector(".operation-workspace");
        if (!content) return;
        const contentHeight = Math.ceil(content.getBoundingClientRect().bottom + (frame.contentWindow?.scrollY || 0));
        if (contentHeight > 0) frame.style.height = `${contentHeight}px`;
      });
    };

    const observeFrame = () => {
      resizeObserver?.disconnect();
      const content = frame?.contentDocument?.querySelector(".operation-workspace");
      if (!content) return;
      resizeObserver = new ResizeObserver(syncFrameHeight);
      resizeObserver.observe(content);
      syncFrameHeight();
    };

    const observeLoadedFrame = () => {
      if (!frame?.contentDocument?.querySelector(".app-shell")) return false;
      observeFrame();
      return true;
    };

    const readinessTimer = window.setInterval(() => {
      if (observeLoadedFrame()) window.clearInterval(readinessTimer);
    }, 100);
    frame?.addEventListener("load", () => {
      window.clearInterval(readinessTimer);
      observeFrame();
    });
    observeFrame();
    mobileLayout.addEventListener("change", syncFrameHeight);
    window.addEventListener("resize", syncFrameHeight, { passive: true });
  })();
</script>
</SiteLayout>

<style>
  .remote-driving-main {
    width: 100%;
    min-height: calc(100vh - 64px);
    background: #090d12;
  }

  .remote-driving-frame {
    display: block;
    width: 100%;
    height: calc(100vh - 64px);
    min-height: 760px;
    border: 0;
    background: #090d12;
  }

  @media (max-width: 760px) {
    .remote-driving-main {
      min-height: calc(100vh - 56px);
    }

    .remote-driving-frame {
      height: calc(100vh - 56px);
      min-height: 840px;
    }
  }
</style>
