---
import OptimizedImage from "../components/OptimizedImage.astro";
import SiteLayout from "../components/SiteLayout.astro";
import {
  contactInfo,
  securityDrivers,
  securityPainPoints,
  siteDescription,
  siteName,
  siteUrl
} from "../data/site-content.js";

const homeStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: siteName,
    url: siteUrl,
    logo: new URL("/assets/s19_91432e393d0c.png", siteUrl).toString(),
    email: contactInfo.email,
    address: {
      "@type": "PostalAddress",
      addressCountry: "CN",
      addressRegion: "广东省",
      addressLocality: "深圳市",
      streetAddress: "坪山区新能源汽车产业园区2期"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteName,
    url: siteUrl,
    inLanguage: "zh-CN",
    description: siteDescription
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "安防巡逻与园区自动驾驶机器人方案",
    provider: {
      "@type": "Organization",
      name: siteName,
      url: siteUrl
    },
    areaServed: "中国",
    serviceType: ["安防巡逻机器人", "园区自动驾驶", "AI 导览", "端云协同 AI 检测"],
    description: "面向园区、景区、政务和城市公共空间的机器人、平台与 AI 一体化服务。"
  }
];
---

<SiteLayout
  title={siteName}
  description="深圳吉光智界科技有限公司专注安防巡逻、园区自动驾驶、端云协同 AI 检测、智能交互与云端运维的一体化机器人方案。"
  currentPath="/"
  structuredData={homeStructuredData}
>
  <header class="page-hero">
    <OptimizedImage
      src="/assets/fallback/home-hero-1920.jpg"
      webpSrcset="/assets/optimized/home-hero-960.webp 960w, /assets/optimized/home-hero-1920.webp 1920w"
      sizes="100vw"
      alt="安防巡逻行业场景"
      class="hero-media"
      width="1920"
      height="882"
      fetchpriority="high"
      data-parallax
    />
    <div class="hero-overlay"></div>
    <div class="hero-grid"></div>
    <div class="page-hero-shell">
      <div class="page-hero-copy reveal" data-reveal>
        <p class="page-kicker">PAGE 01 · COMPANY</p>
        <h1 class="page-title">深圳吉光智界科技有限公司</h1>
        <p class="page-subtitle">
          面向安防巡逻行业爆发窗口，吉光智界正在把"机器人 + 平台 + AI"带入园区、景区、政务和城市公共空间。系统围绕覆盖率、实时响应、可追溯与运营联动持续升级。
        </p>
      </div>
    </div>
  </header>

  <main class="page-main grid-bg">

    <!-- 三大核心数字 -->
    <section class="page-section">
      <div class="glass-card section-card reveal" data-reveal>
        <p class="section-kicker">市场规模</p>
        <h2 class="section-title">行业正站在爆发临界点上</h2>
        <div class="industry-numbers-grid">
          <div class="industry-number-card">
            <p class="industry-number"><span data-count-to="2710">2710</span><span class="industry-number-unit">亿元</span></p>
            <p class="industry-number-label">2024 年中国安防服务市场</p>
            <p class="industry-number-sub">人防服务占比 67.34%，年增速超 10%</p>
          </div>
          <div class="industry-number-card">
            <p class="industry-number"><span data-count-to="4050">4050</span><span class="industry-number-unit">亿美元</span></p>
            <p class="industry-number-label">2023 年全球安防市场规模</p>
            <p class="industry-number-sub">中国仅占 20%，欧美市场合计超 50%</p>
          </div>
          <div class="industry-number-card industry-number-card--accent">
            <p class="industry-number">~<span data-count-to="1" data-count-decimals="1">1</span><span class="industry-number-unit">万亿</span></p>
            <p class="industry-number-label">全球安防巡逻机器人整体市场</p>
            <p class="industry-number-sub">2025–2027 年迎来机器人爆发临界点</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 行业痛点 -->
    <section class="page-section">
      <div class="glass-card section-card reveal" data-reveal>
        <p class="section-kicker">安防巡逻痛点</p>
        <h2 class="section-title">为什么传统安防巡逻越来越难支撑现场治理</h2>
        <div class="page-grid-two">
          <ul class="stack-list">
            {securityPainPoints.map((item) => (
              <li class="page-card">{item}</li>
            ))}
          </ul>
          <div class="industry-chart-card page-card">
            <OptimizedImage
              src="/assets/bp-industry-pain-points.png"
              webp="/assets/optimized/bp-industry-pain-points-1000.webp"
              alt="安防巡逻行业四大痛点"
              loading="lazy"
              decoding="async"
              width="1440"
              height="810"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- 爆发驱动力 + 市场图表 -->
    <section class="page-section">
      <div class="glass-card section-card reveal" data-reveal>
        <p class="section-kicker">爆发驱动力</p>
        <h2 class="section-title">行业从试点期走向规模化的 3 个直接原因</h2>
        <div class="page-grid-three">
          {securityDrivers.map((item) => (
            <article class="page-card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>

        <!-- 市场图表：人力成本+消费层级 / 全球市场 -->
        <div class="industry-charts-row">
          <figure class="industry-chart-figure">
            <OptimizedImage
              src="/assets/fallback/bp-industry-market-scale-1000.jpg"
              webp="/assets/optimized/bp-industry-market-scale-1000.webp"
              alt="安防市场规模与人机协同消费层级分析"
              loading="lazy"
              decoding="async"
              width="1000"
              height="562"
            />
            <figcaption>人机协同的蓝海市场 · 安防市场规模与城镇居民可支配收入消费层级</figcaption>
          </figure>
          <figure class="industry-chart-figure">
            <OptimizedImage
              src="/assets/fallback/bp-industry-global-market-1000.jpg"
              webp="/assets/optimized/bp-industry-global-market-1000.webp"
              alt="全球安防市场规模与增长趋势"
              loading="lazy"
              decoding="async"
              width="1000"
              height="562"
            />
            <figcaption>全球安防市场 · 中国仍有巨大增长空间，整体市场约 1 万亿人民币</figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- 机器人能力入口 -->
    <section class="page-section">
      <div class="glass-card section-card home-capability-section reveal" data-reveal>
        <div class="home-capability-layout">
          <div class="home-capability-copy">
            <p class="section-kicker">机器人能力</p>
            <h2 class="section-title">AI 对话、地图导览与 AI 检测进入车端屏幕</h2>
            <p class="section-copy">
              白泽智机器人把现场问答、地图路线、地点知识和事件检测整合到同一套车端交互里。访客可以直接问路线和场地信息，运营侧可以把异常识别、巡逻记录和复盘数据接入云端。
            </p>
            <div class="chip-list">
              <a class="chip-item" href="/robot-capabilities">查看机器人能力</a>
              <span class="chip-item">AI 对话</span>
              <span class="chip-item">地图导览</span>
              <span class="chip-item">端云 AI 检测</span>
            </div>
          </div>
          <div class="home-capability-media" aria-label="车端能力界面示例">
            <figure class="home-capability-screen">
              <OptimizedImage
                src="/assets/fallback/capability-shenzhen-bay-guide-720.jpg"
                webp="/assets/optimized/capability-shenzhen-bay-guide-720.webp"
                alt="深圳湾公园 AI 对话与地图导览界面"
                loading="lazy"
                decoding="async"
                width="720"
                height="1280"
              />
              <figcaption>深圳湾公园</figcaption>
            </figure>
            <figure class="home-capability-screen">
              <OptimizedImage
                src="/assets/fallback/capability-guangming-science-guide-720.jpg"
                webp="/assets/optimized/capability-guangming-science-guide-720.webp"
                alt="光明科学公园 AI 对话、地图导览与事件检测界面"
                loading="lazy"
                decoding="async"
                width="720"
                height="1280"
              />
              <figcaption>光明科学公园</figcaption>
            </figure>
          </div>
        </div>
      </div>
    </section>

    <!-- 落地案例 -->
    <section class="page-section">
      <div class="glass-card section-card reveal" data-reveal>
        <p class="section-kicker">落地案例</p>
        <h2 class="section-title">白泽智机器人 · 深圳多场景实地部署</h2>
        <div class="page-grid-three">
          <article class="page-card deploy-scene-card">
            <div class="deploy-scene-img-wrap">
              <OptimizedImage
                src="/assets/fallback/site-futian-committee-800.jpg"
                webp="/assets/optimized/site-futian-committee-800.webp"
                alt="福田区委大院 机器人落地"
                loading="lazy"
                decoding="async"
                width="800"
                height="600"
              />
            </div>
            <h3>福田区委大院</h3>
            <p>广东省深圳市福民路 123 号，中共福田区委机关大院，政务场景落地部署。</p>
          </article>
          <article class="page-card deploy-scene-card">
            <div class="deploy-scene-img-wrap">
              <OptimizedImage
                src="/assets/site-civic-center-1.jpg"
                webp="/assets/optimized/site-civic-center-800.webp"
                alt="市民中心 智慧安防机器人"
                loading="lazy"
                decoding="async"
                width="1911"
                height="1125"
              />
            </div>
            <h3>市民中心</h3>
            <p>深圳福田区福中三路，市民中心地铁站 C 口，公共服务核心区智慧安防。</p>
          </article>
          <article class="page-card deploy-scene-card">
            <div class="deploy-scene-img-wrap">
              <OptimizedImage
                src="/assets/fallback/site-window-of-world-800.jpg"
                webp="/assets/optimized/site-window-of-world-800.webp"
                alt="世界之窗 景区安防巡逻"
                loading="lazy"
                decoding="async"
                width="800"
                height="600"
              />
            </div>
            <h3>世界之窗</h3>
            <p>深圳市南山区深南大道 9037 号，大型旅游景区高人流场景安防巡逻。</p>
          </article>
        </div>
      </div>
    </section>

  </main>

  <script is:inline>
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    var DURATION = 1800;
    function easeOut(t) { return 1 - Math.pow(1 - t, 3); }

    function animateCount(el) {
      var target = parseFloat(el.dataset.countTo);
      var decimals = parseInt(el.dataset.countDecimals || '0', 10);
      var mult = Math.pow(10, decimals);
      var targetInt = Math.round(target * mult);
      var startTime = performance.now();
      var numEl = el.closest('.industry-number');

      function tick(now) {
        var t = Math.min((now - startTime) / DURATION, 1);
        var cur = Math.round(easeOut(t) * targetInt);
        el.textContent = decimals > 0 ? (cur / mult).toFixed(decimals) : String(cur);
        if (t < 1) {
          requestAnimationFrame(tick);
        } else {
          el.textContent = decimals > 0 ? String(Math.round(target)) : String(target);
          if (numEl) {
            numEl.classList.add('count-done');
            numEl.addEventListener('animationend', function () {
              numEl.classList.remove('count-done');
            }, { once: true });
          }
        }
      }
      requestAnimationFrame(tick);
    }

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          animateCount(entry.target);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.4 });

    document.querySelectorAll('[data-count-to]').forEach(function (el) {
      observer.observe(el);
    });
  })();
  </script>
</SiteLayout>
