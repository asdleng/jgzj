---
import SiteLayout from "../components/SiteLayout.astro";
import {
  securityDrivers,
  securityPainPoints
} from "../data/site-content.js";
---

<SiteLayout
  title="安防巡逻行业爆发"
  description="聚焦安防巡逻行业爆发背景下的场景痛点、增长驱动力与机器人落地方向。"
  currentPath="/"
>
  <header class="page-hero">
    <img
      src="/assets/s03_04142025eb07.jpg"
      alt="安防巡逻行业场景"
      class="hero-media"
      data-parallax
    />
    <div class="hero-overlay"></div>
    <div class="hero-grid"></div>
    <div class="page-hero-shell">
      <div class="page-hero-copy reveal" data-reveal>
        <p class="page-kicker">PAGE 01 · INDUSTRY</p>
        <h1 class="page-title">安防巡逻行业爆发</h1>
        <p class="page-subtitle">
          安防巡逻正在从"人工值守"进入"机器人 + 平台 + AI"的系统升级阶段。对覆盖率、实时响应、可追溯与运营联动的要求同步抬升，推动行业进入真正的爆发窗口。
        </p>
      </div>
    </div>
  </header>

  <main class="page-main grid-bg">

    <!-- 三大核心数字 -->
    <section class="page-section">
      <div class="glass-card section-card reveal" data-reveal>
        <p class="section-kicker">市场规模</p>
        <h2 class="section-title">行业正站在爆发临界点上</h2>
        <div class="industry-numbers-grid">
          <div class="industry-number-card">
            <p class="industry-number"><span data-count-to="2710">2710</span><span class="industry-number-unit">亿元</span></p>
            <p class="industry-number-label">2024 年中国安防服务市场</p>
            <p class="industry-number-sub">人防服务占比 67.34%，年增速超 10%</p>
          </div>
          <div class="industry-number-card">
            <p class="industry-number"><span data-count-to="4050">4050</span><span class="industry-number-unit">亿美元</span></p>
            <p class="industry-number-label">2023 年全球安防市场规模</p>
            <p class="industry-number-sub">中国仅占 20%，欧美市场合计超 50%</p>
          </div>
          <div class="industry-number-card industry-number-card--accent">
            <p class="industry-number">~<span data-count-to="1" data-count-decimals="1">1</span><span class="industry-number-unit">万亿</span></p>
            <p class="industry-number-label">全球安防巡逻机器人整体市场</p>
            <p class="industry-number-sub">2025–2027 年迎来机器人爆发临界点</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 行业痛点 -->
    <section class="page-section">
      <div class="glass-card section-card reveal" data-reveal>
        <p class="section-kicker">安防巡逻痛点</p>
        <h2 class="section-title">为什么传统安防巡逻越来越难支撑现场治理</h2>
        <div class="page-grid-two">
          <ul class="stack-list">
            {securityPainPoints.map((item) => (
              <li class="page-card">{item}</li>
            ))}
          </ul>
          <div class="industry-chart-card page-card">
            <img
              src="/assets/bp-industry-pain-points.png"
              alt="安防巡逻行业四大痛点"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- 爆发驱动力 + 市场图表 -->
    <section class="page-section">
      <div class="glass-card section-card reveal" data-reveal>
        <p class="section-kicker">爆发驱动力</p>
        <h2 class="section-title">行业从试点期走向规模化的 3 个直接原因</h2>
        <div class="page-grid-three">
          {securityDrivers.map((item) => (
            <article class="page-card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>

        <!-- 市场图表：人力成本+消费层级 / 全球市场 -->
        <div class="industry-charts-row">
          <figure class="industry-chart-figure">
            <img
              src="/assets/bp-industry-market-scale.png"
              alt="安防市场规模与人机协同消费层级分析"
              loading="lazy"
              decoding="async"
            />
            <figcaption>人机协同的蓝海市场 · 安防市场规模与城镇居民可支配收入消费层级</figcaption>
          </figure>
          <figure class="industry-chart-figure">
            <img
              src="/assets/bp-industry-global-market.png"
              alt="全球安防市场规模与增长趋势"
              loading="lazy"
              decoding="async"
            />
            <figcaption>全球安防市场 · 中国仍有巨大增长空间，整体市场约 1 万亿人民币</figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- 落地案例 -->
    <section class="page-section">
      <div class="glass-card section-card reveal" data-reveal>
        <p class="section-kicker">落地案例</p>
        <h2 class="section-title">白泽智机器人 · 深圳多场景实地部署</h2>
        <div class="page-grid-three">
          <article class="page-card deploy-scene-card">
            <div class="deploy-scene-img-wrap">
              <img
                src="/assets/site-futian-committee-1.jpg"
                alt="福田区委大院 机器人落地"
                loading="lazy"
                decoding="async"
              />
            </div>
            <h3>福田区委大院</h3>
            <p>广东省深圳市福民路 123 号，中共福田区委机关大院，政务场景落地部署。</p>
          </article>
          <article class="page-card deploy-scene-card">
            <div class="deploy-scene-img-wrap">
              <img
                src="/assets/site-civic-center-1.jpg"
                alt="市民中心 智慧安防机器人"
                loading="lazy"
                decoding="async"
              />
            </div>
            <h3>市民中心</h3>
            <p>深圳福田区福中三路，市民中心地铁站 C 口，公共服务核心区智慧安防。</p>
          </article>
          <article class="page-card deploy-scene-card">
            <div class="deploy-scene-img-wrap">
              <img
                src="/assets/site-window-of-world-1.jpg"
                alt="世界之窗 景区安防巡逻"
                loading="lazy"
                decoding="async"
              />
            </div>
            <h3>世界之窗</h3>
            <p>深圳市南山区深南大道 9037 号，大型旅游景区高人流场景安防巡逻。</p>
          </article>
        </div>
      </div>
    </section>

  </main>

  <script is:inline>
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    var DURATION = 1800;
    function easeOut(t) { return 1 - Math.pow(1 - t, 3); }

    function animateCount(el) {
      var target = parseFloat(el.dataset.countTo);
      var decimals = parseInt(el.dataset.countDecimals || '0', 10);
      var mult = Math.pow(10, decimals);
      var targetInt = Math.round(target * mult);
      var startTime = performance.now();
      var numEl = el.closest('.industry-number');

      function tick(now) {
        var t = Math.min((now - startTime) / DURATION, 1);
        var cur = Math.round(easeOut(t) * targetInt);
        el.textContent = decimals > 0 ? (cur / mult).toFixed(decimals) : String(cur);
        if (t < 1) {
          requestAnimationFrame(tick);
        } else {
          el.textContent = decimals > 0 ? String(Math.round(target)) : String(target);
          if (numEl) {
            numEl.classList.add('count-done');
            numEl.addEventListener('animationend', function () {
              numEl.classList.remove('count-done');
            }, { once: true });
          }
        }
      }
      requestAnimationFrame(tick);
    }

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          animateCount(entry.target);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.4 });

    document.querySelectorAll('[data-count-to]').forEach(function (el) {
      observer.observe(el);
    });
  })();
  </script>
</SiteLayout>
