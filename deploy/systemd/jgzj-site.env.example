PORT=8888
UPSTREAM_CHAT_BASE_URL=http://127.0.0.1:8050
UPSTREAM_CHAT_STREAM_PATH=/chat/stream
UPSTREAM_CHAT_HEALTH_PATH=/healthz
CHAT_PROXY_TIMEOUT_MS=120000
JGZJ_PUBLIC_SITE_URL=http://idtrd.kmdns.net:7791
JGZJ_AUTH_COOKIE_NAME=jgzj_session
JGZJ_AUTH_TTL_MS=604800000
JGZJ_EMAIL_VERIFICATION_TTL_MS=86400000
JGZJ_EMAIL_VERIFICATION_RESEND_MS=60000
JGZJ_EMAIL_OUTBOX_PATH=/home/admin1/jgzj/.runtime/email-outbox.log

# Fill these in to send real verification email. Without SMTP_HOST and SMTP_FROM,
# verification links are appended to JGZJ_EMAIL_OUTBOX_PATH.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Park PCM hourly report. Fill PARK_PCM_FEISHU_WEBHOOK_URL with the Feishu/Lark
# custom bot webhook to enable hourly delivery.
PARK_PCM_REPORT_ENABLED=true
PARK_PCM_REPORT_INTERVAL_MS=3600000
PARK_PCM_REPORT_BOOT_DELAY_MS=60000
PARK_PCM_FEISHU_WEBHOOK_URL=

# OpenAI-compatible relay. The public endpoint is /v1/* on this backend.
# Use an OpenAI Platform API key here. ChatGPT Pro subscription access is not
# an API credential and is billed/configured separately from platform API usage.
OPENAI_GATEWAY_ENABLED=false
OPENAI_GATEWAY_UPSTREAM_BASE_URL=https://api.openai.com
OPENAI_GATEWAY_UPSTREAM_API_KEY=
OPENAI_GATEWAY_UPSTREAM_ORGANIZATION=
OPENAI_GATEWAY_UPSTREAM_PROJECT=
OPENAI_GATEWAY_SUBKEYS=default:change-me
OPENAI_GATEWAY_RATE_LIMIT_PER_MINUTE=120
OPENAI_GATEWAY_TIMEOUT_MS=600000
OPENAI_GATEWAY_MAX_BODY_BYTES=26214400
OPENAI_GATEWAY_CORS_ORIGINS=
OPENAI_GATEWAY_LOG_PATH=.runtime/openai-gateway-requests.jsonl
